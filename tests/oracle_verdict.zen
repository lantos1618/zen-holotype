// tests/oracle_verdict.zen — PROOF category for the Zen oracle harness: a small representative slice of
// VERDICT cases (accept/reject, some pinned by error kind). Demonstrates the pattern against oracle_lib.
{ VerdictCase, run_verdicts } = oracle_lib

oracle_verdict_run* = () i32 {
    run_verdicts("verdict (proof)", [
        VerdictCase(src: "test* = () i32 { a: u32 := 0 - 1  0 }", should_pass: false, kind: ""),
        VerdictCase(src: "test* = () i32 { a: u64 := 0 - 1  0 }", should_pass: false, kind: ""),
        VerdictCase(src: "test* = () i32 { a: i8 := 127  0 }", should_pass: true, kind: ""),
        VerdictCase(src: "test* = () i32 { a: i8 := 200  0 }", should_pass: false, kind: ""),
        VerdictCase(src: "test* = () i32 { n := 1  v := n.match ({ 1 => 5, _ => \"s\" })  0 }", should_pass: false, kind: ""),
        VerdictCase(src: "A*: { x: i32 }\nB*: { y: i32 }\ntest* = () i32 { n := 1  v := n.match ({ 1 => A( x: 1 ), _ => B( y: 2 ) })  0 }", should_pass: false, kind: ""),
        VerdictCase(src: "Box<T>: { n: i32 }\nempty<T> = (k: i32) Box<T> { Box<T>( n: k ) }\ntest* = () i32 { m: Box<i32> := empty(7)  0 }", should_pass: true, kind: ""),
        VerdictCase(src: "bad = (xs: ...i32, y: i32) i32 { y }\ntest* = () i32 { bad(1, 2, 3) }", should_pass: false, kind: ""),
        VerdictCase(src: "g* = (x: i32) i32 { x }\nf* = (flags: RawPtr<u8>, i: i32, n: i32) void { (i < n).match({ true => { g(1, 2, 3)  store_i64(flags, 1) }, false => {} }) }\ntest* = () i32 { 0 }", should_pass: false, kind: ""),
        VerdictCase(src: "f* = (flags: RawPtr<u8>, i: i32, n: i32) void { (i < n).match({ true => { store_i64(flags)  store_i64(flags, 1) }, false => {} }) }\ntest* = () i32 { 0 }", should_pass: false, kind: ""),
        VerdictCase(src: "add* = (a: i32, b: i32) i32 { a + b }\ntest* = () i32 { add(1) }", should_pass: false, kind: "arity"),
        VerdictCase(src: "one* = (a: i32) i32 { a }\ntest* = () i32 { one() }", should_pass: false, kind: "arity"),
        VerdictCase(src: "P*: { x: i32 }\nneeds_p* = (p: P) i32 { p.x }\nmk* = () i64 { 5 }\ntest* = () i32 { needs_p(mk()) }", should_pass: false, kind: "arg-type"),
        VerdictCase(src: "test* = () i32 { foo(1) + bar(2) }", should_pass: false, kind: "undefined-name"),
        VerdictCase(src: "f* = (b: bool) i32 {\n b.match({ false => { return 9 } })\n 7\n}\ntest* = () i32 { f(false) }", should_pass: false, kind: "undefined-name"),
    ])
}
