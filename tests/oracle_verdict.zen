        should_pass: false,
        kind: "conformance",
    ), VerdictCase(
        src: "foo* = () i32 { 1 }\nfoo* = () i32 { 2 }\ntest* = () i32 { foo() }",
        should_pass: false,
        kind: "dup-fn",
    ), VerdictCase(
        src: "a* = () i32 { 1 }\ndup* = () i32 { 2 }\ndup* = () i32 { 3 }\ntest* = () i32 { a() }",
