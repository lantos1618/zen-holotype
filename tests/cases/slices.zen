// Slices `[T]` — a (ptr, len) view. A literal is homogeneous; indexing reads an
// element; the element-form loop binds the element at the slice's element type.

ends* = () i32 {
    xs := [1, 2, 3, 4]
    xs[0] + xs[3]
}                                                              //~ ends PASS

length* = () i64 {
    xs := [10, 20, 30]
    xs.len
}                                                              //~ length PASS

sumloop* = () i32 {
    xs := [10, 20, 30]
    n := 0
    loop(xs, (h, i, x) { n = n + x })
    n
}                                                              //~ sumloop PASS

// the element x has the slice's element type — bool used where i32 is wanted
elem_mismatch* = () i32 {
    flags := [true, false, true]
    n := 0
    loop(flags, (h, i, x) { n = n + x })
    n
}                                                              //~ elem_mismatch FAIL

// a slice literal must be homogeneous
hetero* = () i32 { xs := [1, true, 3]  0 }                     //~ hetero FAIL
