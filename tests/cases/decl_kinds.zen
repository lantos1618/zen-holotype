// Using a name as the wrong kind of declaration is a clean error, never a crash.
Color*: Red | Green        // an enum
helper* = () i32 { 0 }    // a function
Vec*: { len: i32 }        // a struct

// struct-literal syntax only works on a struct
lit_on_enum* = () i32 { Color { x: 1 } }   //~ lit_on_enum FAIL is not a struct
lit_on_fn*   = () i32 { helper { x: 1 } }  //~ lit_on_fn FAIL is not a struct
lit_ok*      = () i32 { Vec { len: 3 }.len } //~ lit_ok PASS
