    ), ShellCase(
        name: "project_link_directive",
        cmd: "rm -rf $ZT/zll && cp -r tests/fixtures/project/linklib_demo $ZT/zll && sed -i \"s#@@NATIVE@@#$ZT/zll/native.c#\" $ZT/zll/zen.toml && ./zenc build $ZT/zll >/dev/null 2>&1 && test -x $ZT/zll/linklib-bin && { b=$($ZT/zll/linklib-bin); test \"$?\" = 51; } && test \"$b\" = \"link libm\" && { o=$(./zenc run $ZT/zll); test \"$?\" = 51; } && test \"$o\" = \"link libm\" && sed -i \"/^link = /d;s/linklib-bin/linklib-bin-nolink/\" $ZT/zll/zen.toml && ./zenc build $ZT/zll >/dev/null 2>&1 && test -x $ZT/zll/linklib-bin-nolink && { $ZT/zll/linklib-bin-nolink; test \"$?\" = 51; }",
    ), ShellCase(
        name: "help_version_zen_root",
        cmd: "{ ./zenc --help >$ZT/zh.txt 2>&1; test \"$?\" = 0; } && grep -Fq \"usage:\" $ZT/zh.txt && grep -Fq \"zenc doc\" $ZT/zh.txt && { ./zenc --version >$ZT/zv.txt 2>&1; test \"$?\" = 0; } && grep -Fq \"zenc\" $ZT/zv.txt && { printf \"test* = () i32 { 1 }\\n\" | ./zenc 2>/dev/null | grep -Fq zslice; } && cp ./zenc $ZT/zenc-moved && printf \"main = () i32 { 42 }\\n\" > $ZT/zrm.zen && { ZEN_ROOT=$(pwd) $ZT/zenc-moved run $ZT/zrm.zen; test \"$?\" = 42; }",
