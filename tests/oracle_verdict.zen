        kind: "infinite-type",
    ), VerdictCase(
        src: "Node*: { next: Ptr<Node>, v: i32 }\ntest* = () i32 { 0 }",
        should_pass: true,
        kind: "",
    ), VerdictCase(
        src: "E*: A(Ptr<E>) | B\ntest* = () i32 { 0 }",
        should_pass: true,
        kind: "",
    ), VerdictCase(
        src: "Tree*: { kids: [Tree], v: i32 }\ntest* = () i32 { 0 }",
        should_pass: true,
        kind: "",
