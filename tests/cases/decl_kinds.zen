// Using a name as the wrong kind of declaration is a clean error, never a crash.
pub Color: Red, Green        // an enum
pub helper = () i32 { 0 }    // a function
pub Vec: { len: i32 }        // a struct

// struct-literal syntax only works on a struct
pub lit_on_enum = () i32 { Color { x: 1 } }   //~ lit_on_enum FAIL is not a struct
pub lit_on_fn   = () i32 { helper { x: 1 } }  //~ lit_on_fn FAIL is not a struct
pub lit_ok      = () i32 { Vec { len: 3 }.len } //~ lit_ok PASS
