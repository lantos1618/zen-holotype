// tests/oracle_value.zen — the VALUE category of the Zen-native correctness oracle (the self-hosted
// replacement for the pytest value harness). Each VCase's `src` defines `test* = () iNN { … }`; the
// emitted+compiled program must print `want`. These are the silent-miscompile guards — ported 1:1 from
// the golden VALUE_CASES corpus (tests/_oracle_corpus.py). See oracle_lib.zen for the contract.
{ VCase, run_values } = oracle_lib
oracle_value_run* = () i32 {
    run_values("value", [VCase(
        src: "test* = () i64 { sizeof(i64) }",
        want: "8",
    ), VCase(
        src: "test* = () i64 { sizeof(i32) }",
        want: "4",
    ), VCase(
        src: "test* = () i64 { sizeof(u8) }",
        want: "1",
    ), VCase(
        src: "test* = () i64 { sizeof(bool) }",
        want: "1",
    ), VCase(
        src: "test* = () i64 { sizeof(f64) }",
        want: "8",
    ), VCase(
        src: "test* = () i64 {\n  n: i64 := 4\n  n * sizeof(i64)\n}",
        want: "32",
    ), VCase(
        src: "id<T> = (x: T) T { x }\ntest* = () i64 { id(sizeof(i64)) }",
        want: "8",
    ), VCase(
        src: "test* = () i64 { 10000000000 / 10 }",
        want: "1000000000",
    ), VCase(
        src: "test* = () i64 { a: u64 := 9000000000000000000  b: u64 := 9000000000000000000  s: u64 := a + b  to_i64(s / 2) }",
        want: "9000000000000000000",
    ), VCase(
        src: "test* = () i64 { a: u64 := 9000000000000000000  b: u64 := 9000000000000000000  s: u64 := a + b  to_i64(s % 1000000000) }",
        want: "0",
    ), VCase(
        src: "test* = () i64 { x: u64 := 18446744073709551615  to_i64(x % 1000000000) }",
        want: "709551615",
    ), VCase(
        src: "test* = () i64 { x: u64 := 18446744073709551615  to_i64(x / 2) }",
        want: "9223372036854775807",
    ), VCase(
        src: "test* = () i64 { x: u64 := 18446744073709551615  to_i64(x - 18446744073709551610) }",
        want: "5",
    ), VCase(
        src: "test* = () i64 { x: u32 := 4294967295  to_i64(x) }",
        want: "4294967295",
    ), VCase(
        src: "test* = () i64 { x: u8 := 255  to_i64(x) }",
        want: "255",
    ), VCase(
        src: "test* = () i64 { 9999999999 - 9999999990 }",
        want: "9",
    ), VCase(
        src: "test* = () i64 { 5000000000 + 5000000000 }",
        want: "10000000000",
    ), VCase(
        // untyped-literal OPERAND width: products/shifts whose RESULT exceeds i32 must compute at >=64-bit
        src: "test* = () i64 { 100000 * 100000 }",
        want: "10000000000",
    ), VCase(
        src: "test* = () i64 { 1024 * 1024 * 1024 * 1024 }",
        want: "1099511627776",
    ), VCase(
        src: "test* = () i64 { 0xFF * 0x1000000 }",
        want: "4278190080",
    ), VCase(
        src: "test* = () i64 { 1 << 40 }",
        want: "1099511627776",
    ), VCase(
        // the widened comparison the bug used to get wrong (would be 0 at int width)
        src: "test* = () i32 { (100000 * 100000 > 5000000000).match ({ true => 1, false => 0 }) }",
        want: "1",
    ), VCase(
        // small i32 math must stay unchanged
        src: "test* = () i32 { 2 + 3 }",
        want: "5",
    ), VCase(
        src: "test* = () i32 {\n  1 + /* outer /* inner */ still-comment */ 41\n}",
        want: "42",
    ), VCase(
        src: "test* = () i32 { 3 + /* plain */ 4 }",
        want: "7",
    ), VCase(
        src: "bad* = () i32 { 'ab' }\ntest* = () i32 { 5 }",
        want: "5",
    ), VCase(
        src: "test* = () i32 { 'A' }",
        want: "65",
    ), VCase(
        src: "test* = () i32 {\n  x := 7\n  [1]\n  x\n}",
        want: "7",
    ), VCase(
        src: "test* = () i32 {\n  [9, 9]\n  1 + 2\n}",
        want: "3",
    ), VCase(
        src: "test* = () i32 {\n  s := [10, 20, 30]\n  s[2]\n}",
        want: "30",
    ), VCase(
        src: "Box<T>: { v: T }\nwrap<T> = (x: T) Box<T> { Box<T>(v: x) }\nget<T> = (b: Box<T>) i32 { b.v }\ntest* = () i32 {\n  n := 5\n  get(wrap(n))\n}",
        want: "5",
    ), VCase(
        src: "Box<T>: { v: T }\nwrap<T> = (x: T) Box<T> { Box<T>(v: x) }\nget<T> = (b: Box<T>) i32 { b.v }\ntest* = () i32 {\n  n := 9\n  w := wrap(n)\n  get(w)\n}",
        want: "9",
    ), VCase(
        src: "Opt<T>: Some(T) | None\ntest* = () i32 { (.Some(5)).match({ .Some(x) => x, .None => 0 }) }",
        want: "5",
    ), VCase(
        src: "Opt<T>: Some(T) | None\ntest* = () i32 {\n  o := .Some(7)\n  o.match({ .Some(x) => x, .None => 0 })\n}",
        want: "7",
    ), VCase(
        src: "Opt<T>: Some(T) | None\nmk<T> = (x: T) Opt<T> { .Some(x) }\ntest* = () i32 { mk(8).match({ .Some(x) => x, .None => 0 }) }",
        want: "8",
    ), VCase(
        src: "Opt<T>: Some(T) | None\none<T> = (x: T) Opt<T> { .None }\ntest* = () i32 { one(5).match({ .Some(x) => x, .None => 3 }) }",
        want: "3",
    ), VCase(
        src: "Opt<T>: Some(T) | None\npick<T> = (x: T, b: i32) Opt<T> { (b == 1).match({ true => .Some(x), false => .None }) }\ntest* = () i32 { pick(9, 0).match({ .Some(x) => x, .None => 3 }) }",
        want: "3",
    ), VCase(
        src: "Opt<T>: Some(T) | None\nunwrap<T> = (o: Opt<T>, d: T) T { o.match({ .Some(x) => x, .None => d }) }\ntest* = () i32 {\n  o := .Some(7)\n  unwrap(o, 0)\n}",
        want: "7",
    ), VCase(
        src: "Opt2<T>: Some(T) | Nada\nOpt<T>: Some(T) | None\ntest* = () i32 {\n  a: Opt2<i32> := .Some(42)\n  a.match({ .Some(x) => x, .Nada => 0 })\n}",
        want: "42",
    ), VCase(
        src: "Opt2<T>: Some(T) | Nada\nPlain: Some(i32) | Other\ntest* = () i32 {\n  a: Opt2<i32> := .Some(7)\n  a.match({ .Some(x) => x, .Nada => 0 })\n}",
        want: "7",
    ), VCase(
        src: "Opt2<T>: Some(T) | Nada\nPlain: Some(i32) | Other\ntest* = () i32 {\n  p: Plain := .Some(9)\n  p.match({ .Some(x) => x, .Other => 0 })\n}",
        want: "9",
    ), VCase(
        src: "Uniq<T>: Only(T) | Empty\nOpt2<T>: Some(T) | Nada\ntest* = () i32 {\n  u: Uniq<i32> := .Only(5)\n  u.match({ .Only(x) => x, .Empty => 0 })\n}",
        want: "5",
    ), VCase(
        src: "Box<M>: { buf: [M]  n: i32  at = (b: MutPtr<Box<M>>, i: i32) M { b.buf[i] } }\ntest* = () i32 { data := [111, 222, 333]  b := Box<i32>(buf: data, n: 3)  p := b.addr()  p.at(0) + p.at(1) }",
        want: "333",
    ), VCase(
        src: "Box<M>: { buf: [M]  n: i32  sum = (b: Box<M>) M { ms: [M] := b.buf  ms[0] + ms[1] } }\ntest* = () i32 { data := [10, 20, 30]  b := Box<i32>(buf: data, n: 3)  b.sum() }",
        want: "30",
    ), VCase(
        src: "Result<T, E>: Ok(T) | Err(E)\nIoError: NotFound\nok2<T, E> = (x: T) Result<T, E> { .Ok(x) }\ngetit = () Result<i32, IoError> { ok2(42) }\ntest* = () i32 { getit().match({ .Ok(v) => v, .Err(e) => 0 - 1 }) }",
        want: "42",
    ), VCase(
        src: "first<T> = (xs: [T]) T { xs[0] }\ntest* = () i32 { first([7, 8]) }",
        want: "7",
    ), VCase(
        src: "pick2<T> = (xs: [T], a: T) T { xs[1] + a }\ntest* = () i32 { pick2([3, 4], 5) }",
        want: "9",
    ), VCase(
        src: "test* = () i64 {\n  xs := [10, 20, 30]\n  xs.len()\n}",
        want: "3",
    ), VCase(
        src: "test* = () i64 {\n  xs := [10, 20, 30]\n  xs.len() + xs.len\n}",
        want: "6",
    ), VCase(
        src: "sum = (xs: ...i32) i32 { t := 0  xs.loop((h, i, x) { t = t + x })  t }\ntest* = () i32 { sum(1, 2, 3, 4) }",
        want: "10",
    ), VCase(
        src: "sum = (xs: ...i32) i32 { t := 0  xs.loop((h, i, x) { t = t + x })  t }\ntest* = () i32 { sum() }",
        want: "0",
    ), VCase(
        src: "sum = (xs: ...i32) i32 { t := 0  xs.loop((h, i, x) { t = t + x })  t }\ntest* = () i32 { sum(7) }",
        want: "7",
    ), VCase(
        src: "addv = (base: i32, xs: ...i32) i32 { t := base  xs.loop((h, i, x) { t = t + x })  t }\ntest* = () i32 { addv(100, 1, 2, 3) }",
        want: "106",
    ), VCase(
        src: "join = (sep: str, xs: ...str) i32 { n := 0  xs.loop((h, i, x) { n = n + 1 })  n }\ntest* = () i32 { join(\", \", \"a\", \"b\") }",
        want: "2",
    ), VCase(
        src: "Node*: { tag: i32, val: i32 }\ndiv = (kids: ...Node) i32 { s := 0  kids.loop((h, i, c) { s = s + c.val })  s }\ntest* = () i32 { div(Node(tag: 1, val: 10), Node(tag: 2, val: 20)) }",
        want: "30",
    ), VCase(
        src: "Box<T>: { v: T }\nmk<T> = (x: T) Box<T> { Box<T>(v: x) }\nget<T> = (b: Box<T>) T { b.v }\ntest* = () i32 {\n  b := mk(42)\n  b.get()\n}",
        want: "42",
    ), VCase(
        src: "idn<T> = (x: T, n: i32) T { (n <= 0).match({ true => x, false => idn(x, n - 1) }) }\ntest* = () i32 { idn(42, 5) }",
        want: "42",
    ), VCase(
        src: "C*: { z: i32 }\nsumv<A> = (a: MutPtr<A>, xs: [i32], i: i64, acc: i32) i32 { (i >= xs.len).match({ true => acc, false => a.sumv(xs, i + 1, acc + xs[i]) }) }\ntest* = () i32 {\n  c := C(z: 0)\n  c.addr().sumv([1, 2, 3, 4], 0, 0)\n}",
        want: "10",
    ), VCase(
        src: "Box<T>: { v: T }\nboxn<T> = (x: T, n: i32) Box<T> { (n <= 0).match({ true => Box<T>(v: x), false => boxn(x, n - 1) }) }\ntest* = () i32 { boxn(7, 3).v }",
        want: "7",
    ), VCase(
        src: "Store<S>: { state: S }\nAppState: { count: i32 }\ntest* = () i32 {\n  st := Store(state: AppState(count: 5))\n  st.state.count\n}",
        want: "5",
    ), VCase(
        src: "Store<S>: { state: S }\nAppState: { count: i32 }\ntest* = () i32 {\n  st: Store<AppState> := Store(state: AppState(count: 5))\n  st.state.count\n}",
        want: "5",
    ), VCase(
        src: "Store<S>: { state: S }\nAppState: { count: i32 }\ntest* = () i32 {\n  st := Store<AppState>(state: AppState(count: 5))\n  st.state.count\n}",
        want: "5",
    ), VCase(
        src: "Pair<A, B>: { a: A, b: B }\ntest* = () i32 {\n  p := Pair(a: 7, b: 9)\n  p.a + p.b\n}",
        want: "16",
    ), VCase(
        src: "Reducer<A>: { reduce: (Self, A) Self }\nStore<S>: { state: S }\nAppState: { count: i32, clicks: i32 }\nAction: Inc | Dec | Add(i32)\nAppState.impl(Reducer<Action>, { reduce = (s: AppState, a: Action) AppState { a.match({ .Inc => AppState(count: s.count + 1, clicks: s.clicks + 1), .Dec => AppState(count: s.count - 1, clicks: s.clicks + 1), .Add(n) => AppState(count: s.count + n, clicks: s.clicks + 1) }) } })\ndispatch<S, A> = (st: MutPtr<Store<S>>, a: A) void { st.state = st.state.reduce(a) }\ntest* = () i32 {\n  st := Store(state: AppState(count: 0, clicks: 0))\n  p := st.addr()\n  dispatch(p, Action.Inc)\n  dispatch(p, Action.Add(10))\n  dispatch(p, Action.Dec)\n  st.state.count\n}",
        want: "10",
    ), VCase(
        src: "Cell*: { x: i64 }\nDoubler*: { dbl: (Self) i64 }\ni64.impl(Doubler, { dbl = (n: i64) i64 { n * 2 } })\napply<T> = (x: T) i64 { x.dbl() }\nE*: Num(i64) | Add(i64)\ntest* = () i64 {\n  c := Cell(x: 0)\n  e := E.Num(21)\n  e.match({ .Num(n) => store_i64(c.addr(), apply(n)), .Add(m) => store_i64(c.addr(), apply(m)) })\n  load_i64(c.addr())\n}",
        want: "42",
    ), VCase(
        src: "Cell*: { x: i64 }\nDoubler*: { dbl: (Self) i64 }\ni64.impl(Doubler, { dbl = (n: i64) i64 { n * 2 } })\napply<T> = (x: T) i64 { x.dbl() }\nW*: Obj([i32]) | None\ntest* = () i64 {\n  c := Cell(x: 0)\n  w := W.Obj([10, 20, 30])\n  w.match({ .Obj(ps) => store_i64(c.addr(), apply(ps.len)), .None => store_i64(c.addr(), 0-1) })\n  load_i64(c.addr())\n}",
        want: "6",
    ), VCase(
        src: "B*: OpAdd | OpSub\nO*: Bin(B)\nf = (op: O) i32 { r := 0  op.match({ .Bin(bo) => { r = bo.match({ .OpAdd => 1, .OpSub => 2 }) } })  r }\ntest* = () i32 { f(O.Bin(B.OpSub)) }",
        want: "2",
    ), VCase(
        src: "State*: Idle | Run(i32)\ntest* = () i32 {\n  a := State.Idle\n  b := State.Idle\n  r := (a == b).to_i32()\n  r\n}",
        want: "1",
    ), VCase(
        src: "State*: Idle | Run(i32)\ntest* = () i32 {\n  a := State.Idle\n  b := State.Run(5)\n  r := (a != b).to_i32()\n  r\n}",
        want: "1",
    ), VCase(
        src: "State*: Idle | Run(i32)\ntest* = () i32 {\n  a := State.Run(2)\n  r := (a == State.Idle).to_i32()\n  r\n}",
        want: "0",
    ), VCase(
        src: "Tok*: Num(i64) | End\nExpr*: Num(i64) | Bin(i64)\nsecond<T> = (a: T, b: T) T { b }\nunNum = (t: Tok) i64 { t.match({ .Num(n) => n, .End => 0-1 }) }\ntest* = () i64 {\n  base := Tok.End\n  r := second(base, .Num(7))\n  unNum(r)\n}",
        want: "7",
    ), VCase(
        src: "apply = (f: (i32) i32, x: i32) i32 { f(x) }\ntest* = () i32 {\n  k := 10\n  g := (n) { n + k }\n  apply(g, 41) + apply(g, 2)\n}",
        want: "63",
    ), VCase(
        src: "twice = (f: (i32) i32, x: i32) i32 { f(f(x)) }\ntest* = () i32 {\n  g := (n) { n + 3 }\n  twice(g, 1)\n}",
        want: "7",
    ), VCase(
        src: "Vec<T>: { ptr: RawPtr<u8>, len: i64, cap: i64 }\nmalloc = (n: i64) RawPtr<u8>\nbuf<T> = (v: Vec<T>) [T] { slice(v.ptr, v.cap) }\nget<T> = (v: Vec<T>, i: i64) T { v.buf()[i] }\nof<T> = (xs: [T]) Vec<T> {\n  v := Vec<T>(ptr: malloc(xs.len * sizeof(T)), len: xs.len, cap: xs.len)\n  b := v.buf()\n  xs.loop((h, i, x) { b[i] = x })\n  v\n}\ntest* = () i32 {\n  v := of([10, 20, 30])\n  v.get(0) + v.get(2)\n}",
        want: "40",
    ), VCase(
        src: "srt<T> = (xs: [T], less: (T, T) bool) void {\n  xs.loop((ho, i, e) {\n    xs.loop((hi, k, e2) {\n      j := i - k\n      (j <= 0).match ({\n        true  => { hi.break },\n        false => less(xs[j], xs[j - 1]).match ({\n          true => { tmp := xs[j]  xs[j] = xs[j - 1]  xs[j - 1] = tmp },\n          false => { hi.break }\n        })\n      })\n    })\n  })\n}\ntest* = () i32 {\n  xs := [3, 1, 2, 5, 4]\n  xs.srt((a, b){ a < b })\n  (xs[0] * 10000) + (xs[1] * 1000) + (xs[2] * 100) + (xs[3] * 10) + xs[4]\n}",
        want: "12345",
    ), VCase(
        src: "srt<T> = (xs: [T], less: (T, T) bool) void {\n  xs.loop((ho, i, e) {\n    xs.loop((hi, k, e2) {\n      j := i - k\n      (j <= 0).match ({\n        true  => { hi.break },\n        false => less(xs[j], xs[j - 1]).match ({\n          true => { tmp := xs[j]  xs[j] = xs[j - 1]  xs[j - 1] = tmp },\n          false => { hi.break }\n        })\n      })\n    })\n  })\n}\ntest* = () i32 {\n  xs := [3, 1, 2, 5, 4]\n  xs.srt((a, b){ a > b })\n  (xs[0] * 10000) + (xs[1] * 1000) + (xs[2] * 100) + (xs[3] * 10) + xs[4]\n}",
        want: "54321",
    ), VCase(
        src: "Vec<T>: { ptr: RawPtr<u8>, len: i64, cap: i64 }\nmalloc = (n: i64) RawPtr<u8>\nbuf<T> = (v: Vec<T>) [T] { slice(v.ptr, v.cap) }\nempty<T> = () Vec<T> { Vec<T>(ptr: malloc(sizeof(T)), len: 0, cap: 1) }\npush<T> = (v: Vec<T>, x: T) Vec<T> { b := v.buf()  b[v.len] = x  Vec<T>(ptr: v.ptr, len: v.len + 1, cap: v.cap) }\nget<T> = (v: Vec<T>, i: i64) T { v.buf()[i] }\ntest* = () i32 {\n  v: Vec<i32> := empty()\n  v = v.push(42)\n  v.get(0)\n}",
        want: "42",
    ), VCase(
        src: "Pairs<T>: { ks: [str], vs: [T]\n    each_pair = (p: Pairs<T>, f: (str, T) void) void {\n        p.ks.loop((h, i, k) { f(k, p.vs[i]) })\n    }\n}\ntest* = () i32 {\n    p := Pairs<i32>(ks: [\"a\", \"b\", \"c\"], vs: [10, 20, 30])\n    s := 0\n    p.each_pair((k, v){ s = s + v })\n    s\n}",
        want: "60",
    ), VCase(
        src: "Opt<T>: Some(T) | None\nu<T> = (o: Opt<T>) i32 { o.match({ .Some(x) => 1, .None => 0 }) }\ntest* = () i32 { u(.Some(42)) }",
        want: "1",
    ), VCase(
        src: "Opt<T>: Some(T) | None\nunwrap<T> = (o: Opt<T>, d: T) T { o.match({ .Some(x) => x, .None => d }) }\ntest* = () i32 { unwrap(.Some(7), 0) }",
        want: "7",
    ), VCase(
        src: "A*: { v: i32 }\nB*: { v: i32 }\nShow*: { area: (Ptr<Self>) i32 }\nA.impl(Show, { area = (a: Ptr<A>) i32 { a.v } })\nB.impl(Show, { area = (b: Ptr<B>) i32 { b.v * b.v } })\ntest* = () i32 {\n  a := A(v: 5)\n  b := B(v: 6)\n  a.addr().area() + b.addr().area()\n}",
        want: "41",
    ), VCase(
        src: "P*: { x: i32 }\nQ*: { x: i32 }\nDbl*: { f: (Ptr<Self>, i32) i32 }\nP.impl(Dbl, { f = (p: Ptr<P>, k: i32) i32 { p.x + k } })\nQ.impl(Dbl, { f = (q: Ptr<Q>, k: i32) i32 { q.x * k } })\ntest* = () i32 {\n  p := P(x: 10)\n  q := Q(x: 3)\n  p.addr().f(2) + q.addr().f(4)\n}",
        want: "24",
    ), VCase(
        src: "Show*: { area = (s: Ptr<Self>) i32 { 100 } }\nA*: { v: i32 }\nB*: { v: i32 }\nA.impl(Show, { })\nB.impl(Show, { area = (b: Ptr<B>) i32 { b.v * b.v } })\ntest* = () i32 {\n  a := A(v: 5)\n  b := B(v: 6)\n  a.addr().area() + b.addr().area()\n}",
        want: "136",
    ), VCase(
        src: "Show*: { area = (s: Ptr<Self>) i32 { s.v + 1 } }\nA*: { v: i32 }\nA.impl(Show, { })\ntest* = () i32 { a := A(v: 41)  a.addr().area() }",
        want: "42",
    ), VCase(
        src: "T*: { a = (s: Ptr<Self>) i32 { 1 }, b = (s: Ptr<Self>) i32 { 2 } }\nN*: { v: i32 }\nN.impl(T, { b = (s: Ptr<N>) i32 { 20 } })\ntest* = () i32 { n := N(v: 0)  n.addr().a() * 100 + n.addr().b() }",
        want: "120",
    ), VCase(
        src: "Greet*: {\n  name = (s: Ptr<Self>) i32 { 7 }\n  greet = (s: Ptr<Self>) i32 { s.name() + 1 }\n}\nP*: { v: i32 }\nP.impl(Greet, { })\ntest* = () i32 { p := P(v: 0)  p.addr().greet() }",
        want: "8",
    ), VCase(
        src: "malloc = (n: i64) RawPtr<u8>\nAlloc*: { acquire = (s: MutPtr<Self>, n: i64) RawPtr<u8> { malloc(n) } }\nHeap*: { _: i32 }\nBump*: { buf: RawPtr<u8>, off: i64 }\nHeap.impl(Alloc, { })\nBump.impl(Alloc, { acquire = (s: MutPtr<Bump>, n: i64) RawPtr<u8> { p := s.buf.offset(s.off)  s.off = s.off + n  p } })\nfill<A> = (a: MutPtr<A>) i64 { p := a.acquire(8)  store_i64(p, 21)  q := a.acquire(8)  store_i64(q, 21)  load_i64(p) + load_i64(q) }\ntest* = () i32 {\n  h := Heap(_: 0)\n  b := Bump(buf: malloc(64), off: 0)\n  to_i32(fill(h.addr()) + fill(b.addr()) + b.off)\n}",
        want: "100",
