// .or_return() — keyword-free error propagation: `x := g().or_return()` yields the Ok payload, or
// early-returns the Err from the enclosing function. Exit 61 = f(1) yields Ok(6); f(0) early-returns Err.
{ Result, IoError } = std.core.result
g = (ok: i32) Result<i32, IoError> { (ok == 1).match ({ true => .Ok(5), false => .Err(.NotFound) }) }
mkok = (v: i32) Result<i32, IoError> { .Ok(v) }
f = (ok: i32) Result<i32, IoError> {
    x := g(ok).or_return()    // ok==1: yields 5 ; ok==0: returns .Err(.NotFound) from f
    mkok(x + 1)
}
main = () i32 {
    a := f(1).match ({
        .Ok(v)  => v,
        .Err(e) => 0,
    })    // 6
    b := f(0).match ({
        .Ok(v)  => 0,
        .Err(e) => 1,
    })    // 1 (Err propagated)
    a * 10 + b
}
