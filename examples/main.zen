{ Vec } = core.vec
{ len, cap, bump } = ops

area = (v: Ptr<Vec>) i32 { len(v) * cap(v) }

// these two are SUPPOSED to fail the checker -> excluded from the build:
bad    = (v: Option<Ptr<Vec>>) i32 { len(v) }   // nullable into nonnull
dirbad = (v: Ptr<Vec>) i32 { bump(v) }          // read-only into mut-required

main = () i32 { area(addr(Vec { len: 3, cap: 4 })) }   // 3 * 4 = 12
