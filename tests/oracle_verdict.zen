        should_pass: false,
        kind: "",
    ), VerdictCase(
        // soundness hole 4: a generic call's CONCRETE result type (Box<i32> from mk(255)) must be
        // fit-checked against the annotation Box<u8> — a real mismatch, not an unknown leaked to cc.
        src: "Box<T>: { v: T }\nmk<T> = (x: T) Box<T> { Box<T>(v: x) }\ntest* = () i32 { bu: Box<u8> := mk(255)  0 }",
        should_pass: false,
        kind: "assign-fit",
    ), VerdictCase(
        // hole 4 still-accept: the inferred instance IS correct (Box<i32>), so it type-checks.
        src: "Box<T>: { v: T }\nmk<T> = (x: T) Box<T> { Box<T>(v: x) }\nunbox<T> = (b: Box<T>) T { b.v }\ntest* = () i32 { bi: Box<i32> := mk(7)  unbox(bi) }",
        should_pass: true,
        kind: "",
    ), VerdictCase(
        // hole 4 return position: returning Box<i32> from a Box<u8> function is a return-fit error.
        src: "Box<T>: { v: T }\nmk<T> = (x: T) Box<T> { Box<T>(v: x) }\ngetu8* = () Box<u8> { mk(7) }\ntest* = () i32 { 0 }",
        should_pass: false,
        kind: "return-fit",
    ), VerdictCase(
        // soundness hole 5: i32 + i64 is i64 (the WIDER operand), so it cannot fit an i32 slot —
        // no silent truncation, and no order-dependence (`a + b` and `b + a` both reject).
        src: "f* = () i32 { a: i32 := 0  b: i64 := 4294967297  a + b }\ntest* = () i32 { f() }",
        should_pass: false,
        kind: "return-fit",
    ), VerdictCase(
        // hole 5 still-accept: legitimate i64 math and same-width i32 math are unchanged.
        src: "f* = () i64 { a: i64 := 3  b: i64 := 4294967297  a + b }\ng* = () i32 { a: i32 := 5  b: i32 := 7  a + b }\ntest* = () i32 { g() }",
        should_pass: true,
        kind: "",
    ), VerdictCase(
        // hole 5 still-accept: a numeric LITERAL operand adapts, so `c + 1` (u8 + int-lit) stays u8.
        src: "f* = (c: u8) u8 { c + 1 }\ntest* = () i32 { 0 }",
        should_pass: true,
        kind: "",
    ), VerdictCase(
        // soundness hole 6: a UFCS trait method on a receiver that does NOT impl the trait (Box has
        // no Area impl) is a trait-bound error, not a bare `area` symbol leaked to the linker.
        src: "Area*: { area: (Ptr<Self>) i32 }\nCircle*: { r: i32 }\nBox*: { w: i32 }\nCircle.impl(Area, { area = (c: Ptr<Circle>) i32 { c.r * c.r } })\ntest* = () i32 { b := Box(w: 3)  b.addr().area() }",
        should_pass: false,
        kind: "trait-bound",
    ), VerdictCase(
        // hole 6 still-accept: valid UFCS trait dispatch (Circle DOES impl Area) resolves and runs.
        src: "Area*: { area: (Ptr<Self>) i32 }\nCircle*: { r: i32 }\nCircle.impl(Area, { area = (c: Ptr<Circle>) i32 { c.r * c.r } })\ntest* = () i32 { c := Circle(r: 4)  c.addr().area() }",
        should_pass: true,
        kind: "",
    ), VerdictCase(
        // R1: a read-only `Ptr<T>` value must NOT satisfy a writable `MutPtr<T>` parameter (silent
        // write-laundering). do_bump would mutate through a pointer the caller declared read-only.
        src: "Counter*: { n: i32 }\ndo_bump* = (c: MutPtr<Counter>) void { c.n = c.n + 1 }\ntest* = () i32 { c := Counter(n: 0)  p: Ptr<Counter> := c.addr()  do_bump(p)  c.n }",
        should_pass: false,
        kind: "",
    ), VerdictCase(
        // R1 still-accept: a writable `MutPtr<T>` DOES satisfy a read-only `Ptr<T>` parameter.
        src: "Counter*: { n: i32 }\npeek* = (c: Ptr<Counter>) i32 { c.n }\ntest* = () i32 { c := Counter(n: 0)  p: MutPtr<Counter> := c.addr()  peek(p) }",
        should_pass: true,
        kind: "",
    ), VerdictCase(
        // R8: assert_nonnull on a genuinely non-pointer arg (a scalar) is rejected (would emit a void
        // value into a non-void slot at cc time).
        src: "test* = () i64 { x := 5  q := assert_nonnull(x)  load(q) }",
        should_pass: false,
        kind: "",
    ), VerdictCase(
        // R8 still-accept: assert_nonnull on a real nullable `RawPtr<T>` narrows it to `MutPtr<T>`.
        src: "test* = () i64 { p: RawPtr<i64> := malloc(8)  q := assert_nonnull(p)  store(q, 7)  load(q) }",
        should_pass: true,
        kind: "",
    )])
    // Stage 3 nullability: deref of a nullable `RawPtr<T>` (T != u8) without a null-check is REJECTED.
    // store / offset through a nullable `RawPtr<T>` are likewise rejected.
    // `assert_nonnull` proves non-null (yields `MutPtr<T>`), so the subsequent load is accepted.
    // the `RawPtr<u8>` byte-buffer floor is EXEMPT — it derefs freely.
    // a non-null `Ptr<T>` / `MutPtr<T>` deref is unaffected by the nullability rule.
    // A one-armed bool `.match` in STATEMENT position (a guard followed by more code) is LEGAL — the
    // missing arm defaults to `{}`. The early `return` fires for the covered case and falls through otherwise.
    // In VALUE position there is nothing for the missing branch to evaluate to → still rejected (exhaustiveness).
    b := run_verdicts("verdict-kind (100)", [VerdictCase(
        src: "g* = (x: i32) i32 { x }\nf* = (flags: RawPtr<u8>, i: i32, n: i32) void { (i < n).match({ true => { g(1, 2, 3)  store_i64(flags, 1) }, false => {} }) }\ntest* = () i32 { 0 }",
        should_pass: false,
        kind: "arity",
    ), VerdictCase(
        src: "f* = (flags: RawPtr<u8>, i: i32, n: i32) void { (i < n).match({ true => { store_i64(flags)  store_i64(flags, 1) }, false => {} }) }\ntest* = () i32 { 0 }",
        should_pass: false,
        kind: "arity",
    ), VerdictCase(
        src: "add* = (a: i32, b: i32) i32 { a + b }\ntest* = () i32 { add(1) }",
        should_pass: false,
        kind: "arity",
    ), VerdictCase(
        src: "add* = (a: i32, b: i32) i32 { a + b }\ntest* = () i32 { add(1, 2, 3) }",
        should_pass: false,
        kind: "arity",
    ), VerdictCase(
        src: "zero* = () i32 { 0 }\ntest* = () i32 { zero(1) }",
        should_pass: false,
        kind: "arity",
    ), VerdictCase(
        src: "one* = (a: i32) i32 { a }\ntest* = () i32 { one() }",
        should_pass: false,
        kind: "arity",
    ), VerdictCase(
        src: "test* = () i64 { p := malloc(8)  store_i64(p)  0 }",
        should_pass: false,
        kind: "arity",
    ), VerdictCase(
        src: "test* = () i64 { p := malloc(8)  store_i64(p, 1, 2)  0 }",
        should_pass: false,
        kind: "arity",
    ), VerdictCase(
        src: "test* = () i64 { p := malloc(8)  q := offset(p)  0 }",
        should_pass: false,
        kind: "arity",
    ), VerdictCase(
        src: "test* = () i64 { p := null_ptr(7)  0 }",
        should_pass: false,
        kind: "arity",
    ), VerdictCase(
        src: "g* = (a: i32) i32 { a }\nf* = (b: bool) i32 { b.match({ true => { g(1, 2)  1 }, false => 0 }) }\ntest* = () i32 { f(1 < 2) }",
        should_pass: false,
        kind: "arity",
    ), VerdictCase(
        src: "takes_u8* = (b: u8) i32 { 0 }\nbig* = () i64 { 9999999999 }\ntest* = () i32 { takes_u8(big()) }",
        should_pass: false,
        kind: "arg-type",
    ), VerdictCase(
        src: "P*: { x: i32 }\nneeds_p* = (p: P) i32 { p.x }\nmk* = () i64 { 5 }\ntest* = () i32 { needs_p(mk()) }",
        should_pass: false,
        kind: "arg-type",
