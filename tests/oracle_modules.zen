    // ── the net is NOT hollow: cross-module calls are arity/arg-type checked (test_modules_oracle) ──
    // ── transitive / clash rejections (test_resolver_oracle) ─────────────────────────────────
    // ── namespace-bound diagnostics keep the USER source span (test_user_imports) ────────────
    // ── loader-error QUALITY: clean messages, not raw linker spew (test_user_imports) ────────
    // ── sibling name COLLISIONS reject with origin + hint (test_user_imports) ────────────────
    // the collision diagnostic NAMES the origin module + the redefining module.
    // C-keyword symbol-key collision (struct vs struct_zk) is still caught.
    // ── test_resolver_fixes.py — driver-level check cases ────────────────────────────────────
    // bug 1: co-imports whose closures share generic decls (new<T>, release<T>*, dup<T>) check clean.
    // generic-heavy modules check clean on their own.
    // bug 3: multi-line impl bodies (runtime) + multi-line imports (ast) resolve clean.
    // std.concurrent.actor standalone-checks: indented `sent = true` is code, not an import of sibling `true`;
    // and actor exports spawn/try_spawn despite the coroutine substrate owning the same names.
    // a user decl that collides with a name in its imported std closure is rejected (no silent shadow).
    // two imported modules sharing a name still dedup silently (dependency-first, no false dup).
    // unknown type names in annotations / returns / lets are rejected (driver unknown-type pass).
    // defined / primitive / generic / imported types must NOT be flagged (no false positive).
    // must-use: a discarded value-mold (Self,…) Self self-mutation result is rejected; rebind/tail OK.
    // lambdas: a bound local lambda used as a HOF arg compiles; a non-capturing field/returned lambda
    // is lifted (accepts); a CAPTURING field lambda rejects with error[lambda-value].
    // ── a large namespace-bound compiler module resolves without overflowing the resolver ────
    e := run_mod_emits("modules emit (resolution-before-cgen / literal preservation)", [ModEmitCase(
        files: [ModFile(
            name: "right.zen",
            src: "default* = (n: i32) i32 { n + 5 }\n",
        ), ModFile(
            name: "p.zen",
            src: "heap = std.mem.heap\nright = right\nmain = () i32 {\n    h := heap.gpa()\n    to_i32(30) + right.default(7)\n}\n",
        )],
        entry: "p.zen",
        present: ["heap__gpa()", "right__default(7LL)"],
        absent: ["default_zk(heap)", "default_zk(right"],
    ), ModEmitCase(
        files: [ModFile(
            name: "right.zen",
            src: "thing* = () i32 { 5 }\ntext* = () str { \"thing\" } // thing in a comment should stay inert\n",
        ), ModFile(
            name: "p.zen",
            src: "right = right\n{ eq } = std.text.str\n{ to_exit } = std.core.bool\nmain = () i32 {\n    literal := \"right.thing\"\n    ok := eq(literal, \"right.thing\") && eq(right.text(), \"thing\")\n    ok.to_exit()\n}\n",
        )],
        entry: "p.zen",
        present: ["\"right.thing\""],
        absent: ["\"right__thing\""],
    ), ModEmitCase(
        files: [ModFile(
            name: "p.zen",
            src: "cv = compiler.check_validate\nmain = () i32 { 0 }\n",
        )],
        entry: "p.zen",
        present: ["cv__diagnostic_from_source"],
        absent: [],
    ), ModEmitCase(
        files: [ModFile(
            name: "helper.zen",
            src: "addh* = (a: i32, b: i32) i32 { a + b }\n",
        ), ModFile(
            name: "main.zen",
            src: "{addh} = helper\ntest* = () i32 { addh(3, 4) }\nmain = () i32 { test() }\n",
        )],
        entry: "main.zen",
        present: ["return addh(3LL, 4LL)", "int32_t addh("],
        absent: [],
    ), ModEmitCase(
        files: [ModFile(
            name: "helper.zen",
            src: "addh* = (a: i32, b: i32) i32 { a + b }\n",
        ), ModFile(
            name: "main.zen",
            src: "{ addh } = helper\ntest* = () i32 { addh(3, 4) }\nmain = () i32 { test() }\n",
        )],
        entry: "main.zen",
        present: ["return addh(3LL, 4LL)", "int32_t addh("],
        absent: [],
    ), ModEmitCase(
        files: [ModFile(
            name: "helper.zen",
            src: "addh* = (a: i32, b: i32) i32 { a + b }\n",
        ), ModFile(
            name: "main.zen",
            src: "{addh } = helper\ntest* = () i32 { addh(3, 4) }\nmain = () i32 { test() }\n",
        )],
        entry: "main.zen",
        present: ["return addh(3LL, 4LL)", "int32_t addh("],
        absent: [],
    ), ModEmitCase(
        files: [ModFile(
            name: "helper.zen",
            src: "addh* = (a: i32, b: i32) i32 { a + b }\n",
        ), ModFile(
            name: "main.zen",
            src: "{ addh} = helper\ntest* = () i32 { addh(3, 4) }\nmain = () i32 { test() }\n",
        )],
        entry: "main.zen",
        present: ["return addh(3LL, 4LL)", "int32_t addh("],
        absent: [],
    )])
    // namespace-bound calls are rewritten to module-qualified C symbols before cgen.
    // the namespace rewriter preserves string literals + comments (only real calls rewritten).
    // a large namespace-bound compiler module emits the qualified symbol without overflow.
    // import-head spacing variants all emit the resolved sibling call (test_modules_oracle).
    dc := run_mod_docs("modules doc (exported signatures)", [ModDocCase(
        module: "std.concurrent.actor",
        present: ["spawn*<A, M, ActorT>", "try_spawn*<A, M, ActorT>"],
    )])
    // std.concurrent.actor exports the generic spawn/try_spawn signatures.
    sd := run_mod_stdins("modules stdin (no program dir)", [ModStdinCase(
        src: "{ helper } = b\nmain = () i32 { helper(21) }\n",
        should_succeed: false,
        present: ["sibling import 'b'", "stdin"],
    ), ModStdinCase(
        src: "main = () i32 { 6 * 7 }\n",
        should_succeed: true,
        present: ["int32_t zen_main("],
    )])
    // a sibling import from STDIN has no directory to resolve from → clean error, no half-emitted C.
    // import-free source stays the classic source→C filter (Zen main emitted as zen_main).
    v + d + e + dc + sd
}
// escape "\n" (newline) → the literal backslash-n in a generated source so it can be embedded inside a
// Zen string literal in the GENERATED program text. The byte we look for is ASCII 10.
esc_nl = (mp: MutPtr<Malloc>, s: str) str {
    out := mp.new_in()
    v: [u8] := s.view()
    i: i64 := 0
    n: i64 := len(s)
    @while (i < n) {
        (v[i] == 10).match ({ true => {
            out = out.append_in(mp, "\\n")
        }, false => {
            out = out.push_in(mp, v[i])
        } })
        i = i + 1
    }
    mp.finish_in(out)
}
edges700_esc = (mp: MutPtr<Malloc>, s: str) str { mp.esc_nl(s) }
// ════════════════════════════════════════════════════════════════════════════════════════════════
// PARITY MAP — what the deleted/kept pytest cross-module suites map to here.
//
// tests/test_resolver_fixes.py  → FULLY PORTED → DELETED. Every test fn is a black-box `zenc
//   check`/`run`/`doc` over a small program, so each became a ModVerdictCase / ModValCase / ModDocCase:
//     generic_decl_co_imports(fmt+rc,vec+rc,fmt+arc,fmt+drop), generic_heavy_module_alone(io.c,cown),
//     ns_bind_qualified_call_runs(c=std.io.c→37), std_runtime/std_ast imports_clean, std_actor standalone
//     + spawn/try_spawn doc, user_shadow_of_imported_std_name(dup), import_vs_import_collision(first-wins),
//     std_ast_builders_usable, std_ast_decl_buffer_uses_explicit_allocator, undefined-type
//     (annotation/return/local-let/nested-let), value-mold must-use (discard reject / rebind / tail),
//     defined+imported types not flagged, lambda (hof-arg / field-lift / capturing-reject / returned-lift).
//
// tests/test_modules_oracle.py  → user-facing PORTED → DELETED. The "net is not hollow" verdicts
//   (wrong-arity/arg-type reject, correct accept, slice.len no-misdispatch) + the 4 import-head spacing
//   variants (now ModEmitCase asserting the resolved sibling C) cover its CLI behavior. The two
//   parametrized invariants — test_module_typechecks_against_its_imports / test_bootstrap_sources_typecheck
//   — drive _oracle.check_linked, a PYTHON harness that layers synthetic module headers; that invariant is
//   not a CLI behavior but is enforced every build (the committed zenc is compiled from the whole stdlib,
//   so any cross-module type error breaks the bootstrap) — dropped as Python-harness impl-detail.
//   test_modules_oracle_has_no_python_frontend_dependency is moot in a zero-Python repo.
//
// tests/test_user_imports.py    → KEPT (cannot reach full parity). Almost everything is ported here:
//   sibling/two-module/namespace-bind/same-name/same-type/cycle loads; the std-export collision suite
//   (slice.buf/dup, bytes.at, str.at, alloc.default, num.integer/float+Result, collections.of, vec.Vec<T>,
//   runtime.sync/async, actor.cell, string+actor coexist, slice+str dup coexist, cown.buf/file, ownership
//   ctors); loader-error quality + collision origin/hint; emit resolution-before-cgen + literal/comment
//   preservation; the std.internal.resolve PUBLIC API as `zenc run` programs (import_edges, try_import_edges,
//   provided_symbols_in, try_symbol_key_in, module_graph_in, strip_ns_into) INCLUDING the stack-growth
//   stress (240/120/260 decls, 700 edges, 220 symbols, 3500-call rewrite — sources generated in-Zen); and
//   stdin no-program-dir mode. The THREE deep-loader tests — resolve_program_data /
//   resolve_parsed_program / check_parsed_program (module_table, parsed-program AST boundary, graph-linked
//   check) — do NOT port reliably: the committed compiler's resolve_program_data has a heap-layout-sensitive
//   bug (the identical resolution call passes with few downstream string constants and fails "unknown module
//   'left'" with more), so they are the remaining blockers. They test resolver-INTERNAL data structures whose
//   user-observable guarantees (transitive namespace loading + graph-linked cross-module arity) are already
//   covered above; recommend fixing the loader heap bug, then porting them, OR keeping them in Python.
//   (Also covered-by-equivalent, not separately ported: the 81-file edge fan-out ≡ the 700-edge in-string
//   stress; the long-line / many-line / large-literal strip_ns variants ≡ the 3500-call rewrite stress.)
//
// tests/test_resolver_oracle.py → KEPT. Its user-observable cases (name-clash resolves to the imported
//   module + wrong-call rejected, transitive re-export + arity) ARE ported (sm.thing, base→mid→app Pt). But
//   the bulk — module_graph / topo_order / reachable / split_decls / bootstrap-manifest-scc / the
//   per-module namespaced-resolver check / the naive-flat-concat false-positive control — assert on
//   tests/_resolver.py, a PYTHON reimplementation of the resolver's graph/topo/splitter, NOT on the
//   compiler. They are unportable to a black-box oracle (there is no CLI surface for "the Python harness's
//   internal data structure"); they stay in Python. tests/_resolver.py therefore remains (also imported by
//   tests/_oracle.py's check_namespaced_count).
// ════════════════════════════════════════════════════════════════════════════════════════════════
