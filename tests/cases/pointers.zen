// Direction lattice, exercised through real call sites.
pub Vec: { len: i32, cap: i32 }

pub take_ptr = (v: Ptr<Vec>) i32 { v.len }
pub take_mut = (v: MutPtr<Vec>) i32 { v.cap }

// MutPtr is more capable, so it stands in where a read-only Ptr is wanted.
pub mut_into_ptr = (v: MutPtr<Vec>) i32 { take_ptr(v) }   //~ PASS

// ...but a read-only Ptr cannot satisfy a mutate-required slot.
pub ptr_into_mut = (v: Ptr<Vec>) i32 { take_mut(v) }      //~ FAIL MutPtr<Vec>
