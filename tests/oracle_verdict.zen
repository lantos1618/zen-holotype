        kind: "",
    ), VerdictCase(
        src: "test* = () i32 { x := 5\n p: Ptr<i32> := x.addr()\n load(p) }",
        should_pass: true,
        kind: "",
    ), VerdictCase(
        src: "foo* = () i32 { 1 }\nfoo* = () i32 { 2 }\ntest* = () i32 { foo() }",
        should_pass: false,
