// tests/oracle.zen — the thin MAIN of the Zen-native correctness oracle (the self-hosted replacement
// for the pytest value/verdict harness). It imports the harness library + each category file and sums
// their fail counts into the process exit code. NO Python anywhere — the compiler tests itself, in
// itself, by driving the committed `zenc` binary via std.io.
//
//   make -f bootstrap/Makefile oracle      # build this with zenc, run it; exit = total fail count
//
// ── ADDING A CATEGORY ────────────────────────────────────────────────────────────────────────────
// A category agent writes tests/oracle_<cat>.zen exporting `oracle_<cat>_run*() i32` (see oracle_lib.zen
// for the contract). Wire it in here with two edits: import its run fn, and add it to the sum below.
// The `oracle_<cat>_run` names are unique, so the flat imports never collide.
{ fixpoint_ok, run_suite, zo_ensure, zo_cleanup } = oracle_lib
{ oracle_value_run } = oracle_value
{ oracle_verdict_run } = oracle_verdict
{ oracle_build_run } = oracle_build
{ oracle_modules_run } = oracle_modules
{ oracle_boundaries_run } = oracle_boundaries
{ oracle_misc_run } = oracle_misc
{ oracle_fuzz_run } = oracle_fuzz
{ out } = std.io.file
{ getEnv } = std.os
{ is_empty } = std.text.str
main* = () i32 {
    // FAST mode (env ZEN_ORACLE_FAST set non-empty, e.g. `make oracle-fast`): run ONLY the quick
    // deterministic correctness suites (value + verdict, ~13s) and skip the slow subprocess-heavy
    // ones (modules ~90s of multi-file builds, build/boundaries/misc/fuzz, + the full self-host
    // fixpoint). For inner-loop iteration; the full `make oracle` stays the merge gate.
    fast := is_empty(getEnv("ZEN_ORACLE_FAST")).match ({ true => false, false => true })
    // create this run's private scratch dir BEFORE any case writes into it (see oracle_lib zo_*).
    zo_ensure()
    fails := 0
    // fast subset — always run (deterministic, a few seconds).
    fails = fails + oracle_value_run()
    fails = fails + oracle_verdict_run()
    // slow subprocess-heavy suites — only when NOT in fast mode. `match` is control flow, so in fast
    // mode the false arm (every slow suite call) is never evaluated.
    fails = fails + fast.match ({
        true  => 0,
        false => oracle_modules_run() + oracle_build_run() + oracle_boundaries_run() + oracle_misc_run() + oracle_fuzz_run() + run_suite("fixpoint", [fixpoint_ok()]),
    })
    // remove this run's private scratch dir (unique per pid, so cleanup is best-effort housekeeping).
    zo_cleanup()
    (fails == 0).match ({ true => out("\nzen oracle: ALL PASS\n"), false => out("\nzen oracle: FAILURES above (see F marks); exit = total fail count\n") })
    fails
}
