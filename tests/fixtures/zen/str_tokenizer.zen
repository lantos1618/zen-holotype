halloc = std.mem.heap
{ Arena, make_in } = std.mem.arena
{ find, substr, parse_int, len } = std.text.str
{ println } = std.text.fmt
// print the words of s[from..] (split on ' '), each followed by its parse_int
tok_words = (a: MutPtr<Arena>, s: str, from: i64) i64 {
    rest := a.substr(s, from, s.len() - from)
    sp := rest.find(" ")
    (sp < 0).match ({ true => {
        println(rest)
        println(rest.parse_int())
        0
    }, false => {
        w := a.substr(rest, 0, sp)
        println(w)
        println(w.parse_int())
        a.tok_words(s, from + sp + 1)
    } })
}
main = () i32 {
    heap := halloc.gpa()
    scratch: Arena := heap.addr().make_in(4096)
    scratch.addr().tok_words("zen has 3 frontends and -1 regrets", 0)
    scratch.addr().free_in(heap.addr())
    0
}
