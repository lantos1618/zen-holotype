halloc = std.mem.heap
vec = std.collections.vec
main = () i32 {
    alloc := halloc.gpa()
    a := alloc.addr()
    v0 := vec.of(a, [1])
    v1 := v0.push(a, 2)
    v2 := v1.push(a, 3)
    v3 := v2.push(a, 4)
    v4 := v3.push(a, 5)
    v5 := v4.push(a, 6)
    v5.get(0) + v5.get(1) + v5.get(2) + v5.get(3) + v5.get(4) + v5.get(5)
}
