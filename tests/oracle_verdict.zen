        src: "Inner*: { n: i32 }\nOuter*: { p: Ptr<Inner>, tag: i32 }\ntest* = () i32 { o := Outer(tag: 7)  o.tag }",
        should_pass: false,
        kind: "struct-field",
    ), VerdictCase(
        src: "Box*: { v: i32 }\ntest* = () i32 { b := Box(v: 5, v: 9)  b.v }",
