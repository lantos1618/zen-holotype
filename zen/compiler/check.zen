// compiler.check — resolve and infer over the shared genc AST.
// This pass fills enum names, constructor types, UFCS dispatch, generic instances, and the
// type facts the validator/backend need. Child nodes are rebuilt, not mutated in place.
{ Expr, Stmt, Decl, Func, Param, Ty, EnumDecl, StructDecl, Field, ImplData, TraitDefData, ArmData, MatchData, VariantDef, LetData, AssignData, IndexSetData, IndexData, MemberData, ArrowData, VarData, CallData, MethodCallData, CondData, BinData, BlockData, LambdaData, GenericData, MakeStructData, MakeEnumData, TagData, vref, vref_at, ty_cname_in, bin, bin_at, cond, call, call_at, raw_call_at, member, arrow, ematch, ematchp, mkenum, mktag, arm, eindex, eloop, LoopData, lam, slet, slett, sassign, sassign_at, sret, sexpr, sif, swhile, sidxset, sidxset_at, mkstruct, finit, FieldInit, slit, SliceData, block, is_fnt, has_fnt_param, is_generic_fn, fnt_from_func_in, fntype, subst_ty_in, mangle_str_in, impl_cname_in, dfunc, dforeign, dglobal, GlobalData, mkstructg, mkenumg, mktagg, no_tys, expr_null, is_expr_null, GenEnumDecl, GenStructDecl, find_genenum, tgeneric, FnTData, flit, ti32, ti64, tu8, tf64, tbool, tstr, tcstr, ttext, tnamed, tptr, tslice, tvoid, gstr_string, gstr_grow, gstr_reserve, gstr_push, gstr_append, gstr_finish } = compiler.genc
{ Allocator, Malloc } = std.mem.alloc
{ panic } = std.core.result
{ view, eq, is_empty } = std.text.str
{ String } = std.text.string
{ at } = std.text.bytes
{ Map, of } = std.collections.map

// ── DECLARATION INDEX ───────────────────────────────────────────────────────
// name → decl array index, an O(1) hash map (std.collections.map). Built once per
// resolve/check pass from the (immutable, within a pass) decls slice and threaded through Env,
// replacing the O(n) linear `the_func`/sibling scans that dominated compile time. `put` overwrites,
// so each name maps to its LAST occurrence — identical to the old last-match scans (top-level names
// are unique post-dedup anyway). -1 means absent.
DeclIndex*: {
    func_idx:   Map<i64>,   // DFunc.name | DForeign.name → index
    struct_idx: Map<i64>,   // DStruct.name → index
    enum_idx:   Map<i64>,   // DEnum.name → index
    global_idx: Map<i64>,   // DGlobal.name → index
    impl_idx:   Map<i64>,   // DImpl.ty → presence marker (a type with at least one impl)
    tdef_idx:   Map<i64>    // (trait "\t" method) → presence: the trait provides a default for the method
}
// the combined key for a trait-default lookup; trait/method are identifiers, so a TAB can't collide.
tdkey = (a: MutPtr<Malloc>, tr: str, m: str) str { a.gstr_string(64).gstr_append(a, tr).gstr_append(a, "\t").gstr_append(a, m).gstr_finish(a) }
build_decl_index* = (a: MutPtr<Malloc>, decls: [Decl]) DeclIndex {
    seed: i64 := 0 - 1
    idx := DeclIndex(
        func_idx:   of(a, "", seed),
        struct_idx: of(a, "", seed),
        enum_idx:   of(a, "", seed),
        global_idx: of(a, "", seed),
        impl_idx:   of(a, "", seed),
        tdef_idx:   of(a, "", seed)
    )
    decls.loop((h, i, d) {
        d.match ({
            .DFunc(f)    => { idx = DeclIndex( func_idx: idx.func_idx.put(a, f.name, i), struct_idx: idx.struct_idx, enum_idx: idx.enum_idx, global_idx: idx.global_idx, impl_idx: idx.impl_idx, tdef_idx: idx.tdef_idx ) },
            .DForeign(f) => { idx = DeclIndex( func_idx: idx.func_idx.put(a, f.name, i), struct_idx: idx.struct_idx, enum_idx: idx.enum_idx, global_idx: idx.global_idx, impl_idx: idx.impl_idx, tdef_idx: idx.tdef_idx ) },
            .DStruct(s)  => { idx = DeclIndex( func_idx: idx.func_idx, struct_idx: idx.struct_idx.put(a, s.name, i), enum_idx: idx.enum_idx, global_idx: idx.global_idx, impl_idx: idx.impl_idx, tdef_idx: idx.tdef_idx ) },
            .DEnum(e)    => { idx = DeclIndex( func_idx: idx.func_idx, struct_idx: idx.struct_idx, enum_idx: idx.enum_idx.put(a, e.name, i), global_idx: idx.global_idx, impl_idx: idx.impl_idx, tdef_idx: idx.tdef_idx ) },
            .DGlobal(g)  => { idx = DeclIndex( func_idx: idx.func_idx, struct_idx: idx.struct_idx, enum_idx: idx.enum_idx, global_idx: idx.global_idx.put(a, g.name, i), impl_idx: idx.impl_idx, tdef_idx: idx.tdef_idx ) },
            .DImpl(im)   => { idx = DeclIndex( func_idx: idx.func_idx, struct_idx: idx.struct_idx, enum_idx: idx.enum_idx, global_idx: idx.global_idx, impl_idx: idx.impl_idx.put(a, im.ty, i), tdef_idx: idx.tdef_idx ) },
            .DTraitDefault(td) => { idx = DeclIndex( func_idx: idx.func_idx, struct_idx: idx.struct_idx, enum_idx: idx.enum_idx, global_idx: idx.global_idx, impl_idx: idx.impl_idx, tdef_idx: idx.tdef_idx.put(a, a.tdkey(td.trname, td.fn.name), i) ) },
            _            => {}
        })
    })
    idx
}

// Variable environment: params plus prior lets, as a cons-list.
VList*: VNil | VCons(VCell)
VCell*: { name: str, ty: Ty, tail: Ptr<VList> }
// exp is the current expected type; tvoid() means no expectation.
Env*: { vars: Ptr<VList>, decls: [Decl], didx: DeclIndex, exp: Ty, a: MutPtr<Malloc> }   // a = allocator (heap-alloc in infer); didx = name→decl index
with_exp = (env: Env, t: Ty) Env { Env( vars: env.vars, decls: env.decls, didx: env.didx, exp: t, a: env.a ) }
clr_exp = (env: Env) Env { env.with_exp(tvoid()) }
let_exp = (env: Env, t: Ty) Env { t.is_void_ty().match ({ true => env.clr_exp(), false => Env( vars: env.vars, decls: env.decls, didx: env.didx, exp: t, a: env.a ) }) }
// O(1) indexed lookups, replacing the O(n) decls scans. `the_func`/`fn_ret`/etc. linear forms below
// remain for the few decls-only callers (template inlining, trait conformance) that lack an Env.
env_func* = (env: Env, name: str) Func {
    i := env.didx.func_idx.get(name, 0 - 1)
    (i >= 0 && i < env.decls.len).match ({
        true  => env.decls[i].match ({ .DFunc(f) => f, .DForeign(f) => f, _ => Func( name: "", params: empty_params(), ret: tvoid(), tparams: empty_params(), body: no_stmts() ) }),
        false => Func( name: "", params: empty_params(), ret: tvoid(), tparams: empty_params(), body: no_stmts() )
    })
}

// Heap-node helpers. c* names avoid flat-TU collisions with parser helpers.
cebuf<A> = (a: MutPtr<A>, n: i64) [Expr] { slice(a.acquire(n * sizeof(Expr)), n) }
cenode<A> = (a: MutPtr<A>, v: Expr) Ptr<Expr> {
    buf := a.cebuf(1)
    buf[0] = v
    buf[0].addr()
}
// Pos-preserving rebuilds. Bare call()/vref() are only for synthesized nodes.
recall = (a: MutPtr<Malloc>, c: CallData, fn: str, args: [Expr]) Ptr<Expr> { a.cenode(c.raw.match ({ true => raw_call_at(fn, args, c.pos), false => call_at(fn, args, c.pos) })) }
revar = (a: MutPtr<Malloc>, v: VarData, name: str) Ptr<Expr> { a.cenode(vref_at(name, v.pos)) }
var_call = (a: MutPtr<Malloc>, v: VarData, args: [Expr]) Ptr<Expr> { a.cenode(call_at(v.name, args, v.pos)) }
abuf = (a: MutPtr<Malloc>, n: i64) [ArmData] { slice(a.acquire(n * sizeof(ArmData)), n) }
sbuf = (a: MutPtr<Malloc>, n: i64) [Stmt] { slice(a.acquire(n * sizeof(Stmt)), n) }
dbuf* = (a: MutPtr<Malloc>, n: i64) [Decl] { slice(a.acquire(n * sizeof(Decl)), n) }
tbuf = (a: MutPtr<Malloc>, n: i64) [Ty] { slice(a.acquire(n * sizeof(Ty)), n) }
// Heap-own a Ty so Ptr<Ty> fields do not dangle.
tnode* = (a: MutPtr<Malloc>, t: Ty) Ptr<Ty> {
    buf := a.tbuf(1)
    buf[0] = t
    buf[0].addr()
}

vlbuf = (a: MutPtr<Malloc>) [VList] { slice(a.acquire(sizeof(VList)), 1) }
vlnode = (a: MutPtr<Malloc>, v: VList) Ptr<VList> {
    buf := a.vlbuf()
    buf[0] = v
    buf[0].addr()
}
vnil_val  = () VList { .VNil() }
vcons_val = (nm: str, t: Ty, tail: Ptr<VList>) VList { .VCons(VCell( name: nm, ty: t, tail: tail )) }
vnil = (a: MutPtr<Malloc>) Ptr<VList> { a.vlnode(vnil_val()) }
vcons = (a: MutPtr<Malloc>, nm: str, t: Ty, tail: Ptr<VList>) Ptr<VList> { a.vlnode(vcons_val(nm, t, tail)) }
params_env* = (a: MutPtr<Malloc>, ps: [Param]) Ptr<VList> {
    e := a.vnil()
    ps.loop((h, i, p) { e = a.vcons(p.name, p.ty, e) })
    e
}
lookup_var = (v: Ptr<VList>, name: str) Ty {
    v.match ({
        .VNil     => tvoid(),
        .VCons(c) => eq(c.name, name).match ({ true => c.ty, false => c.tail.lookup_var(name) })
    })
}
// Infer global init types; bind the global name while doing so to avoid self-recursive lookup.
infer_global_init = (env: Env, name: str, init: Ptr<Expr>) Ty {
    env2 := Env( vars: env.a.vcons(name, tnamed(""), env.vars), decls: env.decls, didx: env.didx, exp: env.exp, a: env.a )
    env2.infer_expr(init)
}
global_ty = (env: Env, name: str) Ty {
    i := env.didx.global_idx.get(name, 0 - 1)
    (i >= 0 && i < env.decls.len).match ({
        true  => env.decls[i].match ({ .DGlobal(g) => env.infer_global_init(g.name, g.init), _ => tvoid() }),
        false => tvoid()
    })
}
// a bare reference to a top-level function NAME is a first-class function value: its type is the
// function's FnT signature (its params + ret). This lets `f := some_fn` bind `f` to a fn value and
// `f()` call through it (an indirect call). Falls back after locals + globals so a same-named local wins.
fn_value_ty = (env: Env, name: str) Ty {
    f := env.env_func(name)
    eq(f.name, name).match ({ true => env.a.fnt_from_func_in(f), false => tvoid() })
}
global_or_fn = (env: Env, name: str) Ty {
    g := env.global_ty(name)
    g.is_void_ty().match ({ true => env.fn_value_ty(name), false => g })
}
var_or_global* = (env: Env, name: str) Ty {
    lv := env.vars.lookup_var(name)
    lv.is_void_ty().match ({ true => env.global_or_fn(name), false => lv })
}
var_ty = (env: Env, name: str) Ty {
    (eq(name, "true") || eq(name, "false")).match ({
        true  => tbool(),
        false => env.var_or_global(name)
    })
}
// Membership check, distinct from type lookup; void-typed locals still count as bound.
var_bound = (v: Ptr<VList>, name: str) bool {
    v.match ({ .VNil => false, .VCons(c) => eq(c.name, name).match ({ true => true, false => c.tail.var_bound(name) }) })
}
is_bound* = (env: Env, name: str) bool { env.vars.var_bound(name) || (env.didx.global_idx.get(name, 0 - 1) >= 0) }
ty_name = (t: Ty) str { t.match ({ .Named(n) => n, _ => "" }) }
recv_name* = (t: Ty) str {
    t.match ({
        .I32 => "i32", .I64 => "i64", .U8 => "u8", .F64 => "f64", .Bool => "bool", .Str => "str", .Cstr => "str", .Text => "str",
        .Named(n)   => n,
        .Generic(g) => g.mangled,
        .Ptr(p)     => load(p).recv_name(),
        _           => ""
    })
}
enum_name* = (t: Ty) str { t.match ({ .Named(n) => n, .Generic(g) => g.mangled, .Ptr(p) => load(p).ty_name(), _ => "" }) }
ty_is_ptr = (t: Ty) bool { t.match ({ .Ptr(p) => true, _ => false }) }
elem_of = (t: Ty) Ty { t.match ({ .Slice(e) => load(e), _ => tvoid() }) }
enum_has = (ed: EnumDecl, vn: str) bool {
    f := false
    ed.variants.loop((h, i, v) { f = eq(v.name, vn).match ({ true => true, false => f }) })
    f
}
pick_enum = (ed: EnumDecl, vn: str, found: str) str { ed.enum_has(vn).match ({ true => ed.name, false => found }) }
gen_enum_has = (g: GenEnumDecl, vn: str) bool {
    f := false
    g.variants.loop((h, i, v) { f = eq(v.name, vn).match ({ true => true, false => f }) })
    f
}
// Find the enum, concrete or generic, that declares variant `vn`.
enum_of_variant = (decls: [Decl], vn: str) str {
    found := ""
    decls.loop((h, i, d) { found = d.match ({
        .DEnum(ed)   => ed.pick_enum(vn, found),
        .DGenEnum(g) => g.gen_enum_has(vn).match ({ true => g.name, false => found }),
        _            => found
    }) })
    found
}
named_has = (decls: [Decl], ename: str, vn: str) bool {
    found := false
    decls.loop((h, i, d) { found = d.match ({ .DEnum(ed) => eq(ed.name, ename).match ({ true => ed.enum_has(vn), false => found }), _ => found }) })
    found
}
// Constructor enum: expected type wins, otherwise scan by variant name.
ctor_enum_plain = (env: Env, vn: str) str {
    en := env.exp.enum_name()
    env.decls.named_has(en, vn).match ({ true => en, false => env.decls.enum_of_variant(vn) })
}

// Infer expression types needed by resolve and validate.
fn_ret = (decls: [Decl], name: str) Ty { decls.the_func(name).ret }   // the_func's sentinel.ret is tvoid()
field_ty = (sd: StructDecl, fname: str) Ty {
    found := tvoid()
    sd.fields.loop((h, i, f) { found = eq(f.name, fname).match ({ true => f.ty, false => found }) })
    found
}
struct_field = (decls: [Decl], sname: str, fname: str) Ty {
    found := tvoid()
    decls.loop((h, i, d) { found = d.match ({ .DStruct(sd) => eq(sd.name, sname).match ({ true => sd.field_ty(fname), false => found }), _ => found }) })
    found
}
// O(1) indexed struct-field lookup for the light/inline path.
idx_struct_field* = (idx: DeclIndex, decls: [Decl], sname: str, fname: str) Ty {
    i := idx.struct_idx.get(sname, 0 - 1)
    (i >= 0 && i < decls.len).match ({
        true  => decls[i].match ({ .DStruct(sd) => sd.field_ty(fname), _ => tvoid() }),
        false => tvoid()
    })
}
is_cmp_op = (op: str) bool {
    // Bool-result ops; bitwise ops keep the lhs type.
    b  := op.at(0)
    b1 := op.at(1)
    (b == '=') || (b == '!')
        || (((b == '<') || (b == '>')) && (b1 != b))
        || (((b == '&') || (b == '|')) && (b1 == b))
}
bin_ty = (op: str, lt: Ty) Ty { op.is_cmp_op().match ({ true => tbool(), false => lt }) }
// Numeric literals are polymorphic until a context fixes their size.
is_lit_numeric* = (e: Ptr<Expr>) bool {
    load(e).match ({
        .Int(n)  => true,
        .Byte(n) => true,
        .Bin(b)  => b.op.is_cmp_op().match ({ true => false, false => b.lhs.is_lit_numeric() && b.rhs.is_lit_numeric() }),
        .Cond(c) => c.t.is_lit_numeric() && c.e.is_lit_numeric(),
        _        => false
    })
}
// Conditionals defer to the else branch when the then branch is a numeric literal.
cond_ty = (env: Env, d: CondData) Ty {
    d.t.is_lit_numeric().match ({ true => env.infer_expr(d.e), false => env.infer_expr(d.t) })
}
// Generic enum constructors: compute base enum, type args, and mangled concrete name.
EnumInst*: { base: str, mty: str, targs: [Ty] }
gen_variant_payload = (g: GenEnumDecl, vname: str) Ty {
    found := tvoid()
    g.variants.loop((h, i, v) { found = eq(v.name, vname).match ({ true => v.payload, false => found }) })
    found
}
infer_enum_targs = (env: Env, g: GenEnumDecl, variant: str, pty: Ty) [Ty] {
    vpt := g.gen_variant_payload(variant)
    buf := env.a.tbuf(g.tparams.len)
    g.tparams.loop((h, i, tp) { buf[i] = vpt.unify_ty(pty, tp.name) })
    buf
}
enum_inst_payload = (env: Env, g: GenEnumDecl, base: str, variant: str, pty: Ty) EnumInst {
    ta := env.infer_enum_targs(g, variant, pty)
    EnumInst( base: base, mty: env.a.mangle_str_in(base, ta), targs: ta )
}
enum_inst_gen = (env: Env, g: GenEnumDecl, base: str, variant: str, pty: Ty) EnumInst {
    env.exp.match ({
        .Generic(ge) => eq(ge.name, base).match ({ true => EnumInst( base: base, mty: ge.mangled, targs: ge.args ), false => env.enum_inst_payload(g, base, variant, pty) }),
        _            => env.enum_inst_payload(g, base, variant, pty)
    })
}
enum_inst_of = (env: Env, base: str, variant: str, pty: Ty) EnumInst {
    g := env.decls.find_genenum(base)
    eq(g.name, "").match ({
        true  => EnumInst( base: base, mty: base, targs: no_tys() ),     // a non-generic enum
        false => env.enum_inst_gen(g, base, variant, pty)
    })
}
enum_inst_mk = (env: Env, variant: str, payload: Ptr<Expr>) EnumInst { env.enum_inst_of(env.ctor_enum_plain(variant), variant, env.infer_expr(payload)) }
enum_inst_tag = (env: Env, variant: str) EnumInst { env.enum_inst_of(env.ctor_enum_plain(variant), variant, tvoid()) }
// Block expressions take their trailing expression/return type.
last_stmt_ty = (env: Env, stmts: [Stmt]) Ty {
    stmts[stmts.len - 1].match ({ .ExprStmt(e) => env.infer_expr(e), .Return(r) => env.infer_expr(r), _ => tvoid() })
}
block_ty = (env: Env, b: BlockData) Ty {
    env.block_ty_from(b.stmts, 0)
}
block_ty_from = (env: Env, stmts: [Stmt], i: i32) Ty {
    (i >= stmts.len).match ({
        true  => tvoid(),
        false => (i == stmts.len - 1).match ({
            true  => env.last_stmt_ty(stmts),
            false => env.a.extend_env(env, stmts[i]).block_ty_from(stmts, i + 1)
        })
    })
}
// Prefer a concrete stored index element type; generic inlining may make re-inference lose it.
index_elem = (env: Env, ix: IndexData) Ty {
    ix.elem.is_void_ty().match ({ true => env.infer_expr(ix.seq).elem_of(), false => ix.elem })
}
infer_expr* = (env: Env, e: Ptr<Expr>) Ty {
    load(e).match ({
        .Int(n)        => ((n > 2147483647) || (n < 0 - 2147483648)).match ({ true => ti64(), false => ti32() }),
        .Block(b)      => env.block_ty(b),
        .Byte(n)       => tu8(),
        .FloatLit(ft)  => tf64(),
        .Var(v)        => env.var_ty(v.name),
        .Bin(b)        => bin_ty(b.op, env.infer_expr(b.lhs)),
        .Call(c)       => env.infer_call(c),
        .Cond(d)       => env.cond_ty(d),
        .Member(mm)    => env.infer_member(mm),
        .Arrow(ar)     => env.infer_arrow(ar),
        .MakeEnum(mk)  => env.mkenum_ty(mk),
        .Tag(t)        => env.tag_ty(t),
        .MakeStruct(s) => (s.targs.len > 0).match ({ true => tgeneric(s.ty, s.targs, s.mty), false => tnamed(s.ty) }),
        .StrLit(x)     => ttext(),
        .Match(m)      => env.infer_match_ty(m),
        .Index(ix)     => env.index_elem(ix),
        .Loop(l)       => tvoid(),
        .SliceLit(sd)  => tslice(env.a.tnode(env.sl_elem(sd.items))),
        _              => tvoid()
    })
}
pointee_of = (t: Ty) Ty { t.match ({ .Ptr(p) => load(p), _ => tvoid() }) }
// Generic calls infer type args from arguments, then use the expected return type
// for params that only appear in the result.
targ_of = (env: Env, params: [Param], args: [Expr], tp: str) Ty {
    found := tvoid()
    params.loop((h, i, p) { found = found.is_void_ty().match ({ true => (i < args.len).match ({ true => p.ty.unify_ty(env.infer_expr(args[i].addr()), tp), false => found }), false => found }) })
    found
}
ret_targ_of = (env: Env, ret: Ty, tp: str) Ty {
    env.exp.is_void_ty().match ({ true => tvoid(), false => ret.unify_ty(env.exp, tp) })
}
call_targ* = (env: Env, f: Func, args: [Expr], tp: str) Ty {
    arg := env.targ_of(f.params, args, tp)
    arg.is_void_ty().match ({ true => env.ret_targ_of(f.ret, tp), false => arg })
}
call_targs = (env: Env, f: Func, args: [Expr]) [Ty] {
    buf := env.a.tbuf(f.tparams.len)
    f.tparams.loop((h, i, tp) { buf[i] = env.call_targ(f, args, tp.name) })
    buf
}
// UFCS trait dispatch: route `x.m()` to the receiver type's impl when one exists.
method_in = (methods: [Param], fn: str) bool {
    f := false
    methods.loop((h, i, n) { f = eq(n.name, fn).match ({ true => true, false => f }) })
    f
}
// Trait default methods dispatch as if the impl listed them.
trait_default_exists = (decls: [Decl], trname: str, m: str) bool {
    found := false
    decls.loop((h, i, d) { found = d.match ({
        .DTraitDefault(td) => (eq(td.trname, trname) && eq(td.fn.name, m)).match ({ true => true, false => found }),
        _ => found }) })
    found
}
dispatch_recv = (a: MutPtr<Malloc>, decls: [Decl], didx: DeclIndex, fn: str, tyname: str) str {
    found := ""
    decls.loop((h, i, d) {
        found = d.match ({
            .DImpl(im) => eq(im.ty, tyname).match ({
                // trait-default check is now an O(1) index lookup instead of a full decl scan per impl.
                true  => (im.methods.method_in(fn) || (didx.tdef_idx.get(a.tdkey(im.trname, fn), 0 - 1) >= 0)).match ({ true => a.impl_cname_in(im.trname, im.ty, fn), false => found }),
                false => found
            }),
            _ => found
        })
    })
    is_empty(found).match ({ true => fn, false => found })
}
dispatch_name = (env: Env, c: CallData) str {
    (c.args.len > 0).match ({
        true  => {
            tyname := env.infer_expr(c.args[0].addr()).dispatch_recv_name()
            // Fast path: a receiver type with NO impl can never redirect dispatch, so skip the O(n)
            // impl scan entirely (the common case for primitive/struct receivers).
            (env.didx.impl_idx.get(tyname, 0 - 1) < 0).match ({
                true  => c.fn,
                false => env.a.dispatch_recv(env.decls, env.didx, c.fn, tyname)
            })
        },
        false => c.fn
    })
}
dispatch_recv_name = (t: Ty) str {
    t.match ({
        .Generic(g) => g.name,
        .Ptr(p)     => load(p).dispatch_recv_name(),
        _           => t.recv_name()
    })
}
fnt_ret = (t: Ty) Ty { t.match ({ .FnT(ft) => load(ft.ret), _ => tvoid() }) }
gen_call_ret = (env: Env, c: CallData) Ty {
    dn := env.dispatch_name(c)
    f  := env.env_func(dn)
    eq(f.name, "").match ({
        // not a known function: an INDIRECT call through a function-VALUE (a fn-valued local or field
        // bound to a local) — its result type is the value's FnT return type.
        true  => env.var_or_global(c.fn).fnt_ret(),
        false => (f.tparams.len > 0).match ({
            true  => env.a.subst_ty_in(f.tparams, env.call_targs(f, c.args), f.ret),
            false => f.ret
        })
    })
}
// Bounds-safe operand inference for 1-arg intrinsics.
arg0_ty = (env: Env, c: CallData) Ty {
    (c.args.len > 0).match ({ true => env.infer_expr(c.args[0].addr()), false => tvoid() })
}
infer_call = (env: Env, c: CallData) Ty {
    eq(c.fn, "sizeof").match ({
    true  => ti64(),
    false => eq(c.fn, "__str_eq").match ({
    true  => tbool(),
    false => eq(c.fn, "__str_ne").match ({
    true  => tbool(),
    false => eq(c.fn, "load").match ({
        true  => env.arg0_ty(c).pointee_of(),
        false => eq(c.fn, "load_i64").match ({
            true  => ti64(),
            false => eq(c.fn, "atomic_add_i64").match ({
            true  => ti64(),
            false => eq(c.fn, "to_i32").match ({
            true  => ti32(),
            false => eq(c.fn, "to_i64").match ({
            true  => ti64(),
            false => eq(c.fn, "to_u8").match ({
            true  => tu8(),
            false => eq(c.fn, "to_f64").match ({
            true  => tf64(),
            false => eq(c.fn, "null_ptr").match ({
                true  => tptr(env.a.tnode(tu8())),
                false => eq(c.fn, "cstr").match ({
                    true  => tcstr(),
                    false => eq(c.fn, "addr").match ({
                    true  => tptr(env.a.tnode(env.arg0_ty(c))),
                    false => env.gen_call_ret(c)
                    })
                })
            }) }) }) }) })
            })
        })
    }) }) }) })
}
// Constructor types keep generic args so later match-arm binds recover concrete payload types.
einst_ty = (ei: EnumInst) Ty { (ei.targs.len > 0).match ({ true => tgeneric(ei.base, ei.targs, ei.mty), false => tnamed(ei.mty) }) }
mkenum_ty = (env: Env, mk: MakeEnumData) Ty {
    eq(mk.mty, "").match ({
        true  => env.enum_inst_mk(mk.variant, mk.payload).einst_ty(),
        false => (mk.targs.len > 0).match ({ true => tgeneric(mk.ty, mk.targs, mk.mty), false => tnamed(mk.mty) })
    })
}
tag_ty = (env: Env, t: TagData) Ty {
    eq(t.mty, "").match ({
        true  => env.enum_inst_tag(t.variant).einst_ty(),
        false => (t.targs.len > 0).match ({ true => tgeneric(t.ty, t.targs, t.mty), false => tnamed(t.mty) })
    })
}
// Generic struct field reads substitute the receiver's concrete type args.
gen_field_at = (fields: [Field], fname: str) Ty {
    found := tvoid()
    fields.loop((h, i, f) { found = eq(f.name, fname).match ({ true => f.ty, false => found }) })
    found
}
gen_struct_field = (a: MutPtr<Malloc>, decls: [Decl], gname: str, fname: str, targs: [Ty]) Ty {
    found := tvoid()
    decls.loop((h, i, d) { found = d.match ({
        .DGenStruct(gsd) => eq(gsd.name, gname).match ({ true => a.subst_ty_in(gsd.tparams, targs, gsd.fields.gen_field_at(fname)), false => found }),
        _ => found }) })
    found
}
ty_under_ptr = (t: Ty) Ty { t.match ({ .Ptr(p) => load(p), _ => t }) }
slice_member = (a: MutPtr<Malloc>, field: str) Ty {
    eq(field, "len").match ({
        true  => ti64(),
        false => eq(field, "ptr").match ({ true => tptr(a.tnode(tu8())), false => tvoid() })
    })
}
// Field-type inference, auto-deref'd. Shared by `obj.field` (Member) and `obj->field` (Arrow); the
// latter exists because resolve_member rewrites a pointer receiver to Arrow, and a later re-resolve
// (e.g. dispatch on a generic-struct field receiver in an inlined template body) must re-infer it.
infer_field = (env: Env, oty: Ty, field: str) Ty {
    oty.ty_under_ptr().match ({
        .Generic(g) => env.a.gen_struct_field(env.decls, g.name, field, g.args),
        .Slice(e)   => env.a.slice_member(field),
        _           => env.didx.idx_struct_field(env.decls, oty.enum_name(), field)
    })
}
infer_member = (env: Env, m: MemberData) Ty { env.infer_field(env.infer_expr(m.obj), m.field) }
infer_arrow = (env: Env, ar: ArrowData) Ty { env.infer_field(env.infer_expr(ar.obj), ar.field) }
infer_arm_ty = (env: Env, subjty: Ty, ar: ArmData) Ty {
    env.a.arm_env(env, subjty, ar).infer_expr(ar.body)
}
common_ty = (a: Ty, b: Ty) Ty {
    a.is_void_ty().match ({
        true  => b,
        false => b.is_void_ty().match ({
            true  => a,
            false => ((a.ty_rank() >= 0) && (b.ty_rank() >= 0)).match ({
                true  => a.ty_rank().match ({
                    0 => b,
                    1 => (b.ty_rank() > 1).match ({ true => b, false => a }),
                    _ => a
                }),
                false => a.ty_eq(b).match ({ true => a, false => tvoid() })
            })
        })
    })
}
infer_match_common_ty = (env: Env, subjty: Ty, arms: [ArmData]) Ty {
    out := tvoid()
    arms.loop((h, i, ar) { out = out.common_ty(env.infer_arm_ty(subjty, ar)) })
    out
}
infer_match_ty = (env: Env, m: MatchData) Ty {
    subjty := env.infer_expr(m.subj)
    env.infer_match_common_ty(subjty, m.arms)
}

// Stamp enum constructors with their concrete generic instance when needed.
resolve_mkenum = (a: MutPtr<Malloc>, env: Env, ety: str, emty: str, etargs: [Ty], variant: str, payload: Ptr<Expr>) Ptr<Expr> {
    p := a.resolve_expr(env.clr_exp(), payload)
    (etargs.len > 0).match ({
        true  => a.cenode(mkenumg(ety, emty, etargs, variant, p)),
        false => eq(ety, "").match ({
            true  => a.resolve_mkenum_fresh(env, variant, p),
            false => a.cenode(mkenumg(ety, emty, no_tys(), variant, p))
        })
    })
}
resolve_mkenum_fresh = (a: MutPtr<Malloc>, env: Env, variant: str, p: Ptr<Expr>) Ptr<Expr> {
    inst := env.enum_inst_mk(variant, p)
    a.cenode(mkenumg(inst.base, inst.mty, inst.targs, variant, p))
}
resolve_mktag = (a: MutPtr<Malloc>, env: Env, ety: str, emty: str, etargs: [Ty], variant: str) Ptr<Expr> {
    (etargs.len > 0).match ({
        true  => a.emit_tag_or_default(env, ety, emty, etargs, variant),
        false => eq(ety, "").match ({
            true  => a.resolve_mktag_fresh(env, variant),
            false => a.emit_tag_or_default(env, ety, emty, no_tys(), variant)
        })
    })
}
resolve_mktag_fresh = (a: MutPtr<Malloc>, env: Env, variant: str) Ptr<Expr> {
    inst := env.enum_inst_tag(variant)
    a.emit_tag_or_default(env, inst.base, inst.mty, inst.targs, variant)
}
// A zero-arg `.Name` / `Type.Name`: if the variant declares a default (`Name = expr`), build the
// payload constructor with the baked-in constant; otherwise the bare tag.
emit_tag_or_default = (a: MutPtr<Malloc>, env: Env, base: str, mty: str, targs: [Ty], variant: str) Ptr<Expr> {
    def := env.didx.idx_variant_default(env.decls, base, variant)
    def.is_expr_null().match ({
        true  => a.cenode(mktagg(base, mty, targs, variant)),
        false => a.cenode(mkenumg(base, mty, targs, variant, a.resolve_expr(env.clr_exp(), def)))
    })
}
// Keep concrete slice element types across re-resolve.
keep_elem = (env: Env, existing: Ty, seq: Ptr<Expr>) Ty {
    existing.is_void_ty().match ({ true => env.infer_expr(seq).elem_of(), false => existing })
}
// For index assignment, fall back to the stored value's type when the sequence elem is unknown.
set_elem = (env: Env, existing: Ty, seq: Ptr<Expr>, value: Ptr<Expr>) Ty {
    e := env.keep_elem(existing, seq)
    e.is_void_ty().match ({ true => env.infer_expr(value), false => e })
}
// Generic struct constructor monomorphization. A literal `Scope<A>(alloc: x)` carries the type-param
// `A` verbatim as its targ; infer the concrete arg from the field-init types so the instance mangles
// to `Scope_SyncArena` and field reads/dispatch (`s.alloc.acquire`) resolve to the concrete impl.
gstruct_of = (decls: [Decl], name: str) GenStructDecl {
    found := GenStructDecl( name: "", tparams: slice(null_ptr(), 0), fields: slice(null_ptr(), 0) )
    decls.loop((h, i, d) { found = d.match ({ .DGenStruct(g) => eq(g.name, name).match ({ true => g, false => found }), _ => found }) })
    found
}
has_tparam = (tparams: [Param], n: str) bool {
    f := false
    tparams.loop((h, i, tp) { f = eq(tp.name, n).match ({ true => true, false => f }) })
    f
}
// A written targ that is just the struct's own type-param name (e.g. literal `A`) needs inference.
is_placeholder_targ = (tparams: [Param], t: Ty) bool {
    t.match ({ .Named(n) => tparams.has_tparam(n), _ => false })
}
init_field_ty = (env: Env, inits: [FieldInit], fname: str) Ty {
    found := tvoid()
    inits.loop((h, i, fi) { found = eq(fi.name, fname).match ({ true => env.infer_expr(fi.value), false => found }) })
    found
}
// Unify each declared field type against its init's inferred type to recover one tparam's concrete arg.
struct_targ_one = (env: Env, fields: [Field], inits: [FieldInit], tp: str) Ty {
    found := tvoid()
    fields.loop((h, i, f) { found = found.is_void_ty().match ({ true => f.ty.unify_ty(env.init_field_ty(inits, f.name), tp), false => found }) })
    found
}
pick_targ = (inf: Ty, fallback: Ty) Ty { inf.is_void_ty().match ({ true => fallback, false => inf }) }
infer_struct_targs = (a: MutPtr<Malloc>, env: Env, gsd: GenStructDecl, written: [Ty], inits: [FieldInit]) [Ty] {
    buf := a.tbuf(written.len)
    written.loop((h, i, t) {
        buf[i] = ((i < gsd.tparams.len) && gsd.tparams.is_placeholder_targ(t)).match ({
            true  => env.struct_targ_one(gsd.fields, inits, gsd.tparams[i].name).pick_targ(t),
            false => t
        })
    })
    buf
}
genlit_g = (a: MutPtr<Malloc>, env: Env, sd: MakeStructData, inits: [FieldInit]) Ptr<Expr> {
    nt := a.infer_struct_targs(env, env.decls.gstruct_of(sd.ty), sd.targs, inits)
    a.cenode(mkstructg(sd.ty, a.mangle_str_in(sd.ty, nt), nt, inits))
}
// the expected type's args, when it names generic struct `base` — the authoritative source for a bare
// literal's type args under a `st: Store<AppState> := …` annotation (or any expected-type position).
exp_targs_for = (exp: Ty, base: str) [Ty] {
    exp.match ({ .Generic(g) => eq(g.name, base).match ({ true => g.args, false => no_tys() }), _ => no_tys() })
}
// Type args for a BARE generic-struct literal (no explicit `<…>`): the expected/annotation type wins,
// else infer each tparam by unifying its declared field types against the supplied field-value types.
bare_struct_targs = (a: MutPtr<Malloc>, env: Env, gsd: GenStructDecl, inits: [FieldInit]) [Ty] {
    exp_args := env.exp.exp_targs_for(gsd.name)
    (exp_args.len == gsd.tparams.len).match ({
        true  => exp_args,
        false => {
            buf := a.tbuf(gsd.tparams.len)
            gsd.tparams.loop((h, i, tp) { buf[i] = env.struct_targ_one(gsd.fields, inits, tp.name) })
            buf
        }
    })
}
// A bare `Store(state: …)` literal of a GENERIC struct carries no type args; infer them so the instance
// is mangled (mty) and discovered/emitted by compiler.mono, exactly like the explicit `Store<…>(…)` form.
// A bare literal of a plain (non-generic) struct is unchanged.
resolve_genlit_bare = (a: MutPtr<Malloc>, env: Env, sd: MakeStructData, inits: [FieldInit]) Ptr<Expr> {
    gsd := env.decls.gstruct_of(sd.ty)
    is_empty(gsd.name).match ({
        true  => a.cenode(mkstructg(sd.ty, sd.mty, sd.targs, inits)),
        false => {
            nt := a.bare_struct_targs(env, gsd, inits)
            a.cenode(mkstructg(sd.ty, a.mangle_str_in(sd.ty, nt), nt, inits))
        }
    })
}
resolve_genlit = (a: MutPtr<Malloc>, env: Env, sd: MakeStructData) Ptr<Expr> {
    inits := a.resolve_inits(env.clr_exp(), sd.inits)
    (sd.targs.len > 0).match ({
        true  => a.genlit_g(env, sd, inits),
        false => a.resolve_genlit_bare(env, sd, inits)
    })
}
// Rebuild expressions with resolved enum, constructor, member, and loop metadata.
resolve_expr = (a: MutPtr<Malloc>, env: Env, e: Ptr<Expr>) Ptr<Expr> {
    load(e).match ({
        .Match(m)     => a.resolve_match(env, m),
        .MakeEnum(mk) => a.resolve_mkenum(env, mk.ty, mk.mty, mk.targs, mk.variant, mk.payload),
        .Tag(t)       => a.resolve_mktag(env, t.ty, t.mty, t.targs, t.variant),
        .Bin(b)       => a.resolve_bin(env, b),
        .Cond(c)      => a.cenode(cond(a.resolve_expr(env.clr_exp(), c.c), a.resolve_expr(env, c.t), a.resolve_expr(env, c.e))),
        .Call(c)      => a.resolve_call(env, c),
        .Member(mm)   => a.resolve_member(env, mm),
        .MakeStruct(sd) => a.resolve_genlit(env, sd),
        .Index(ix)    => a.cenode(eindex(a.resolve_expr(env.clr_exp(), ix.seq), a.resolve_expr(env.clr_exp(), ix.idx), env.keep_elem(ix.elem, ix.seq))),
        .Loop(l)      => a.resolve_loop(env, l),
        .SliceLit(sd) => a.resolve_slicelit(env, sd),
        .Block(b)     => a.cenode(block(a.resolve_body(env, b.stmts))),
        _             => e
    })
}
// Slice literal element type comes from the first item; empty stays void.
sl_elem = (env: Env, items: [Expr]) Ty {
    (items.len == 0).match ({ true => tvoid(), false => env.infer_expr(items[0].addr()) })
}
resolve_slicelit = (a: MutPtr<Malloc>, env: Env, sd: SliceData) Ptr<Expr> {
    a.cenode(slit(env.sl_elem(sd.items), a.resolve_args(env.clr_exp(), sd.items)))
}
// Field access auto-derefs pointer receivers.
resolve_member = (a: MutPtr<Malloc>, env: Env, mm: MemberData) Ptr<Expr> {
    obj := a.resolve_expr(env.clr_exp(), mm.obj)
    env.infer_expr(mm.obj).ty_is_ptr().match ({
        true  => a.cenode(arrow(obj, mm.field)),
        false => a.cenode(member(obj, mm.field))
    })
}
// Resolve foreach body with index and element bindings.
resolve_loop = (a: MutPtr<Malloc>, env: Env, l: LoopData) Ptr<Expr> {
    et   := env.keep_elem(l.elemTy, l.seq)
    env2 := Env( vars: a.vcons(l.elem, et, a.vcons(l.idx, ti32(), env.vars)), decls: env.decls, didx: env.didx, exp: env.exp, a: env.a )
    a.cenode(eloop(a.resolve_expr(env.clr_exp(), l.seq), l.idx, l.elem, et, a.resolve_body(env2, l.body), l.h))
}
fbuf = (a: MutPtr<Malloc>, n: i64) [FieldInit] { slice(a.acquire(n * sizeof(FieldInit)), n) }
resolve_inits = (a: MutPtr<Malloc>, env: Env, inits: [FieldInit]) [FieldInit] {
    buf := a.fbuf(inits.len)
    inits.loop((h, i, fi) { buf[i] = finit(fi.name, a.resolve_expr(env, fi.value)) })
    buf
}
vdef_payload = (vs: [VariantDef], vn: str) Ty {
    found := tvoid()
    vs.loop((h, i, v) { found = eq(v.name, vn).match ({ true => v.payload, false => found }) })
    found
}
concrete_variant_payload = (decls: [Decl], ename: str, vn: str) Ty {
    found := tvoid()
    decls.loop((h, i, d) { found = d.match ({
        .DEnum(ed) => eq(ed.name, ename).match ({ true => ed.variants.vdef_payload(vn), false => found }),
        _          => found
    }) })
    found
}
// O(1) indexed variant-payload lookup for an enum named `ename`.
idx_variant_payload* = (idx: DeclIndex, decls: [Decl], ename: str, vn: str) Ty {
    i := idx.enum_idx.get(ename, 0 - 1)
    (i >= 0 && i < decls.len).match ({
        true  => decls[i].match ({ .DEnum(ed) => ed.variants.vdef_payload(vn), _ => tvoid() }),
        false => tvoid()
    })
}
// The default constant expr for a `Name = expr` variant, or a null Ptr<Expr> when the variant has none.
vdef_default_of = (vs: [VariantDef], vn: str) Ptr<Expr> {
    found := expr_null()
    vs.loop((h, i, v) { found = eq(v.name, vn).match ({ true => v.dflt, false => found }) })
    found
}
idx_variant_default* = (idx: DeclIndex, decls: [Decl], ename: str, vn: str) Ptr<Expr> {
    i := idx.enum_idx.get(ename, 0 - 1)
    (i >= 0 && i < decls.len).match ({
        true  => decls[i].match ({ .DEnum(ed) => ed.variants.vdef_default_of(vn), _ => expr_null() }),
        false => expr_null()
    })
}
// Concrete payload type for a match arm bind, including generic enum substitution.
subj_variant_payload* = (env: Env, t: Ty, variant: str) Ty {
    t.match ({
        .Generic(g) => env.decls.find_genenum(g.name).gen_variant_payload(variant).gsubst(env, g),
        _           => env.didx.idx_variant_payload(env.decls, t.enum_name(), variant)
    })
}
gsubst = (pty: Ty, env: Env, g: GenericData) Ty { env.a.subst_ty_in(env.decls.find_genenum(g.name).tparams, g.args, pty) }
// Fill match enum name and choose pointer/value tag access.
resolve_match = (a: MutPtr<Malloc>, env: Env, m: MatchData) Ptr<Expr> {
    subj2 := a.resolve_expr(env.clr_exp(), m.subj)
    t     := env.infer_expr(subj2)
    en    := t.enum_name()
    arms  := a.resolve_arms(env, t, m.arms)
    t.ty_is_ptr().match ({
        true  => a.cenode(ematchp(subj2, en, arms)),
        false => a.cenode(ematch(subj2, en, arms))
    })
}
resolve_args = (a: MutPtr<Malloc>, env: Env, args: [Expr]) [Expr] {
    buf := a.cebuf(args.len)
    args.loop((h, i, ar) { buf[i] = load(a.resolve_expr(env, ar.addr())) })
    buf
}
arg_exp = (ps: [Param], i: i32) Ty { (i < ps.len).match ({ true => ps[i].ty, false => tvoid() }) }
// String equality lowers to backend-specific content comparison intrinsics.
is_str_t* = (t: Ty) bool { t.match ({ .Str => true, .Cstr => true, .Text => true, _ => false }) }
str_eq_args = (a: MutPtr<Malloc>, lhs: Ptr<Expr>, rhs: Ptr<Expr>) [Expr] {
    buf := a.cebuf(2)
    buf[0] = load(lhs)
    buf[1] = load(rhs)
    buf
}
// An enum VALUE is a tagged union; raw C `==` on the struct is invalid. `==`/`!=` between two enum
// VALUES of the same type lower to a TAG comparison (concrete + generic-instance enums). A POINTER to
// an enum is NOT included: `p == null_ptr()` / `p1 == p2` are pointer-identity comparisons (valid C),
// not value equality — including Ptr here mis-lowered `e == null_ptr()` (e: Ptr<Expr>, Expr an enum)
// to `e->tag == …`. NOTE: tag-only compares the active VARIANT, not the payload — `Run(1) == Run(2)`
// is `true`; payloadless / state-style enums (the common case) compare exactly; full structural
// (payload) equality is a deliberate follow-up.
is_enum_ty = (env: Env, t: Ty) bool {
    t.match ({
        .Named(n)   => env.didx.enum_idx.get(n, 0 - 1) >= 0,
        .Generic(g) => is_empty(env.decls.find_genenum(g.name).name) == false,
        _           => false
    })
}
resolve_bin = (a: MutPtr<Malloc>, env: Env, b: BinData) Ptr<Expr> {
    lhs := a.resolve_expr(env.clr_exp(), b.lhs)
    rhs := a.resolve_expr(env.clr_exp(), b.rhs)
    cmp := eq(b.op, "==") || eq(b.op, "!=")
    lty := env.infer_expr(lhs)
    (cmp && lty.is_str_t() && env.infer_expr(rhs).is_str_t()).match ({
        true  => a.cenode(call(eq(b.op, "==").match ({ true => "__str_eq", false => "__str_ne" }), a.str_eq_args(lhs, rhs))),
        false => (cmp && env.is_enum_ty(lty)).match ({
            true  => a.cenode(bin_at(b.op, a.subj_tag(lhs, lty.ty_is_ptr()), a.subj_tag(rhs, lty.ty_is_ptr()), b.pos)),
            false => a.resolve_f64_neg(env, b.op, lhs, rhs, b.pos)
        })
    })
}
// Prefix `-f64` parses as `0 - x`; rewrite that zero to `0.0`.
is_int_zero = (e: Ptr<Expr>) bool { load(e).match ({ .Int(n) => n == 0, _ => false }) }
resolve_f64_neg = (a: MutPtr<Malloc>, env: Env, op: str, lhs: Ptr<Expr>, rhs: Ptr<Expr>, p: i32) Ptr<Expr> {
    (eq(op, "-") && lhs.is_int_zero() && env.infer_expr(rhs).is_f64_ty()).match ({
        true  => a.cenode(bin_at(op, a.cenode(flit("0.0")), rhs, p)),
        false => a.cenode(bin_at(op, lhs, rhs, p))
    })
}
// ── variadic params: a trailing `...T` param collects the surplus call args into a `[T]` ──
// Detect the marker (set by the parser), the element type T, and the per-arg expected type
// (T for a collected element). Lowering happens AFTER arg resolution, in resolve_call.
last_variadic = (ps: [Param]) bool { (ps.len > 0).match ({ true => ps[ps.len - 1].variadic, false => false }) }
vararg_elem = (t: Ty) Ty { t.match ({ .Slice(e) => load(e), _ => t }) }
// expected type for arg i: the element type T for any arg in a variadic param's collected tail.
arg_exp_v = (ps: [Param], i: i32) Ty {
    last_variadic(ps).match ({
        false => ps.arg_exp(i),
        true  => {
            fixed := ps.len - 1
            (i < fixed).match ({ true => ps.arg_exp(i), false => ps[fixed].ty.vararg_elem() })
        }
    })
}
// resolve_module re-runs resolve_decl several times (resolve/inline passes), so collection must be
// IDEMPOTENT: a call already lowered has exactly param-count args with a SliceLit in the variadic
// slot. Re-collecting it would nest `[[…]]`. Detect that shape and leave it untouched.
is_slicelit_expr = (e: Expr) bool { e.match ({ .SliceLit(s) => true, _ => false }) }
already_collected = (ps: [Param], args: [Expr]) bool {
    (args.len == ps.len).match ({ true => (args.len > 0).match ({ true => is_slicelit_expr(args[args.len - 1]), false => false }), false => false })
}
// rewrite `f(a, b, c)` with `f = (x: X, ys: ...Y)` into `f(a, [b, c])`: surplus args → one SliceLit.
collect_varargs = (a: MutPtr<Malloc>, ps: [Param], args: [Expr]) [Expr] {
    (last_variadic(ps) && (ps.already_collected(args) == false)).match ({
        false => args,
        true  => {
            fixed := ps.len - 1
            (args.len < fixed).match ({
                true  => args,                                          // too few args: let the validator report arity
                false => {
                    elem := ps[fixed].ty.vararg_elem()
                    vbuf := a.cebuf(args.len - fixed)
                    args.loop((h, j, e) { (j >= fixed).match ({ true => { vbuf[j - fixed] = e }, false => {} }) })
                    out  := a.cebuf(fixed + 1)
                    args.loop((h, j, e) { (j < fixed).match ({ true => { out[j] = e }, false => {} }) })
                    out[fixed] = slit(elem, vbuf)
                    out
                }
            })
        }
    })
}
// The expected type for argument `i` of a (generic or plain) call. For a generic fn, the param type may
// name a tparam (`x: T`); substituting the inferred type args gives the CONCRETE expected type, which
// lets a bare variant ctor argument (`.Num(n)` for a `Vec<Tok>.push`) resolve against the right enum
// instead of guessing by variant name. FnT (lambda) params keep the void expected-type they had before
// (they are spliced/inlined later), so existing template-lambda resolution is unchanged. A variadic
// param's collected args take element type T (via arg_exp_v) before any tparam substitution.
call_arg_exp = (env: Env, tmpl: bool, tparams: [Param], targs: [Ty], ps: [Param], i: i32) Ty {
    pty := ps.arg_exp_v(i)
    tmpl.match ({
        false => pty,
        true  => pty.is_fnt().match ({
            true  => tvoid(),
            false => env.a.subst_ty_in(tparams, targs, pty)
        })
    })
}
// `b.op(args)` desugars to `op(b, args)`; when `op` names no function but IS a function-VALUE field of
// b's type (FnT), this is an INDIRECT call through that field (M1 closures). Detect it: the callee is
// not a known/dispatched function and arg0 has an FnT field of that name.
fnfield_ty = (env: Env, recv: Ptr<Expr>, field: str) Ty { env.infer_expr(env.a.cenode(member(recv, field))) }
is_fn_field_call = (env: Env, dn: str, args: [Expr]) bool {
    (eq(env.env_func(dn).name, "") && (args.len > 0)).match ({
        true  => env.fnfield_ty(args[0].addr(), dn).is_fnt(),
        false => false
    })
}
// rewrite `op(b, x, y)` -> `({ __zclos_recv := b.op   __zclos_recv(x, y) })`: bind the field value to a
// local, then call the local. This reuses the existing local-fn-value call path (C `__auto_type` +
// native indirect call) — no new genc call node. Block scoping keeps the fixed temp name nesting-safe.
rewrite_fn_field_call = (a: MutPtr<Malloc>, env: Env, field: str, buf: [Expr]) Ptr<Expr> {
    rest := a.cebuf(buf.len - 1)
    buf.loop((h, i, e) { (i > 0).match ({ true => { rest[i - 1] = e }, false => {} }) })
    letst := slet("__zclos_recv", a.cenode(member(buf[0].addr(), field)))
    callx := a.cenode(call("__zclos_recv", rest))
    sbuf2 := a.sbuf(2)
    sbuf2[0] = letst
    sbuf2[1] = sexpr(callx)
    a.cenode(block(sbuf2))
}
// `recv.len()` on a slice `[T]` is the slice's length FIELD (the element count). Resolving it
// receiver-type-aware here means it NEVER mis-dispatches to a same-named free fn (e.g. str.len, whose
// receiver is `str`, not `[T]`) — which otherwise yields a misleading arg-type error. Rewriting to the
// `.len` Member reuses the fully-supported field path (infer/validate/genc) and stays idempotent: a
// later resolve pass sees a Member, not a Call.
is_slice_len_call = (env: Env, fn: str, buf: [Expr]) bool {
    (eq(fn, "len") && (buf.len == 1)).match ({
        true  => env.infer_expr(buf[0].addr()).match ({ .Slice(e) => true, _ => false }),
        false => false
    })
}
resolve_call = (a: MutPtr<Malloc>, env: Env, c: CallData) Ptr<Expr> {
    dn    := env.dispatch_name(c)
    fn    := env.env_func(dn)
    ps    := fn.params
    tmpl  := fn.is_generic_fn()
    targs := tmpl.match ({ true => env.call_targs(fn, c.args), false => no_tys() })
    buf   := a.cebuf(c.args.len)
    c.args.loop((h, i, ar) {
        ex     := env.call_arg_exp(tmpl, fn.tparams, targs, ps, i)
        buf[i] = load(a.resolve_expr(env.with_exp(ex), ar.addr()))
    })
    env.is_slice_len_call(c.fn, buf).match ({
        true  => a.cenode(member(buf[0].addr(), "len")),
        false => env.is_fn_field_call(dn, buf).match ({
            true  => a.rewrite_fn_field_call(env, c.fn, buf),
            false => a.recall(c, env.rec_dispatch(dn, fn, c.args), a.collect_varargs(ps, buf))
        })
    })
}
// A call to a recursive generic fn routes to the mangled monomorphic instance once mono_rec has emitted
// it (the instance decl exists in the index). Until then — in resolve passes BEFORE mono_rec runs, and
// for the never-instantiated template itself — it stays the bare template name. This guard keeps
// resolve_call idempotent across passes and unchanged for every non-recursive call.
rec_dispatch = (env: Env, dn: str, fn: Func, args: [Expr]) str {
    (eq(fn.name, dn) && (fn.params.len == args.len) && fn.rc_is_rec_gen_f()).match ({
        true  => {
            m := env.a.mangle_str_in(dn, env.call_targs(fn, args))
            (env.didx.func_idx.get(m, 0 - 1) >= 0).match ({ true => m, false => dn })
        },
        false => dn
    })
}
// Arm payload binds get their concrete payload type.
arm_env* = (a: MutPtr<Malloc>, env: Env, t: Ty, ar: ArmData) Env {
    eq(ar.bind, "").match ({
        true  => env,
        false => Env( vars: a.vcons(ar.bind, env.subj_variant_payload(t, ar.variant), env.vars), decls: env.decls, didx: env.didx, exp: env.exp, a: env.a )
    })
}
resolve_arms = (a: MutPtr<Malloc>, env: Env, t: Ty, arms: [ArmData]) [ArmData] {
    buf := a.abuf(arms.len)
    arms.loop((h, i, ar) { buf[i] = arm(ar.variant, ar.bind, a.resolve_expr(a.arm_env(env, t, ar), ar.body)) })
    buf
}

// Discarded matches lower to `if` so arm returns remain real returns. Value-position matches
// stay expressions. Non-exhaustive enum matches stay Match nodes for the validator to reject.
match_has_wild = (m: MatchData) bool {
    f := false
    m.arms.loop((h, i, ar) { f = eq(ar.variant, "_").match ({ true => true, false => f }) })
    f
}
arm_covers_v = (m: MatchData, vn: str) bool {
    f := false
    m.arms.loop((h, i, ar) { f = eq(ar.variant, vn).match ({ true => true, false => f }) })
    f
}
ed_covered = (ed: EnumDecl, m: MatchData) bool {
    all := true
    ed.variants.loop((h, i, v) { all = m.arm_covers_v(v.name).match ({ true => all, false => false }) })
    all
}
enum_exhaustive = (decls: [Decl], m: MatchData) bool {
    found := false
    decls.loop((h, i, d) { found = d.match ({ .DEnum(ed) => eq(ed.name, m.ename).match ({ true => ed.ed_covered(m), false => found }), _ => found }) })
    found
}
match_lowerable = (decls: [Decl], m: MatchData) bool {
    match_has_wild(m).match ({ true => true, false => decls.enum_exhaustive(m) })
}

one_stmt = (a: MutPtr<Malloc>, st: Stmt) [Stmt] {
    buf := a.sbuf(1)
    buf[0] = st
    buf
}
branch_stmts = (a: MutPtr<Malloc>, e: Ptr<Expr>) [Stmt] {
    out := a.one_stmt(sexpr(e))
    load(e).match ({
        .Block(b) => { out = b.stmts },
        _
    })
    out
}
tag_const* = (a: MutPtr<Malloc>, ename: str, variant: str) str {
    s := a.gstr_string(64)
    s = s.gstr_append(a, ename)
    s = s.gstr_append(a, "_")
    s = s.gstr_append(a, variant)
    s.gstr_finish(a)
}
subj_tag = (a: MutPtr<Malloc>, subj: Ptr<Expr>, ptr: bool) Ptr<Expr> {
    out := a.cenode(member(subj, "tag"))
    ptr.match ({ true => { out = a.cenode(arrow(subj, "tag")) }, _ })
    out
}
subj_payload = (a: MutPtr<Malloc>, subj: Ptr<Expr>, variant: str, ptr: bool) Ptr<Expr> {
    u := a.cenode(member(subj, "u"))
    ptr.match ({ true => { u = a.cenode(arrow(subj, "u")) }, _ })
    a.cenode(member(u, variant))
}
arm_then = (a: MutPtr<Malloc>, env: Env, t: Ty, m: MatchData, ar: ArmData) [Stmt] {
    body := a.branch_stmts(ar.body)
    out := body
    eq(ar.bind, "").match ({
        true  => {},
        // TYPED payload let (not bare slet): without the concrete payload type, a later light/inline
        // inference can't recover the binding's type from the enum union access (`e.u.Num`), so a
        // generic call on it (`println(n)`) fails to monomorphize → link error. Same fix the or_return
        // lowering already uses (slett with subj_variant_payload). Void payload type falls back to slet.
        false => { out = a.cons_stmt(slett(ar.bind, env.subj_variant_payload(t, ar.variant), a.subj_payload(m.subj, ar.variant, m.ptr)), body) }
    })
    out
}
cons_stmt = (a: MutPtr<Malloc>, head: Stmt, rest: [Stmt]) [Stmt] {
    buf := a.sbuf(rest.len + 1)
    buf[0] = head
    rest.loop((h, i, st) { buf[i + 1] = st })
    buf
}
// Build if/else chain over enum arms.
lower_match_arms = (a: MutPtr<Malloc>, env: Env, t: Ty, m: MatchData, i: i32) [Stmt] {
    out := no_stmts()
    (i >= m.arms.len).match ({
        true  => {},
        false => {
            ar := m.arms[i]
            eq(ar.variant, "_").match ({
                true  => { out = a.branch_stmts(ar.body) },
                false => {
                    cond := a.cenode(bin("==", a.subj_tag(m.subj, m.ptr), a.cenode(vref(a.tag_const(m.ename, ar.variant)))))
                    out = a.one_stmt(sif(cond, a.arm_then(env, t, m, ar), a.lower_match_arms(env, t, m, i + 1)))
                }
            })
        }
    })
    out
}
lower_match_stmt = (a: MutPtr<Malloc>, env: Env, m: MatchData) Stmt {
    t     := env.infer_expr(m.subj)
    stmts := a.lower_match_arms(env, t, m, 0)
    out := sexpr(a.cenode(block(stmts)))
    (stmts.len == 1).match ({ true => { out = stmts[0] }, _ })
    out
}
// Bool/literal match in statement position: Cond -> if/else, recursing for literal chains.
lower_cond_stmt = (a: MutPtr<Malloc>, d: CondData) Stmt {
    sif(d.c, a.branch_stmts(d.t), a.cond_else(d.e))
}
cond_else = (a: MutPtr<Malloc>, e: Ptr<Expr>) [Stmt] {
    out := a.branch_stmts(e)
    load(e).match ({
        .Cond(d) => { out = a.one_stmt(a.lower_cond_stmt(d)) },
        _
    })
    out
}
// Lower resolved statement-position expressions whose values are discarded.
lower_stmt_expr = (a: MutPtr<Malloc>, env: Env, e: Ptr<Expr>) Stmt {
    out := sexpr(e)
    load(e).match ({
        .Match(m) => env.decls.match_lowerable(m).match ({
            true => { out = a.lower_match_stmt(env, m) },
            _    => { out = sexpr(e) }
        }),
        .Cond(d)  => { out = a.lower_cond_stmt(d) },
        _         => { out = sexpr(e) }
    })
    out
}

// Resolve statements, preserving expected type only for value-producing tail expressions.
store_local_ty = (t: Ty) Ty {
    t.match ({
        .Void => tvoid(),
        .FnT(ft) => tvoid(),
        _ => t
    })
}
resolve_let = (a: MutPtr<Malloc>, env: Env, l: LetData) Stmt {
    v := a.resolve_expr(env.let_exp(l.ty), l.value)
    ty := l.ty.is_void_ty().match ({
        // Infer the stored type under the SAME cleared expected-type the value was resolved with: an
        // unannotated let has no target type, so the enclosing function's `exp` must not leak in. Else a
        // generic call whose return is a bare tparam (`with_sync … R`) unifies R against that stray exp
        // (e.g. main's i32) and the let is mistyped — value Result, type i32.
        true  => env.clr_exp().infer_expr(v).store_local_ty(),
        false => l.ty
    })
    slett(l.name, ty, v)
}
resolve_stmt = (a: MutPtr<Malloc>, env: Env, st: Stmt, last: bool) Stmt {
    out := st
    st.match ({
        .Let(l)    => { out = a.resolve_let(env, l) },
        .Assign(x) => { out = sassign_at(a.resolve_expr(env, x.target), a.resolve_expr(env.clr_exp(), x.value), x.pos) },
        .Return(r) => { out = sret(a.resolve_expr(env, r)) },
        .ExprStmt(e) => {
            last.match ({
                true  => env.exp.is_void_ty().match ({
                    true  => { out = a.lower_stmt_expr(env, a.resolve_expr(env.clr_exp(), e)) },
                    false => { out = sexpr(a.resolve_expr(env, e)) }
                }),
                false => { out = a.lower_stmt_expr(env, a.resolve_expr(env.clr_exp(), e)) }
            })
        },
        .If(f)     => { out = sif(a.resolve_expr(env.clr_exp(), f.c), a.resolve_body(env, f.then), a.resolve_body(env, f.els)) },
        .While(w)  => { out = swhile(a.resolve_expr(env.clr_exp(), w.c), a.resolve_body(env, w.body)) },
        .IndexSet(x) => { out = sidxset_at(a.resolve_expr(env.clr_exp(), x.seq), a.resolve_expr(env.clr_exp(), x.idx), env.set_elem(x.elem, x.seq, x.value), a.resolve_expr(env.clr_exp(), x.value), x.pos) }
    })
    out
}
// `x := recv.or_return()` is keyword-free error propagation: the Ok payload becomes x, while an Err
// early-returns the receiver from the enclosing function. It lowers to a temp-bind + Err-guard +
// Ok-payload bind (three statements), so one source statement expands into three resolved ones.
is_or_return_call = (e: Ptr<Expr>) bool {
    load(e).match ({ .Call(c) => eq(c.fn, "or_return") && (c.args.len == 1), _ => false })
}
let_is_or_return = (st: Stmt) bool {
    st.match ({ .Let(l) => l.value.is_or_return_call(), _ => false })
}
stmt_out_span = (st: Stmt) i32 { st.let_is_or_return().match ({ true => 3, false => 1 }) }
body_out_len = (body: [Stmt]) i32 {
    n := 0
    body.loop((h, i, st) { n = n + st.stmt_out_span() })
    n
}
or_return_recv = (a: MutPtr<Malloc>, e: Ptr<Expr>) Ptr<Expr> {
    out := e
    load(e).match ({ .Call(c) => { out = c.args[0].addr() }, _ => {} })
    out
}
or_temp_name = (a: MutPtr<Malloc>, name: str) str {
    s := a.gstr_string(64)
    s = s.gstr_append(a, "_orret_")
    s = s.gstr_append(a, name)
    s.gstr_finish(a)
}
lower_or_return_let = (a: MutPtr<Malloc>, env: Env, l: LetData) [Stmt] {
    recv2 := a.resolve_expr(env.clr_exp(), a.or_return_recv(l.value))
    t     := env.infer_expr(recv2)
    en    := t.enum_name()
    ptr   := t.ty_is_ptr()
    tmp   := a.or_temp_name(l.name)
    cnd   := a.cenode(bin("==", a.subj_tag(a.cenode(vref(tmp)), ptr), a.cenode(vref(a.tag_const(en, "Err")))))
    buf   := a.sbuf(3)
    buf[0] = slett(tmp, t, recv2)
    buf[1] = sif(cnd, a.one_stmt(sret(a.cenode(vref(tmp)))), no_stmts())
    buf[2] = slett(l.name, env.subj_variant_payload(t, "Ok"), a.subj_payload(a.cenode(vref(tmp)), "Ok", ptr))
    buf
}
lower_or_return = (a: MutPtr<Malloc>, env: Env, st: Stmt) [Stmt] {
    out := no_stmts()
    st.match ({ .Let(l) => { out = a.lower_or_return_let(env, l) }, _ => {} })
    out
}
// Resolve a statement sequence while threading let bindings.
noop2 = () void { }
resolve_body = (a: MutPtr<Malloc>, env: Env, body: [Stmt]) [Stmt] {
    buf := a.sbuf(body.body_out_len())
    a.fill_stmts(env, body, buf, 0, 0)
    buf
}
fill_stmts = (a: MutPtr<Malloc>, env: Env, body: [Stmt], buf: [Stmt], i: i32, o: i32) void {
    (i < body.len).match ({ true => a.fill_stmt(env, body, buf, i, o), false => noop2() })
}
fill_stmt = (a: MutPtr<Malloc>, env: Env, body: [Stmt], buf: [Stmt], i: i32, o: i32) void {
    st := body[i]
    st.let_is_or_return().match ({
        true  => a.fill_or_return(env, body, buf, i, o),
        false => {
            resolved := a.resolve_stmt(env, st, i == body.len - 1)
            buf[o]   = resolved
            a.fill_stmts(a.extend_env(env, resolved), body, buf, i + 1, o + 1)
        }
    })
}
fill_or_return = (a: MutPtr<Malloc>, env: Env, body: [Stmt], buf: [Stmt], i: i32, o: i32) void {
    stmts      := a.lower_or_return(env, body[i])
    buf[o]     = stmts[0]
    buf[o + 1] = stmts[1]
    buf[o + 2] = stmts[2]
    env2       := a.extend_env(a.extend_env(a.extend_env(env, stmts[0]), stmts[1]), stmts[2])
    a.fill_stmts(env2, body, buf, i + 1, o + 3)
}
extend_env* = (a: MutPtr<Malloc>, env: Env, st: Stmt) Env {
    st.match ({
        .Let(l) => Env( vars: a.vcons(l.name, l.ty.is_void_ty().match ({ true => env.infer_expr(l.value), false => l.ty }), env.vars), decls: env.decls, didx: env.didx, exp: env.exp, a: env.a ),
        _       => env
    })
}

// Rebuild decls with resolved bodies/inits.
resolve_func = (a: MutPtr<Malloc>, decls: [Decl], idx: DeclIndex, f: Func) Func {
    env := Env( vars: a.params_env(f.params), decls: decls, didx: idx, exp: f.ret, a: a )
    Func( name: f.name, params: f.params, ret: f.ret, tparams: f.tparams, body: a.resolve_body(env, f.body) )
}
resolve_global = (a: MutPtr<Malloc>, decls: [Decl], idx: DeclIndex, g: GlobalData) Decl {
    env := Env( vars: a.params_env(empty_params()), decls: decls, didx: idx, exp: tvoid(), a: a )
    dglobal(g.name, env.infer_expr(g.init), a.resolve_expr(env, g.init))
}
resolve_decl = (a: MutPtr<Malloc>, decls: [Decl], idx: DeclIndex, d: Decl) Decl {
    d.match ({ .DFunc(f) => dfunc(a.resolve_func(decls, idx, f)), .DGlobal(g) => a.resolve_global(decls, idx, g), _ => d })
}

// Template/lambda inlining pass.
no_stmts* = () [Stmt] { slice(null_ptr(), 0) }
empty_args = () [Expr] { slice(null_ptr(), 0) }
pidx = (params: [Param], name: str, found: i32, i: i32) i32 {
    (i == params.len).match ({
        true  => found,
        false => eq(params[i].name, name).match ({ true => i, false => params.pidx(name, found, i + 1) })
    })
}
param_index = (params: [Param], name: str) i32 { params.pidx(name, 0 - 1, 0) }
hide_param = (a: MutPtr<Malloc>, params: [Param], name: str) [Param] {
    idx := params.param_index(name)
    (idx < 0).match ({
        true  => params,
        false => {
            buf := a.pbuf(params.len)
            params.loop((h, i, p) { buf[i] = eq(p.name, name).match ({ true => Param( name: "", ty: p.ty, variadic: p.variadic ), false => p }) })
            buf
        }
    })
}
local_marks = (a: MutPtr<Malloc>, s: String, n: i64) String {
    (n <= 0).match ({ true => s, false => a.local_marks(s.gstr_append(a, "_"), n - 1) })
}
// inline-expansion scope marks: the chain of functions currently being inlined (env's empty-named
// markers, pushed by inline_template). Distinguishes locals from DIFFERENT inlined functions that
// share a param-count depth — e.g. cenode and cebuf both at depth 2 would otherwise rename their
// `buf` to the same C local and alias into a self-referential node. Same-function re-inlines stay
// distinct via C block scoping. This is what lets the compiler internals be generic (inlined) safely.
inline_marks = (a: MutPtr<Malloc>, s: String, env: Ptr<VList>) String {
    env.match ({
        .VNil     => s,
        .VCons(c) => c.ty.is_empty_named().match ({
            true  => a.inline_marks(s.gstr_append(a, "_").gstr_append(a, c.name), c.tail),
            false => a.inline_marks(s, c.tail)
        })
    })
}
local_name_at = (a: MutPtr<Malloc>, name: str, env: Ptr<VList>, depth: i64) str {
    s := a.gstr_string(128)
    s = s.gstr_append(a, "__zen_local")
    s = a.inline_marks(s, env)
    s = a.local_marks(s, depth)
    s = s.gstr_append(a, "_")
    s = s.gstr_append(a, name)
    s.gstr_finish(a)
}
add_subst_param = (a: MutPtr<Malloc>, params: [Param], name: str) [Param] {
    base := a.hide_param(params, name)
    buf := a.pbuf(base.len + 1)
    base.loop((h, i, p) { buf[i] = p })
    buf[base.len] = Param( name: name, ty: tvoid(), variadic: false )
    buf
}
add_subst_arg = (a: MutPtr<Malloc>, args: [Expr], name: str) [Expr] {
    buf := a.cebuf(args.len + 1)
    args.loop((h, i, e) { buf[i] = e })
    buf[args.len] = vref(name)
    buf
}
// A lambda bound to a local (`g := (n){…}`) has no C closure value. Instead the inliner treats the
// local as a COMPILE-TIME ALIAS: shadow the name as an FnT "param" whose substituted "arg" is the
// (already-xformed) lambda, so every later use — a direct call `g(x)` or a HOF arg `apply(g,…)` —
// splices the lambda exactly like a directly-passed one. The `g := …` statement itself is dropped.
add_fnt_param = (a: MutPtr<Malloc>, params: [Param], name: str) [Param] {
    base := a.hide_param(params, name)
    buf := a.pbuf(base.len + 1)
    base.loop((h, i, p) { buf[i] = p })
    buf[base.len] = Param( name: name, ty: fntype(no_tys(), a.tnode(tvoid())) )
    buf
}
add_lambda_arg = (a: MutPtr<Malloc>, args: [Expr], lamx: Ptr<Expr>) [Expr] {
    buf := a.cebuf(args.len + 1)
    args.loop((h, i, e) { buf[i] = e })
    buf[args.len] = load(lamx)
    buf
}
// is this Let's value a lambda literal? (drives the alias lowering above)
let_value_lambda = (st: Stmt) bool {
    st.match ({
        .Let(l) => load(l.value).match ({ .Lambda(lm) => true, _ => false }),
        _       => false
    })
}
the_func* = (decls: [Decl], name: str) Func {
    found := Func( name: "", params: empty_params(), ret: tvoid(), tparams: empty_params(), body: no_stmts() )
    decls.loop((h, i, d) { found = d.match ({ .DFunc(f) => eq(f.name, name).match ({ true => f, false => found }), .DForeign(f) => eq(f.name, name).match ({ true => f, false => found }), _ => found }) })
    found
}
// O(1) indexed Func lookup for the inline/template path (mirrors env_func; same last-match result).
idx_func* = (idx: DeclIndex, decls: [Decl], name: str) Func {
    i := idx.func_idx.get(name, 0 - 1)
    (i >= 0 && i < decls.len).match ({
        true  => decls[i].match ({ .DFunc(f) => f, .DForeign(f) => f, _ => Func( name: "", params: empty_params(), ret: tvoid(), tparams: empty_params(), body: no_stmts() ) }),
        false => Func( name: "", params: empty_params(), ret: tvoid(), tparams: empty_params(), body: no_stmts() )
    })
}
is_template_call = (decls: [Decl], name: str) bool { decls.the_func(name).is_generic_fn() }
idx_template_call = (idx: DeclIndex, decls: [Decl], name: str) bool { idx.idx_func(decls, name).is_generic_fn() }
subst_var = (a: MutPtr<Malloc>, params: [Param], args: [Expr], name: str, e: Ptr<Expr>) Ptr<Expr> {
    idx := params.param_index(name)
    (idx < 0).match ({ true => e, false => args[idx].addr() })
}
// the C name a substituted arg carries: a Var holds the (renamed) local it stands for, so an
// indirect call `f()` through a renamed local let recovers `f`'s renamed C name. Falls back to the
// original callee name when the substituted arg isn't a plain Var.
callee_subst_name = (e: Expr, fallback: str) str { e.match ({ .Var(v) => v.name, _ => fallback }) }
// Inline body as block expression: trailing return becomes the result expression.
ret_to_expr = (st: Stmt) Stmt { st.match ({ .Return(e) => sexpr(e), _ => st }) }
block_of = (a: MutPtr<Malloc>, stmts: [Stmt]) Ptr<Expr> {
    buf: [Stmt] := a.sbuf(stmts.len)
    stmts.loop((h, i, st) { buf[i] = (i == stmts.len - 1).match ({ true => ret_to_expr(st), false => st }) })
    a.cenode(block(buf))
}
// One value statement inlines directly; larger bodies become block expressions.
blockify = (a: MutPtr<Malloc>, stmts: [Stmt]) Ptr<Expr> {
    (stmts.len == 1).match ({
        true  => stmts[0].match ({ .Return(e) => e, .ExprStmt(e) => e, _ => a.block_of(stmts) }),
        false => a.block_of(stmts)
    })
}
xform_args = (a: MutPtr<Malloc>, decls: [Decl], idx: DeclIndex, args: [Expr], params: [Param], fargs: [Expr], env: Ptr<VList>) [Expr] {
    buf := a.cebuf(args.len)
    args.loop((h, i, ar) { buf[i] = load(a.xform_expr(decls, idx, ar.addr(), params, fargs, env)) })
    buf
}
xform_arm_payload = (a: MutPtr<Malloc>, decls: [Decl], idx: DeclIndex, subj: Ty, ename: str, ar: ArmData) Ty {
    subj.match ({
        .Generic(g) => a.subst_ty_in(decls.find_genenum(g.name).tparams, g.args, decls.find_genenum(g.name).gen_variant_payload(ar.variant)),
        _           => idx.idx_variant_payload(decls, ename, ar.variant)
    })
}
xform_arm_env = (a: MutPtr<Malloc>, decls: [Decl], idx: DeclIndex, subj: Ty, ename: str, ar: ArmData, env: Ptr<VList>) Ptr<VList> {
    out := env
    eq(ar.bind, "").match ({
        true  => {},
        false => { out = a.vcons(ar.bind, a.xform_arm_payload(decls, idx, subj, ename, ar), env) }
    })
    out
}
xform_arms = (a: MutPtr<Malloc>, decls: [Decl], idx: DeclIndex, subj: Ty, ename: str, arms: [ArmData], params: [Param], fargs: [Expr], env: Ptr<VList>, exp: Ty) [ArmData] {
    buf := a.abuf(arms.len)
    arms.loop((h, i, ar) {
        bind := ""
        ps := params
        xs := fargs
        eq(ar.bind, "").match ({
            true  => {},
            false => {
                bind = a.local_name_at(ar.bind, env, params.len)
                ps = a.add_subst_param(params, ar.bind)
                xs = a.add_subst_arg(fargs, bind)
            }
        })
        br := arm(ar.variant, bind, ar.body)
        buf[i] = arm(ar.variant, bind, a.xform_expr_exp(decls, idx, ar.body, ps, xs, a.xform_arm_env(decls, idx, subj, ename, br, env), exp))
    })
    buf
}
inline_lambda = (a: MutPtr<Malloc>, decls: [Decl], idx: DeclIndex, lamx: Expr, cargs: [Expr], env: Ptr<VList>) Ptr<Expr> {
    lamx.match ({
        .Lambda(lm) => a.blockify(a.xform_body(decls, idx, lm.body, lm.params, cargs, env, tvoid())),
        .Var(v)     => a.var_call(v, cargs),
        _           => a.cenode(lamx)
    })
}
// Generic template calls infer type args at the call site before splicing.
// Light types are enough to unify tparams, including local Var args.
lty_node = (a: MutPtr<Malloc>, t: Ty) Ptr<Ty> { a.tnode(t) }
light_sl_elem = (a: MutPtr<Malloc>, items: [Expr], env: Ptr<VList>, decls: [Decl], idx: DeclIndex) Ty {
    (items.len == 0).match ({ true => tvoid(), false => items[0].addr().light_ty(a, env, decls, idx) })
}
light_slice = (a: MutPtr<Malloc>, sd: SliceData, env: Ptr<VList>, decls: [Decl], idx: DeclIndex) Ty {
    sd.elem.is_void_ty().match ({
        true  => tslice(a.lty_node(a.light_sl_elem(sd.items, env, decls, idx))),
        false => tslice(a.lty_node(sd.elem))
    })
}
// Light call type mirrors infer_call for template-splice inference.
light_one = (params: [Param], a: MutPtr<Malloc>, args: [Expr], tp: str, env: Ptr<VList>, decls: [Decl], idx: DeclIndex) Ty {
    found := tvoid()
    params.loop((h, i, p) { found = found.is_void_ty().match ({ true => (i < args.len).match ({ true => p.ty.unify_ty(args[i].addr().light_ty(a, env, decls, idx), tp), false => found }), false => found }) })
    found
}
light_ret_one = (ret: Ty, exp: Ty, tp: str) Ty {
    exp.is_void_ty().match ({ true => tvoid(), false => ret.unify_ty(exp, tp) })
}
light_targ = (f: Func, a: MutPtr<Malloc>, args: [Expr], exp: Ty, tp: str, env: Ptr<VList>, decls: [Decl], idx: DeclIndex) Ty {
    arg := f.params.light_one(a, args, tp, env, decls, idx)
    arg.is_void_ty().match ({ true => f.ret.light_ret_one(exp, tp), false => arg })
}
light_targs = (f: Func, a: MutPtr<Malloc>, args: [Expr], exp: Ty, env: Ptr<VList>, decls: [Decl], idx: DeclIndex) [Ty] {
    buf := a.tbuf(f.tparams.len)
    f.tparams.loop((h, i, tp) { buf[i] = f.light_targ(a, args, exp, tp.name, env, decls, idx) })
    buf
}
light_call_ty = (decls: [Decl], idx: DeclIndex, a: MutPtr<Malloc>, c: CallData, env: Ptr<VList>) Ty {
    eq(c.fn, "cstr").match ({
        true  => tcstr(),
        false => {
            f := idx.idx_func(decls, c.fn)
            (f.tparams.len > 0).match ({
                true  => a.subst_ty_in(f.tparams, f.light_targs(a, c.args, tvoid(), env, decls, idx), f.ret),
                false => f.ret
            })
        }
    })
}
light_last_stmt_ty = (a: MutPtr<Malloc>, stmts: [Stmt], env: Ptr<VList>, decls: [Decl], idx: DeclIndex) Ty {
    stmts[stmts.len - 1].match ({ .ExprStmt(e) => e.light_ty(a, env, decls, idx), .Return(r) => r.light_ty(a, env, decls, idx), _ => tvoid() })
}
light_extend = (a: MutPtr<Malloc>, env: Ptr<VList>, st: Stmt, decls: [Decl], idx: DeclIndex) Ptr<VList> {
    st.match ({ .Let(l) => a.vcons(l.name, l.ty.is_void_ty().match ({ true => l.value.light_ty(a, env, decls, idx), false => l.ty }), env), _ => env })
}
light_block_ty_from = (a: MutPtr<Malloc>, stmts: [Stmt], env: Ptr<VList>, decls: [Decl], idx: DeclIndex, i: i32) Ty {
    (i >= stmts.len).match ({
        true  => tvoid(),
        false => (i == stmts.len - 1).match ({
            true  => a.light_last_stmt_ty(stmts, env, decls, idx),
            false => a.light_block_ty_from(stmts, a.light_extend(env, stmts[i], decls, idx), decls, idx, i + 1)
        })
    })
}
light_block_ty = (a: MutPtr<Malloc>, b: BlockData, env: Ptr<VList>, decls: [Decl], idx: DeclIndex) Ty {
    a.light_block_ty_from(b.stmts, env, decls, idx, 0)
}
light_member_ty = (a: MutPtr<Malloc>, decls: [Decl], idx: DeclIndex, obj: Ty, field: str) Ty {
    obj.ty_under_ptr().match ({
        .Generic(g) => a.gen_struct_field(decls, g.name, field, g.args),
        .Slice(e)   => a.slice_member(field),
        _           => idx.idx_struct_field(decls, obj.enum_name(), field)
    })
}
light_ty = (e: Ptr<Expr>, a: MutPtr<Malloc>, env: Ptr<VList>, decls: [Decl], idx: DeclIndex) Ty {
    load(e).match ({
        .Int(n)        => ti32(),
        .Block(b)      => a.light_block_ty(b, env, decls, idx),
        .Byte(n)       => tu8(),
        .FloatLit(ft)  => tf64(),
        .StrLit(s)     => ttext(),
        .MakeStruct(m) => (m.targs.len > 0).match ({ true => tgeneric(m.ty, m.targs, m.mty), false => tnamed(m.ty) }),
        .MakeEnum(mk)  => (mk.targs.len > 0).match ({ true => tgeneric(mk.ty, mk.targs, mk.mty), false => tnamed(mk.ty) }),
        .Tag(t)        => (t.targs.len > 0).match ({ true => tgeneric(t.ty, t.targs, t.mty), false => tnamed(t.ty) }),
        .SliceLit(sd)  => a.light_slice(sd, env, decls, idx),
        .Var(v)        => env.lookup_var(v.name),
        .Call(c)       => light_call_ty(decls, idx, a, c, env),
        .Member(m)     => a.light_member_ty(decls, idx, m.obj.light_ty(a, env, decls, idx), m.field),
        .Bin(b)        => bin_ty(b.op, b.lhs.light_ty(a, env, decls, idx)),
        .Cond(d)       => d.t.light_ty(a, env, decls, idx),
        _              => tvoid()
    })
}
// Unify a param type against an arg type to infer one tparam.
unify_ty = (pty: Ty, aty: Ty, tp: str) Ty {
    pty.match ({
        .Named(n)   => eq(n, tp).match ({ true => aty, false => tvoid() }),
        .Generic(g) => aty.match ({ .Generic(ga) => g.args.unify_args(ga.args, tp), _ => tvoid() }),
        .Ptr(p)     => aty.match ({ .Ptr(pa) => load(p).unify_ty(load(pa), tp), _ => tvoid() }),
        .Slice(e)   => aty.match ({ .Slice(ea) => load(e).unify_ty(load(ea), tp), _ => tvoid() }),
        _           => tvoid()
    })
}
unify_args = (pargs: [Ty], aargs: [Ty], tp: str) Ty {
    found := tvoid()
    pargs.loop((h, i, pa) { found = found.is_void_ty().match ({ true => (i < aargs.len).match ({ true => pa.unify_ty(aargs[i], tp), false => found }), false => found }) })
    found
}
infer_one = (params: [Param], a: MutPtr<Malloc>, cargs: [Expr], tp: str, env: Ptr<VList>, decls: [Decl], idx: DeclIndex) Ty {
    found := tvoid()
    params.loop((h, i, p) { found = found.is_void_ty().match ({ true => (i < cargs.len).match ({ true => p.ty.unify_ty(cargs[i].addr().light_ty(a, env, decls, idx), tp), false => found }), false => found }) })
    found
}
infer_one_exp = (params: [Param], ret: Ty, exp: Ty, a: MutPtr<Malloc>, cargs: [Expr], tp: str, env: Ptr<VList>, decls: [Decl], idx: DeclIndex) Ty {
    arg := params.infer_one(a, cargs, tp, env, decls, idx)
    arg.is_void_ty().match ({ true => ret.light_ret_one(exp, tp), false => arg })
}
infer_targs = (a: MutPtr<Malloc>, tparams: [Param], params: [Param], ret: Ty, exp: Ty, cargs: [Expr], env: Ptr<VList>, decls: [Decl], idx: DeclIndex) [Ty] {
    buf := a.tbuf(tparams.len)
    tparams.loop((h, i, tp) { buf[i] = params.infer_one_exp(ret, exp, a, cargs, tp.name, env, decls, idx) })
    buf
}
// Substitute tparams in type-bearing expression/statement nodes.
subst_targs = (a: MutPtr<Malloc>, tparams: [Param], targs: [Ty], xs: [Ty]) [Ty] {
    buf := a.tbuf(xs.len)
    xs.loop((h, i, t) { buf[i] = a.subst_ty_in(tparams, targs, t) })
    buf
}
subst_genlit_g = (a: MutPtr<Malloc>, tparams: [Param], targs: [Ty], m: MakeStructData) Expr {
    nt := a.subst_targs(tparams, targs, m.targs)
    mkstructg(m.ty, a.mangle_str_in(m.ty, nt), nt, a.subst_inits(tparams, targs, m.inits))
}
subst_genlit = (a: MutPtr<Malloc>, tparams: [Param], targs: [Ty], m: MakeStructData) Expr {
    (m.targs.len > 0).match ({
        true  => a.subst_genlit_g(tparams, targs, m),
        false => mkstruct(m.ty, a.subst_inits(tparams, targs, m.inits))
    })
}
subst_inits = (a: MutPtr<Malloc>, tparams: [Param], targs: [Ty], inits: [FieldInit]) [FieldInit] {
    buf := a.fbuf(inits.len)
    inits.loop((h, i, fi) { buf[i] = finit(fi.name, a.subst_expr(tparams, targs, fi.value)) })
    buf
}
subst_exprs = (a: MutPtr<Malloc>, tparams: [Param], targs: [Ty], xs: [Expr]) [Expr] {
    buf := a.cebuf(xs.len)
    xs.loop((h, i, x) { buf[i] = load(a.subst_expr(tparams, targs, x.addr())) })
    buf
}
subst_arms = (a: MutPtr<Malloc>, tparams: [Param], targs: [Ty], arms: [ArmData]) [ArmData] {
    buf := a.abuf(arms.len)
    arms.loop((h, i, ar) { buf[i] = arm(ar.variant, ar.bind, a.subst_expr(tparams, targs, ar.body)) })
    buf
}
subst_match = (a: MutPtr<Malloc>, tparams: [Param], targs: [Ty], m: MatchData) Ptr<Expr> {
    subj := a.subst_expr(tparams, targs, m.subj)
    arms := a.subst_arms(tparams, targs, m.arms)
    m.ptr.match ({ true => a.cenode(ematchp(subj, m.ename, arms)), false => a.cenode(ematch(subj, m.ename, arms)) })
}
// Substitute and remangle generic-enum ctors/tags inside template bodies.
subst_mkenum = (a: MutPtr<Malloc>, tparams: [Param], targs: [Ty], ety: str, etargs: [Ty], variant: str, p: Ptr<Expr>) Ptr<Expr> {
    (etargs.len > 0).match ({
        true  => a.cenode(a.subst_mkenum_g(tparams, targs, ety, etargs, variant, p)),
        false => a.cenode(mkenum(ety, variant, p))
    })
}
subst_mkenum_g = (a: MutPtr<Malloc>, tparams: [Param], targs: [Ty], ety: str, etargs: [Ty], variant: str, p: Ptr<Expr>) Expr {
    nt := a.subst_targs(tparams, targs, etargs)
    mkenumg(ety, a.mangle_str_in(ety, nt), nt, variant, p)
}
subst_tag = (a: MutPtr<Malloc>, tparams: [Param], targs: [Ty], ety: str, etargs: [Ty], variant: str) Ptr<Expr> {
    (etargs.len > 0).match ({
        true  => a.cenode(a.subst_tag_g(tparams, targs, ety, etargs, variant)),
        false => a.cenode(mktag(ety, variant))
    })
}
subst_tag_g = (a: MutPtr<Malloc>, tparams: [Param], targs: [Ty], ety: str, etargs: [Ty], variant: str) Expr {
    nt := a.subst_targs(tparams, targs, etargs)
    mktagg(ety, a.mangle_str_in(ety, nt), nt, variant)
}
// `sizeof(T)` uses the tparam name as a value; rewrite it to the concrete C type name.
subst_tparam_var = (a: MutPtr<Malloc>, tparams: [Param], targs: [Ty], v: VarData, e: Ptr<Expr>) Ptr<Expr> {
    i := tparams.param_index(v.name)
    (i < 0).match ({ true => e, false => a.revar(v, a.ty_cname_in(targs[i])) })
}
subst_expr = (a: MutPtr<Malloc>, tparams: [Param], targs: [Ty], e: Ptr<Expr>) Ptr<Expr> {
    load(e).match ({
        .Var(v)       => a.subst_tparam_var(tparams, targs, v, e),
        .Bin(b)       => a.cenode(bin_at(b.op, a.subst_expr(tparams, targs, b.lhs), a.subst_expr(tparams, targs, b.rhs), b.pos)),
        .Cond(d)      => a.cenode(cond(a.subst_expr(tparams, targs, d.c), a.subst_expr(tparams, targs, d.t), a.subst_expr(tparams, targs, d.e))),
        .Member(m)    => a.cenode(member(a.subst_expr(tparams, targs, m.obj), m.field)),
        .Arrow(ar)    => a.cenode(arrow(a.subst_expr(tparams, targs, ar.obj), ar.field)),
        .Call(c)      => a.recall(c, c.fn, a.subst_exprs(tparams, targs, c.args)),
        .MakeEnum(mk) => a.subst_mkenum(tparams, targs, mk.ty, mk.targs, mk.variant, a.subst_expr(tparams, targs, mk.payload)),
        .Tag(t)       => a.subst_tag(tparams, targs, t.ty, t.targs, t.variant),
        .MakeStruct(m)=> a.cenode(a.subst_genlit(tparams, targs, m)),
        .Match(mm)    => a.subst_match(tparams, targs, mm),
        .Index(ix)    => a.cenode(eindex(a.subst_expr(tparams, targs, ix.seq), a.subst_expr(tparams, targs, ix.idx), a.subst_ty_in(tparams, targs, ix.elem))),
        .Loop(l)      => a.cenode(eloop(a.subst_expr(tparams, targs, l.seq), l.idx, l.elem, a.subst_ty_in(tparams, targs, l.elemTy), a.subst_body(tparams, targs, l.body), l.h)),
        .SliceLit(sd) => a.cenode(slit(a.subst_ty_in(tparams, targs, sd.elem), a.subst_exprs(tparams, targs, sd.items))),
        .Block(b)     => a.cenode(block(a.subst_body(tparams, targs, b.stmts))),
        _             => e
    })
}
subst_stmt = (a: MutPtr<Malloc>, tparams: [Param], targs: [Ty], st: Stmt) Stmt {
    st.match ({
        .Let(l)      => slett(l.name, a.subst_ty_in(tparams, targs, l.ty), a.subst_expr(tparams, targs, l.value)),
        .Assign(x)   => sassign_at(a.subst_expr(tparams, targs, x.target), a.subst_expr(tparams, targs, x.value), x.pos),
        .Return(r)   => sret(a.subst_expr(tparams, targs, r)),
        .ExprStmt(e) => sexpr(a.subst_expr(tparams, targs, e)),
        .If(f)       => sif(a.subst_expr(tparams, targs, f.c), a.subst_body(tparams, targs, f.then), a.subst_body(tparams, targs, f.els)),
        .While(w)    => swhile(a.subst_expr(tparams, targs, w.c), a.subst_body(tparams, targs, w.body)),
        .IndexSet(x) => sidxset_at(a.subst_expr(tparams, targs, x.seq), a.subst_expr(tparams, targs, x.idx), a.subst_ty_in(tparams, targs, x.elem), a.subst_expr(tparams, targs, x.value), x.pos)
    })
}
subst_body = (a: MutPtr<Malloc>, tparams: [Param], targs: [Ty], body: [Stmt]) [Stmt] {
    buf := a.sbuf(body.len)
    body.loop((h, i, st) { buf[i] = a.subst_stmt(tparams, targs, st) })
    buf
}
// Empty Named marks a generic template currently being inlined.
is_empty_named = (t: Ty) bool { t.match ({ .Named(n) => eq(n, ""), _ => false }) }
// Break recursive-generic inlining by noticing an in-progress template in the env.
is_inlining = (v: Ptr<VList>, name: str) bool {
    v.match ({
        .VNil     => false,
        .VCons(c) => (eq(c.name, name) && c.ty.is_empty_named()).match ({ true => true, false => c.tail.is_inlining(name) })
    })
}
inline_template = (a: MutPtr<Malloc>, decls: [Decl], idx: DeclIndex, name: str, cargs: [Expr], env: Ptr<VList>, exp: Ty) Ptr<Expr> {
    tf   := idx.idx_func(decls, name)
    ienv := a.vcons(name, tnamed(""), env)
    body := (tf.tparams.len > 0).match ({
        true  => a.subst_body(tf.tparams, a.infer_targs(tf.tparams, tf.params, tf.ret, exp, cargs, env, decls, idx), tf.body),
        false => tf.body
    })
    a.blockify(a.xform_body(decls, idx, body, tf.params, cargs, ienv, exp))
}
maybe_template = (a: MutPtr<Malloc>, decls: [Decl], idx: DeclIndex, c: CallData, cargs: [Expr], env: Ptr<VList>, exp: Ty) Ptr<Expr> {
    idx.idx_template_call(decls, c.fn).match ({
        // A recursive generic fn cannot be inlined (the splice never terminates); leave the call as a
        // bare call to the template name. compiler.check's mono_rec emits one concrete C instance per
        // (template, concrete-targs) and resolve_call rewrites the call to it. (is_inlining is the same
        // recursion-break, but a recursive generic must NEVER splice even on its first reach.)
        true  => (env.is_inlining(c.fn) || idx.idx_func(decls, c.fn).rc_is_rec_gen_f()).match ({
            true  => a.recall(c, c.fn, cargs),
            false => (idx.idx_func(decls, c.fn).params.len == cargs.len).match ({
                true  => a.inline_template(decls, idx, c.fn, cargs, env, exp),
                false => a.recall(c, c.fn, cargs)
            })
        }),
        false => a.recall(c, c.fn, cargs)
    })
}
xform_call = (a: MutPtr<Malloc>, decls: [Decl], idx: DeclIndex, c: CallData, params: [Param], fargs: [Expr], env: Ptr<VList>, exp: Ty) Ptr<Expr> {
    cargs := a.xform_args(decls, idx, c.args, params, fargs, env)
    fi    := params.param_index(c.fn)
    (fi < 0).match ({
        true  => a.maybe_template(decls, idx, c, cargs, env, exp),
        false => params[fi].ty.is_fnt().match ({
            true  => a.inline_lambda(decls, idx, fargs[fi], cargs, env),
            // an indirect call through a renamed local (a fn-value let): the substituted arg is the
            // renamed local's Var, so recall through its renamed C name (not the stale original).
            false => a.recall(c, fargs[fi].callee_subst_name(c.fn), cargs)
        })
    })
}
xform_match = (a: MutPtr<Malloc>, decls: [Decl], idx: DeclIndex, m: MatchData, params: [Param], fargs: [Expr], env: Ptr<VList>, exp: Ty) Ptr<Expr> {
    subj := a.xform_expr(decls, idx, m.subj, params, fargs, env)
    st   := subj.light_ty(a, env, decls, idx)
    arms := a.xform_arms(decls, idx, st, m.ename, m.arms, params, fargs, env, exp)
    out := a.cenode(ematch(subj, m.ename, arms))
    m.ptr.match ({ true => { out = a.cenode(ematchp(subj, m.ename, arms)) }, _ })
    out
}
xform_inits = (a: MutPtr<Malloc>, decls: [Decl], idx: DeclIndex, inits: [FieldInit], params: [Param], fargs: [Expr], env: Ptr<VList>) [FieldInit] {
    buf := a.fbuf(inits.len)
    inits.loop((h, i, fi) { buf[i] = finit(fi.name, a.xform_expr(decls, idx, fi.value, params, fargs, env)) })
    buf
}
xform_lambda = (a: MutPtr<Malloc>, decls: [Decl], idx: DeclIndex, lm: LambdaData, params: [Param], fargs: [Expr], env: Ptr<VList>) Ptr<Expr> {
    ps := params
    xs := fargs
    lm.params.loop((h, i, p) {
        ps = a.add_subst_param(ps, p.name)
        xs = a.add_subst_arg(xs, p.name)
    })
    a.cenode(lam(lm.params, a.xform_body(decls, idx, lm.body, ps, xs, env, tvoid())))
}
xform_expr = (a: MutPtr<Malloc>, decls: [Decl], idx: DeclIndex, e: Ptr<Expr>, params: [Param], fargs: [Expr], env: Ptr<VList>) Ptr<Expr> {
    a.xform_expr_exp(decls, idx, e, params, fargs, env, tvoid())
}
xform_expr_exp = (a: MutPtr<Malloc>, decls: [Decl], idx: DeclIndex, e: Ptr<Expr>, params: [Param], fargs: [Expr], env: Ptr<VList>, exp: Ty) Ptr<Expr> {
    out := e
    load(e).match ({
        .Var(v)       => { out = a.subst_var(params, fargs, v.name, e) },
        .Call(c)      => { out = a.xform_call(decls, idx, c, params, fargs, env, exp) },
        .Bin(b)       => { out = a.cenode(bin_at(b.op, a.xform_expr(decls, idx, b.lhs, params, fargs, env), a.xform_expr(decls, idx, b.rhs, params, fargs, env), b.pos)) },
        .Cond(d)      => { out = a.cenode(cond(a.xform_expr(decls, idx, d.c, params, fargs, env), a.xform_expr_exp(decls, idx, d.t, params, fargs, env, exp), a.xform_expr_exp(decls, idx, d.e, params, fargs, env, exp))) },
        .Member(m)    => { out = a.cenode(member(a.xform_expr(decls, idx, m.obj, params, fargs, env), m.field)) },
        .Arrow(ar)    => { out = a.cenode(arrow(a.xform_expr(decls, idx, ar.obj, params, fargs, env), ar.field)) },
        .MakeEnum(mk) => { out = a.cenode(mkenumg(mk.ty, mk.mty, mk.targs, mk.variant, a.xform_expr(decls, idx, mk.payload, params, fargs, env))) },
        .MakeStruct(sd) => { out = a.cenode(mkstructg(sd.ty, sd.mty, sd.targs, a.xform_inits(decls, idx, sd.inits, params, fargs, env))) },
        .Match(m)     => { out = a.xform_match(decls, idx, m, params, fargs, env, exp) },
        .Index(ix)    => { out = a.cenode(eindex(a.xform_expr(decls, idx, ix.seq, params, fargs, env), a.xform_expr(decls, idx, ix.idx, params, fargs, env), ix.elem)) },
        .Loop(l)      => {
            lidx := a.local_name_at(l.idx, env, params.len)
            elem := a.local_name_at(l.elem, env, params.len + 1)
            hnd  := a.local_name_at(l.h, env, params.len + 2)
            ps1  := a.add_subst_param(a.add_subst_param(a.add_subst_param(params, l.idx), l.elem), l.h)
            xs1  := a.add_subst_arg(a.add_subst_arg(a.add_subst_arg(fargs, lidx), elem), hnd)
            out = a.cenode(eloop(a.xform_expr(decls, idx, l.seq, params, fargs, env), lidx, elem, l.elemTy, a.xform_body(decls, idx, l.body, ps1, xs1, env, tvoid()), hnd))
        },
        .Lambda(lm)   => { out = a.xform_lambda(decls, idx, lm, params, fargs, env) },
        .SliceLit(sd) => { out = a.cenode(slit(sd.elem, a.xform_args(decls, idx, sd.items, params, fargs, env))) },
        .Block(b)     => { out = a.cenode(block(a.xform_body(decls, idx, b.stmts, params, fargs, env, exp))) },
        _             => {}
    })
    out
}
xform_stmt = (a: MutPtr<Malloc>, decls: [Decl], idx: DeclIndex, st: Stmt, params: [Param], fargs: [Expr], env: Ptr<VList>, exp: Ty) Stmt {
    out := st
    st.match ({
        .Let(l)      => { out = st.let_value_lambda().match ({
                              true  => sexpr(a.cenode(block(no_stmts()))),   // lambda-alias let: dropped (spliced at uses)
                              false => slett(a.local_name_at(l.name, env, params.len), l.ty, a.xform_expr_exp(decls, idx, l.value, params, fargs, env, l.ty))
                          }) },
        .Assign(x)   => { out = sassign_at(a.xform_expr(decls, idx, x.target, params, fargs, env), a.xform_expr(decls, idx, x.value, params, fargs, env), x.pos) },
        .Return(r)   => { out = sret(a.xform_expr_exp(decls, idx, r, params, fargs, env, exp)) },
        .ExprStmt(e) => { out = sexpr(a.xform_expr_exp(decls, idx, e, params, fargs, env, exp)) },
        .If(f)       => { out = sif(a.xform_expr(decls, idx, f.c, params, fargs, env), a.xform_body(decls, idx, f.then, params, fargs, env, tvoid()), a.xform_body(decls, idx, f.els, params, fargs, env, tvoid())) },
        .While(w)    => { out = swhile(a.xform_expr(decls, idx, w.c, params, fargs, env), a.xform_body(decls, idx, w.body, params, fargs, env, tvoid())) },
        .IndexSet(x) => { out = sidxset_at(a.xform_expr(decls, idx, x.seq, params, fargs, env), a.xform_expr(decls, idx, x.idx, params, fargs, env), x.elem, a.xform_expr(decls, idx, x.value, params, fargs, env), x.pos) }
    })
    out
}
// Thread local light types so generic call args can infer from Vars.
xform_let_ext = (a: MutPtr<Malloc>, env: Ptr<VList>, st: Stmt, decls: [Decl], idx: DeclIndex, params: [Param]) Ptr<VList> {
    out := env
    st.match ({ .Let(l) => {
        ty := l.ty
        l.ty.is_void_ty().match ({ true => { ty = l.value.light_ty(a, env, decls, idx) }, _ })
        out = a.vcons(a.local_name_at(l.name, env, params.len), ty, env)
    }, _ })
    out
}
xform_param_shadow = (a: MutPtr<Malloc>, params: [Param], st: Stmt) [Param] {
    out := params
    st.match ({ .Let(l) => { out = st.let_value_lambda().match ({
                                 true  => a.add_fnt_param(params, l.name),
                                 false => a.add_subst_param(params, l.name)
                             }) }, _ })
    out
}
xform_arg_shadow = (a: MutPtr<Malloc>, decls: [Decl], idx: DeclIndex, args: [Expr], st: Stmt, params: [Param], env: Ptr<VList>) [Expr] {
    out := args
    st.match ({ .Let(l) => { out = st.let_value_lambda().match ({
                                 true  => a.add_lambda_arg(args, a.xform_expr(decls, idx, l.value, params, args, env)),
                                 false => a.add_subst_arg(args, a.local_name_at(l.name, env, params.len))
                             }) }, _ })
    out
}
xform_body = (a: MutPtr<Malloc>, decls: [Decl], idx: DeclIndex, body: [Stmt], params: [Param], fargs: [Expr], env: Ptr<VList>, exp: Ty) [Stmt] {
    buf := a.sbuf(body.len)
    e   := env
    ps  := params
    xs  := fargs
    body.loop((h, i, st) {
        want := tvoid()
        (i == body.len - 1).match ({ true => { want = exp }, _ })
        buf[i] = a.xform_stmt(decls, idx, st, ps, xs, e, want)
        e = a.xform_let_ext(e, st, decls, idx, ps)
        xs = a.xform_arg_shadow(decls, idx, xs, st, ps, e)
        ps = a.xform_param_shadow(ps, st)
    })
    buf
}
inline_decl = (a: MutPtr<Malloc>, decls: [Decl], idx: DeclIndex, d: Decl) Decl {
    d.match ({
        .DFunc(f) => dfunc(Func( name: f.name, params: f.params, ret: f.ret, tparams: f.tparams, body: a.xform_body(decls, idx, f.body, empty_params(), empty_args(), a.params_env(f.params), f.ret) )),
        _         => d
    })
}

// Trait default methods are materialized for impls that omit them.
pbuf = (a: MutPtr<Malloc>, n: i64) [Param] { slice(a.acquire(n * sizeof(Param) + sizeof(Param)), n) }
tybuf1 = (a: MutPtr<Malloc>) [Ty] { slice(a.acquire(sizeof(Ty)), 1) }
self_param = (a: MutPtr<Malloc>) [Param] { buf := a.pbuf(1)  buf[0] = param("Self", tvoid())  buf }
self_arg = (a: MutPtr<Malloc>, tyname: str) [Ty] { buf := a.tybuf1()  buf[0] = tnamed(tyname)  buf }
// Specialize default Func to a concrete impl type.
default_for_type = (a: MutPtr<Malloc>, td: TraitDefData, tyname: str) Func {
    sp := a.self_param()
    ag := a.self_arg(tyname)
    ps := a.pbuf(td.fn.params.len)
    td.fn.params.loop((h, i, p) { ps[i] = param(p.name, a.subst_ty_in(sp, ag, p.ty)) })
    Func( name: a.impl_cname_in(td.trname, tyname, td.fn.name), params: ps,
           ret: a.subst_ty_in(sp, ag, td.fn.ret), tparams: td.fn.tparams, body: td.fn.body )
}
param_names_have = (names: [Param], m: str) bool {
    found := false
    names.loop((h, i, p) { found = eq(p.name, m).match ({ true => true, false => found }) })
    found
}
// Does this impl already provide method m?
def_provided = (decls: [Decl], tyname: str, trname: str, m: str) bool {
    found := false
    decls.loop((h, i, d) { found = d.match ({
        .DImpl(im) => (eq(im.ty, tyname) && eq(im.trname, trname)).match ({
            true  => im.methods.param_names_have(m).match ({ true => true, false => found }),
            false => found }),
        _ => found }) })
    found
}
default_expansion_count = (decls: [Decl]) i64 {
    n := 0
    decls.loop((h, i, d) { d.match ({ .DTraitDefault(td) => decls.loop((h2, j, e) { e.match ({
        .DImpl(im) => (eq(im.trname, td.trname) && (decls.def_provided(im.ty, td.trname, td.fn.name) == false)).match ({ true => { n = n + 1 }, false => {} }),
        _ => {} }) }), _ => {} }) })
    n
}
emit_defaults_for = (a: MutPtr<Malloc>, decls: [Decl], td: TraitDefData, buf: [Decl], j: i64) i64 {
    k := j
    decls.loop((h, i, d) { d.match ({
        .DImpl(im) => (eq(im.trname, td.trname) && (decls.def_provided(im.ty, td.trname, td.fn.name) == false)).match ({
            true  => { buf[k] = dfunc(a.default_for_type(td, im.ty))  k = k + 1 },
            false => {} }),
        _ => {} }) })
    k
}
expand_defaults = (a: MutPtr<Malloc>, decls: [Decl]) [Decl] {
    extra := decls.default_expansion_count()
    (extra == 0).match ({
        true  => decls,
        false => {
            buf := a.dbuf(decls.len + extra)
            decls.loop((h, i, d) { buf[i] = d })
            k := decls.len
            decls.loop((h, i, d) { d.match ({ .DTraitDefault(td) => { k = a.emit_defaults_for(decls, td, buf, k) }, _ => {} }) })
            buf
        }
    })
}
// Resolve module: defaults, resolve, inline templates, then re-resolve concrete inline residue.
// Lambdas splice bodies back into their caller, so that re-resolve can expose more template calls
// such as captured generic receiver methods; run one more inline/resolve pass for that residue.
// ── DESUGAR: faithful MethodCall -> flat Call (UFCS lowering) ───────────────────────────────
// parse_module keeps `recv.method(args)` as a faithful MethodCall (so the formatter sees the surface
// UFCS form). This pass — run at the very START of resolve_module, before any other pass — rewrites each
// MethodCall back into the EXACT flat `Call(fn: method, args: [recv] ++ args, pos: method-pos, raw: false)`
// the old flattening parser produced, so the resolve/inline/genc pipeline downstream is byte-for-byte
// unchanged. The walk mutates IN PLACE: parse_module builds a fresh tree (no aliased nodes), so each
// child node is rewritten through its own Ptr/slice slot, touching nothing but the MethodCall sites.
desugar_method_calls* = (a: MutPtr<Malloc>, decls: [Decl]) [Decl] {
    decls.loop((h, i, d) { a.dmc_decl(d) })
    decls
}
dmc_decl = (a: MutPtr<Malloc>, d: Decl) void {
    d.match ({
        .DFunc(f)          => a.dmc_body(f.body),
        .DGlobal(g)        => a.dmc_expr(g.init),
        .DTraitDefault(td) => a.dmc_body(td.fn.body),
        _                  => {}
    })
}
dmc_body = (a: MutPtr<Malloc>, body: [Stmt]) void {
    body.loop((h, i, st) { a.dmc_stmt(body[i].addr()) })
}
dmc_stmt = (a: MutPtr<Malloc>, sp: Ptr<Stmt>) void {
    sp.match ({
        .Let(l)      => a.dmc_expr(l.value),
        .Assign(asn) => { a.dmc_expr(asn.target)  a.dmc_expr(asn.value) },
        .Return(e)   => a.dmc_expr(e),
        .If(f)       => { a.dmc_expr(f.c)  a.dmc_body(f.then)  a.dmc_body(f.els) },
        .While(w)    => { a.dmc_expr(w.c)  a.dmc_body(w.body) },
        .IndexSet(x) => { a.dmc_expr(x.seq)  a.dmc_expr(x.idx)  a.dmc_expr(x.value) },
        .ExprStmt(e) => a.dmc_expr(e)
    })
}
dmc_args = (a: MutPtr<Malloc>, args: [Expr]) void {
    args.loop((h, i, ar) { a.dmc_expr(args[i].addr()) })
}
dmc_inits = (a: MutPtr<Malloc>, inits: [FieldInit]) void {
    inits.loop((h, i, fi) { a.dmc_expr(fi.value) })
}
dmc_arms = (a: MutPtr<Malloc>, arms: [ArmData]) void {
    arms.loop((h, i, ar) { a.dmc_expr(ar.body) })
}
// `recv.method(args)` -> `Call(fn: method, args: [recv, ...args], pos, raw: false)` — exactly what the
// old parse_method built (buf[0] = recv, method args from index 1, via call_at).
dmc_lower = (a: MutPtr<Malloc>, mc: MethodCallData) Expr {
    buf := a.cebuf(mc.args.len + 1)
    buf[0] = load(mc.recv)
    mc.args.loop((h, i, ar) { buf[i + 1] = mc.args[i] })
    call_at(mc.method, buf, mc.pos)
}
dmc_expr = (a: MutPtr<Malloc>, ep: Ptr<Expr>) void {
    ep.match ({
        .Bin(b)        => { a.dmc_expr(b.lhs)  a.dmc_expr(b.rhs) },
        .Call(c)       => a.dmc_args(c.args),
        .MethodCall(mc) => {
            a.dmc_expr(mc.recv)
            a.dmc_args(mc.args)
            store(ep, a.dmc_lower(mc))
        },
        .Cond(d)       => { a.dmc_expr(d.c)  a.dmc_expr(d.t)  a.dmc_expr(d.e) },
        .Member(m)     => a.dmc_expr(m.obj),
        .Arrow(ar)     => a.dmc_expr(ar.obj),
        .MakeEnum(m)   => a.dmc_expr(m.payload),
        .MakeStruct(m) => a.dmc_inits(m.inits),
        .Match(m)      => { a.dmc_expr(m.subj)  a.dmc_arms(m.arms) },
        .SliceLit(sd)  => a.dmc_args(sd.items),
        .Index(ix)     => { a.dmc_expr(ix.seq)  a.dmc_expr(ix.idx) },
        .Loop(l)       => { a.dmc_expr(l.seq)  a.dmc_body(l.body) },
        .Lambda(lm)    => a.dmc_body(lm.body),
        .Block(b)      => a.dmc_body(b.stmts),
        _              => {}
    })
}

// Enum-variant defaults (`Name = expr`) are parsed with a void payload + the default expr; before any
// other pass, infer each default's type into the payload so codegen lays out the union slot and match
// arms bind correctly.
vbuf = (a: MutPtr<Malloc>, n: i64) [VariantDef] { slice(a.acquire(n * sizeof(VariantDef)), n) }
default_payload = (a: MutPtr<Malloc>, decls: [Decl], idx: DeclIndex, v: VariantDef) Ty {
    v.dflt.is_expr_null().match ({
        true  => v.payload,
        false => v.dflt.light_ty(a, a.vnil(), decls, idx)
    })
}
fill_variant_defaults = (a: MutPtr<Malloc>, decls: [Decl], idx: DeclIndex, vs: [VariantDef]) [VariantDef] {
    buf := a.vbuf(vs.len)
    vs.loop((h, i, v) { buf[i] = VariantDef( name: v.name, payload: a.default_payload(decls, idx, v), dflt: v.dflt ) })
    buf
}
fill_enum_defaults = (a: MutPtr<Malloc>, decls: [Decl], idx: DeclIndex) [Decl] {
    buf := a.dbuf(decls.len)
    decls.loop((h, i, d) { buf[i] = d.match ({
        .DEnum(ed) => .DEnum(EnumDecl( name: ed.name, variants: a.fill_variant_defaults(decls, idx, ed.variants) )),
        _          => d
    }) })
    buf
}
// ── RECURSIVE GENERIC FUNCTION MONOMORPHIZATION ──────────────────────────────────────────────
// A generic FUNCTION that calls itself can't be inlined (the splice never terminates), so the inliner
// leaves the self-call as a bare call to the template name, which links to nothing. This pass mirrors
// compiler.mono's struct/enum monomorphization for FUNCTIONS: it discovers every distinct (template,
// concrete-targs) the program uses and emits one concrete C function per instance (tparam→arg
// substituted), with a deterministic mangled name (the SAME scheme as generic structs/enums, via
// mangle_str_in). resolve_call then rewrites each recursive-generic call to its mangled instance.
// Only DIRECT type-param recursion is handled; FnT-splice generics and mutual recursion still inline.

// detection: does `body` contain a DIRECT call to `nm`? (the self-call test)
rc_calls_es = (xs: [Expr], nm: str) bool {
    f := false
    xs.loop((h, i, x) { f = f.match ({ true => true, false => x.addr().rc_calls_e(nm) }) })
    f
}
rc_calls_inits = (inits: [FieldInit], nm: str) bool {
    f := false
    inits.loop((h, i, fi) { f = f.match ({ true => true, false => fi.value.rc_calls_e(nm) }) })
    f
}
rc_calls_arms = (arms: [ArmData], nm: str) bool {
    f := false
    arms.loop((h, i, ar) { f = f.match ({ true => true, false => ar.body.rc_calls_e(nm) }) })
    f
}
rc_calls_e = (e: Ptr<Expr>, nm: str) bool {
    load(e).match ({
        .Call(c)       => eq(c.fn, nm) || c.args.rc_calls_es(nm),
        .Bin(b)        => b.lhs.rc_calls_e(nm) || b.rhs.rc_calls_e(nm),
        .Cond(d)       => d.c.rc_calls_e(nm) || d.t.rc_calls_e(nm) || d.e.rc_calls_e(nm),
        .Member(m)     => m.obj.rc_calls_e(nm),
        .Arrow(ar)     => ar.obj.rc_calls_e(nm),
        .MakeEnum(mk)  => mk.payload.rc_calls_e(nm),
        .MakeStruct(s) => s.inits.rc_calls_inits(nm),
        .Match(m)      => m.subj.rc_calls_e(nm) || m.arms.rc_calls_arms(nm),
        .Index(ix)     => ix.seq.rc_calls_e(nm) || ix.idx.rc_calls_e(nm),
        .SliceLit(sd)  => sd.items.rc_calls_es(nm),
        .Loop(l)       => l.seq.rc_calls_e(nm) || l.body.rc_calls_body(nm),
        .Block(bl)     => bl.stmts.rc_calls_body(nm),
        .Lambda(la)    => la.body.rc_calls_body(nm),
        _              => false
    })
}
rc_calls_stmt = (st: Stmt, nm: str) bool {
    st.match ({
        .Let(l)      => l.value.rc_calls_e(nm),
        .Assign(x)   => x.target.rc_calls_e(nm) || x.value.rc_calls_e(nm),
        .Return(r)   => r.rc_calls_e(nm),
        .ExprStmt(e) => e.rc_calls_e(nm),
        .If(f)       => f.c.rc_calls_e(nm) || f.then.rc_calls_body(nm) || f.els.rc_calls_body(nm),
        .While(w)    => w.c.rc_calls_e(nm) || w.body.rc_calls_body(nm),
        .IndexSet(x) => x.seq.rc_calls_e(nm) || x.idx.rc_calls_e(nm) || x.value.rc_calls_e(nm)
    })
}
rc_calls_body* = (body: [Stmt], nm: str) bool {
    f := false
    body.loop((h, i, st) { f = f.match ({ true => true, false => st.rc_calls_stmt(nm) }) })
    f
}
// a recursive generic = type-param generic (NOT FnT-splice) with a body that calls itself directly.
rc_is_rec_gen_f* = (f: Func) bool {
    ((f.tparams.len > 0) && (f.params.has_fnt_param() == false)).match ({
        true  => f.body.rc_calls_body(f.name),
        false => false
    })
}

// instance buffer: deduped by mangled name, bounded against polymorphic-recursion blowup (like mono).
rc_gbuf = (a: MutPtr<Malloc>, n: i64) [GenericData] { slice(a.acquire(n * sizeof(GenericData)), n) }
rc_has = (buf: [GenericData], cnt: i32, m: str) bool {
    found := false
    buf.loop((h, i, e) { found = (i < cnt).match ({ true => eq(e.mangled, m).match ({ true => true, false => found }), false => found }) })
    found
}
rc_ty_depth = (t: Ty) i32 {
    t.match ({ .Generic(g) => 1 + g.args.rc_tys_depth(), .Ptr(p) => load(p).rc_ty_depth(), .Slice(e) => load(e).rc_ty_depth(), _ => 0 })
}
rc_tys_depth = (ts: [Ty]) i32 {
    d := 0
    ts.loop((h, i, t) { dd := t.rc_ty_depth()  d = (dd > d).match ({ true => dd, false => d }) })
    d
}
rc_add = (buf: [GenericData], cnt: i32, g: GenericData) i32 {
    // a polymorphic-recursive self-call (deeper targs each step) would grow the worklist forever; drop
    // the absurdly-deep instance (a well-formed one is shallow) and never write past the buffer.
    ((1 + g.args.rc_tys_depth()) > 24).match ({ true => { return cnt }, false => {} })
    (cnt >= buf.len).match ({ true => panic("zenc: too many recursive-generic fn instances (rc_gbuf cap; raise it in compiler.check)\n"), false => {} })
    buf[cnt] = g
    cnt + 1
}

// discovery: walk concrete bodies (Env-threaded for full type inference incl. addr/dispatch), recording
// one instance per recursive-generic call site (targs inferred exactly as resolve_call will mangle them).
rc_col_es = (env: Env, buf: [GenericData], cnt: i32, xs: [Expr]) i32 {
    c := cnt
    xs.loop((h, i, x) { c = env.rc_col_e(buf, c, x.addr()) })
    c
}
rc_col_inits = (env: Env, buf: [GenericData], cnt: i32, inits: [FieldInit]) i32 {
    c := cnt
    inits.loop((h, i, fi) { c = env.rc_col_e(buf, c, fi.value) })
    c
}
rc_col_match = (env: Env, buf: [GenericData], cnt: i32, m: MatchData) i32 {
    c := env.rc_col_e(buf, cnt, m.subj)
    t := env.infer_expr(m.subj)
    m.arms.loop((h, i, ar) { c = env.a.arm_env(env, t, ar).rc_col_e(buf, c, ar.body) })
    c
}
rc_col_loop = (env: Env, buf: [GenericData], cnt: i32, l: LoopData) i32 {
    c := env.rc_col_e(buf, cnt, l.seq)
    e := Env( vars: env.a.vcons(l.elem, l.elemTy, env.a.vcons(l.idx, ti64(), env.vars)), decls: env.decls, didx: env.didx, exp: env.exp, a: env.a )
    e.rc_col_body(buf, c, l.body)
}
rc_lam_env = (env: Env, ps: [Param]) Env {
    e := env
    ps.loop((h, i, p) { e = Env( vars: e.a.vcons(p.name, p.ty, e.vars), decls: e.decls, didx: e.didx, exp: e.exp, a: e.a ) })
    e
}
rc_col_call = (env: Env, buf: [GenericData], cnt: i32, c: CallData) i32 {
    c2 := env.rc_col_es(buf, cnt, c.args)
    dn := env.dispatch_name(c)
    f  := env.env_func(dn)
    (eq(f.name, dn) && (f.params.len == c.args.len) && f.rc_is_rec_gen_f()).match ({
        true  => {
            targs := env.call_targs(f, c.args)
            m     := env.a.mangle_str_in(dn, targs)
            buf.rc_has(c2, m).match ({ true => c2, false => buf.rc_add(c2, GenericData( name: dn, args: targs, mangled: m )) })
        },
        false => c2
    })
}
rc_col_e = (env: Env, buf: [GenericData], cnt: i32, e: Ptr<Expr>) i32 {
    load(e).match ({
        .Call(c)       => env.rc_col_call(buf, cnt, c),
        .Bin(b)        => env.rc_col_e(buf, env.rc_col_e(buf, cnt, b.lhs), b.rhs),
        .Cond(d)       => env.rc_col_e(buf, env.rc_col_e(buf, env.rc_col_e(buf, cnt, d.c), d.t), d.e),
        .Member(m)     => env.rc_col_e(buf, cnt, m.obj),
        .Arrow(ar)     => env.rc_col_e(buf, cnt, ar.obj),
        .MakeEnum(mk)  => env.rc_col_e(buf, cnt, mk.payload),
        .MakeStruct(s) => env.rc_col_inits(buf, cnt, s.inits),
        .Match(m)      => env.rc_col_match(buf, cnt, m),
        .Index(ix)     => env.rc_col_e(buf, env.rc_col_e(buf, cnt, ix.seq), ix.idx),
        .SliceLit(sd)  => env.rc_col_es(buf, cnt, sd.items),
        .Loop(l)       => env.rc_col_loop(buf, cnt, l),
        .Block(bl)     => env.rc_col_body(buf, cnt, bl.stmts),
        .Lambda(la)    => env.rc_lam_env(la.params).rc_col_body(buf, cnt, la.body),
        _              => cnt
    })
}
rc_col_stmt = (env: Env, buf: [GenericData], cnt: i32, st: Stmt) i32 {
    st.match ({
        .Let(l)      => env.rc_col_e(buf, cnt, l.value),
        .Assign(x)   => env.rc_col_e(buf, env.rc_col_e(buf, cnt, x.target), x.value),
        .Return(r)   => env.rc_col_e(buf, cnt, r),
        .ExprStmt(e) => env.rc_col_e(buf, cnt, e),
        .If(f)       => env.rc_col_body(buf, env.rc_col_body(buf, env.rc_col_e(buf, cnt, f.c), f.then), f.els),
        .While(w)    => env.rc_col_body(buf, env.rc_col_e(buf, cnt, w.c), w.body),
        .IndexSet(x) => env.rc_col_e(buf, env.rc_col_e(buf, env.rc_col_e(buf, cnt, x.seq), x.idx), x.value)
    })
}
rc_col_body = (env: Env, buf: [GenericData], cnt: i32, body: [Stmt]) i32 {
    c := cnt
    e := env
    body.loop((h, i, st) {
        c = e.rc_col_stmt(buf, c, st)
        e = e.a.extend_env(e, st)
    })
    c
}
// seed from CONCRETE functions only (a template body's self-call has a tparam targ, not a concrete one).
rc_fn_env = (env: Env, f: Func) Env { Env( vars: env.a.params_env(f.params), decls: env.decls, didx: env.didx, exp: f.ret, a: env.a ) }
rc_seed = (env: Env, buf: [GenericData], cnt: i32) i32 {
    c := cnt
    env.decls.loop((h, i, d) { c = d.match ({
        .DFunc(f) => f.is_generic_fn().match ({ true => c, false => env.rc_fn_env(f).rc_col_body(buf, c, f.body) }),
        _         => c
    }) })
    c
}
// the substituted param list of one instance (tparam→arg in each param type).
rc_subst_params = (a: MutPtr<Malloc>, tparams: [Param], targs: [Ty], ps: [Param]) [Param] {
    buf := a.pbuf(ps.len)
    ps.loop((h, i, p) { buf[i] = param(p.name, a.subst_ty_in(tparams, targs, p.ty)) })
    buf
}
// transitive closure: each instance's substituted body may name further instances (its own self-call,
// or a call to another recursive generic), so walk every instance body until no new ones appear.
rc_expand_one = (env: Env, buf: [GenericData], count: i32, i: i32) i32 {
    g       := buf[i]
    tf      := env.didx.idx_func(env.decls, g.name)
    iparams := env.a.rc_subst_params(tf.tparams, g.args, tf.params)
    ibody   := env.a.subst_body(tf.tparams, g.args, tf.body)
    ienv    := Env( vars: env.a.params_env(iparams), decls: env.decls, didx: env.didx, exp: env.a.subst_ty_in(tf.tparams, g.args, tf.ret), a: env.a )
    env.rc_expand(buf, ienv.rc_col_body(buf, count, ibody), i + 1)
}
rc_expand = (env: Env, buf: [GenericData], count: i32, i: i32) i32 {
    (i >= count).match ({ true => count, false => env.rc_expand_one(buf, count, i) })
}
// the concrete DFunc for one instance: template params/ret/body with tparam→arg substituted, given the
// mangled name. Its self-call stays the bare template name; the final resolve_call mangles it (the
// instance decl now exists), which also resolves dispatch (e.g. allocator methods) on the concrete type.
rc_gen = (env: Env, g: GenericData) Decl {
    tf := env.didx.idx_func(env.decls, g.name)
    dfunc(Func(
        name: g.mangled,
        params: env.a.rc_subst_params(tf.tparams, g.args, tf.params),
        ret: env.a.subst_ty_in(tf.tparams, g.args, tf.ret),
        tparams: empty_params(),
        body: env.a.subst_body(tf.tparams, g.args, tf.body)
    ))
}
// append one concrete C function per discovered recursive-generic instance. The templates stay in the
// decl list (emit skips them via is_template); resolve_call — run after this — rewrites the calls.
mono_rec* = (a: MutPtr<Malloc>, decls: [Decl], idx: DeclIndex) [Decl] {
    base := Env( vars: a.vnil(), decls: decls, didx: idx, exp: tvoid(), a: a )
    buf  := a.rc_gbuf(4096)
    cnt  := base.rc_expand(buf, base.rc_seed(buf, 0), 0)
    (cnt == 0).match ({
        true  => decls,
        false => {
            out := a.dbuf(decls.len + cnt)
            decls.loop((h, i, d) { out[i] = d })
            k := decls.len
            buf.loop((h, i, g) { (i < cnt).match ({ true => { out[k] = base.rc_gen(g)  k = k + 1 }, false => {} }) })
            slice(out.ptr, k)
        }
    })
}

// ── M1b: lift a NON-CAPTURING lambda LITERAL in a value position to a top-level function ──────────
// A lambda stored in a struct field or returned can't be inline-spliced; lift its body to a generated
// top-level fn (params typed from the expected FnT) and replace the literal with the fn name (a fn
// value, M1). A CAPTURING lambda (one that references an enclosing local) is NOT lifted — it falls
// through to the clean error[lambda-value] (real captures need the M2 env/lifetime design).

// capture analysis: does this lambda body reference a FREE variable — a name that is neither one of the
// lambda's params, a binder introduced inside the body, a top-level fn/global, nor true/false? Such a
// name is a captured enclosing local. `bound` threads the in-scope binder names (scope-correct).
lift_toplevel = (idx: DeclIndex, decls: [Decl], n: str) bool { (idx.func_idx.get(n, 0 - 1) >= 0) || (idx.global_idx.get(n, 0 - 1) >= 0) }
lift_is_captured = (decls: [Decl], idx: DeclIndex, bound: Ptr<VList>, n: str) bool {
    (bound.var_bound(n) || idx.lift_toplevel(decls, n) || eq(n, "true") || eq(n, "false")).match ({ true => false, false => true })
}
lift_extend = (a: MutPtr<Malloc>, bound: Ptr<VList>, st: Stmt) Ptr<VList> {
    st.match ({ .Let(l) => a.vcons(l.name, tvoid(), bound), _ => bound })
}
lift_lamparams = (a: MutPtr<Malloc>, bound: Ptr<VList>, ps: [Param]) Ptr<VList> {
    out := bound
    ps.loop((h, i, p) { out = a.vcons(p.name, tvoid(), out) })
    out
}
lift_args_cap = (a: MutPtr<Malloc>, decls: [Decl], idx: DeclIndex, bound: Ptr<VList>, xs: [Expr]) bool {
    found := false
    xs.loop((h, i, x) { found = found.match ({ true => true, false => a.lift_expr_cap(decls, idx, bound, x.addr()) }) })
    found
}
lift_inits_cap = (a: MutPtr<Malloc>, decls: [Decl], idx: DeclIndex, bound: Ptr<VList>, inits: [FieldInit]) bool {
    found := false
    inits.loop((h, i, fi) { found = found.match ({ true => true, false => a.lift_expr_cap(decls, idx, bound, fi.value) }) })
    found
}
lift_arms_cap = (a: MutPtr<Malloc>, decls: [Decl], idx: DeclIndex, bound: Ptr<VList>, arms: [ArmData]) bool {
    found := false
    arms.loop((h, i, ar) { found = found.match ({ true => true, false => a.lift_expr_cap(decls, idx, a.vcons(ar.bind, tvoid(), bound), ar.body) }) })
    found
}
lift_body_cap = (a: MutPtr<Malloc>, decls: [Decl], idx: DeclIndex, bound: Ptr<VList>, body: [Stmt]) bool {
    found := false
    b := bound
    body.loop((h, i, st) { found = found.match ({ true => true, false => a.lift_stmt_cap(decls, idx, b, st) })  b = a.lift_extend(b, st) })
    found
}
lift_stmt_cap = (a: MutPtr<Malloc>, decls: [Decl], idx: DeclIndex, bound: Ptr<VList>, st: Stmt) bool {
    st.match ({
        .Let(l)      => a.lift_expr_cap(decls, idx, bound, l.value),
        .Assign(x)   => a.lift_expr_cap(decls, idx, bound, x.target) || a.lift_expr_cap(decls, idx, bound, x.value),
        .Return(r)   => a.lift_expr_cap(decls, idx, bound, r),
        .ExprStmt(e) => a.lift_expr_cap(decls, idx, bound, e),
        .If(f)       => a.lift_expr_cap(decls, idx, bound, f.c) || a.lift_body_cap(decls, idx, bound, f.then) || a.lift_body_cap(decls, idx, bound, f.els),
        .While(w)    => a.lift_expr_cap(decls, idx, bound, w.c) || a.lift_body_cap(decls, idx, bound, w.body),
        .IndexSet(x) => a.lift_expr_cap(decls, idx, bound, x.seq) || a.lift_expr_cap(decls, idx, bound, x.idx) || a.lift_expr_cap(decls, idx, bound, x.value)
    })
}
lift_expr_cap = (a: MutPtr<Malloc>, decls: [Decl], idx: DeclIndex, bound: Ptr<VList>, e: Ptr<Expr>) bool {
    load(e).match ({
        .Var(v)        => lift_is_captured(decls, idx, bound, v.name),
        .Bin(b)        => a.lift_expr_cap(decls, idx, bound, b.lhs) || a.lift_expr_cap(decls, idx, bound, b.rhs),
        .Call(c)       => a.lift_args_cap(decls, idx, bound, c.args),
        .Cond(d)       => a.lift_expr_cap(decls, idx, bound, d.c) || a.lift_expr_cap(decls, idx, bound, d.t) || a.lift_expr_cap(decls, idx, bound, d.e),
        .Member(m)     => a.lift_expr_cap(decls, idx, bound, m.obj),
        .Arrow(ar)     => a.lift_expr_cap(decls, idx, bound, ar.obj),
        .MakeEnum(mk)  => a.lift_expr_cap(decls, idx, bound, mk.payload),
        .MakeStruct(s) => a.lift_inits_cap(decls, idx, bound, s.inits),
        .Match(m)      => a.lift_expr_cap(decls, idx, bound, m.subj) || a.lift_arms_cap(decls, idx, bound, m.arms),
        .Index(ix)     => a.lift_expr_cap(decls, idx, bound, ix.seq) || a.lift_expr_cap(decls, idx, bound, ix.idx),
        .SliceLit(sd)  => a.lift_args_cap(decls, idx, bound, sd.items),
        .Loop(l)       => a.lift_expr_cap(decls, idx, bound, l.seq) || a.lift_body_cap(decls, idx, a.vcons(l.idx, tvoid(), a.vcons(l.elem, tvoid(), bound)), l.body),
        .Block(bl)     => a.lift_body_cap(decls, idx, bound, bl.stmts),
        .Lambda(la)    => a.lift_body_cap(decls, idx, a.lift_lamparams(bound, la.params), la.body),
        _              => false
    })
}
// a lambda is liftable iff it does NOT capture (only its own params + body binders + top-level names).
lift_liftable = (a: MutPtr<Malloc>, decls: [Decl], idx: DeclIndex, lm: LambdaData) bool {
    a.lift_body_cap(decls, idx, a.lift_lamparams(a.vnil(), lm.params), lm.body) == false
}
// --- the lift transform: replace each liftable lambda (in a field-init / return value) with the name
//     of a freshly generated top-level fn, collected (with a shared counter) for appending. ---
lift_digit = (n: i64) u8 { ('0'.to_i64() + n).to_u8() }
lift_digits = (a: MutPtr<Malloc>, s: String, n: i64) String {
    base := (n >= 10).match ({ true => a.lift_digits(s, n / 10), false => s })
    base.gstr_push(a, lift_digit(n % 10))
}
lift_name = (a: MutPtr<Malloc>, k: i64) str {
    s := a.gstr_string(24).gstr_append(a, "__lam_")
    a.lift_digits(s, k).gstr_finish(a)
}
// the (function) type of struct `sty`'s field `fname` — substituted for a generic instance's targs.
field_fnt = (a: MutPtr<Malloc>, decls: [Decl], sty: str, targs: [Ty], fname: str) Ty {
    (targs.len > 0).match ({ true => a.gen_struct_field(decls, sty, fname, targs), false => decls.struct_field(sty, fname) })
}
// generate the top-level fn for a lifted lambda: params typed from the expected FnT, body = lambda body.
lift_func_of = (a: MutPtr<Malloc>, lm: LambdaData, ft: FnTData, name: str) Decl {
    ps := a.pbuf(lm.params.len)
    lm.params.loop((h, i, p) { ps[i] = param(p.name, (i < ft.params.len).match ({ true => ft.params[i], false => tvoid() })) })
    dfunc(Func( name: name, params: ps, ret: load(ft.ret), tparams: empty_params(), body: lm.body ))
}
// lift the value `val` if it is a liftable lambda whose expected type `fnt` is a function type; else
// recurse so nested lift sites are still found.
lift_at = (a: MutPtr<Malloc>, decls: [Decl], idx: DeclIndex, gcp: RawPtr<u8>, gen: [Decl], fnt: Ty, val: Ptr<Expr>) Ptr<Expr> {
    load(val).match ({
        .Lambda(lm) => fnt.match ({
            .FnT(ft) => a.lift_liftable(decls, idx, lm).match ({
                true  => {
                    k  := load_i64(gcp)
                    nm := a.lift_name(k)
                    gen[k.to_i32()] = a.lift_func_of(lm, ft, nm)
                    store_i64(gcp, k + 1)
                    a.cenode(vref(nm))
                },
                false => a.lift_rw_expr(decls, idx, gcp, gen, val)
            }),
            _ => a.lift_rw_expr(decls, idx, gcp, gen, val)
        }),
        _ => a.lift_rw_expr(decls, idx, gcp, gen, val)
    })
}
lift_rw_args = (a: MutPtr<Malloc>, decls: [Decl], idx: DeclIndex, gcp: RawPtr<u8>, gen: [Decl], xs: [Expr]) [Expr] {
    buf := a.cebuf(xs.len)
    xs.loop((h, i, x) { buf[i] = load(a.lift_rw_expr(decls, idx, gcp, gen, x.addr())) })
    buf
}
lift_rw_inits = (a: MutPtr<Malloc>, decls: [Decl], idx: DeclIndex, gcp: RawPtr<u8>, gen: [Decl], sty: str, targs: [Ty], inits: [FieldInit]) [FieldInit] {
    buf := a.fbuf(inits.len)
    inits.loop((h, i, fi) { buf[i] = finit(fi.name, a.lift_at(decls, idx, gcp, gen, a.field_fnt(decls, sty, targs, fi.name), fi.value)) })
    buf
}
lift_rw_arms = (a: MutPtr<Malloc>, decls: [Decl], idx: DeclIndex, gcp: RawPtr<u8>, gen: [Decl], arms: [ArmData]) [ArmData] {
    buf := a.abuf(arms.len)
    arms.loop((h, i, ar) { buf[i] = arm(ar.variant, ar.bind, a.lift_rw_expr(decls, idx, gcp, gen, ar.body)) })
    buf
}
lift_rw_expr = (a: MutPtr<Malloc>, decls: [Decl], idx: DeclIndex, gcp: RawPtr<u8>, gen: [Decl], e: Ptr<Expr>) Ptr<Expr> {
    load(e).match ({
        .MakeStruct(s) => a.cenode(mkstructg(s.ty, s.mty, s.targs, a.lift_rw_inits(decls, idx, gcp, gen, s.ty, s.targs, s.inits))),
        .Bin(b)        => a.cenode(bin_at(b.op, a.lift_rw_expr(decls, idx, gcp, gen, b.lhs), a.lift_rw_expr(decls, idx, gcp, gen, b.rhs), b.pos)),
        .Cond(d)       => a.cenode(cond(a.lift_rw_expr(decls, idx, gcp, gen, d.c), a.lift_rw_expr(decls, idx, gcp, gen, d.t), a.lift_rw_expr(decls, idx, gcp, gen, d.e))),
        .Member(m)     => a.cenode(member(a.lift_rw_expr(decls, idx, gcp, gen, m.obj), m.field)),
        .Arrow(ar)     => a.cenode(arrow(a.lift_rw_expr(decls, idx, gcp, gen, ar.obj), ar.field)),
        .Call(c)       => a.recall(c, c.fn, a.lift_rw_args(decls, idx, gcp, gen, c.args)),
        .MakeEnum(mk)  => a.cenode(mkenumg(mk.ty, mk.mty, mk.targs, mk.variant, a.lift_rw_expr(decls, idx, gcp, gen, mk.payload))),
        .Match(m)      => m.ptr.match ({ true  => a.cenode(ematchp(a.lift_rw_expr(decls, idx, gcp, gen, m.subj), m.ename, a.lift_rw_arms(decls, idx, gcp, gen, m.arms))),
                                         false => a.cenode(ematch(a.lift_rw_expr(decls, idx, gcp, gen, m.subj), m.ename, a.lift_rw_arms(decls, idx, gcp, gen, m.arms))) }),
        .Index(ix)     => a.cenode(eindex(a.lift_rw_expr(decls, idx, gcp, gen, ix.seq), a.lift_rw_expr(decls, idx, gcp, gen, ix.idx), ix.elem)),
        .SliceLit(sd)  => a.cenode(slit(sd.elem, a.lift_rw_args(decls, idx, gcp, gen, sd.items))),
        .Loop(l)       => a.cenode(eloop(a.lift_rw_expr(decls, idx, gcp, gen, l.seq), l.idx, l.elem, l.elemTy, a.lift_rw_body(decls, idx, gcp, gen, tvoid(), l.body), l.h)),
        .Block(bl)     => a.cenode(block(a.lift_rw_body(decls, idx, gcp, gen, tvoid(), bl.stmts))),
        .Lambda(lm)    => a.cenode(lam(lm.params, a.lift_rw_body(decls, idx, gcp, gen, tvoid(), lm.body))),
        _              => e
    })
}
// Lambdas lift in value positions the inliner can't splice: STRUCT-FIELD inits (lift_rw_inits) and
// RETURN / tail-expression positions (a body's implicit return) when the declared return type is a
// function type — `fnret` carries that type; `tail` marks the body's last (implicit-return) statement.
lift_rw_stmt = (a: MutPtr<Malloc>, decls: [Decl], idx: DeclIndex, gcp: RawPtr<u8>, gen: [Decl], fnret: Ty, tail: bool, st: Stmt) Stmt {
    st.match ({
        .Let(l)      => slett(l.name, l.ty, a.lift_rw_expr(decls, idx, gcp, gen, l.value)),
        .Assign(x)   => sassign_at(a.lift_rw_expr(decls, idx, gcp, gen, x.target), a.lift_rw_expr(decls, idx, gcp, gen, x.value), x.pos),
        .Return(r)   => sret(a.lift_at(decls, idx, gcp, gen, fnret, r)),
        .ExprStmt(e) => sexpr(tail.match ({ true => a.lift_at(decls, idx, gcp, gen, fnret, e), false => a.lift_rw_expr(decls, idx, gcp, gen, e) })),
        .If(f)       => sif(a.lift_rw_expr(decls, idx, gcp, gen, f.c), a.lift_rw_body(decls, idx, gcp, gen, fnret, f.then), a.lift_rw_body(decls, idx, gcp, gen, fnret, f.els)),
        .While(w)    => swhile(a.lift_rw_expr(decls, idx, gcp, gen, w.c), a.lift_rw_body(decls, idx, gcp, gen, tvoid(), w.body)),
        .IndexSet(x) => sidxset_at(a.lift_rw_expr(decls, idx, gcp, gen, x.seq), a.lift_rw_expr(decls, idx, gcp, gen, x.idx), x.elem, a.lift_rw_expr(decls, idx, gcp, gen, x.value), x.pos)
    })
}
lift_rw_body = (a: MutPtr<Malloc>, decls: [Decl], idx: DeclIndex, gcp: RawPtr<u8>, gen: [Decl], fnret: Ty, body: [Stmt]) [Stmt] {
    buf := a.sbuf(body.len)
    body.loop((h, i, st) { buf[i] = a.lift_rw_stmt(decls, idx, gcp, gen, fnret, i == body.len - 1, st) })
    buf
}
lift_rw_decl = (a: MutPtr<Malloc>, decls: [Decl], idx: DeclIndex, gcp: RawPtr<u8>, gen: [Decl], d: Decl) Decl {
    d.match ({
        .DFunc(f) => dfunc(Func( name: f.name, params: f.params, ret: f.ret, tparams: f.tparams, body: a.lift_rw_body(decls, idx, gcp, gen, f.ret, f.body) )),
        _         => d
    })
}
lift_lambdas* = (a: MutPtr<Malloc>, decls: [Decl], idx: DeclIndex) [Decl] {
    gcp: RawPtr<u8> := a.acquire(8)
    store_i64(gcp, 0)
    gen := a.dbuf(4096)
    out := a.dbuf(decls.len + 4096)
    decls.loop((h, i, d) { out[i] = a.lift_rw_decl(decls, idx, gcp, gen, d) })
    n := load_i64(gcp)
    k := decls.len
    gen.loop((h, i, g) { (i < n.to_i32()).match ({ true => { out[k] = g  k = k + 1 }, false => {} }) })
    slice(out.ptr, k)
}

resolve_module* = (a: MutPtr<Malloc>, raw: [Decl]) [Decl] {
    decls0 := a.expand_defaults(a.desugar_method_calls(raw))
    decls := a.fill_enum_defaults(decls0, a.build_decl_index(decls0))
    // Decl order/count are stable across resolve+inline passes (each rebuilds bodies in place), so a
    // name→index map is rebuilt once per pass over the current slice.
    didx := a.build_decl_index(decls)
    buf := a.dbuf(decls.len)
    decls.loop((h, i, d) { buf[i] = a.resolve_decl(decls, didx, d) })
    bidx := a.build_decl_index(buf)
    inl := a.dbuf(buf.len)
    buf.loop((h, i, d) { inl[i] = a.inline_decl(buf, bidx, d) })
    iidx := a.build_decl_index(inl)
    out := a.dbuf(inl.len)
    inl.loop((h, i, d) { out[i] = a.resolve_decl(inl, iidx, d) })
    oidx := a.build_decl_index(out)
    inl2 := a.dbuf(out.len)
    out.loop((h, i, d) { inl2[i] = a.inline_decl(out, oidx, d) })
    i2idx := a.build_decl_index(inl2)
    // emit one concrete fn per recursive-generic instance BEFORE the final resolve, so each instance
    // body gets resolved (dispatch on its concrete types) and resolve_call rewrites recursive calls to it.
    exp2 := a.mono_rec(inl2, i2idx)
    // lift non-capturing lambda LITERALS in value positions (struct-field inits / returns) to top-level
    // fns BEFORE the final resolve, so the generated fns + the fn-value references they leave behind get
    // resolved. Capturing lambdas are left for check_validate's error[lambda-value].
    lifted := a.lift_lambdas(exp2, a.build_decl_index(exp2))
    eidx := a.build_decl_index(lifted)
    out2 := a.dbuf(lifted.len)
    lifted.loop((h, i, d) { out2[i] = a.resolve_decl(lifted, eidx, d) })
    out2
}

// Type lattice: integer widening u8 <= i32 <= i64; all else exact structural equality.
// f64 is intentionally outside the integer rank chain.
ty_rank* = (t: Ty) i32 { t.match ({ .U8 => 0, .I32 => 1, .I64 => 2, _ => 0 - 1 }) }
is_f64_ty* = (t: Ty) bool { t.match ({ .F64 => true, _ => false }) }
ty_eq* = (g: Ty, w: Ty) bool {
    g.match ({
        .I32      => w.match ({ .I32 => true, _ => false }),
        .I64      => w.match ({ .I64 => true, _ => false }),
        .U8       => w.match ({ .U8 => true, _ => false }),
        .F64      => w.match ({ .F64 => true, _ => false }),
        .Bool     => w.match ({ .Bool => true, _ => false }),
        .Void     => w.match ({ .Void => true, _ => false }),
        .Str      => w.match ({ .Str => true, _ => false }),
        .Cstr     => w.match ({ .Cstr => true, .Str => true, _ => false }),
        .Text     => w.match ({ .Text => true, .Str => true, .Cstr => true, _ => false }),
        .Named(a) => w.match ({ .Named(b) => eq(a, b), .Generic(gb) => eq(a, gb.mangled), _ => false }),
        .Ptr(pa)  => w.match ({ .Ptr(pb) => load(pa).ty_eq(load(pb)), _ => false }),
        .Slice(pa) => w.match ({ .Slice(pb) => load(pa).ty_eq(load(pb)), _ => false }),
        .FnT(fa)  => false,
        .Generic(ga) => w.match ({ .Generic(gb) => eq(ga.mangled, gb.mangled), .Named(b) => eq(ga.mangled, b), _ => false })
    })
}
// `RawPtr<u8>` is the raw-pointer floor: it fits any typed pointer slot (this is what `null_ptr()`
// returns, so a null can initialize/assign any `Ptr<T>` field/param without a cast).
is_raw_ptr_ty* = (t: Ty) bool { t.match ({ .Ptr(p) => load(p).match ({ .U8 => true, _ => false }), _ => false }) }
is_ptr_ty_g* = (t: Ty) bool { t.match ({ .Ptr(p) => true, _ => false }) }
fits* = (g: Ty, w: Ty) bool {
    numeric := (g.ty_rank() >= 0) && (w.ty_rank() >= 0)
    numeric.match ({
        true  => g.ty_rank() <= w.ty_rank(),
        false => (g.is_raw_ptr_ty() && w.is_ptr_ty_g()).match ({ true => true, false => g.ty_eq(w) })
    })
}

// Shared by resolve_module and check_validate.
empty_params* = () [Param] { slice(null_ptr(), 0) }
fn_params* = (decls: [Decl], fn: str) [Param] { decls.the_func(fn).params }
is_void_ty* = (t: Ty) bool { t.match ({ .Void => true, _ => false }) }
