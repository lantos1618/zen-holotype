// ACCEPTANCE PROOF (PARALLELISM goal item E — "Arc safe under real contention").
//
// The pool's actor state is Arc-backed: a handle is an atomic-refcounted pointer. This test hammers
// that refcount from many threads while the actor runs on OTHER workers, proving a cross-thread handle
// is safe — no use-after-free, no double-free, no leak; the actor frees exactly when the LAST handle
// drops.
//
// SCENARIO 1 (refcount-arithmetic invariant): NPROD producer OS-threads each, per message, CLONE a
// shared actor handle (atomic +1), send through it, then DROP that clone (atomic -1) — maximum
// concurrent ref/unref churn — while WORKERS worker threads concurrently schedule/run/deschedule the
// same actors (each schedule = a clone, each deschedule = a drop). The owner thread holds the spawn
// reference throughout, so the actor must stay alive. After producers join + the pool quiesces, every
// actor's refcount must be EXACTLY 1 (only the owner's reference remains): no lost decrement (would
// leak / read >1) and no premature free (the delivered-count assert below would also fail). Then the
// owner drops its reference → count 0 → freed exactly once. Repeated ITERS times (races are
// probabilistic).
//
// SCENARIO 2 (scheduler frees the last handle): spawn an actor, send a burst, then DROP THE OWNER
// REFERENCE while the actor may still be queued/running. Now the only thing keeping it alive is the
// scheduler's "scheduled" reference — so the actor is freed on a WORKER thread when it finally
// deschedules (the last drop happens under contention, not on the main thread). Run under ASan this
// proves the cross-thread free path has no UAF/double-free/leak.
{ pool_open, pool_spawn, pool_send, pool_actor_ref, pool_actor_unref, pool_actor_free, pool_actor_count, pool_quiesce_stop, pool_close, pool_view, pool_raw, Pool } = std.concurrent.pool
{ spawn, join, JoinHandle } = std.thread
{ println } = std.text.fmt

NPROD   := 8       // producer threads
MSGS    := 1500    // messages per producer (each does a ref+send+unref → heavy atomic churn)
NACT    := 6       // shared actors hammered concurrently
WORKERS := 4
ITERS   := 50

processed := malloc(8)
behave = (user: RawPtr<u8>, msg: i64) void { atomic_add_i64(user, 1) }

// producer arg layout: [0]=pool_raw [8]=actors_ptr [16]=pid [24]=ok_out
PA_POOL := 0
PA_ACTS := 8
PA_PID  := 16
PA_OK   := 24

// per message: clone the handle (+1), send, drop the clone (-1) — the owner ref keeps the actor alive
// so this unref never frees, but it races every other producer's ref/unref AND the workers' scheduled
// clone/drop on the SAME refcount word.
send_loop = (p: MutPtr<Pool>, acts: RawPtr<u8>, pid: i64, k: i64, ok: i64) i64 {
    (k >= MSGS).match ({
        true  => ok,
        false => {
            target := (pid + k) % NACT
            a := acts.offset(target * 8).load_i64().offset(0)
            h := pool_actor_ref(a)              // clone (atomic +1) — independent cross-thread handle
            sent := p.pool_send(h, 1)
            pool_actor_unref(h)                 // drop the clone (atomic -1) — must NOT free (owner alive)
            send_loop(p, acts, pid, k + 1, sent.match ({ true => ok + 1, false => ok }))
        }
    })
}
producer = (arg: RawPtr<u8>) RawPtr<u8> {
    pool_raw := load_i64(arg.offset(PA_POOL)).offset(0)
    acts := load_i64(arg.offset(PA_ACTS)).offset(0)
    pid := load_i64(arg.offset(PA_PID))
    p := pool_view(pool_raw)
    ok := send_loop(p, acts, pid, 0, 0)
    arg.offset(PA_OK).store_i64(ok)
    null_ptr()
}

spawn_actors = (acts: RawPtr<u8>, i: i64) void {
    (i < NACT).match ({ true => { acts.offset(i * 8).store_i64(pool_spawn(processed, NPROD * MSGS + 16, behave))  spawn_actors(acts, i + 1) }, false => {} })
}
// after quiesce, EVERY actor's refcount must be exactly 1 (only the owner's reference survived the
// concurrent clone/drop storm); returns 1 if so, 0 on any leaked/lost reference.
check_counts = (acts: RawPtr<u8>, i: i64, ok: i64) i64 {
    (i < NACT).match ({
        true  => check_counts(acts, i + 1, (pool_actor_count(acts.offset(i * 8).load_i64().offset(0)) == 1).match ({ true => ok, false => 0 })),
        false => ok
    })
}
free_actors = (acts: RawPtr<u8>, i: i64) void {
    (i < NACT).match ({ true => { pool_actor_free(acts.offset(i * 8).load_i64().offset(0))  free_actors(acts, i + 1) }, false => {} })
}
start_prods = (pool_raw: RawPtr<u8>, acts: RawPtr<u8>, hs: RawPtr<u8>, ar: RawPtr<u8>, i: i64) void {
    (i < NPROD).match ({
        true => {
            c := ar.offset(i * 32)
            c.offset(PA_POOL).store_i64(pool_raw)
            c.offset(PA_ACTS).store_i64(acts)
            c.offset(PA_PID).store_i64(i)
            c.offset(PA_OK).store_i64(0)
            h := spawn(producer, c)
            hs.offset(i * 8).store_i64(h.tid)
            start_prods(pool_raw, acts, hs, ar, i + 1)
        },
        false => {}
    })
}
join_prods = (hs: RawPtr<u8>, ar: RawPtr<u8>, i: i64, acc: i64) i64 {
    (i < NPROD).match ({
        true  => { join(JoinHandle(tid: hs.offset(i * 8).load_i64().offset(0)))  join_prods(hs, ar, i + 1, acc + ar.offset(i * 32).offset(PA_OK).load_i64()) },
        false => acc
    })
}

// one scenario-1 iteration: returns 1 on pass, 0 on fail.
iteration = () i64 {
    store_i64(processed, 0)
    acts := malloc(NACT * 8)
    spawn_actors(acts, 0)
    p := pool_open(WORKERS, NACT + 8)
    pool_raw := p.pool_raw()
    hs := malloc(NPROD * 8)
    ar := malloc(NPROD * 32)
    start_prods(pool_raw, acts, hs, ar, 0)
    sent := join_prods(hs, ar, 0, 0)     // total ACCEPTED sends across producers
    p.pool_quiesce_stop()
    got := load_i64(processed)
    counts_ok := check_counts(acts, 0, 1)        // every actor back to refcount 1 (owner only)
    free_actors(acts, 0)                         // owner drops its ref → count 0 → freed exactly once
    p.pool_close()
    free(acts)  free(hs)  free(ar)
    // exactly-once delivery (got == sent) AND every refcount returned to the owner (counts_ok).
    (got == sent).match ({ true => (counts_ok == 1).match ({ true => 1, false => 0 }), false => 0 })
}
run_iters = (i: i64, passes: i64) i64 {
    (i >= ITERS).match ({ true => passes, false => run_iters(i + 1, passes + iteration()) })
}

// SCENARIO 2: the owner drops its reference while the actor is still in flight; the actor is freed by
// the worker that runs its last deschedule. No count is read afterwards (the block is gone) — ASan
// proves the worker-side free is exactly-once with no UAF.
burst = (p: MutPtr<Pool>, a: RawPtr<u8>, k: i64) void { (k < 4000).match ({ true => { p.pool_send(a, 1)  burst(p, a, k + 1) }, false => {} }) }
scheduler_frees_last = () void {
    store_i64(processed, 0)
    p := pool_open(WORKERS, 16)
    a := pool_spawn(processed, 4096, behave)
    burst(p, a, 0)
    pool_actor_free(a)                           // owner drops NOW; the scheduled ref keeps it alive,
    p.pool_quiesce_stop()                        // and a WORKER frees it on the final deschedule.
    p.pool_close()
}

main = () i32 {
    scheduler_frees_last()
    passes := run_iters(0, 0)
    println(passes)
    free(processed)
    (passes == ITERS).match ({ true => 42, false => 1 })
}
