// Generic enums: the payload type-param is solved from the expected enum type,
// and the instance is monomorphized to concrete C (Opt<i32> -> Opt_i32).
Opt*<T>: None, Some(T)
Result*<T, E>: Ok(T), Err(E)

wrap*   = (n: i32) Opt<i32> { .Some(n) }             //~ wrap PASS
empty*  = () Opt<i32> { .None() }                    //~ empty PASS
unwrap* = (o: Opt<i32>) i32 { o.match { .None => 0, .Some(v) => v } }  //~ unwrap PASS

two_param* = (a: i32) Result<i32, bool> { .Ok(a) }   //~ two_param PASS

// the payload must fit the instantiated type-param (T = i32 here, not bool)
bad_payload* = () Opt<i32> { .Some(true) }           //~ bad_payload FAIL bool
