{ eq } = std.text.str
{ to_exit } = std.core.bool
Box<T>: {
    value: T,
    get = (box: Box<T>) T { box.value }
}
Msg*: Empty | Hold(Box<str>)
main = () i32 {
    msg := Msg.Hold(Box<str>(value: "generic"))
    got := msg.match({
        .Empty => "empty",
        .Hold(box) => box.get()
    })
    eq(got, "generic").to_exit()
}
