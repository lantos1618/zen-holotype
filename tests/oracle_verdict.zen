    ), VerdictCase(
        src: "Box*: { v: i32 }\nbump* = (b: MutPtr<Box>) void { b.v = b.v + 1 }\ntest* = () i32 { 0 }",
        should_pass: true,
        kind: "",
    ), VerdictCase(
        src: "Inner*: { n: i32 }\nOuter*: { p: Ptr<Inner>, tag: i32 }\nmk* = (ip: Ptr<Inner>) Outer { Outer(p: ip, tag: 7) }\ntest* = () i32 { 0 }",
        should_pass: true,
        kind: "",
    ), VerdictCase(
        src: "Box*: { v: i32 }\ngetv* = (p: MutPtr<Box>) i32 { p.v }\ntest* = () i32 { r: RawPtr<Box> := null_ptr()  q := assert_nonnull(r)  getv(q) }",
        should_pass: true,
        kind: "",
    ), VerdictCase(
        src: "use* = (p: RawPtr<u8>) i32 { 0 }\ntest* = () i32 { b: RawPtr<u8> := malloc(8)  use(b) }",
