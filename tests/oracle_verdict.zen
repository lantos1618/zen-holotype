        should_pass: false,
        kind: "",
    ), VerdictCase(
        src: "test* = () i32 {  }",
        should_pass: false,
        kind: "",
    ), VerdictCase(
        src: "test* = () i32 {\n  x := 5\n}",
        should_pass: false,
        kind: "",
    ), VerdictCase(
        src: "test* = () i32 {\n  x := 5\n  x = 6\n}",
        should_pass: false,
