{ print, println } = std.text.fmt
{ default } = std.mem.alloc
{ new_in } = std.text.string

main = () i32 {
    println("borrowed")
    println("alias")

    alloc := default()
    a := alloc.addr()
    s := a.new_in().append_in(a, "owned")
    print(s)
    println("!")
    println(s)
    s.free_in(a)

    0
}
