raw = std.mem.raw
{ Result, IoError } = std.core.result
{ to_exit } = std.core.bool
ptr_ok = () bool {
    p0: Result<RawPtr<u8>, IoError> := raw.try_alloc(8)
    p0.match({
        .Ok(p) => {
            raw.release(p)
            p1: Result<RawPtr<u8>, IoError> := raw.try_zeroed(1)
            p1.match({ .Ok(q) => { raw.release(q)  true }, .Err(e) => false })
        },
        .Err(e) => false
    })
}
slice_ok = () bool {
    r: Result<[i32], IoError> := raw.try_of(7, 3)
    r.match({
        .Ok(xs) => {
            xs[1] = 35
            ok := (xs[0] + xs[1]) == 42
            raw.release(xs.ptr)
            ok
        },
        .Err(e) => false
    })
}
slice_err = () bool {
    r: Result<[i32], IoError> := raw.try_of(7, 0)
    r.match({
        .Err(e) => e.match({ .NotFound => true, _ => false }),
        .Ok(xs) => false
    })
}
main = () i32 { (ptr_ok() && slice_ok() && slice_err()).to_exit() }
