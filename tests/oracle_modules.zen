            src: "{ strip_ns_into, add_name } = std.internal.resolve\n{ Malloc } = std.mem.alloc\n{ String, init } = std.text.string\n{ contains, len, view } = std.text.str\n{ new_in, append_in, finish_in } = std.text.string\n{ to_exit } = std.core.bool\nsname = (s: str) String { a := Malloc(_: 0)  a.addr().init(32).append_in(a.addr(), s) }\ngenrep = (mp: MutPtr<Malloc>, chunk: str, n: i32) str { s := mp.new_in()  i := 0  @while (i < n) { s = s.append_in(mp, chunk)  i = i + 1 }  mp.finish_in(s) }\nmain = () i32 {\n    a := Malloc(_: 0)\n    ap := a.addr()\n    body := ap.genrep(\"right.thing()\\n\", 3500)\n    src := ap.new_in().append_in(ap, \"main = () i32 {\\n\").append_in(ap, body).append_in(ap, \"}\\n\").finish_in(ap)\n    quals := ap.init(32).add_name(ap, sname(\"right\"))\n    qnames := ap.init(64).add_name(ap, sname(\"right.thing\"))\n    empty := ap.init(1)\n    out := ap.init(65536).strip_ns_into(ap, src, 0, quals, qnames, qnames, empty, true).finish_in(ap)\n    ok := out.contains(\"right__thing()\") && (!out.contains(\"right.thing()\"))\n    ok.to_exit()\n}\n",
        )],
        entry: "p.zen",
        want: 0,
    ), ModValCase(
        files: [ModFile(
            name: "p.zen",
            src: mp.joinv([z, "{ Malloc } = std.mem.alloc\n{ dedup_decls } = std.internal.resolve\n{ contains } = std.text.str\n{ to_exit } = std.core.bool\nmain = () i32 {\n    a := Malloc(_: 0)\n    src := \"", esc_nl(mp, dedup260), "\"\n    out := a.addr().dedup_decls(src, 0, 0)\n    ok := out.contains(\"v259\") && (!out.contains(\"777\"))\n    ok.to_exit()\n}\n"]),
        )],
        entry: "p.zen",
        want: 0,
    )])
    // ── sibling import loading (test_user_imports) ──────────────────────────────────────────
    // ── namespace binds `x = mod` + qualified `x.fn()` (test_user_imports) ───────────────────
    // ── import-head spacing variants all resolve the sibling (test_modules_oracle) ───────────
    // ── std-export name collisions resolved by namespace binding (test_user_imports) ─────────
    // std.core.slice.dup / std.text.str.dup_bytes — two same-named exports, namespace-qualified.
    // ── audit C2: a TYPE reached via a module ALIAS keeps ONE canonical C identity ────────────
    // A qualified-alias type ref (`str.ParseError`) must mangle to the SAME C struct as the bare
    // name `num` consumes (`{ ParseError } = std.text.str`), so a `Result<_, str.ParseError>` that
    // mixes both import paths in one conditional unifies instead of "type mismatch in conditional".
    // the acceptance combo: map alias alongside a type-bearing str alias compiles + runs.
    // std.text.bytes.at vs a sibling `at`.
    // std.text.str.at and std.text.bytes.at both `at`, plus a sibling `at`.
    // std.mem ownership modules export the same constructor names — namespace binds keep distinct.
    // std.text.num.integer / float vs sibling integer/float.
    // std.text.num allocator + Result formatting.
    // std.concurrent.runtime sync/async vs sibling sync/async.
    // std.concurrent.actor cell.request survives an export-name collision with a sibling `cell`.
    // std.text.string + std.concurrent.actor coexist without a bare `new_in` arity collision (BUG #4).
    // std.core.slice dup/node_in coexist with std.text.str (loaded via fmt) without a dup_in collision (COLLIDE-1).
    // std.concurrent.cown buf/file vs sibling buf/file.
    // ── name-clash namespacing + transitive re-export as REAL projects (test_resolver_oracle) ─
    // ── test_resolver_fixes.py — driver-level run cases ──────────────────────────────────────
    // bug 2: namespace bind `c = std.io.c` + qualified call compiles AND runs.
    // the renamed std.internal.ast builders (dupx/eqx) actually run.
    // std.internal.ast's decl buffer uses an explicit allocator (Counting allocator observes the acquire/release).
    // ── std.internal.resolve PUBLIC API, driven as Zen programs via `zenc run` (test_user_imports) ──
    // import_edges: structured edges with module/alias/namespace/start/next.
    // try_import_edges: an allocator that fails after K acquires returns .Err; with enough budget, .Ok.
    // provided_symbols: imported / foreign / type / fn symbols with precise spans.
    // try_symbol_key_in: keyword-safe symbol key with a Result allocator path.
    // module_graph: import edges + symbol set with keyword-safe keys.
    // strip_ns_into preserves multi-line block comments while rewriting qualified calls.
    // ── stress: huge generated projects/sources resolve without recursive stack growth ───────
    // 240-decl user module imported through a 2-name head (symbol-consumer stress). want = v0()+v239() = 0+9.
    // 120-name import head validation (import-head stress). want = v0()+v119() = 0+9.
    // 700-edge import_edges walk (edge-walk stack stress); first/last edges verified.
    // 220-symbol provided_symbols + module_graph + decl_names stress (self-generating program).
    // 3500-call namespace rewriter (strip_ns_into) stack-growth stress (self-generating program).
    // 260-decl final-dedup (with a duplicate v0) handled without a recursive walk.
    d := run_mod_verdicts("modules verdict (cross-module check / loader errors)", [ModVerdictCase(
