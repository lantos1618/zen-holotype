        src: "halloc = std.mem.heap\n{ Resource, new_in } = std.mem.own\nmain = () i32 {\n    alloc := halloc.gpa()\n    o := alloc.addr().new_in(Resource(id: 7, slot: 0))\n    o.release_in(alloc.addr())\n    o.get().id\n}\n",
