// Declared in build.zen as `Test { root: "test.zen" }`.
// A test is a no-arg fn returning bool — `zen build` runs each and
// reports PASS/FAIL from the result. It imports the project like any module.
{ Vec } = core.vec
{ len, cap } = ops

test_len* = () bool { len(addr(Vec { len: 3, cap: 4 })) == 3 }
test_cap* = () bool { cap(addr(Vec { len: 3, cap: 4 })) == 4 }
