// Literal inference (i32 widening to i64, bool) and let-bound locals.

narrow* = () i32  { 5 }                 //~ PASS
widen*  = () i64  { 5 }                 //~ PASS  (i32 literal widens to i64)
flag*   = () bool { true }              //~ PASS
bool_is_not_int* = () i32 { true }      //~ FAIL

via_let* = () i32 {
    a := 6
    b := 7
    a * b
}                                          //~ via_let PASS

let_widens* = () i64 {
    x := 41
    x
}                                          //~ let_widens PASS

eq_is_bool*   = () bool { (3 * 4) == 12 }   //~ PASS
eq_not_int*   = () i32  { 1 == 1 }          //~ FAIL
eq_mismatch*  = () bool { 1 == true }       //~ FAIL operands differ
