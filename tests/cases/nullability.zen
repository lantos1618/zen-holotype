// Option<T> is the only way to be null; the null guard is just fits().
pub Vec: { len: i32, cap: i32 }

pub need_nonnull = (v: Ptr<Vec>) i32 { v.len }
pub need_option  = (v: Option<Ptr<Vec>>) i32 { 0 }

// nonnull is accepted where null is allowed  (T ≤ Option<T>)
pub nonnull_into_option = (v: Ptr<Vec>) i32 { need_option(v) }       //~ PASS

// nullable flowing into a non-null slot is rejected
pub null_into_nonnull = (v: Option<Ptr<Vec>>) i32 { need_nonnull(v) } //~ FAIL Option<Ptr<Vec>>
