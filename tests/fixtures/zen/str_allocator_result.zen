{ system_allocator } = std.mem.alloc
{ dup, dup_in, try_dup_in, substr_in, try_substr_in } = std.text.str
{ println } = std.text.fmt

main = () i32 {
    a := system_allocator()

    plain := dup("xy")
    println(plain.len)

    owned := a.addr().dup_in("abc")
    println(owned.len)
    println(owned[0])
    println(a.addr().substr_in("hello", 1, 3))

    a.addr().try_dup_in("").match ({
        .Ok(bytes) => println(bytes.len),
        .Err(e) => println(99)
    })
    a.addr().try_substr_in("world", 1, 2).match ({
        .Ok(s) => println(s),
        .Err(e) => println("err")
    })

    0
}
