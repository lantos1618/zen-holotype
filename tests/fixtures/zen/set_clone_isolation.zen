halloc = std.mem.heap
sets = std.collections.set
{ println } = std.text.fmt
main = () i32 {
    alloc := halloc.system()
    a := alloc.addr()
    x := sets.of(a, 1)
    x = x.add(a, 2)
    c := x.clone(a)
    c = c.add(a, 3)
    c = c.add(a, 4)
    println(c.len())
    println(x.len())
    println(x.has(3).match ({ true => 1, false => 0 }))
    println(c.has(1).match ({ true => 1, false => 0 }))
    x.free(a)
    c.free(a)
    0
}
