// Pattern matching consumes the enums that F3 builds: a .Variant(v) arm binds
// the payload (narrowing it inside that arm), and the match must be exhaustive.
Status*: Idle, Busy(i32)

code* = (s: Status) i32 {
    s.match {
        .Idle => 0,
        .Busy(n) => n,                 // n : i32 — the payload, narrowed here
    }
}                                      //~ code PASS

with_wildcard* = (s: Status) i32 {
    s.match { .Busy(n) => n, _ => 0 }
}                                      //~ with_wildcard PASS

// missing .Busy and no wildcard -> non-exhaustive
non_exhaustive* = (s: Status) i32 {
    s.match { .Idle => 0 }
}                                      //~ non_exhaustive FAIL non-exhaustive

// a variant the enum doesn't have
bad_variant* = (s: Status) i32 {
    s.match { .Idle => 0, .Nope => 1 }
}                                      //~ bad_variant FAIL no variant '.Nope'

// arms must agree on a result type (bool ⊀ i32)
arms_differ* = (s: Status) i32 {
    s.match { .Idle => 0, .Busy(n) => true }
}                                      //~ arms_differ FAIL

// an enum payload is reachable ONLY through match — never by field access
no_punning* = (s: Status) i32 { s.Busy }   //~ no_punning FAIL use match
