// `loop` is the one iteration construct; it desugars onto the `@while` primitive,
// which lowers to a structured C `for`. `while`/`for` keywords do not exist.

countup* = () i32 {
    s := 0
    loop(5, (h, i) { s = s + i })
    s
}                                                              //~ countup PASS

// iterless, handle-driven: the handle does h.break() / h.continue()
iterless* = () i32 {
    r := 0
    loop((h) { r = r + 1  (r < 5).match { true => h.continue(), false => h.break() } })
    r
}                                                              //~ iterless PASS

// the @while primitive directly
prim* = () i32 {
    n := 0
    @while(n < 5) { n = n + 1 }
    n
}                                                              //~ prim PASS

// @while needs a bool condition
notbool* = () i32 { @while(5) { }  0 }                         //~ notbool FAIL bool
