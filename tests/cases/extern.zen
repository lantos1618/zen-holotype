// extern binds a C symbol — type-checked as callable, no body.
extern putchar = (c: i32) i32
extern malloc  = (n: i64) RawPtr<u8>
extern free    = (p: RawPtr<u8>) void

pub nl       = () i32  { putchar(10) }            //~ nl PASS
pub use_heap = () void { free(malloc(64)) }       //~ use_heap PASS

// the signature is enforced: putchar wants i32, malloc gives RawPtr<u8>
pub bad_arg  = () i32  { putchar(malloc(8)) }     //~ bad_arg FAIL
