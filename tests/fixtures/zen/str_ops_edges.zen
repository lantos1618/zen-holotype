halloc = std.mem.heap
{ Arena, make_in } = std.mem.arena
{ find, contains, substr, parse_int, starts_with, at, eq, len } = std.text.str
{ println } = std.text.fmt

bi = (b: bool) i64 {
    b.match ({ true => 1, false => 0 })
}

main = () i32 {
    heap := halloc.system()
    scratch: Arena := heap.addr().make_in(256)
    a := scratch.addr()

    println(find("hello world", "world"))
    println(find("hello world", "x"))
    println(find("hello world", ""))
    println(find("aaab", "aab"))
    println(bi(contains("hello", "ell")) + bi(starts_with("hello", "he")))
    println(bi(starts_with("he", "hello")))
    println(bi(eq(a.substr("hello world", 6, 5), "world")))
    println(bi(eq(a.substr("hi", 1, 99), "i")))
    println(len(a.substr("hi", 5, 2)))
    println(bi(eq(a.substr("hi", -3, 1), "h")))
    println(at("abc", 2) - 'c')
    println(at("abc", 3) + at("abc", -1))
    println(parse_int("-7"))
    println(parse_int("12ab"))
    println(parse_int("zen") + parse_int("") + parse_int("-"))
    println(parse_int("123456789012"))
    scratch.addr().free_in(heap.addr())
    0
}
