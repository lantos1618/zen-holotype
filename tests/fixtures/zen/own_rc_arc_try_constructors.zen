{ Allocator, malloc, free } = std.mem.alloc
{ IoError } = std.core.result
{ to_exit } = std.core.bool
own = std.mem.own
rc = std.mem.rc
arc = std.mem.arc
Counting: { left: i32, acquired: i32, released: i32 }
Counting.impl(Allocator, {
    acquire = (a: MutPtr<Counting>, n: i64) RawPtr<u8> {
        a.acquired = a.acquired + 1
        (a.left > 0).match({
            true => {
                a.left = a.left - 1
                malloc(n)
            },
            false => null_ptr()
        })
    }
    resize = (a: MutPtr<Counting>, p: RawPtr<u8>, n: i64) RawPtr<u8> { null_ptr() }
    release = (a: MutPtr<Counting>, p: RawPtr<u8>) void {
        a.released = a.released + 1
        free(p)
    }
})
not_found = (e: IoError) bool { e.match({ .NotFound => true, _ => false }) }
own_success = () bool {
    c := Counting(left: 1, acquired: 0, released: 0)
    r := own.try_new_in(c.addr(), own.Resource(id: 7, slot: 0))
    r.match({
        .Ok(o) => {
            ok := (o.get().id == 7) && (o.count() == 1) && (c.acquired == 1)
            o.release_in(c.addr())
            ok && (c.released == 1)
        },
        .Err(e) => false
    })
}
rc_success = () bool {
    c := Counting(left: 1, acquired: 0, released: 0)
    r := rc.try_new_in(c.addr(), 41)
    r.match({
        .Ok(rc) => {
            ok := (rc.get() == 41) && (rc.count() == 1) && (c.acquired == 1)
            rc.drop_in(c.addr())
            ok && (c.released == 1)
        },
        .Err(e) => false
    })
}
arc_success = () bool {
    c := Counting(left: 1, acquired: 0, released: 0)
    r := arc.try_new_in(c.addr(), 41)
    r.match({
        .Ok(arc) => {
            ok := (arc.get() == 41) && (arc.count() == 1) && (c.acquired == 1)
            arc.drop_in(c.addr())
            ok && (c.released == 1)
        },
        .Err(e) => false
    })
}
own_failure = () bool {
    c := Counting(left: 0, acquired: 0, released: 0)
    r := own.try_new_in(c.addr(), own.Resource(id: 9, slot: 0))
    r.match({
        .Err(e) => e.not_found() && (c.acquired == 1) && (c.released == 0),
        .Ok(o) => false
    })
}
rc_failure = () bool {
    c := Counting(left: 0, acquired: 0, released: 0)
    r := rc.try_new_in(c.addr(), 9)
    r.match({
        .Err(e) => e.not_found() && (c.acquired == 1) && (c.released == 0),
        .Ok(rc) => false
    })
}
arc_failure = () bool {
    c := Counting(left: 0, acquired: 0, released: 0)
    r := arc.try_new_in(c.addr(), 9)
    r.match({
        .Err(e) => e.not_found() && (c.acquired == 1) && (c.released == 0),
        .Ok(arc) => false
    })
}
main = () i32 {
    (own_success() && rc_success() && arc_success() && own_failure() && rc_failure() && arc_failure()).to_exit()
}
