// Generic functions: type-args are inferred at the call site by unification,
// then checked with the same fits() / lattice as everything else.
pub Vec: { len: i32, cap: i32 }
pub Box<T>: { val: T }

pub id<T>    = (x: Ptr<T>) Ptr<T> { x }
pub unbox<U> = (b: Ptr<Box<U>>) U { b.val }   // field of a generic struct keeps its arg

// T is inferred = Vec, so id(v) : Ptr<Vec> and .len type-checks
pub use_id = (v: Ptr<Vec>) i32 { id(v).len }                 //~ PASS

// MutPtr ≤ Ptr still holds under instantiation
pub use_id_mut = (v: MutPtr<Vec>) i32 { id(v).cap }          //~ PASS

// the arg shape doesn't match Box<U>, so U can't be inferred
pub cannot_infer = (v: Ptr<Vec>) i32 { unbox(v) }            //~ FAIL cannot infer type U

// returning the inferred T where a different type is wanted is rejected
pub wrong_use = (v: Ptr<Vec>) i32 { id(v) }                  //~ FAIL

// generic DATA types: the type-arg of Box is inferred from the field value 7
pub boxed_int = () i32 { unbox(addr(Box { val: 7 })) }       //~ boxed_int PASS
