halloc = std.mem.heap
{ String, new_in, try_init } = std.text.string
main = () i32 {
    m := halloc.gpa()
    s := m.addr().new_in()
    s = s.append_in(m.addr(), "abc")
    n := s.len
    s.free_in(m.addr())
    m.addr().try_init(2).match ({
        .Ok(t0) => t0.try_append_in(m.addr(), "hello").match ({
            .Ok(t)  => {
                tn := t.len
                t.free_in(m.addr())
                to_i32(n + tn)
            },
            .Err(e) => 90,
        }),
        .Err(e) => 91,
    })
}
