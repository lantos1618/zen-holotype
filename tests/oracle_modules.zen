// tests/oracle_modules.zen — the CROSS-MODULE / import-resolution category of the Zen-native oracle.
// Where oracle_value/oracle_verdict drive single-file `zenc emit`/`zenc check`, this file drives the
// REAL multi-file path: it writes a small PROJECT (several sibling .zen files) into a temp dir and runs
// `./zenc run <entry>` / `./zenc check <entry>` / `./zenc emit <entry>` / `./zenc doc <module>`, so the
// committed compiler's import loader (std.internal.resolve) + cross-module type-checker (check_linked)
// are exercised end-to-end — the dimension the flat oracle structurally cannot reach.
//
// It ports the FULL cross-module pytest suites (see PARITY map at the bottom):
//   tests/test_user_imports.py      — sibling/namespace import loading + value + loader-error quality
//                                       + the std.internal.resolve public API (import_edges / provided_symbols /
//                                       module_graph / dedup_decls / strip_ns_into / resolve_program_data /
//                                       resolve_parsed_program / check_parsed_program), driven as Zen programs
//                                       run via `zenc run` (exit code == observable result), INCLUDING the
//                                       recursion-depth / stack-growth stress cases (sources generated in-Zen).
//   tests/test_modules_oracle.py    — cross-module arity/arg-type rejection ("the net is not hollow")
//   tests/test_resolver_oracle.py   — name-clash namespacing + transitive re-export, as real projects
//   tests/test_resolver_fixes.py    — the resolver triple-fix + unknown-type / must-use / lambda / value-mold
//                                       driver checks, all through `zenc check`/`run`/`emit`/`doc`.
//
// CUSTOM RUNNER: a ModValCase / ModVerdictCase / ModEmitCase carries `files: [ModFile]` (name + source).
// The runner `mkdir`s a fresh temp dir, `save`s each file, then drives the committed `./zenc`:
//   * VALUE   — `zenc run <entry>` exit code must equal `want` (the program's `main` return).
//   * VERDICT — `zenc check <entry>`: should_pass => accept (rc 0); else reject (rc != 0), and if
//               `needle` is non-empty the captured stderr must contain it (pins the rejection REASON).
//   * EMIT    — `zenc emit <entry>`: must succeed and the emitted C must contain every `present` substring
//               and none of the `absent` ones (resolution-before-cgen / literal-comment preservation).
//   * DOC     — `zenc doc <module>`: must succeed and contain every `present` substring (exported sigs).
// Resolver-API VALUE cases are ordinary Zen programs that import std.internal.resolve and `to_exit()` —
// the loader's data structures are tested at the CLI boundary, no Python harness anywhere.
{ Malloc } = std.mem.alloc
{ out, save, contents_in, shell } = std.io.file
{ eq, len, contains, is_empty, view } = std.text.str
{ new_in, append_in, finish_in, push_in } = std.text.string
{ integer_in } = std.text.num
{ zo_path, zo_cmd } = oracle_lib
// one source file of a project: `name` is the basename (e.g. "p.zen"), `src` its full text.
ModFile*: {
    name: str,
    src: str,
}
// a VALUE case: write `files`, `zenc run <entry>`; the program's exit code must equal `want`.
ModValCase*: {
    files: [ModFile],
    entry: str,
    want: i32,
}
// a VERDICT case: write `files`, `zenc check <entry>`. should_pass => accept; else reject, and when
// `needle` is non-empty the diagnostic must contain it (error kind / loader message / user source span).
ModVerdictCase*: {
    files: [ModFile],
    entry: str,
    should_pass: bool,
    needle: str,
}
// an EMIT case: write `files`, `zenc emit <entry>`; emitted C must contain every `present`, no `absent`.
ModEmitCase*: {
    files: [ModFile],
    entry: str,
    present: [str],
    absent: [str],
}
// a DOC case: `zenc doc <module>`; stdout must contain every `present` substring.
ModDocCase*: {
    module: str,
    present: [str],
}
// a STDIN case: pipe `src` into `./zenc` (no file, no program dir); should_succeed => exit 0 else != 0;
// the combined stdout+stderr must contain every `present` substring.
ModStdinCase*: {
    src: str,
    should_succeed: bool,
    present: [str],
}
// this run's private project dir (trailing slash), unique per process so concurrent runs never clash.
mod_dir = (mp: MutPtr<Malloc>) str { mp.zo_path("zo_mods/") }
// concat two / three strings through an allocator-owned String (no fixed-buffer assumptions).
join2 = (mp: MutPtr<Malloc>, a: str, b: str) str {
    s := mp.new_in()
    s = s.append_in(mp, a)
    s = s.append_in(mp, b)
    mp.finish_in(s)
}
join3 = (mp: MutPtr<Malloc>, a: str, b: str, c: str) str {
    s := mp.new_in()
    s = s.append_in(mp, a)
    s = s.append_in(mp, b)
    s = s.append_in(mp, c)
    mp.finish_in(s)
}
// concat an arbitrary list of pieces through an allocator-owned String.
joinv = (mp: MutPtr<Malloc>, parts: [str]) str {
    s := mp.new_in()
    parts.loop((h, i, p) {
        s = s.append_in(mp, p)
    })
    mp.finish_in(s)
}
// ── source generators (for the recursion-depth / stack-growth stress cases) ──────────────────────
// "v0* = () i32 { 0 }\n" … "v{n-1}* = () i32 { (i%10) }\n" — an n-decl module body.
gen_decls = (mp: MutPtr<Malloc>, n: i32) str {
    s := mp.new_in()
    i := 0
    @while (i < n) {
        s = s.append_in(mp, "v")
        s = s.append_in(mp, mp.integer_in(to_i64(i)).finish_in(mp))
        s = s.append_in(mp, "* = () i32 { ")
        s = s.append_in(mp, mp.integer_in(to_i64(i % 10)).finish_in(mp))
        s = s.append_in(mp, " }\n")
        i = i + 1
    }
    mp.finish_in(s)
}
// "v0, v1, … v{n-1}" — a comma-separated import-head name list.
gen_names = (mp: MutPtr<Malloc>, n: i32) str {
    s := mp.new_in()
    i := 0
    @while (i < n) {
        (i > 0).match ({ true => {
            s = s.append_in(mp, ", ")
        } })
        s = s.append_in(mp, "v")
        s = s.append_in(mp, mp.integer_in(to_i64(i)).finish_in(mp))
        i = i + 1
    }
    mp.finish_in(s)
}
// `chunk` repeated `n` times.
gen_repeat = (mp: MutPtr<Malloc>, chunk: str, n: i32) str {
    s := mp.new_in()
    i := 0
    @while (i < n) {
        s = s.append_in(mp, chunk)
        i = i + 1
    }
    mp.finish_in(s)
}
// fresh temp project dir, then every file written into it (paths are mod_dir + basename).
write_files = (mp: MutPtr<Malloc>, files: [ModFile]) void {
    shell(mp.zo_cmd("rm -rf $ZT/zo_mods && mkdir -p $ZT/zo_mods"))
    files.loop((h, i, f) {
        p := mp.join2(mp.mod_dir(), f.name)
        save(p, f.src, len(f.src))
    })
}
// VALUE: build the project, `zenc run <entry>`, compare its exit code to `want`.
run_mod_value* = (mc: ModValCase) bool {
    m := Malloc(_: 0)
    mp := m.addr()
    mp.write_files(mc.files)
    entry := mp.join2(mp.mod_dir(), mc.entry)
    cmd := mp.join3("./zenc run ", entry, " > $ZT/zo_mods_out.txt 2>&1")
    rc := shell(mp.zo_cmd(cmd))
    // `shell` returns the raw waitpid status; for a normal exit the program's exit code is the high
    // byte (WEXITSTATUS), i.e. status / 256. A build/loader failure surfaces as rc != 0.
    rc / 256 == mc.want
}
// VERDICT: build the project, `zenc check <entry>`. should_pass => rc 0; else rc != 0 and (if `needle`
// non-empty) the captured diagnostic must contain `needle`.
run_mod_verdict* = (mc: ModVerdictCase) bool {
    m := Malloc(_: 0)
    mp := m.addr()
    mp.write_files(mc.files)
    entry := mp.join2(mp.mod_dir(), mc.entry)
    cmd := mp.join3("./zenc check ", entry, " > $ZT/zo_mods_chk.txt 2>&1")
    rc := shell(mp.zo_cmd(cmd))
    mc.should_pass.match ({ true => rc == 0, false => (rc == 0).match ({ true => false, false => is_empty(mc.needle).match ({ true => true, false => mp.contents_in(mp.zo_path("zo_mods_chk.txt")).match ({
        .Ok(txt) => txt.contains(mc.needle),
        .Err(e)  => false,
    }) }) }) })
}
// EMIT: build the project, `zenc emit <entry>`; must succeed and the C must hold every `present`
// substring and none of the `absent` ones.
run_mod_emit* = (mc: ModEmitCase) bool {
    m := Malloc(_: 0)
    mp := m.addr()
    mp.write_files(mc.files)
    entry := mp.join2(mp.mod_dir(), mc.entry)
    cmd := mp.join3("./zenc emit ", entry, " > $ZT/zo_mods_emit.txt 2>&1")
    rc := shell(mp.zo_cmd(cmd))
    (rc == 0).match ({ true => mp.contents_in(mp.zo_path("zo_mods_emit.txt")).match ({
        .Err(e)  => false,
        .Ok(txt) => {
            bad := 0
            mc.present.loop((h, i, s) {
                txt.contains(s).match ({ false => {
                    bad = bad + 1
                } })
            })
            mc.absent.loop((h, i, s) {
                txt.contains(s).match ({ true => {
                    bad = bad + 1
                } })
            })
            bad == 0
        },
    }), false => false })
}
// DOC: `zenc doc <module>`; must succeed and contain every `present` substring.
run_mod_doc* = (mc: ModDocCase) bool {
    m := Malloc(_: 0)
    mp := m.addr()
    cmd := mp.join3("./zenc doc ", mc.module, " > $ZT/zo_mods_doc.txt 2>&1")
    rc := shell(mp.zo_cmd(cmd))
    (rc == 0).match ({ true => mp.contents_in(mp.zo_path("zo_mods_doc.txt")).match ({
        .Err(e)  => false,
        .Ok(txt) => {
            bad := 0
            mc.present.loop((h, i, s) {
                txt.contains(s).match ({ false => {
                    bad = bad + 1
                } })
            })
            bad == 0
        },
    }), false => false })
}
// STDIN: pipe `src` into `./zenc` (no file arg → the source→C filter / sibling-from-stdin path).
// should_succeed => exit 0 else != 0; combined stdout+stderr must contain every `present` substring.
run_mod_stdin* = (mc: ModStdinCase) bool {
    m := Malloc(_: 0)
    mp := m.addr()
    save(mp.zo_path("zo_mods_stdin.zen"), mc.src, len(mc.src))
    rc := shell(mp.zo_cmd("./zenc < $ZT/zo_mods_stdin.zen > $ZT/zo_mods_stdin_out.txt 2>&1"))
    ok_rc := mc.should_succeed.match ({ true => rc == 0, false => rc != 0 })
    ok_rc.match ({ true => mp.contents_in(mp.zo_path("zo_mods_stdin_out.txt")).match ({
        .Err(e)  => false,
        .Ok(txt) => {
            bad := 0
            mc.present.loop((h, i, s) {
                txt.contains(s).match ({ false => {
                    bad = bad + 1
                } })
            })
            bad == 0
        },
    }), false => false })
}
// batch runners + reporters: run every case, print '.'/'F', return the failing count.
run_mod_values = (name: str, cs: [ModValCase]) i32 {
    out(name)
    out("\n")
    fails := 0
    cs.loop((h, i, c) {
        run_mod_value(c).match ({ true => out("."), false => {
            out("F")
            fails = fails + 1
        } })
    })
    out("\n")
    fails
}
run_mod_verdicts = (name: str, cs: [ModVerdictCase]) i32 {
    out(name)
    out("\n")
    fails := 0
    cs.loop((h, i, c) {
        run_mod_verdict(c).match ({ true => out("."), false => {
            out("F")
            fails = fails + 1
        } })
    })
    out("\n")
    fails
}
run_mod_emits = (name: str, cs: [ModEmitCase]) i32 {
    out(name)
    out("\n")
    fails := 0
    cs.loop((h, i, c) {
        run_mod_emit(c).match ({ true => out("."), false => {
            out("F")
            fails = fails + 1
        } })
    })
    out("\n")
    fails
}
run_mod_docs = (name: str, cs: [ModDocCase]) i32 {
    out(name)
    out("\n")
    fails := 0
    cs.loop((h, i, c) {
        run_mod_doc(c).match ({ true => out("."), false => {
            out("F")
            fails = fails + 1
        } })
    })
    out("\n")
    fails
}
run_mod_stdins = (name: str, cs: [ModStdinCase]) i32 {
    out(name)
    out("\n")
    fails := 0
    cs.loop((h, i, c) {
        run_mod_stdin(c).match ({ true => out("."), false => {
            out("F")
            fails = fails + 1
        } })
    })
    out("\n")
    fails
}
oracle_modules_run* = () i32 {
    m := Malloc(_: 0)
    mp := m.addr()
    z: str := ""    // a str-typed leading element so mixed literal/variable joinv arrays infer as [str]
    // ── generated stress sources (recursion-depth / stack-growth guards) ─────────────────────────
    big240 := mp.gen_decls(240)    // 240 top-level decls (symbol-consumer stress)
    big120 := mp.gen_decls(120)    // 120 decls + a 120-name import head
    names120 := mp.gen_names(120)
    dedup260 := mp.join2(mp.gen_decls(260), "v0* = () i32 { 777 }\n")    // 260 + a dup v0 (final-dedup stress)
    mid700 := mp.gen_repeat("right = right\n", 700)
    edges700 := mp.joinv([z, "first = first\n", mid700, "{ last } = last\nmain = () i32 { 0 }\n"])
    v := run_mod_values("modules value (import resolution / value)", [ModValCase(
        files: [ModFile(
            name: "b.zen",
            src: "helper* = (x: i32) i32 { x * 2 }\n",
        ), ModFile(
            name: "p.zen",
            src: "{ helper } = b\nmain = () i32 { helper(21) }\n",
        )],
        entry: "p.zen",
        want: 42,
    ), ModValCase(
        files: [ModFile(
            name: "m1.zen",
            src: "one* = () i32 { 1 }\n",
        ), ModFile(
            name: "m2.zen",
            src: "two* = () i32 { 2 }\n",
        ), ModFile(
            name: "p.zen",
            src: "{ one } = m1\n{ two } = m2\nmain = () i32 { one() + two() }\n",
        )],
        entry: "p.zen",
        want: 3,
    ), ModValCase(
        files: [ModFile(
            name: "h.zen",
            src: "{ println } = std.text.fmt\nshout* = (s: str) i64 { println(s) }\n",
        ), ModFile(
            name: "p.zen",
            src: "{ shout } = h\nmain = () i32 { shout(\"hi\") 0 }\n",
        )],
        entry: "p.zen",
        want: 0,
    ), ModValCase(
        files: [ModFile(
            name: "aa.zen",
            src: "{ g } = bb\nf* = (n: i32) i32 { (n <= 0).match ({ true => 0, false => g(n - 1) + 1 }) }\n",
        ), ModFile(
            name: "bb.zen",
            src: "{ f } = aa\ng* = (n: i32) i32 { (n <= 0).match ({ true => 0, false => f(n - 1) + 1 }) }\n",
        ), ModFile(
            name: "p.zen",
            src: "{ f } = aa\nmain = () i32 { f(7) }\n",
        )],
        entry: "p.zen",
        want: 7,
    ), ModValCase(
        files: [ModFile(
            name: "left.zen",
            src: "thing* = () i32 { 10 }\n",
        ), ModFile(
            name: "right.zen",
            src: "thing* = () i32 { 20 }\n",
        ), ModFile(
            name: "p.zen",
            src: "left = left\nright = right\nmain = () i32 { left.thing() + right.thing() }\n",
        )],
        entry: "p.zen",
        want: 30,
    ), ModValCase(
        files: [ModFile(
            name: "helper.zen",
            src: "value* = () i32 { 7 }\n",
        ), ModFile(
            name: "left.zen",
            src: "helper = helper\ncalc* = () i32 { helper.value() + 1 }\n",
        ), ModFile(
            name: "p.zen",
            src: "left = left\nmain = () i32 { left.calc() }\n",
        )],
        entry: "p.zen",
        want: 8,
    ), ModValCase(
        files: [ModFile(
            name: "helper.zen",
            src: "value* = () i32 { 40 }\n",
        ), ModFile(
            name: "left.zen",
            src: "helper = helper\ncalc* = () i32 { helper.value() + 2 }\n",
        ), ModFile(
            name: "p.zen",
            src: "{ calc } = left\nmain = () i32 { calc() }\n",
        )],
        entry: "p.zen",
        want: 42,
    ), ModValCase(
        files: [ModFile(
            name: "left.zen",
            src: "Box*: { v: i32 }\nmake* = () Box { Box(v: 7) }\n",
        ), ModFile(
            name: "right.zen",
            src: "Box*: { v: i32 }\nmake* = () Box { Box(v: 9) }\n",
        ), ModFile(
            name: "p.zen",
            src: "left = left\nright = right\nmain = () i32 { left.make().v + right.make().v }\n",
        )],
        entry: "p.zen",
        want: 16,
    ), ModValCase(
        files: [ModFile(
            name: "helper.zen",
            src: "addh* = (a: i32, b: i32) i32 { a + b }\n",
        ), ModFile(
            name: "p.zen",
            src: "{addh} = helper\nmain = () i32 { addh(3, 4) }\n",
        )],
        entry: "p.zen",
        want: 7,
    ), ModValCase(
        files: [ModFile(
            name: "helper.zen",
            src: "addh* = (a: i32, b: i32) i32 { a + b }\n",
        ), ModFile(
            name: "p.zen",
            src: "{ addh} = helper\nmain = () i32 { addh(3, 4) }\n",
        )],
        entry: "p.zen",
        want: 7,
    ), ModValCase(
        files: [ModFile(
            name: "helper.zen",
            src: "addh* = (a: i32, b: i32) i32 { a + b }\n",
        ), ModFile(
            name: "p.zen",
            src: "{addh } = helper\nmain = () i32 { addh(3, 4) }\n",
        )],
        entry: "p.zen",
        want: 7,
    ), ModValCase(
        files: [ModFile(
            name: "right.zen",
            src: "buf* = (n: i32) i32 { n + 5 }\n",
        ), ModFile(
            name: "p.zen",
            src: "slice = std.core.slice\nheap = std.mem.heap\nright = right\nmain = () i32 {\n  h := heap.gpa()\n  xs := slice.buf(h.addr(), 2, [0])\n  xs[0] = 30\n  xs[1] = 7\n  xs[0] + xs[1] + right.buf(0)\n}\n",
        )],
        entry: "p.zen",
        want: 42,
    ), ModValCase(
        files: [ModFile(
            name: "right.zen",
            src: "default* = (n: i32) i32 { n + 5 }\n",
        ), ModFile(
            name: "p.zen",
            src: "heap = std.mem.heap\nright = right\nmain = () i32 {\n  h := heap.gpa()\n  p := h.addr().acquire(8)\n  p.store_i64(30)\n  n := p.load_i64()\n  h.addr().release(p)\n  to_i32(n) + right.default(7)\n}\n",
        )],
        entry: "p.zen",
        want: 42,
    ), ModValCase(
        files: [ModFile(
            name: "right.zen",
            src: "of* = (n: i32) i32 { n + 5 }\n",
        ), ModFile(
            name: "p.zen",
            src: "vec = std.collections.vec\nmaps = std.collections.map\nright = right\nhalloc = std.mem.heap\nmain = () i32 {\n  alloc := halloc.gpa()\n  a := alloc.addr()\n  v := vec.of(a, [10, 20])\n  m := maps.of(a, \"x\", 1)\n  ok := v.get(0) + v.get(1) + m.get(\"x\", 0) + right.of(6)\n  v.free(alloc.addr())\n  m.free(alloc.addr())\n  ok\n}\n",
        )],
        entry: "p.zen",
        want: 42,
    ), ModValCase(
        files: [ModFile(
            name: "p.zen",
            src: "vec = std.collections.vec\nheap = std.mem.heap\nsum = (v: vec.Vec<i32>) i32 { v.get(0) + v.get(1) }\nmain = () i32 {\n  h := heap.gpa()\n  v := vec.of(h.addr(), [19, 23])\n  v.sum()\n}\n",
        )],
        entry: "p.zen",
        want: 42,
    ), ModValCase(
        files: [ModFile(
            name: "p.zen",
            src: "slice = std.core.slice\ntext = std.text.str\nheap = std.mem.heap\nmain = () i32 {\n  h := heap.gpa()\n  nums := slice.dup(h.addr(), [10, 20])\n  bytes := text.dup_bytes(h.addr(), \"ab\")\n  ok := (nums[0] == 10) && (nums[1] == 20) && (bytes[0] == 'a') && (bytes[1] == 'b')\n  ok.match({ true => 0, false => 1 })\n}\n",
        )],
        entry: "p.zen",
        want: 0,
    ), ModValCase(
        files: [ModFile(
            name: "p.zen",
            src: "{ Result } = std.core.result\nstr = std.text.str\nnum = std.text.num\npick = (s: str, b: bool) Result<i64, str.ParseError> {\n  b.match ({ true => str.try_parse_int(s), false => num.parse_i64_checked(s) })\n}\nmain = () i32 { pick(\"42\", true).match ({ .Ok(v) => to_i32(v), .Err(e) => 0 }) }\n",
        )],
        entry: "p.zen",
        want: 42,
    ), ModValCase(
        files: [ModFile(
            name: "p.zen",
            src: "{ Result } = std.core.result\nmaps = std.collections.map\nstr = std.text.str\nmain = () i32 { str.try_parse_int(\"9\").match ({ .Ok(v) => to_i32(v), .Err(e) => 0 }) }\n",
        )],
        entry: "p.zen",
        want: 9,
    ), ModValCase(
        files: [ModFile(
            name: "right.zen",
            src: "at* = (n: i32) i32 { n + 5 }\n",
        ), ModFile(
            name: "p.zen",
            src: "bytes = std.text.bytes\nright = right\nmain = () i32 {\n  (bytes.at(\"AZ\", 1) - 'Z') + right.at(37)\n}\n",
        )],
        entry: "p.zen",
        want: 42,
    ), ModValCase(
        files: [ModFile(
            name: "right.zen",
            src: "at* = (n: i32) i32 { n + 5 }\n",
        ), ModFile(
            name: "p.zen",
            src: "text = std.text.str\nbytes = std.text.bytes\nright = right\nmain = () i32 {\n  (text.at(\"abc\", 1) - 'b') + (bytes.at(\"AZ\", 1) - 'Z') + right.at(37)\n}\n",
        )],
        entry: "p.zen",
        want: 42,
    ), ModValCase(
