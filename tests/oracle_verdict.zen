        should_pass: false,
        kind: "",
    ), VerdictCase(
        src: "f* = (b: bool) i32 {\n b.match({ false => { return 9 } })\n 7\n}\ntest* = () i32 { f(false) }",
        should_pass: true,
        kind: "",
    ), VerdictCase(
        src: "f* = (b: bool) i32 {\n b.match({ false => 9 })\n}\ntest* = () i32 { f(false) }",
        should_pass: false,
        kind: "",
    ), VerdictCase(
        src: "f* = (b: bool) i32 {\n b.match({ true => 1 })\n}\ntest* = () i32 { f(true) }",
        should_pass: false,
        kind: "",
    ), VerdictCase(
        src: "f* = (n: i32) i32 {\n n.match({ 0 => 9 })\n}\ntest* = () i32 { f(5) }",
        should_pass: false,
        kind: "",
