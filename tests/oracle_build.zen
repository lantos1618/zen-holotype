    ), ShellCase(
        name: "fmt_block_comments",
        cmd: "cp tests/fixtures/fmt/block_comments_unformatted.zen $ZT/zfmt.zen && { ./zenc fmt --check $ZT/zfmt.zen 2>$ZT/zfmt_e.txt; test \"$?\" = 1; } && grep -Fq \"needs formatting\" $ZT/zfmt_e.txt && ./zenc fmt $ZT/zfmt.zen >/dev/null && cmp -s $ZT/zfmt.zen tests/fixtures/fmt/block_comments_formatted.zen && ./zenc fmt --check $ZT/zfmt.zen && cp $ZT/zfmt.zen $ZT/zfmt_b.zen && ./zenc fmt $ZT/zfmt.zen >/dev/null && cmp -s $ZT/zfmt.zen $ZT/zfmt_b.zen",
    ), ShellCase(
        name: "fmt_literals",
        cmd: "cp tests/fixtures/fmt/literals_unformatted.zen $ZT/zfmt.zen && { ./zenc fmt --check $ZT/zfmt.zen 2>$ZT/zfmt_e.txt; test \"$?\" = 1; } && grep -Fq \"needs formatting\" $ZT/zfmt_e.txt && ./zenc fmt $ZT/zfmt.zen >/dev/null && cmp -s $ZT/zfmt.zen tests/fixtures/fmt/literals_formatted.zen && ./zenc fmt --check $ZT/zfmt.zen && cp $ZT/zfmt.zen $ZT/zfmt_b.zen && ./zenc fmt $ZT/zfmt.zen >/dev/null && cmp -s $ZT/zfmt.zen $ZT/zfmt_b.zen",
    ), ShellCase(
        name: "sibling_source_location",
        cmd: "rm -rf $ZT/zsib && mkdir -p $ZT/zsib && printf \"bad* = () i32 { missing() }\\n\" > $ZT/zsib/bad.zen && printf \"{ bad } = bad\\nmain = () i32 { bad() }\\n\" > $ZT/zsib/main.zen && { ./zenc check $ZT/zsib/main.zen >$ZT/zsib_o.txt 2>&1; test \"$?\" = 1; } && grep -Fq \"bad.zen:1:17: error[undefined-name]: undefined name\" $ZT/zsib_o.txt && grep -Fq \"bad* = () i32 { missing() }\" $ZT/zsib_o.txt",
    ), ShellCase(
        name: "implicit_trait_bound_emit_equal",
        cmd: "./zenc emit tests/fixtures/zen/implicit_trait_bound_sugar.zen >$ZT/zse_s.c 2>/dev/null && ./zenc emit tests/fixtures/zen/implicit_trait_bound_explicit.zen >$ZT/zse_e.c 2>/dev/null && cmp -s $ZT/zse_s.c $ZT/zse_e.c",
    ), ShellCase(
        name: "doc_local_file",
        cmd: "printf \"// Public counter type\\nCounter*: { n: i32 }\\n\\nhelper = () i32 { 1 }\\nvisible* = () i32 { 2 }\\n\" > $ZT/zdoc_local.zen && ./zenc doc $ZT/zdoc_local.zen >$ZT/zdoc_local_o.txt 2>&1 && grep -Fq \"Public counter type\" $ZT/zdoc_local_o.txt && grep -Fq \"Counter*: { n: i32 }\" $ZT/zdoc_local_o.txt && grep -Fq \"visible* = () i32 { 2 }\" $ZT/zdoc_local_o.txt && ! grep -Fq \"helper\" $ZT/zdoc_local_o.txt",
    ), ShellCase(
        name: "io_file_result_paths",
        cmd: "cp tests/fixtures/zen/io_file_result_paths.zen $ZT/iofile.zen && sed -i \"s#@@T@@#$ZT#g\" $ZT/iofile.zen && ./zenc build $ZT/iofile.zen -o $ZT/iofile_bin 2>/dev/null && { $ZT/iofile_bin; test \"$?\" = 0; }",
    ), ShellCase(
        name: "cown_result_paths",
        cmd: "cp tests/fixtures/zen/cown_result_paths.zen $ZT/cown.zen && sed -i \"s#@@T@@#$ZT#g\" $ZT/cown.zen && printf \"\" > $ZT/zo_cown_input.txt && ./zenc build $ZT/cown.zen -o $ZT/cown_bin 2>/dev/null && { $ZT/cown_bin; test \"$?\" = 0; }",
    )])
    // io_file_result_paths: substitute this run's private scratch dir for the `@@T@@` placeholder, then
    // build+run; missing/denied/out paths now live under $ZT so concurrent runs never share scratch.
    // cown_result_paths: same substitution, and SEED the input file first so `cown.file_in` opens it
    // successfully and the allocator-wrap failure (LimitAlloc) is what yields the asserted .NotFound.
    // ── (k) bootstrap-binary battery (ported from test_bootstrap.py + test_build_self.py): the committed
    // `./zenc` IS the cc-built bootstrap binary, so drive it directly — emit-compile-run real programs,
    // survive malformed input (no signal death), report missing files, and `--build-self` usage errors.
    // (the self-host FIXPOINT itself is wired separately in oracle.zen via fixpoint_ok.)
    bs := run_shells("bootstrap", [ShellCase(
        name: "bootstrap_compiles_zen",
        cmd: "printf '%s' 'sq* = (n: i32) i32 { n * n }' | ./zenc >$ZT/zbc.c 2>/dev/null && grep -Fq 'int32_t sq(int32_t n)' $ZT/zbc.c && { echo '#include <stdint.h>'; cat $ZT/zbc.c; echo 'int main(void){ return sq(7) == 49 ? 0 : 1; }'; } > $ZT/zbc_full.c && cc -std=gnu11 -w $ZT/zbc_full.c -o $ZT/zbc_bin 2>/dev/null && $ZT/zbc_bin",
    ), ShellCase(
        name: "bootstrap_run_bool_true_first",
        cmd: "printf 'f* = (n: i32) i32 { (n < 5).match({ true => 1, false => 0 }) }' | ./zenc >$ZT/zbp.c 2>/dev/null && { echo '#include <stdint.h>'; echo '#include <stdbool.h>'; cat $ZT/zbp.c; echo 'int main(void){ return f(3)==1 && f(9)==0 ? 0 : 1; }'; } > $ZT/zbp_full.c && cc -std=gnu11 -w $ZT/zbp_full.c -o $ZT/zbp_bin 2>/dev/null && $ZT/zbp_bin",
    ), ShellCase(
        name: "bootstrap_run_bool_false_first",
        cmd: "printf 'g* = (n: i32) i32 { (n < 5).match({ false => 0, true => 1 }) }' | ./zenc >$ZT/zbp.c 2>/dev/null && { echo '#include <stdint.h>'; echo '#include <stdbool.h>'; cat $ZT/zbp.c; echo 'int main(void){ return g(3)==1 && g(9)==0 ? 0 : 1; }'; } > $ZT/zbp_full.c && cc -std=gnu11 -w $ZT/zbp_full.c -o $ZT/zbp_bin 2>/dev/null && $ZT/zbp_bin",
    ), ShellCase(
        name: "bootstrap_run_recursion_fib",
        cmd: "printf 'fib* = (n: i32) i32 { (n < 2).match({ true => n, false => fib(n-1)+fib(n-2) }) }' | ./zenc >$ZT/zbp.c 2>/dev/null && { echo '#include <stdint.h>'; echo '#include <stdbool.h>'; cat $ZT/zbp.c; echo 'int main(void){ return fib(10)==55 ? 0 : 1; }'; } > $ZT/zbp_full.c && cc -std=gnu11 -w $ZT/zbp_full.c -o $ZT/zbp_bin 2>/dev/null && $ZT/zbp_bin",
    ), ShellCase(
        name: "bootstrap_run_while_sum",
        cmd: "printf 'sum* = (n: i32) i32 {\\n s := 0\\n i := 1\\n @while(i <= n) {\\n  s = s + i\\n  i = i + 1\\n }\\n s\\n}' | ./zenc >$ZT/zbp.c 2>/dev/null && { echo '#include <stdint.h>'; echo '#include <stdbool.h>'; cat $ZT/zbp.c; echo 'int main(void){ return sum(5)==15 ? 0 : 1; }'; } > $ZT/zbp_full.c && cc -std=gnu11 -w $ZT/zbp_full.c -o $ZT/zbp_bin 2>/dev/null && $ZT/zbp_bin",
    ), ShellCase(
        name: "bootstrap_run_nested_while",
        cmd: "printf 'grid* = (n: i32) i32 {\\n c := 0\\n i := 0\\n @while(i < n) {\\n  j := 0\\n  @while(j < n) {\\n   c = c + 1\\n   j = j + 1\\n  }\\n  i = i + 1\\n }\\n c\\n}' | ./zenc >$ZT/zbp.c 2>/dev/null && { echo '#include <stdint.h>'; echo '#include <stdbool.h>'; cat $ZT/zbp.c; echo 'int main(void){ return grid(4)==16 ? 0 : 1; }'; } > $ZT/zbp_full.c && cc -std=gnu11 -w $ZT/zbp_full.c -o $ZT/zbp_bin 2>/dev/null && $ZT/zbp_bin",
    ), ShellCase(
        name: "bootstrap_run_enum_match",
        cmd: "printf 'Shape*: Circle(i32) | Square(i32)\\nmk* = (n: i32) Shape {\\n .Circle(n)\\n}\\narea* = (s: Shape) i32 {\\n s.match({ .Circle(r) => r*r*3, .Square(w) => w*w })\\n}' | ./zenc >$ZT/zbp.c 2>/dev/null && { echo '#include <stdint.h>'; echo '#include <stdbool.h>'; cat $ZT/zbp.c; echo 'int main(void){ return area(mk(2))==12 ? 0 : 1; }'; } > $ZT/zbp_full.c && cc -std=gnu11 -w $ZT/zbp_full.c -o $ZT/zbp_bin 2>/dev/null && $ZT/zbp_bin",
    ), ShellCase(
        name: "bootstrap_run_struct_field",
        cmd: "printf 'Pt*: { x: i32, y: i32 }\\nmk* = (a: i32, b: i32) Pt {\\n Pt(x: a, y: b)\\n}\\nnsq* = (p: Pt) i32 {\\n p.x*p.x + p.y*p.y\\n}' | ./zenc >$ZT/zbp.c 2>/dev/null && { echo '#include <stdint.h>'; echo '#include <stdbool.h>'; cat $ZT/zbp.c; echo 'int main(void){ return nsq(mk(3,4))==25 ? 0 : 1; }'; } > $ZT/zbp_full.c && cc -std=gnu11 -w $ZT/zbp_full.c -o $ZT/zbp_bin 2>/dev/null && $ZT/zbp_bin",
    ), ShellCase(
        name: "bootstrap_run_precedence",
        cmd: "printf 'e* = () i32 { 1 + 2 * 3 - 4 }' | ./zenc >$ZT/zbp.c 2>/dev/null && { echo '#include <stdint.h>'; echo '#include <stdbool.h>'; cat $ZT/zbp.c; echo 'int main(void){ return e()==3 ? 0 : 1; }'; } > $ZT/zbp_full.c && cc -std=gnu11 -w $ZT/zbp_full.c -o $ZT/zbp_bin 2>/dev/null && $ZT/zbp_bin",
    ), ShellCase(
        name: "bootstrap_run_compare_and",
        cmd: "printf 'c* = (a: i32, b: i32) bool { (a < b) && (b < 10) }' | ./zenc >$ZT/zbp.c 2>/dev/null && { echo '#include <stdint.h>'; echo '#include <stdbool.h>'; cat $ZT/zbp.c; echo 'int main(void){ return c(3,7) && !c(3,12) ? 0 : 1; }'; } > $ZT/zbp_full.c && cc -std=gnu11 -w $ZT/zbp_full.c -o $ZT/zbp_bin 2>/dev/null && $ZT/zbp_bin",
    ), ShellCase(
        name: "bootstrap_malformed_no_colon_param",
        cmd: "printf 'f* = (p i32) i32 { 1 }' | timeout 15 ./zenc >/dev/null 2>&1; rc=$?; test \"$rc\" -lt 128",
    ), ShellCase(
        name: "bootstrap_malformed_colon_payload_enum",
        cmd: "printf 'E: A | Some: T' | timeout 15 ./zenc >/dev/null 2>&1; rc=$?; test \"$rc\" -lt 128",
    ), ShellCase(
        name: "bootstrap_malformed_truncated_binop",
        cmd: "printf 'g* = () i32 { 6 *' | timeout 15 ./zenc >/dev/null 2>&1; rc=$?; test \"$rc\" -lt 128",
    ), ShellCase(
        name: "bootstrap_malformed_unterminated_block",
        cmd: "printf 'h* = () i32 { 1' | timeout 15 ./zenc >/dev/null 2>&1; rc=$?; test \"$rc\" -lt 128",
    ), ShellCase(
        name: "bootstrap_malformed_unterminated_import",
        cmd: "printf '{ a, b' | timeout 15 ./zenc >/dev/null 2>&1; rc=$?; test \"$rc\" -lt 128",
    ), ShellCase(
        name: "bootstrap_malformed_unterminated_tparams",
        cmd: "printf 'f<T' | timeout 15 ./zenc >/dev/null 2>&1; rc=$?; test \"$rc\" -lt 128",
    ), ShellCase(
        name: "bootstrap_malformed_empty",
        cmd: "printf '' | timeout 15 ./zenc >/dev/null 2>&1; rc=$?; test \"$rc\" -lt 128",
    ), ShellCase(
        name: "bootstrap_malformed_lone_brace",
        cmd: "printf '{' | timeout 15 ./zenc >/dev/null 2>&1; rc=$?; test \"$rc\" -lt 128",
    ), ShellCase(
        name: "bootstrap_malformed_lone_ident",
        cmd: "printf 'x' | timeout 15 ./zenc >/dev/null 2>&1; rc=$?; test \"$rc\" -lt 128",
    ), ShellCase(
        name: "bootstrap_missing_file",
        cmd: "./zenc /nonexistent/zzz.zen >$ZT/zmf.txt 2>&1; test \"$?\" = 1 && grep -Fq 'cannot open' $ZT/zmf.txt",
    ), ShellCase(
        name: "build_self_usage_missing_args",
        cmd: "./zenc --build-self >$ZT/zbs.txt 2>&1; test \"$?\" = 2 && grep -Fq 'usage' $ZT/zbs.txt",
    ), ShellCase(
        name: "build_self_bad_srcroot",
        cmd: "./zenc --build-self $ZT/zbs_x.c /nonexistent/zzz >$ZT/zbs2.txt 2>&1; test \"$?\" = 1 && grep -Fq 'cannot open' $ZT/zbs2.txt",
    )])
    ex + so + ex2 + so2 + exm + vd + r1 + r2 + vd2 + dg + em + dc + sh + bs
}
