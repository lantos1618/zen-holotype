{ to_exit } = std.core.bool
{ String, new_in } = std.text.string
alloc = std.mem.heap
push_byte<A> = (s: String, a: MutPtr<A>, v: u8) String { s.push_in(a, v).push_in(a, v) }
build<A> = (a: MutPtr<A>) str { a.new_in().push_byte(a, 'x').push_byte(a, 'x').push_byte(a, 'x').push_byte(a, 'x').push_byte(a, 'x').push_byte(a, 'x').push_byte(a, 'x').push_byte(a, 'x').finish_in(a) }
main = () i32 {
    heap := alloc.gpa()
    s := build(heap.addr())
    (s.len() == 16).to_exit()
}
