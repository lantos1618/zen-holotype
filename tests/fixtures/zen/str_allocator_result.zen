halloc = std.mem.heap
{ dup_bytes, dup_bytes_in, try_dup_bytes, try_dup_bytes_in, substr, substr_in, try_substr, try_substr_in } = std.text.str
{ println } = std.text.fmt

main = () i32 {
    a := halloc.system()

    plain := a.addr().dup_bytes("xy")
    println(plain.len)

    owned := a.addr().dup_bytes_in("abc")
    println(owned.len)
    println(owned[0])
    println(a.addr().substr("hello", 1, 3))
    println(a.addr().substr_in("hello", 1, 3))

    a.addr().try_dup_bytes("").match ({
        .Ok(bytes) => println(bytes.len),
        .Err(e) => println(99)
    })
    a.addr().try_dup_bytes_in("").match ({
        .Ok(bytes) => println(bytes.len),
        .Err(e) => println(99)
    })
    a.addr().try_substr("world", 1, 2).match ({
        .Ok(s) => println(s),
        .Err(e) => println("err")
    })
    a.addr().try_substr_in("world", 1, 2).match ({
        .Ok(s) => println(s),
        .Err(e) => println("err")
    })

    0
}
