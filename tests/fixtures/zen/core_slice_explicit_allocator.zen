{ nbuf_in, dupx_in, node_in, concat_in } = std.core.slice
{ arena_new, arena_free } = std.mem.arena

main = () i32 {
    a := arena_new(1024)

    xs := a.addr().dupx_in([1, 2, 3])
    ys := a.addr().concat_in(xs, [4, 5])
    p := a.addr().node_in(9)
    zs := a.addr().nbuf_in(2, xs)

    zs[0] = load(p)
    zs[1] = ys[4]
    out := zs[0] + zs[1]

    a.addr().arena_free()
    out
}
