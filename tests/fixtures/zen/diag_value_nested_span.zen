{ diagnostic_from_source } = compiler.check_validate
{ to_exit } = std.core.bool
{ eq } = std.text.str
main = () i32 {
    diag := diagnostic_from_source("main = () i32 { missing_name() }\n", 515, 1)
    ok := eq(diag.kind, "undefined-name")
        && (diag.span.start == 16)
        && (diag.span.width == 12)
        && (diag.count == 1)
        && eq(diag.message, "undefined name")
        && eq(diag.hint, "declare the name, import it, or qualify the intended module binding")
    ok.to_exit()
}
