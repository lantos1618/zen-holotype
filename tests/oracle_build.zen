    ), DiagCase(
        src: "C: Red | Green | Blue\nf = (c: C) i32 {\n    c.match ({ .Red => 1, .Green => 2 })\n}\nmain = () i32 { 0 }\n",
        wants: [":3:5: error[exhaustiveness]: match does not cover every variant", "      c.match ({ .Red => 1, .Green => 2 })", "      ^", "hint: add arms for every variant, or add an explicit `_` arm"],
    ), DiagCase(
        src: "C: Red | Green | Blue\nf = (c: C) i32 {\n    c.match ({ .Red => 1, .Red => 2, _ => 3 })\n}\nmain = () i32 { 0 }\n",
        wants: [":3:5: error[dup-variant]: duplicate match arm variant", "      c.match ({ .Red => 1, .Red => 2, _ => 3 })", "      ^", "hint: remove the repeated match arm for this variant"],
    ), DiagCase(
        src: "f = (n: i32) i32 {\n    x := (n > 3).match ({ true => 1 })\n    x\n}\nmain = () i32 { 0 }\n",
        wants: [":2:13: error[exhaustiveness]: match does not cover every variant", "      x := (n > 3).match ({ true => 1 })", "              ^", "hint: add arms for every variant, or add an explicit `_` arm"],
    ), DiagCase(
        src: "main = () i32 {\n    x := = 5\n    0\n}\n",
