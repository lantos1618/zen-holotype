halloc = std.mem.heap
vec = std.collections.vec
{ println } = std.text.fmt
main = () i32 {
    alloc := halloc.gpa()
    a := alloc.addr()
    v: vec.Vec<i32> := vec.empty(a)
    v = v.push(a, 3)
    v = v.push(a, 5)
    v = v.push(a, 7)
    sum := 0
    v.view().loop((h, i, x) { sum = sum + x })
    println(sum)
    n := v.view().len
    println(n)
    v.free(a)
    0
}
