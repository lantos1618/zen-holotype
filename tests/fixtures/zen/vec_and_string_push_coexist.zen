halloc = std.mem.heap
vec = std.collections.vec
{ String, init } = std.text.string
main = () i32 {
  alloc := halloc.system()
  a := alloc.addr()
  v := vec.of(a, [10, 20])
  v2 := v.push(a, 30)
  s := a.init(4)
  s2 := s.push_in(a, '!')
  out := v2.get(2) + to_i32(s2.len)
  v2.free(a)
  s2.free_in(a)
  out
}
