// Arithmetic (+ - *) requires numeric operands and widens to i64 if either is.
Vec*: { len: i32, cap: i32 }

mul_ints*  = (v: Ptr<Vec>) i32 { v.len * v.cap }   //~ PASS
widens*    = (a: i64) i64 { a * 2 }                //~ PASS  (i64 * i32 -> i64)

ptr_math*  = (v: Ptr<Vec>) i32 { v * v }           //~ FAIL numeric operands
bool_math* = () i32 { true + 1 }                   //~ FAIL numeric operands
eq_result* = () i32 { 1 == 1 }                     //~ FAIL bool

// comparisons (numeric -> bool), logical (bool -> bool), unary not
in_range*  = (a: i32) bool { a >= 1 && a <= 9 }    //~ PASS
negate*    = (a: bool) bool { !a }                 //~ PASS
less*       = (v: Ptr<Vec>) bool { v.len < v.cap } //~ PASS

and_on_int* = (a: i32) bool { a && true }          //~ FAIL bool operands
not_on_int* = (a: i32) bool { !a }                 //~ FAIL bool operand
lt_on_bool* = (a: bool) bool { a < a }             //~ FAIL numeric operands
