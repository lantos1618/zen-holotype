halloc = std.mem.heap
sets = std.collections.set
{ println } = std.text.fmt
main = () i32 {
    alloc := halloc.system()
    a := alloc.addr()
    x := sets.of(a, 1)
    x = x.add(a, 2)
    x = x.add(a, 3)
    y := sets.of(a, 3)
    y = y.add(a, 4)
    y = y.add(a, 5)
    u := sets.union(a, x, y)
    println(u.len())
    n := sets.intersect(a, x, y)
    println(n.len())
    println(n.has(3).match ({ true => 1, false => 0 }))
    d2 := sets.difference(a, x, y)
    println(d2.len())
    println(d2.has(1).match ({ true => 1, false => 0 }))
    println(d2.has(3).match ({ true => 1, false => 0 }))
    println(x.len())
    x.free(a)  y.free(a)  u.free(a)  n.free(a)  d2.free(a)
    0
}
