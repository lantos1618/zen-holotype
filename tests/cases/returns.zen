// The declared return type is checked with the same fits() as everything else.
pub Vec: { len: i32, cap: i32 }

pub keep_ptr = (v: Ptr<Vec>) Ptr<Vec> { v }              //~ PASS

// returning a read-only pointer where a mutable one is promised: rejected
pub upgrade_ret = (v: Ptr<Vec>) MutPtr<Vec> { v }        //~ FAIL MutPtr<Vec>

// returning nonnull where Option is promised: fine
pub widen_ret = (v: Ptr<Vec>) Option<Ptr<Vec>> { v }     //~ PASS
