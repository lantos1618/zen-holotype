{ system_allocator } = std.mem.alloc
{ map_new, mput, mget, mhas, mlen, free_map } = std.collections.map
{ println_int } = std.text.fmt

bump<AllocT> = (alloc: MutPtr<AllocT>, m: Map<i32>, w: str) Map<i32> {
    alloc.mput(m, w, m.mget(w, 0) + 1)
}

main = () i32 {
    alloc := system_allocator()
    a := alloc.addr()

    w := a.map_new("the", 1)
    w = a.bump(w, "cat")
    w = a.bump(w, "sat")
    w = a.bump(w, "on")
    w = a.bump(w, "the")
    w = a.bump(w, "mat")
    w = a.bump(w, "the")
    w = a.bump(w, "cat")

    println_int(w.mget("the", 0))
    println_int(w.mget("cat", 0))
    println_int(w.mget("sat", 0))
    println_int(w.mget("dog", -1))
    println_int(w.mhas("mat").match ({ true => 1, false => 0 }))
    println_int(w.mhas("dog").match ({ true => 1, false => 0 }))
    println_int(w.mlen())

    a.free_map(w)
    0
}
