// Arithmetic (+ - *) requires numeric operands and widens to i64 if either is.
pub Vec: { len: i32, cap: i32 }

pub mul_ints  = (v: Ptr<Vec>) i32 { v.len * v.cap }   //~ PASS
pub widens    = (a: i64) i64 { a * 2 }                //~ PASS  (i64 * i32 -> i64)

pub ptr_math  = (v: Ptr<Vec>) i32 { v * v }           //~ FAIL numeric operands
pub bool_math = () i32 { true + 1 }                   //~ FAIL numeric operands
pub eq_result = () i32 { 1 == 1 }                     //~ FAIL bool
