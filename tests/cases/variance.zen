// The array-store soundness hole, expressed in Zen: a MutPtr is INVARIANT in
// its pointee, so a MutPtr<Vec> must not pass where MutPtr<Option<Vec>> is
// wanted (else the callee could store null into a caller's non-null slot).
pub Vec: { len: i32, cap: i32 }

pub need_mut_opt = (v: MutPtr<Option<Vec>>) i32 { 0 }
pub need_ptr_opt = (v: Ptr<Option<Vec>>) i32 { 0 }

// writable target → invariant pointee → reject
pub mut_pointee_invariant = (v: MutPtr<Vec>) i32 { need_mut_opt(v) }  //~ FAIL

// read-only target → covariant pointee → safe to downgrade
pub read_pointee_covariant = (v: MutPtr<Vec>) i32 { need_ptr_opt(v) } //~ PASS
