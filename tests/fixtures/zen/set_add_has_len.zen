halloc = std.mem.heap
sets = std.collections.set
{ println } = std.text.fmt
main = () i32 {
    alloc := halloc.gpa()
    a := alloc.addr()
    s := sets.of(a, 10)
    s = s.add(a, 10)
    println(s.len())
    s = s.add(a, 20)
    s = s.add(a, 30)
    s = s.add(a, 40)
    s = s.add(a, 20)
    println(s.len())
    println(s.has(30).match ({ true => 1, false => 0 }))
    println(s.has(99).match ({ true => 1, false => 0 }))
    s = s.remove(a, 30)
    println(s.len())
    println(s.has(30).match ({ true => 1, false => 0 }))
    sum := 0
    s.each((x){ sum = sum + x })
    println(sum)
    w: sets.Set<str> := sets.empty(a)
    w = w.add(a, "the")
    w = w.add(a, "cat")
    w = w.add(a, "the")
    println(w.len())
    println(w.has("cat").match ({ true => 1, false => 0 }))
    println(w.has("dog").match ({ true => 1, false => 0 }))
    s.free(a)
    w.free(a)
    0
}
