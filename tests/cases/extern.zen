// A function with no body binds a C symbol — type-checked as callable, no `extern`.
putchar = (c: i32) i32
malloc  = (n: i64) RawPtr<u8>
free    = (p: RawPtr<u8>) void

nl*       = () i32  { putchar(10) }            //~ nl PASS
use_heap* = () void { free(malloc(64)) }       //~ use_heap PASS

// the signature is enforced: putchar wants i32, malloc gives RawPtr<u8>
bad_arg*  = () i32  { putchar(malloc(8)) }     //~ bad_arg FAIL
