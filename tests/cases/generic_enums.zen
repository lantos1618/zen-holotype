// Generic enums: the payload type-param is solved from the expected enum type,
// and the instance is monomorphized to concrete C (Opt<i32> -> Opt_i32).
pub Opt<T>: None, Some(T)
pub Result<T, E>: Ok(T), Err(E)

pub wrap   = (n: i32) Opt<i32> { .Some(n) }             //~ wrap PASS
pub empty  = () Opt<i32> { .None() }                    //~ empty PASS
pub unwrap = (o: Opt<i32>) i32 { match o { .None => 0, .Some(v) => v } }  //~ unwrap PASS

pub two_param = (a: i32) Result<i32, bool> { .Ok(a) }   //~ two_param PASS

// the payload must fit the instantiated type-param (T = i32 here, not bool)
pub bad_payload = () Opt<i32> { .Some(true) }           //~ bad_payload FAIL bool
