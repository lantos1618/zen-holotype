// Traits = generics with a bound that resolves a method to a concrete impl.
Vec*: { len: i32, cap: i32 }
Other*: { x: i32 }

trait Area { area: (Ptr<Self>) i32 }

impl Area for Vec { area = (v: Ptr<Vec>) i32 { v.len * v.cap } }

// a bounded generic body may call the trait method on its T
total*<T: Area> = (x: Ptr<T>) i32 { area(x) }   //~ total PASS

// call site: the type-arg must satisfy the bound
use_ok*  = (v: Ptr<Vec>)   i32 { total(v) }     //~ use_ok PASS
use_bad* = (o: Ptr<Other>) i32 { total(o) }     //~ use_bad FAIL does not implement Area

// a trait method called without a bound in scope is unbound
no_bound* = (o: Ptr<Other>) i32 { area(o) }     //~ no_bound FAIL unbound
