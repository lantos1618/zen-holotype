# bootstrap/zenc.gen.c is the GENERATED compiler seed (the C the Zen frontend emits for the compiler
# sources). It is a build artifact regenerated from .zen source on every PR, so parallel branches
# conflict on it constantly. Route it through a custom merge driver that resolves the conflict to a
# clean, compilable file; a follow-up `make resolve-seed` reproduces the byte-exact seed from source.
# The driver lives in LOCAL git config — register it once with `make -f bootstrap/Makefile setup-git`.
# (Until registered, git falls back to the normal 3-way merge — harmless, just the old conflict.)
bootstrap/zenc.gen.c merge=zenseed
