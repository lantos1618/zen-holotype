{ println } = std.text.fmt
{ Result, IoError } = std.core.result
divmod = (n: i32, d: i32) Result<__anon_q_r, IoError> {
    (d == 0).match ({ true => .Err(.NotFound), false => .Ok(__anon_q_r(
        q: n / d,
        r: n % d,
    )) })
}
main = () i32 {
    divmod(7, 2).match ({
        .Ok(v)  => {
            println(v.q)
            println(v.r)
        },
        .Err(e) => println(0 - 1),
    })
    0
}
__anon_q_r: {
    q: i32,
    r: i32,
}
