// Literal inference (i32 widening to i64, bool) and let-bound locals.

pub narrow = () i32  { 5 }                 //~ PASS
pub widen  = () i64  { 5 }                 //~ PASS  (i32 literal widens to i64)
pub flag   = () bool { true }              //~ PASS
pub bool_is_not_int = () i32 { true }      //~ FAIL

pub via_let = () i32 {
    a := 6
    b := 7
    a * b
}                                          //~ via_let PASS

pub let_widens = () i64 {
    x := 41
    x
}                                          //~ let_widens PASS
