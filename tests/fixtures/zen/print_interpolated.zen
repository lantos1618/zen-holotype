// Section B.7 — {}-template interpolation. std.text.fmt's `format`/`formatln` splice
// a SLICE of pre-wrapped `Arg`s into a printf-style template in ONE call: a string +
// an int + a float (+ bool, owned String, `{{`/`}}` escapes, missing/surplus args).
{ formatln, arg_int, arg_str, arg_flt, arg_bool, arg_owned } = std.text.fmt
halloc = std.mem.heap
{ new_in, append_in } = std.text.string
main = () i32 {
    name := "Zen"
    n := 42
    pi := 3.14
    formatln("name={} n={}", [arg_str(name), arg_int(n)])
    formatln("s={} i={} f={} b={}", [arg_str("hi"), arg_int(7), arg_flt(pi), arg_bool(true)])
    formatln("braces {{}} and {} done", [arg_int(9)])
    formatln("missing {} {} extra", [arg_int(1)])
    alloc := halloc.gpa()
    a := alloc.addr()
    g := a.new_in().append_in(a, "world")
    formatln("owned={}", [arg_owned(g)])
    g.free_in(a)
    0
}
