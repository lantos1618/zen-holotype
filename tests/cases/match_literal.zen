// match on i32/bool with literal patterns — this is the language's branching.
// With recursion it makes the language Turing-complete.

pub classify = (n: i32) i32 {
    match n { 0 => 100, 1 => 200, _ => 300 }
}                                                  //~ classify PASS

pub fact = (n: i32) i32 {
    match n { 0 => 1, _ => n * fact(n - 1) }
}                                                  //~ fact PASS  (recursion)

pub flip = (b: bool) bool {
    match b { true => false, false => true }
}                                                  //~ flip PASS  (bool is exhaustive)

// integers can't be enumerated, so a bare set of literals isn't exhaustive
pub no_default = (n: i32) i32 {
    match n { 0 => 1, 1 => 2 }
}                                                  //~ no_default FAIL non-exhaustive

// a variant pattern makes no sense on an i32
pub wrong_pat = (n: i32) i32 {
    match n { .Some => 1, _ => 0 }
}                                                  //~ wrong_pat FAIL non-enum
