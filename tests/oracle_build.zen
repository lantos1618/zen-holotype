    // ── (h) `zenc emit` C-substring assertions (enum switch / bool ternary / no self-capture) ─────
    em := run_emits("build emit", [EmitCase(
        path: "tests/fixtures/zen/enum_emit.zen",
        present: ["switch (_subj.tag)", "case R_Ok:"],
