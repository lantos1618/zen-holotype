{ system_allocator } = std.mem.alloc
{ new_in, append_in, free_in, try_with_cap, try_append } = std.text.string

main = () i32 {
    m := system_allocator()

    s := m.addr().new_in()
    s = m.addr().append_in(s, "abc")
    n := s.len
    m.addr().free_in(s)

    m.addr().try_with_cap(2).match({
        .Ok(t0) => m.addr().try_append(t0, "hello").match({
            .Ok(t) => {
                tn := t.len
                m.addr().free_in(t)
                to_i32(n + tn)
            },
            .Err(e) => 90
        }),
        .Err(e) => 91
    })
}
