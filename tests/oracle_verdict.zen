// tests/oracle_verdict.zen — the FULL VERDICT + KIND corpus for the Zen-native correctness oracle
// (the self-hosted replacement for the pytest verdict harness). Ported verbatim from
// tests/_oracle_corpus.py: VERDICT_CASES (186, accept/reject) + VERDICT_KIND_CASES (83, a reject
// pinned by its first-error KIND). `zenc check src` must accept (should_pass=true) or reject
// (false); a non-empty `kind` (e.g. "arity") makes the harness require `error[<kind>]` in the
// rejection diagnostic (reject-for-the-right-reason). The harness wraps the bare kind label.
// NO Python anywhere — the compiler tests itself, in itself, by driving the committed `zenc`.
{ VerdictCase, run_verdicts } = oracle_lib
oracle_verdict_run* = () i32 {
    a := run_verdicts("verdict (206)", [VerdictCase(
        src: "test* = () i32 { a: u8 := 300  to_i32(a) }",
        should_pass: false,
        kind: "",
    ), VerdictCase(
        src: "test* = () i32 { x: i32 := 4294967296  to_i32(x) }",
        should_pass: false,
        kind: "",
    ), VerdictCase(
        src: "test* = () i32 { a: i8 := 200  0 }",
        should_pass: false,
        kind: "",
    ), VerdictCase(
        src: "test* = () i32 { a: i16 := 40000  0 }",
        should_pass: false,
        kind: "",
    ), VerdictCase(
        src: "test* = () i32 { a: u16 := 70000  0 }",
        should_pass: false,
        kind: "",
    ), VerdictCase(
        src: "test* = () i32 { a: u32 := 0 - 1  0 }",
        should_pass: false,
        kind: "",
    ), VerdictCase(
        src: "test* = () i32 { a: u64 := 0 - 1  0 }",
        should_pass: false,
        kind: "",
    ), VerdictCase(
        src: "test* = () i32 { a: i8 := 127  0 }",
        should_pass: true,
        kind: "",
    ), VerdictCase(
        src: "test* = () i32 { a: i8 := 0 - 128  0 }",
        should_pass: true,
        kind: "",
    ), VerdictCase(
        src: "P*: { x: u8 }\ntest* = () i32 { p := P( x: 300 )  0 }",
        should_pass: false,
        kind: "",
    ), VerdictCase(
        src: "P*: { x: i32 }\ntest* = () i32 { a: P := P( x: 1 )  c := a == P( x: 2 )  0 }",
        should_pass: false,
        kind: "",
    ), VerdictCase(
        src: "test* = () i32 { x := 5  y := x.foo  0 }",
        should_pass: false,
        kind: "",
    ), VerdictCase(
        src: "test* = () i32 { n := 1  v := n.match ({ 1 => 5, _ => \"s\" })  0 }",
        should_pass: false,
        kind: "",
    ), VerdictCase(
        src: "A*: { x: i32 }\nB*: { y: i32 }\ntest* = () i32 { n := 1  v := n.match ({ 1 => A( x: 1 ), _ => B( y: 2 ) })  0 }",
        should_pass: false,
        kind: "",
    ), VerdictCase(
        src: "test* = () i32 { c := true  v := c.match ({ true => 5, false => \"s\" })  0 }",
        should_pass: false,
        kind: "",
    ), VerdictCase(
        src: "E*: A(i32) | B\ntest* = () i32 { x := E.A(\"s\")  0 }",
        should_pass: false,
        kind: "",
    ), VerdictCase(
        src: "test* = () i32 { n := 1  v := n.match ({ 1 => 5, _ => 7 })  0 }",
        should_pass: true,
        kind: "",
    ), VerdictCase(
        src: "Box<T>: { n: i32 }\nempty<T> = (k: i32) Box<T> { Box<T>( n: k ) }\ntest* = () i32 { m := empty(7)  0 }",
        should_pass: false,
        kind: "",
    ), VerdictCase(
        src: "Box<T>: { n: i32 }\nempty<T> = (k: i32) Box<T> { Box<T>( n: k ) }\ntest* = () i32 { m: Box<i32> := empty(7)  0 }",
        should_pass: true,
        kind: "",
    ), VerdictCase(
        src: "Box<T>: { n: i32 }\nwrap<T> = (x: T) Box<T> { Box<T>( n: 0 ) }\ntest* = () i32 { b := wrap(5)  0 }",
        should_pass: true,
        kind: "",
    ), VerdictCase(
        src: "test* = () i32 { a: i32 := 0 - 1  b: u32 := 1  (a < b).match ({ true => 1, false => 0 }) }",
        should_pass: false,
        kind: "",
    ), VerdictCase(
        src: "test* = () i32 { a: i64 := 0 - 1  b: u64 := 1  (a == b).match ({ true => 1, false => 0 }) }",
        should_pass: false,
        kind: "",
    ), VerdictCase(
        src: "test* = () i32 { n: u64 := 5  (n < 10).match ({ true => 1, false => 0 }) }",
        should_pass: true,
        kind: "",
    ), VerdictCase(
        src: "test* = () i32 { a: u8 := 97  (a == 'a').match ({ true => 1, false => 0 }) }",
