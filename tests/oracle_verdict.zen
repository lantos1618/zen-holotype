        should_pass: false,
        kind: "parse",
    ), VerdictCase(
        src: "test* = () i32 { 0o }",
        should_pass: false,
        kind: "parse",
    ), VerdictCase(
        src: "test* = () i32 { 0x }",
        should_pass: false,
        kind: "parse",
    ), VerdictCase(
        // Q4: an unterminated `/* */` block comment now carets its opening `/*` (was positionless).
        src: "test* = () i32 { 0 }\n/* unterminated\n",
        should_pass: false,
        kind: "parse",
    ), VerdictCase(
        // a valid radix literal + a valid block comment still lex correctly (no over-rejection).
        src: "test* = () i32 { /* hi */ 0xFF_FF + 0b1010 + 0o17 }",
