{ Allocator, malloc, free } = std.mem.alloc
halloc = std.mem.heap
{ Result, IoError } = std.core.result
maps = std.collections.map
LimitAlloc: { left: i32 }
LimitAlloc.impl(Allocator, {
    acquire = (a: MutPtr<LimitAlloc>, n: i64) RawPtr<u8> {
        (a.left > 0).match ({
            true => {
                a.left = a.left - 1
                malloc(n)
            },
            false => null_ptr()
        })
    }
    resize = (a: MutPtr<LimitAlloc>, p: RawPtr<u8>, n: i64) RawPtr<u8> { null_ptr() }
    release = (a: MutPtr<LimitAlloc>, p: RawPtr<u8>) void { free(p) }
})
success = () i32 {
    m := halloc.system()
    a := m.addr()
    r0: Result<maps.Map<i32>, IoError> := maps.try_of(a, "x", 1)
    r0.match ({
        .Ok(w0) => {
            r1: Result<maps.Map<i32>, IoError> := w0.try_put(a, "y", 2)
            r1.match ({
                .Ok(w) => {
                    n := w.get("x", 0) + w.get("y", 0)
                    w.free(a)
                    n
                },
                .Err(e) => 90
            })
        },
        .Err(e) => 91
    })
}
failure = () i32 {
    lim := LimitAlloc(left: 2)
    a := lim.addr()
    r0: Result<maps.Map<i32>, IoError> := maps.try_of(a, "a", 4)
    r0.match ({
        .Ok(w) => {
            r1: Result<maps.Map<i32>, IoError> := w.try_put(a, "b", 5)
            r1.match ({
                .Ok(w2) => {
                    w2.free(a)
                    80
                },
                .Err(e) => {
                    n := w.get("a", 0)
                    w.free(a)
                    n
                }
            })
        },
        .Err(e) => 81
    })
}
main = () i32 {
    n := success() + failure()
    (n == 84).match ({ true => 0, false => n })
}
