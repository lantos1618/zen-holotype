// Section B.6 — formatted/interpolated print. The std.text.fmt Printer builds a
// mixed-type line (i64 + str + f64 + bool + owned String) in ONE chained statement.
{ put } = std.text.fmt
halloc = std.mem.heap
{ new_in } = std.text.string
main = () i32 {
    x: i64 := 3
    y: str := "hello"
    z: f64 := 3.14
    put("x=").i(x).s(" y=").s(y).s(" z=").f(z).nl()
    count: i64 := 5
    put("the").s(": ").i(count).nl()
    flag: bool := true
    put("ok=").b(flag).nl()
    alloc := halloc.gpa()
    a := alloc.addr()
    g := a.new_in().append_in(a, "world")
    put("g=").owned(g).sp().i(count).nl()
    g.free_in(a)
    0
}
