// User enums: a leading-dot ctor learns its enum from the expected type, then
// the variant's payload is checked with the same fits() as everything else.
pub Status: Idle, Busy(i32)

pub mk_idle = () Status { .Idle() }                  //~ PASS
pub mk_busy = (n: i32) Status { .Busy(n) }           //~ PASS

// an i32 literal payload is fine; bool is not (no widening to i32)
pub busy_lit = () Status { .Busy(5) }                //~ PASS
pub busy_bad = () Status { .Busy(true) }             //~ FAIL bool

pub no_such_variant = () Status { .Done() }          //~ FAIL no variant '.Done'
pub payload_on_unit = () Status { .Idle(1) }         //~ FAIL takes no payload
pub missing_payload = () Status { .Busy() }          //~ FAIL takes one payload
