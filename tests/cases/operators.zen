// Arithmetic (+ - *) requires numeric operands and widens to i64 if either is.
pub Vec: { len: i32, cap: i32 }

pub mul_ints  = (v: Ptr<Vec>) i32 { v.len * v.cap }   //~ PASS
pub widens    = (a: i64) i64 { a * 2 }                //~ PASS  (i64 * i32 -> i64)

pub ptr_math  = (v: Ptr<Vec>) i32 { v * v }           //~ FAIL numeric operands
pub bool_math = () i32 { true + 1 }                   //~ FAIL numeric operands
pub eq_result = () i32 { 1 == 1 }                     //~ FAIL bool

// comparisons (numeric -> bool), logical (bool -> bool), unary not
pub in_range  = (a: i32) bool { a >= 1 && a <= 9 }    //~ PASS
pub negate    = (a: bool) bool { !a }                 //~ PASS
pub less       = (v: Ptr<Vec>) bool { v.len < v.cap } //~ PASS

pub and_on_int = (a: i32) bool { a && true }          //~ FAIL bool operands
pub not_on_int = (a: i32) bool { !a }                 //~ FAIL bool operand
pub lt_on_bool = (a: bool) bool { a < a }             //~ FAIL numeric operands
