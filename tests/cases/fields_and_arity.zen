// Field access (auto-deref through a pointer) and call arity.
pub Vec: { len: i32, cap: i32 }

pub area = (v: Ptr<Vec>) i32 { v.len * v.cap }            //~ PASS

pub no_such_field = (v: Ptr<Vec>) i32 { v.depth }         //~ FAIL no field 'depth'

pub one_arg = (v: Ptr<Vec>) i32 { v.len }
pub wrong_arity = (v: Ptr<Vec>) i32 { one_arg(v, v) }     //~ FAIL wants 1
