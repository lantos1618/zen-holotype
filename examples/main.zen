{ Rect } = core.rect
{ width, height, grow } = ops

area = (r: Ptr<Rect>) i32 { width(r) * height(r) }

// these two are SUPPOSED to fail the checker -> excluded from the build:
bad    = (r: Option<Ptr<Rect>>) i32 { width(r) }   // nullable rect into nonnull
dirbad = (r: Ptr<Rect>) i32 { grow(r) }            // read-only rect into mut-required

main = () i32 { area(addr(Rect { w: 3, h: 4 })) }   // 3 * 4 = 12
