// compiler.check_validate — read the resolved AST and count type errors.
// This pass validates calls, fields, matches, operands, indices, returns, assignment, and traits.
{ Expr, Stmt, Decl, Func, Param, Ty, StructDecl, EnumDecl, GenEnumDecl, Field, ImplData, TraitDefData, ArmData, MatchData, BlockData, LetData, VariantDef, AssignData, IndexSetData, IndexData, CallData, BinData, MakeStructData, FieldInit, FnTData, is_fnt, subst_ty_in, call, arm, dforeign, impl_cname_in, ti32, ti64, tu8, tf64, tbool, tstr, tnamed, tptr, tptr_k, tslice, tvoid, gstr_string, gstr_append, gstr_finish } = compiler.genc
{ Env, DeclIndex, build_decl_index, env_func, infer_expr, fits, ty_eq, is_str_t, ty_rank, is_f64_ty, enum_name, recv_name, call_targ, is_lit_numeric, is_void_ty, the_func, fn_params, params_env, tag_const, extend_env, arm_env, subj_variant_payload, is_bound, var_or_global, no_stmts, resolve_module, dbuf, tnode, loop_env, is_readonly_ptr_ty, is_nullable_ptr_ty, is_nonnull_ptr_ty } = compiler.check
{ Allocator, Malloc } = std.mem.alloc
{ Map, of } = std.collections.map    // DeclIndex fields are Map<i64>; .get/.put are UFCS methods, not imports
{ at, is_alnum } = std.text.bytes
{ eq, is_empty, starts_with, ends_with } = std.text.str
// Local fn is known iff the_func finds it by name (sentinel name is ""). The linear `is_known_fn`
// remains for the few decls-only callers; Env-reachable sites use `env_known_fn` (O(1) via the index).
is_known_fn = (decls: [Decl], fn: str) bool { eq(decls.the_func(fn).name, fn) }
env_known_fn = (env: Env, fn: str) bool { eq(env.env_func(fn).name, fn) }
env_params = (env: Env, fn: str) [Param] { env.env_func(fn).params }
// O(1) indexed struct presence/field lookups (Env carries the decl index).
env_is_struct = (env: Env, name: str) bool { env.didx.struct_idx.get(name, 0 - 1) >= 0 }
env_struct_fields = (env: Env, name: str) [Field] {
    i := env.didx.struct_idx.get(name, 0 - 1)
    (i >= 0 && i < env.decls.len).match ({ true => env.decls[i].match ({
        .DStruct(sd) => sd.fields,
        _            => no_fields(),
    }), false => no_fields() })
}
// O(1) for concrete struct/enum names (the common case); only generics fall back to the linear scan.
env_named_declared = (env: Env, n: str) bool { (env.didx.struct_idx.get(n, 0 - 1) >= 0 || env.didx.enum_idx.get(n, 0 - 1) >= 0).match ({ true => true, false => env.decls.named_declared(n) }) }
// Uninferable types are skipped so validation does not false-reject imported/generic residue.
is_uninferable = (t: Ty) bool {
    t.match ({
        .Void     => true,
        .Slice(e) => load(e).is_void_ty(),
        .Ptr(pd)  => load(pd.pointee).is_void_ty(),
        _         => false,
    })
}
// Undeclared Named types are treated as uninferable template residue.
named_declared = (decls: [Decl], n: str) bool {
    found := false
    decls.loop((h, i, d) {
        found = d.match ({
            .DStruct(sd)   => eq(sd.name, n).match ({ true => true, false => found }),
            .DEnum(ed)     => eq(ed.name, n).match ({ true => true, false => found }),
            .DGenStruct(g) => eq(g.name, n).match ({ true => true, false => found }),
            .DGenEnum(g)   => eq(g.name, n).match ({ true => true, false => found }),
            _              => found,
        })
    })
    found
}
// A type the validator can't pin down concretely, so fit-checks against it stay lenient: an
// uninferable residue, an UNDECLARED Named (a generic type param like `T`), a Ptr/Slice WHOSE element
// is itself unknown (`Ptr<T>`, `[T]`), or a generic INSTANCE (`Result<Mailbox, IoError>`) whose
// concrete decl only exists after monomorphization.
// the narrow int/float widths arrive as Named("u32") etc. (no Ty variant), but they ARE valid
// primitives that genc lowers to C types — so the unknown-type pass must treat them as KNOWN.
is_prim_width = (n: str) bool { eq(n, "i8") || eq(n, "i16") || eq(n, "u16") || eq(n, "u32") || eq(n, "u64") || eq(n, "f32") }
unknown_ty = (env: Env, t: Ty) bool {
    t.is_uninferable().match ({ true => true, false => t.match ({
        .Named(n)   => env.env_named_declared(n).match ({ true => false, false => true }),
        .Ptr(pd)    => env.unknown_ty(load(pd.pointee)),
        .Slice(e)   => env.unknown_ty(load(e)),
        // A generic instance is unknown ONLY while a type-arg is still unresolved (an unbound
        // tparam / void residue): its concrete decl appears only after that arg is pinned. Once
        // EVERY arg is concrete (`Box<i32>`), the instance is fully known and its mangled name
        // (`Box_i32`) is authoritative — so a real arg mismatch (`Box<i32>` vs `Box<u8>`) is a Zen
        // fit error here instead of leaking a `Box_u8` unknown-type to cc.
        .Generic(g) => env.gen_args_unknown(g.args),
        _           => false,
    }) })
}
gen_args_unknown = (env: Env, args: [Ty]) bool {
    f := false
    args.loop((h, i, t) {
        f = env.unknown_ty(t).match ({ true => true, false => f })
    })
    f
}
// FnT-vs-FnT signature compatibility: same arity, each param type and the return type equal —
// EXCEPT a position whose type is unknown (an unbound tparam like `S`, generic residue) stays lenient,
// since its concrete type is only known after monomorphization. (Function pointers are not implicitly
// convertible in C, so the CONCRETE positions demand exact structural equality.)
fnt_pos_eq = (env: Env, g: Ty, w: Ty) bool { env.unknown_ty(g) || env.unknown_ty(w) || g.ty_eq(w) }
fnt_tys_eq = (env: Env, ga: [Ty], wa: [Ty], i: i64) bool { (i >= ga.len).match ({ true => true, false => env.fnt_pos_eq(ga[i], wa[i]).match ({ true => env.fnt_tys_eq(ga, wa, i + 1), false => false }) }) }
fnt_sig_fits = (env: Env, g: Ty, w: Ty) bool {
    g.match ({
        .FnT(ga) => w.match ({
            .FnT(wa) => (ga.params.len == wa.params.len).match ({ true => env.fnt_tys_eq(ga.params, wa.params, 0).match ({ true => env.fnt_pos_eq(load(ga.ret), load(wa.ret)), false => false }), false => false }),
            _        => false,
        }),
        _        => false,
    })
}
fit_err = (env: Env, argty: Ty, pty: Ty) i32 {
    // An FnT param/field requires a matching FnT argument (named or lifted fn-value): wrong arity /
    // concrete param-type / return, or a non-fn value, is an error. Uninferable args (lambdas infer to
    // void, generic residue) stay lenient, as do tparam-typed FnT positions (deferred to mono).
    env.unknown_ty(argty).match ({ true => 0, false => pty.is_fnt().match ({ true => env.fnt_sig_fits(argty, pty).match ({ true => 0, false => 1 }), false => fits(argty, pty).match ({ true => 0, false => 1 }) }) })
}
// Constant-fold a numeric literal expr: an `.Int`, or a +/-/* of folded literals — a negative literal
// like `-1` lowers to the Bin `0 - 1`, so folding is what lets unsigned slots reject negatives.
// ok=false when not a foldable integer constant (Byte/Cond/var/shift/…) → range checks stay lenient.
//
// `v` is the i64 BIT PATTERN of the literal. A u64 magnitude above i64-max (e.g. u64 MAX) overflows
// `v` to a negative i64, so `v < 0` alone cannot tell a written magnitude from a real negative. `neg`
// records the SEMANTIC sign: a bare `.Int` is a non-negative written magnitude (neg=false) even when
// `v` wrapped negative; only a subtraction/negation that yields a negative result sets neg=true. That
// lets `x: u64 := 18446744073709551615` fit while `x: u64 := -1` (i.e. `0 - 1`) is still rejected.
LitVal*: {
    ok: bool,
    v: i64,
    neg: bool,
}
lit_binop = (op: str, l: i64, r: i64) LitVal {
    eq(op, "+").match ({ true => LitVal(
        ok: true,
        v: l + r,
        neg: l + r < 0,
    ), false => eq(op, "-").match ({ true => LitVal(
        ok: true,
        v: l - r,
        neg: l - r < 0,
    ), false => eq(op, "*").match ({ true => LitVal(
        ok: true,
        v: l * r,
        neg: l * r < 0,
    ), false => LitVal(
        ok: false,
        v: 0,
        neg: false,
    ) }) }) })
}
lit_val = (e: Ptr<Expr>) LitVal {
    load(e).match ({
        .Int(n) => LitVal(
            ok: true,
            v: n,
            neg: false,
        ),
        .Bin(b) => {
            l := b.lhs.lit_val()
            r := b.rhs.lit_val()
            (l.ok && r.ok).match ({ true => lit_binop(b.op, l.v, r.v), false => LitVal(
                ok: false,
                v: 0,
                neg: false,
            ) })
        },
        _       => LitVal(
            ok: false,
            v: 0,
            neg: false,
        ),
    })
}
// The narrow widths arrive as Named("i8")/Named("u32")/… (no Ty variant); range-check them by name.
// u64 holds values an i64 can't represent as a positive `n`, so its upper bound cannot be checked in
// i64; any non-negative literal fits (every i64 bit pattern is a valid u64). `neg` rejects `-1` etc.
named_int_range_ok = (nm: str, n: i64, neg: bool) bool { eq(nm, "i8").match ({ true => n >= 0 - 128 && n <= 127, false => eq(nm, "i16").match ({ true => n >= 0 - 32768 && n <= 32767, false => eq(nm, "u16").match ({ true => n >= 0 && n <= 65535, false => eq(nm, "u32").match ({ true => n >= 0 && n <= 4294967295, false => eq(nm, "u64").match ({ true => neg.match ({ true => false, false => true }), false => true }) }) }) }) }) }
lit_range_ok = (t: Ty, n: i64, neg: bool) bool {
    t.match ({
        .U8        => n >= 0 && n <= 255,
        .I32       => n >= 0 - 2147483648 && n <= 2147483647,
        .I64       => true,
        .Named(nm) => nm.named_int_range_ok(n, neg),
        _          => true,
    })
}
// Numeric literals fit numeric slots only when in range (constant-folded; lenient on non-constants).
lit_fits = (e: Ptr<Expr>, t: Ty) bool {
    lv := e.lit_val()
    lv.ok.match ({ true => t.lit_range_ok(lv.v, lv.neg), false => true })
}
// the narrow widths are Named, so ty_rank can't see them — recognize them as int slots here.
is_int_width = (n: str) bool { eq(n, "i8") || eq(n, "i16") || eq(n, "u16") || eq(n, "u32") || eq(n, "u64") }
is_int_slot = (t: Ty) bool {
    t.match ({
        .Named(n) => is_int_width(n),
        _         => t.ty_rank() >= 0,
    })
}
// Authoritative verdict for a numeric LITERAL flowing into an int slot: 0 = fits, 1 = overflow,
// -1 = not a literal-into-int-slot (caller falls back to its structural fit logic). This MUST take
// precedence over the unknown_ty leniency, else `x: i8 := 200` (i8 is an undeclared Named → "unknown")
// would silently pass and truncate at cc.
lit_slot_verdict = (e: Ptr<Expr>, t: Ty) i32 { (e.is_lit_numeric() && t.is_int_slot()).match ({ true => e.lit_fits(t).match ({ true => 0, false => 1 }), false => 0 - 1 }) }
// does a type MENTION an (unbound) generic type param? recurses Ptr/Slice/Generic-args. Concrete
// params (bool/Box/i32/…) do NOT mention a tparam → they are still arg/field-checked; only slots
// typed by the callee's own tparam are skipped (their concrete type is known only after mono).
tys_mention_tparam = (tps: [Param], ts: [Ty]) bool {
    f := false
    ts.loop((h, i, t) {
        f = tps.ty_mentions_tparam(t).match ({ true => true, false => f })
    })
    f
}
ty_mentions_tparam = (tps: [Param], t: Ty) bool {
    t.match ({
        .Named(n)   => tps.names_has(n),
        .Ptr(pd)    => tps.ty_mentions_tparam(load(pd.pointee)),
        .Slice(e)   => tps.ty_mentions_tparam(load(e)),
        .Generic(g) => tps.tys_mention_tparam(g.args),
        _           => false,
    })
}
// an argument check, given the callee's tparams: a slot typed by a tparam is skipped; a CONCRETE slot
// of a generic fn is still checked (so `gen2(x: T, b: Box)` rejects a non-Box second arg).
arg_err_at = (env: Env, tps: [Param], params: [Param], i: i32, ar: Expr) i32 {
    (i < params.len).match ({ true => tps.ty_mentions_tparam(params[i].ty).match ({ true => 0, false => {
        lv := ar.addr().lit_slot_verdict(params[i].ty)
        (lv >= 0).match ({ true => lv, false => env.fit_err(env.infer_expr(ar.addr()), params[i].ty) })
    } }), false => 0 })
}
arg_type_errs = (env: Env, tps: [Param], params: [Param], args: [Expr]) i32 {
    acc := 0
    args.loop((h, i, ar) {
        acc = acc + env.arg_err_at(tps, params, i, ar)
    })
    acc
}
names_has = (names: [Param], fn: str) bool {
    found := false
    names.loop((h, i, n) {
        found = eq(n.name, fn).match ({ true => true, false => found })
    })
    found
}
is_imported = (decls: [Decl], fn: str) bool {
    found := false
    decls.loop((h, i, d) {
        found = d.match ({
            .DImport(im) => im.names.names_has(fn).match ({ true => true, false => found }),
            _            => found,
        })
    })
    found
}
// Trait methods can remain unresolved in generic bodies until monomorphization.
is_trait_method = (decls: [Decl], fn: str) bool {
    found := false
    decls.loop((h, i, d) {
        found = d.match ({
            .DImpl(im)         => im.methods.names_has(fn).match ({ true => true, false => found }),
            .DTraitDefault(td) => eq(td.fn.name, fn).match ({ true => true, false => found }),    // a defaulted method an impl may OMIT
            _                  => found,
        })
    })
    found
}
// genc/runtime intrinsics with no Zen declaration.
is_intrinsic = (fn: str) bool { eq(fn, "load").match ({ true => true, false => eq(fn, "store").match ({ true => true, false => eq(fn, "addr").match ({ true => true, false => eq(fn, "assert_nonnull").match ({ true => true, false => eq(fn, "offset").match ({ true => true, false => eq(fn, "cstr").match ({ true => true, false => eq(fn, "slice").match ({ true => true, false => eq(fn, "malloc").match ({ true => true, false => eq(fn, "sizeof").match ({ true => true, false => eq(fn, "load_i64").match ({ true => true, false => eq(fn, "store_i64").match ({ true => true, false => eq(fn, "atomic_add_i64").match ({ true => true, false => eq(fn, "atomic_load_i64").match ({ true => true, false => eq(fn, "atomic_store_i64").match ({ true => true, false => eq(fn, "atomic_cas_i64").match ({ true => true, false => eq(fn, "atomic_fence").match ({ true => true, false => eq(fn, "null_ptr").match ({ true => true, false => eq(fn, "__str_eq").match ({ true => true, false => eq(fn, "__str_ne").match ({ true => true, false => eq(fn, "to_i32").match ({ true => true, false => eq(fn, "to_i64").match ({ true => true, false => eq(fn, "to_u8").match ({ true => true, false => eq(fn, "to_f64").match ({ true => true, false => false }) }) }) }) }) }) }) }) }) }) }) }) }) }) }) }) }) }) }) }) }) }) }) }    // Stage 3: panic-on-null guard, RawPtr<T> -> MutPtr<T>
intrinsic_arity = (fn: str) i32 { eq(fn, "__str_eq").match ({ true => 2, false => eq(fn, "__str_ne").match ({ true => 2, false => eq(fn, "store").match ({ true => 2, false => eq(fn, "offset").match ({ true => 2, false => eq(fn, "slice").match ({ true => 2, false => eq(fn, "null_ptr").match ({ true => 0, false => eq(fn, "atomic_add_i64").match ({ true => 2, false => eq(fn, "atomic_store_i64").match ({ true => 2, false => eq(fn, "atomic_cas_i64").match ({ true => 3, false => eq(fn, "atomic_fence").match ({ true => 0, false => eq(fn, "store_i64").match ({ true => 2, false => 1 }) }) }) }) }) }) }) }) }) }) }) }    // lowered str content equality (resolve_bin)
// A trait-method UFCS call defers to monomorphization ONLY when its receiver type is still
// unresolved (an unbound tparam / generic residue — `unknown_ty`): the concrete impl appears
// after the tparam is pinned. A CONCRETE receiver must resolve NOW — if dispatch finds no impl
// it is a `trait_recv_missing` error, not a deferral that leaks a bare method symbol to the linker.
is_unresolved_trait_call = (env: Env, c: CallData) bool { (c.args.len > 0).match ({ true => env.decls.is_trait_method(c.fn).match ({ true => eq(env.dispatch_name(c), c.fn).match ({ true => env.unknown_ty(env.infer_expr(c.args[0].addr())), false => false }), false => false }), false => false }) }
// A trait-method call whose CONCRETE receiver type implements no matching impl (dispatch finds no
// redirect) and that is neither a free function nor an imported name — would emit a bare `area`
// call and fail at the C linker. Reject it as a Zen receiver/trait-bound error instead.
trait_recv_missing = (env: Env, c: CallData) bool { (c.args.len > 0 && env.decls.is_trait_method(c.fn) && env.decls.is_imported(c.fn) == false && env.env_known_fn(c.fn) == false).match ({ true => eq(env.dispatch_name(c), c.fn) && env.unknown_ty(env.infer_expr(c.args[0].addr())) == false, false => false }) }
is_forbidden_raw_call = (c: CallData) bool { c.raw && eq(c.fn, "malloc") }    // explicit int -> f64 cast
// Intrinsic arity must be checked before emission.
check_call = (env: Env, c: CallData) i32 { c.is_forbidden_raw_call().match ({ true => 1, false => env.is_unresolved_trait_call(c).match ({ true => 0, false => env.env_known_fn(c.fn).match ({ true => env.call_errs(c), false => c.fn.is_intrinsic().match ({ true => (c.args.len == c.fn.intrinsic_arity()).match ({ true => 0, false => 1 }), false => (env.decls.is_imported(c.fn) || env.decls.is_trait_method(c.fn)).match ({ true => env.trait_recv_missing(c).match ({ true => 1, false => 0 }), false => env.var_or_global(c.fn).is_fnt().match ({ true => env.fnval_call_errs(c), false => 1 }) }) }) }) }) }) }    // null_ptr() takes no operands
store_writes_readonly = (env: Env, c: CallData) bool { (eq(c.fn, "store") && c.args.len == 2).match ({ true => env.infer_expr(c.args[0].addr()).is_readonly_ptr_ty(), false => false }) }    // atomic_add_i64(p, delta) -> new value
store_mut_err = (env: Env, c: CallData) i32 { env.store_writes_readonly(c).match ({ true => 1, false => 0 }) }    // atomic_store_i64(p, val) -> void
store_mut_kind = (env: Env, c: CallData) i32 { kv_at(env.store_writes_readonly(c).match ({ true => KPTRWRITE(), false => 0 }), c.pos) }    // atomic_cas_i64(p, expected, desired) -> bool
derefs_nullable = (env: Env, c: CallData) bool { ((eq(c.fn, "load") || eq(c.fn, "store") || eq(c.fn, "offset")) && c.args.len >= 1).match ({ true => env.infer_expr(c.args[0].addr()).is_nullable_ptr_ty(), false => false }) }    // atomic_fence() -> void
null_deref_err = (env: Env, c: CallData) i32 { env.derefs_nullable(c).match ({ true => 1, false => 0 }) }    // atomic_load_i64/load_i64/load/addr/cstr/malloc/sizeof/to_* (incl. to_f64) = 1
// Generic UFCS trait calls may need to defer even if a top-level fn has the same name.
// `@malloc` is not a magic allocator; use an ordinary foreign function or allocator API.
// Calls: local signatures are checked; imported/deferred trait names are accepted; unknowns reject.
// Stage 3 nullability: a `load`/`store`/`offset` whose pointer operand is a nullable `RawPtr<T>`
// (T != u8) that has NOT been proven non-null is rejected. The proof is carried by the TYPE: a
// `q := assert_nonnull(p)` yields `q: MutPtr<T>`, so `load(q)` sees a non-nullable kind and passes.
// `RawPtr<u8>` (the byte-buffer floor) and `Ptr`/`MutPtr` are never nullable, so they are exempt.
null_deref_kind = (env: Env, c: CallData) i32 { kv_at(env.derefs_nullable(c).match ({ true => KNULLDEREF(), false => 0 }), c.pos) }
// A call checks arity, then arg types. For a LOCAL generic only tparam-typed slots defer to mono;
// CONCRETE slots are still checked. An IMPORTED generic (a bodyless header) is skipped entirely — its
// param types still carry unbound tparams that cross-module inference can't resolve at the call site,
// so a strict check there false-rejects real code (text/fmt, concurrent/actor, core/slice).
is_imported_generic = (f: Func) bool { f.tparams.len > 0 && f.body.len == 0 }
// ── bounded generics: `f<A: Trait>` ─────────────────────────────────────────────
// A tparam carries a trait BOUND in its `ty` slot (Named(traitname)); plain tparams leave it Void.
tparam_bound = (tp: Param) str {
    tp.ty.match ({
        .Named(n) => n,
        _         => "",
    })
}
// Does some `Type.impl(Trait)` exist? i.e. a DImpl naming this type + trait.
type_impls_trait = (decls: [Decl], tyname: str, trname: str) bool {
    found := false
    decls.loop((h, i, d) {
        found = d.match ({
            .DImpl(im) => (eq(im.ty, tyname) && eq(im.trname, trname)).match ({ true => true, false => found }),
            _          => found,
        })
    })
    found
}
// Enforce ONE bounded tparam at a call site: bind A to its concrete targ, then require the bound.
// Conservative — only fires when A resolves to a known CONCRETE struct (allocators are structs);
// an unresolved / primitive / generic-passthrough targ defers (0), so plain generics never regress.
bound_err = (env: Env, f: Func, c: CallData, tp: Param) i32 {
    tr := tp.tparam_bound()
    is_empty(tr).match ({ true => 0, false => {
        tn := env.call_targ(f, c.args, tp.name).recv_name()    // unbounded tparam: nothing to check
        // concrete type A binds to
        (is_empty(tn) || env.decls.is_struct(tn) == false).match ({ true => 0, false => env.decls.type_impls_trait(tn, tr).match ({ true => 0, false => 1 }) })
    } })
}    // unresolved / not a concrete struct: defer
bound_errs = (env: Env, f: Func, c: CallData) i32 {
    acc := 0
    f.tparams.loop((h, i, tp) {
        acc = acc + env.bound_err(f, c, tp)
    })
    acc
}
call_errs = (env: Env, c: CallData) i32 {
    f := env.env_func(c.fn)
    ps := env.env_params(c.fn)
    (ps.len == c.args.len).match ({ true => f.is_imported_generic().match ({ true => 0, false => env.arg_type_errs(f.tparams, ps, c.args) }), false => 1 })
}
// An INDIRECT call through a fn-value (`f := g  f(x)`, or an FnT parameter `f`): check the arg COUNT
// against the FnT's params, then each CONCRETE param's arg type. Param positions typed by an unbound
// tparam stay lenient (generic FnT-param templates resolve those at mono). Without this, a wrong-arity
// indirect call slipped past SEMA and broke at cc ("too few arguments to function …").
fnt_arg_err_at = (env: Env, ptys: [Ty], i: i32, ar: Expr) i32 {
    (i < ptys.len).match ({ true => {
        lv := ar.addr().lit_slot_verdict(ptys[i])
        (lv >= 0).match ({ true => lv, false => env.unknown_ty(ptys[i]).match ({ true => 0, false => env.fit_err(env.infer_expr(ar.addr()), ptys[i]) }) })
    }, false => 0 })
}
fnt_arg_errs = (env: Env, ptys: [Ty], args: [Expr]) i32 {
    acc := 0
    args.loop((h, i, ar) {
        acc = acc + env.fnt_arg_err_at(ptys, i, ar)
    })
    acc
}
fnval_call_errs = (env: Env, c: CallData) i32 {
    env.var_or_global(c.fn).match ({
        .FnT(ft) => (ft.params.len == c.args.len).match ({ true => env.fnt_arg_errs(ft.params, c.args), false => 1 }),
        _        => 1,
    })
}
check_args = (env: Env, args: [Expr]) i32 {
    acc := 0
    args.loop((h, i, ar) {
        acc = acc + env.check_expr(ar.addr())
    })
    acc
}
check_arms = (env: Env, subjty: Ty, arms: [ArmData]) i32 {
    acc := 0
    arms.loop((h, i, ar) {
        acc = acc + env.a.arm_env(env, subjty, ar).check_expr(ar.body)
    })
    acc
}
match_result_ty = (env: Env, subjty: Ty, arms: [ArmData]) Ty {
    out := tvoid()
    arms.loop((h, i, ar) {
        aenv := env.a.arm_env(env, subjty, ar)
        got := aenv.infer_expr(ar.body)
        out = out.is_void_ty().match ({ true => (got.is_void_ty() || aenv.unknown_ty(got)).match ({ true => out, false => got }), false => out })
    })
    out
}
result_compatible = (want: Ty, got: Ty) bool { (want.is_str_t() && got.is_str_t()).match ({ true => true, false => (want.ty_rank() >= 0 && got.ty_rank() >= 0).match ({ true => true, false => want.ty_eq(got) }) }) }    // text/str/Cstr are one compatible family
cond_numlike = (t: Ty) bool { t.ty_rank() >= 0 || t.is_f64_ty() }
// A value/bool `.match` (and `if` expression) lowers to a ternary Cond at parse time, so its two
// value branches escape the enum-match arm checks above. Their result types must still be C-compatible
// — `c ? A : B` on incompatible types is a hard cc error. A numeric LITERAL branch is polymorphic and
// coerces to any numeric counterpart (mirrors cond_ty's deferral); void/unknown branches stay lenient.
cond_compatible = (d: CondData, tt: Ty, et: Ty) bool { d.t.is_lit_numeric().match ({ true => et.cond_numlike(), false => d.e.is_lit_numeric().match ({ true => tt.cond_numlike(), false => tt.result_compatible(et) }) }) }
// A one-armed bool `.match` (oa != 0) reaching the validator AS A Cond EXPRESSION is in VALUE position:
// statement-position conds were already lowered to `if` statements (the empty branch a no-op). In value
// position the missing branch has no value to produce → non-exhaustive. (Statement position never gets
// here, so the flag alone decides.) The kind layer reports this as a positioned `exhaustiveness` error.
cond_onearm_err = (d: CondData) i32 { (d.oa == 0).match ({ true => 0, false => 1 }) }
cond_result_err = (env: Env, d: CondData) i32 {
    tt := env.infer_expr(d.t)
    et := env.infer_expr(d.e)
    (tt.is_void_ty() || et.is_void_ty() || env.unknown_ty(tt) || env.unknown_ty(et)).match ({ true => 0, false => d.cond_compatible(tt, et).match ({ true => 0, false => 1 }) })
}
arm_result_err = (env: Env, subjty: Ty, want: Ty, ar: ArmData) i32 {
    aenv := env.a.arm_env(env, subjty, ar)
    got := aenv.infer_expr(ar.body)
    (want.is_void_ty() || got.is_void_ty() || aenv.unknown_ty(want) || aenv.unknown_ty(got)).match ({ true => 0, false => want.result_compatible(got).match ({ true => 0, false => 1 }) })
}
match_arm_result_errs = (env: Env, subjty: Ty, arms: [ArmData]) i32 {
    want := env.match_result_ty(subjty, arms)
    acc := 0
    arms.loop((h, i, ar) {
        acc = acc + env.arm_result_err(subjty, want, ar)
    })
    acc
}
// Early returns inside value-position block arms would be dropped by expression emission.
early_returns = (stmts: [Stmt]) bool {
    found := false
    stmts.loop((h, i, st) {
        found = (i < stmts.len - 1).match ({ true => st.match ({
            .Return(r) => true,
            _          => found,
        }), false => found })
    })
    found
}
expr_drops_return = (e: Ptr<Expr>) i32 {
    load(e).match ({
        .Block(b) => b.stmts.early_returns().match ({ true => 1, false => 0 }),
        _         => 0,
    })
}
arm_return_errs = (arms: [ArmData]) i32 {
    acc := 0
    arms.loop((h, i, ar) {
        acc = acc + ar.body.expr_drops_return()
    })
    acc
}
check_inits = (env: Env, inits: [FieldInit]) i32 {
    acc := 0
    inits.loop((h, i, fi) {
        acc = acc + env.check_expr(fi.value)
    })
    acc
}
// Struct literals check known fields and value fits; imported/generic literals stay lenient.
no_fields = () [Field] { slice(null_ptr(), 0) }
is_struct = (decls: [Decl], name: str) bool {
    f := false
    decls.loop((h, i, d) {
        f = d.match ({
            .DStruct(sd) => eq(sd.name, name).match ({ true => true, false => f }),
            _            => f,
        })
    })
    f
}
struct_fields = (decls: [Decl], name: str) [Field] {
    found := no_fields()
    decls.loop((h, i, d) {
        found = d.match ({
            .DStruct(sd) => eq(sd.name, name).match ({ true => sd.fields, false => found }),
            _            => found,
        })
    })
    found
}
has_field = (fields: [Field], fname: str) bool {
    f := false
    fields.loop((h, i, fl) {
        f = eq(fl.name, fname).match ({ true => true, false => f })
    })
    f
}
field_in = (fields: [Field], fname: str) Ty {
    found := tvoid()
    fields.loop((h, i, fl) {
        found = eq(fl.name, fname).match ({ true => fl.ty, false => found })
    })
    found
}
field_fit_err = (env: Env, fields: [Field], fi: FieldInit) i32 {
    fty := fields.field_in(fi.name)
    lv := fi.value.lit_slot_verdict(fty)    // a numeric literal must fit the field width
    (lv >= 0).match ({ true => lv, false => env.fit_err(env.infer_expr(fi.value), fty) })
}
init_err = (env: Env, fields: [Field], fi: FieldInit) i32 { fields.has_field(fi.name).match ({ true => env.field_fit_err(fields, fi), false => 1 }) }    // unknown field -> 1
struct_init_errs = (env: Env, fields: [Field], inits: [FieldInit]) i32 {
    acc := 0
    inits.loop((h, i, fi) {
        acc = acc + env.init_err(fields, fi)
    })
    acc
}
// generic-struct-literal support: look up the GenStructDecl by base name; a field typed by a struct
// tparam stays lenient, a CONCRETE field (bool/i32/Box/…) is still fit-checked.
cv_no_params = () [Param] { slice(null_ptr(), 0) }
cv_is_gen_struct = (decls: [Decl], name: str) bool {
    f := false
    decls.loop((h, i, d) {
        f = d.match ({
            .DGenStruct(g) => eq(g.name, name).match ({ true => true, false => f }),
            _              => f,
        })
    })
    f
}
gen_struct_fields = (decls: [Decl], name: str) [Field] {
    found := no_fields()
    decls.loop((h, i, d) {
        found = d.match ({
            .DGenStruct(g) => eq(g.name, name).match ({ true => g.fields, false => found }),
            _              => found,
        })
    })
    found
}
gen_struct_tparams = (decls: [Decl], name: str) [Param] {
    found := cv_no_params()
    decls.loop((h, i, d) {
        found = d.match ({
            .DGenStruct(g) => eq(g.name, name).match ({ true => g.tparams, false => found }),
            _              => found,
        })
    })
    found
}
// A generic-struct literal `Box<i32>(v: …)` binds each tparam to its explicit targ, so a field typed
// by a tparam (`v: T`) becomes CONCRETE (`v: i32`) and IS fit-checked — closing the hole where a wrong
// value (`Box<i32>(v: P(…))`) slipped past SEMA and broke at cc. A field whose type stays a tparam after
// substitution (no matching targ) remains lenient, deferred to monomorphization.
gen_field_fit_err = (env: Env, tps: [Param], targs: [Ty], fields: [Field], fi: FieldInit) i32 {
    fty := fields.field_in(fi.name)
    cty := (targs.len == tps.len).match ({ true => env.a.subst_ty_in(tps, targs, fty), false => fty })
    tps.ty_mentions_tparam(cty).match ({ true => 0, false => {
        lv := fi.value.lit_slot_verdict(cty)    // still a tparam -> lenient
        // a numeric literal must fit the field width
        (lv >= 0).match ({ true => lv, false => env.fit_err(env.infer_expr(fi.value), cty) })
    } })
}    // a concrete field -> check the fit
gen_struct_init_errs = (env: Env, tps: [Param], targs: [Ty], fields: [Field], inits: [FieldInit]) i32 {
    acc := 0
    inits.loop((h, i, fi) {
        acc = acc + fields.has_field(fi.name).match ({ true => env.gen_field_fit_err(tps, targs, fields, fi), false => 1 })
    })
    acc
}
inits_has = (inits: [FieldInit], name: str) bool {
    f := false
    inits.loop((h, i, fi) {
        f = eq(fi.name, name).match ({ true => true, false => f })
    })
    f
}    // is this field named in the literal?
// A NON-NULL pointer field (`Ptr<T>`/`MutPtr<T>`) left out of the literal would be default-zeroed to a
// null that the type promises can never happen → a deref segfault the checker currently misses. Require it.
field_missing_nonnull_ptr = (fields: [Field], inits: [FieldInit]) i32 {
    acc := 0
    fields.loop((h, i, fl) {
        acc = acc + (fl.ty.is_nonnull_ptr_ty() && (inits.inits_has(fl.name) == false)).match ({ true => 1, false => 0 })
    })
    acc
}
// A repeated initializer for the same field (`Box(v: 5, v: 9)`) is almost certainly a mistake.
dup_init_errs = (inits: [FieldInit]) i32 {
    acc := 0
    inits.loop((h, i, fi) {
        earlier := false
        inits.loop((h2, j, fj) {
            earlier = (j < i && eq(fj.name, fi.name)).match ({ true => true, false => earlier })
        })
        acc = acc + earlier.match ({ true => 1, false => 0 })
    })
    acc
}
makestruct_err = (env: Env, m: MakeStructData) i32 { (m.targs.len > 0).match ({ true => env.decls.cv_is_gen_struct(m.ty).match ({ true => { gf := env.decls.gen_struct_fields(m.ty)  env.gen_struct_init_errs(env.decls.gen_struct_tparams(m.ty), m.targs, gf, m.inits) + gf.field_missing_nonnull_ptr(m.inits) + m.inits.dup_init_errs() }, false => 0 }), false => env.env_is_struct(m.ty).match ({ true => { sf := env.env_struct_fields(m.ty)  env.struct_init_errs(sf, m.inits) + sf.field_missing_nonnull_ptr(m.inits) + m.inits.dup_init_errs() }, false => 0 }) }) }    // a generic literal: check concrete fields
gen_base_of = (t: Ty) str {
    t.match ({
        .Generic(g) => g.name,    // unknown gen-struct (template residue) -> lenient
        // the BASE name of a generic-struct receiver (`Box` of `Box<i32>`), through a Ptr receiver.
        .Ptr(pd)    => load(pd.pointee).gen_base_of(),
        _           => "",
    })
}
// a primitive scalar has no fields, so `x.foo` on it is a hard error (C: "member in something not a struct").
is_scalar_prim = (t: Ty) bool {
    t.match ({
        .I32  => true,
        .I64  => true,
        .U8   => true,
        .F64  => true,
        .Bool => true,
        _     => false,
    })
}
// Field access checks known concrete struct receivers AND generic-struct instances (field names don't
// depend on the type args, so `Box<i32>.nope` is rejected the same as `Box.nope` would be).
member_err = (env: Env, obj: Ptr<Expr>, field: str) i32 {
    obj.is_lit_numeric().match ({ true => 1, false => {
        rty := env.infer_expr(obj)
        sname := rty.enum_name()
        env.env_is_struct(sname).match ({ true => env.env_struct_fields(sname).has_field(field).match ({ true => 0, false => 1 }), false => {
            base := rty.gen_base_of()
            (is_empty(base) == false && env.decls.cv_is_gen_struct(base)).match ({ true => env.decls.gen_struct_fields(base).has_field(field).match ({ true => 0, false => 1 }), false => rty.is_scalar_prim().match ({ true => 1, false => 0 }) })
        } })
    } })
}    // scalars have no fields; other unknowns (residue) stay lenient
// Enum matches must be exhaustive and have no duplicate arms.
no_variants = () [VariantDef] { slice(null_ptr(), 0) }
enum_variants = (decls: [Decl], ename: str) [VariantDef] {
    found := no_variants()
    decls.loop((h, i, d) {
        found = d.match ({
            .DEnum(ed) => eq(ed.name, ename).match ({ true => ed.variants, false => found }),
            _          => found,
        })
    })
    found
}
has_wildcard = (arms: [ArmData]) bool {
    f := false
    arms.loop((h, i, a) {
        f = eq(a.variant, "_").match ({ true => true, false => f })
    })
    f
}
arm_covers = (arms: [ArmData], vname: str) bool {
    f := false
    arms.loop((h, i, a) {
        f = eq(a.variant, vname).match ({ true => true, false => f })
    })
    f
}
missing_count = (variants: [VariantDef], arms: [ArmData]) i32 {
    n := 0
    variants.loop((h, i, v) {
        n = arms.arm_covers(v.name).match ({ true => n, false => n + 1 })
    })
    n
}
exhaustive_err = (env: Env, m: MatchData) i32 {
    vs := env.decls.enum_variants(m.ename)
    (vs.len == 0).match ({ true => 0, false => (vs.missing_count(m.arms) > 0).match ({ true => 1, false => 0 }) })
}
dup_before = (arms: [ArmData], vname: str, upto: i32) bool {
    f := false
    arms.loop((h, i, a) {
        f = (i < upto).match ({ true => eq(a.variant, vname).match ({ true => true, false => f }), false => f })
    })
    f
}
dup_arm_errs = (arms: [ArmData]) i32 {
    n := 0
    arms.loop((h, i, a) {
        n = n + eq(a.variant, "_").match ({ true => 0, false => arms.dup_before(a.variant, i).match ({ true => 1, false => 0 }) })
    })
    n
}
// Reject constructors whose variant is not declared in the linked decl set.
enum_declares = (decls: [Decl], vn: str) bool {
    f := false
    decls.loop((h, i, d) {
        f = d.match ({
            .DEnum(ed)   => ed.variants.arm_known(vn).match ({ true => true, false => f }),
            .DGenEnum(g) => g.variants.arm_known(vn).match ({ true => true, false => f }),
            _            => f,
        })
    })
    f
}
mkenum_err = (env: Env, ty: str, variant: str) i32 { is_empty(ty).match ({ true => env.decls.enum_declares(variant).match ({ true => 0, false => 1 }), false => 0 }) }
// A constructed enum payload must fit the variant's declared payload type (`E.A("s")` where A(i32)).
// Inferred-enum form (empty ty) and tparam/unknown/void payloads stay lenient — generic variants like
// Result.Ok(x) resolve their payload type only after mono, so subj_variant_payload yields a tparam there.
enum_payload_err = (env: Env, mk: MakeEnumData) i32 {
    is_empty(mk.ty).match ({ true => 0, false => {
        pty := env.subj_variant_payload(tnamed(mk.ty), mk.variant)
        lv := mk.payload.lit_slot_verdict(pty)
        (lv >= 0).match ({ true => lv, false => {
            vt := env.infer_expr(mk.payload)
            (pty.is_void_ty() || env.unknown_ty(pty) || env.unknown_ty(vt)).match ({ true => 0, false => fits(vt, pty).match ({ true => 0, false => 1 }) })
        } })
    } })
}
// Every non-wildcard arm must name a declared variant.
arm_known = (vs: [VariantDef], vname: str) bool {
    f := false
    vs.loop((h, i, v) {
        f = eq(v.name, vname).match ({ true => true, false => f })
    })
    f
}
unknown_arm_errs = (env: Env, m: MatchData) i32 {
    vs := env.decls.enum_variants(m.ename)
    n := 0
    (vs.len == 0).match ({ true => 0, false => {
        m.arms.loop((h, i, a) {
            n = n + eq(a.variant, "_").match ({ true => 0, false => vs.arm_known(a.variant).match ({ true => 0, false => 1 }) })
        })
        n
    } })
}
match_err = (env: Env, m: MatchData) i32 {
    base := m.arms.has_wildcard().match ({ true => m.arms.dup_arm_errs(), false => env.exhaustive_err(m) + m.arms.dup_arm_errs() })
    base + env.unknown_arm_errs(m)
}
// Operand checking stays lenient for uninferable operands.
is_arith_op = (op: str) bool {
    b := op.at(0)
    b == '+' || b == '-' || b == '*' || b == '/' || b == '%'
}
is_logic_op = (op: str) bool { eq(op, "&&") || eq(op, "||") }
// Strict comparisons require numeric operands; shifts are separate bitwise ops.
is_cmp_op_v = (op: str) bool { eq(op, "<") || eq(op, ">") || eq(op, "<=") || eq(op, ">=") }
is_bitwise_op = (op: str) bool { eq(op, "&") || eq(op, "|") || eq(op, "^") || eq(op, "<<") || eq(op, ">>") }
is_bool_ty = (t: Ty) bool {
    t.match ({
        .Bool => true,
        _     => false,
    })
}
non_numeric = (env: Env, e: Ptr<Expr>) bool {
    t := env.infer_expr(e)
    env.unknown_ty(t).match ({ true => false, false => (t.ty_rank() >= 0).match ({ true => false, false => true }) })
}
non_bool = (env: Env, e: Ptr<Expr>) bool {
    t := env.infer_expr(e)
    env.unknown_ty(t).match ({ true => false, false => t.is_bool_ty().match ({ true => false, false => true }) })
}
// f64 operators are strict: no implicit int<->float mixing.
is_eq_op_v = (op: str) bool { eq(op, "==") || eq(op, "!=") }
f64_op_ok = (op: str) bool { eq(op, "+") || eq(op, "-") || eq(op, "*") || eq(op, "/") || op.is_cmp_op_v() }
f64_side_ok = (env: Env, t: Ty) bool { t.is_f64_ty() || env.unknown_ty(t) }
f64_operand_err = (env: Env, op: str, lt: Ty, rt: Ty) i32 { (env.f64_side_ok(lt) && env.f64_side_ok(rt) && op.f64_op_ok()).match ({ true => 0, false => 1 }) }
// Any f64 side routes to the f64 surface; otherwise use integer numeric rules.
num_operand_err = (env: Env, b: BinData) i32 {
    lt := env.infer_expr(b.lhs)
    rt := env.infer_expr(b.rhs)
    (lt.is_f64_ty() || rt.is_f64_ty()).match ({ true => env.f64_operand_err(b.op, lt, rt), false => (env.non_numeric(b.lhs) || env.non_numeric(b.rhs)).match ({ true => 1, false => 0 }) })
}
// the two sides of an ==/!= must share a comparable category: both numeric, both bool, both str-family,
// both pointer, or the same nominal type. (unknown sides pass — no false-reject on template residue.)
is_ptr_ty = (t: Ty) bool {
    t.match ({
        .Ptr(pd) => true,
        _        => false,
    })
}
same_eq_category = (a: Ty, b: Ty) bool { a.ty_rank() >= 0 && b.ty_rank() >= 0 || a.is_bool_ty() && b.is_bool_ty() || a.is_str_t() && b.is_str_t() || a.is_ptr_ty() && b.is_ptr_ty() }
// a NOMINAL ==: only types genc can compare with C's `==` — an enum (tag compare) or a Named non-struct.
// structs and slices CANNOT (`a == b` on two structs is a hard cc error), so they're excluded here.
eq_nominal_ok = (env: Env, a: Ty, b: Ty) bool {
    a.ty_eq(b) && a.match ({
        .Named(n) => env.env_is_struct(n).match ({ true => false, false => true }),
        _         => false,
    })
}
// Equality rejects f64/non-f64 mixes and heterogeneous comparisons (`"hi" == 5`, `true == 5`).
eq_mix_err = (env: Env, b: BinData) i32 {
    lt := env.infer_expr(b.lhs)
    rt := env.infer_expr(b.rhs)
    (lt.is_f64_ty() || rt.is_f64_ty()).match ({ true => (env.f64_side_ok(lt) && env.f64_side_ok(rt)).match ({ true => 0, false => 1 }), false => (env.unknown_ty(lt) || env.unknown_ty(rt)).match ({ true => 0, false => (lt.same_eq_category(rt) || env.eq_nominal_ok(lt, rt)).match ({ true => 0, false => 1 }) }) })
}
// A comparison between a SIGNED int and an UNSIGNED int of rank >= 8 (u16/u32/u64) silently uses C's
// unsigned promotion — `a:i32=-1 < b:u32=1` evaluates FALSE. Reject it. NARROW by design: u8 is
// excluded so byte/char compares (`b == 'a'`) stay fine (u8 always promotes to a signed int safely).
is_signed_int = (t: Ty) bool {
    t.match ({
        .I32      => true,
        .I64      => true,
        .Named(n) => eq(n, "i8") || eq(n, "i16") || eq(n, "i32") || eq(n, "i64"),
        _         => false,
    })
}
is_unsigned_wide = (t: Ty) bool {
    t.match ({
        .Named(n) => eq(n, "u16") || eq(n, "u32") || eq(n, "u64"),
        _         => false,
    })
}
sign_mismatch = (l: Ty, r: Ty) bool { l.is_signed_int() && r.is_unsigned_wide() || l.is_unsigned_wide() && r.is_signed_int() }
// A numeric LITERAL operand is polymorphic and coerces to the other side's type (`n: u64 < 10` is
// fine), so only flag when BOTH sides are non-literal values of genuinely mismatched signedness.
signcmp_err = (env: Env, b: BinData) i32 { ((b.op.is_cmp_op_v() || b.op.is_eq_op_v()) && b.lhs.is_lit_numeric() == false && b.rhs.is_lit_numeric() == false).match ({ true => env.infer_expr(b.lhs).sign_mismatch(env.infer_expr(b.rhs)).match ({ true => 1, false => 0 }), false => 0 }) }
operand_err = (env: Env, b: BinData) i32 { b.op.is_logic_op().match ({ true => (env.non_bool(b.lhs) || env.non_bool(b.rhs)).match ({ true => 1, false => 0 }), false => (b.op.is_arith_op() || b.op.is_bitwise_op() || b.op.is_cmp_op_v()).match ({ true => env.num_operand_err(b) + env.signcmp_err(b), false => b.op.is_eq_op_v().match ({ true => env.eq_mix_err(b) + env.signcmp_err(b), false => 0 }) }) }) }
// Indexing needs a slice and numeric index; uninferable types skip.
is_slice_ty = (t: Ty) bool {
    t.match ({
        .Slice(e) => true,
        _         => false,
    })
}
non_slice = (env: Env, e: Ptr<Expr>) bool {
    t := env.infer_expr(e)
    env.unknown_ty(t).match ({ true => false, false => t.is_slice_ty().match ({ true => false, false => true }) })
}
index_err = (env: Env, ix: IndexData) i32 { (env.non_slice(ix.seq) || env.non_numeric(ix.idx)).match ({ true => 1, false => 0 }) }
// Value-position blocks recurse into statement expressions; full env-threading stays in check_body.
check_block_stmt = (env: Env, st: Stmt) i32 {
    st.match ({
        .Let(l)      => env.check_expr(l.value) + env.let_fit_err(l) + env.let_needannot_err(l),
        .Assign(x)   => env.check_expr(x.target) + env.check_expr(x.value) + env.assign_err(x) + env.assign_ptr_write_err(x),
        .Return(r)   => env.check_expr(r) + env.ret_err(r),
        .ExprStmt(e) => env.check_expr(e),
        .If(f)       => env.check_expr(f.c),
        .While(w)    => env.check_expr(w.c),
        .IndexSet(x) => env.check_expr(x.seq) + env.check_expr(x.idx) + env.check_expr(x.value) + env.idxset_err(x),
    })
}
check_block = (env: Env, stmts: [Stmt]) i32 {
    acc := 0
    e := env
    stmts.loop((h, i, st) {
        acc = acc + e.check_block_stmt(st)
        e = e.a.extend_env(e, st)
    })
    acc
}
// Bare identifiers in value position must resolve to a local/global/function/import/trait/intrinsic.
var_err = (env: Env, name: str) i32 { (eq(name, "true") || eq(name, "false") || env.is_bound(name) || env.env_known_fn(name) || env.decls.is_imported(name) || env.decls.is_trait_method(name) || name.is_intrinsic() || env.decls.is_tag_const(env.a, name)).match ({ true => 0, false => 1 }) }
// Lowered statement-match tag constants count as generated names.
variant_tags_has = (vs: [VariantDef], a: MutPtr<Malloc>, ename: str, name: str) bool {
    found := false
    vs.loop((h, i, v) {
        found = eq(name, a.tag_const(ename, v.name)).match ({ true => true, false => found })
    })
    found
}
// A lowered match over a GENERIC enum instance compares against `<mangled>_<variant>` — e.g.
// `Result_i32_IoError_Err`. The concrete EnumDecl is created only at backend monomorphization, so the
// validator recognizes such a tag by shape: it starts with the gen-enum base name and ends with one
// of its variant names (`Result_…` + `…_Err`). Keeps lowered generic-enum guards from false-rejecting.
variant_affix = (a: MutPtr<Malloc>, lead: str, vn: str) str {
    s := a.gstr_string(64)
    s = s.gstr_append(a, lead)
    s = s.gstr_append(a, vn)
    s.gstr_finish(a)
}
gen_tag_match = (a: MutPtr<Malloc>, vs: [VariantDef], base: str, name: str) bool {
    found := false
    pre := a.variant_affix(base, "_")
    vs.loop((h, i, v) {
        found = (name.starts_with(pre) && name.ends_with(a.variant_affix("_", v.name))).match ({ true => true, false => found })
    })
    found
}
is_tag_const = (decls: [Decl], a: MutPtr<Malloc>, name: str) bool {
    found := false
    decls.loop((h, i, d) {
        found = d.match ({
            .DEnum(ed)   => ed.variants.variant_tags_has(a, ed.name, name).match ({ true => true, false => found }),
            .DGenEnum(g) => a.gen_tag_match(g.variants, g.name, name).match ({ true => true, false => found }),
            _            => found,
        })
    })
    found
}
// every element of a slice literal must fit the element type (inferred from the first item). genc
// types the emitted C array by that first element, so a CATEGORY mismatch (a str in an int slice)
// would be silently coerced under -w — a miscompile. Numeric elements stay lenient (C widens them),
// and unknown/generic-residue elements defer (fit_err handles both).
sl_elem_fit = (env: Env, ety: Ty, it: Expr) i32 {
    ity := env.infer_expr(it.addr())
    (ety.ty_rank() >= 0 && ity.ty_rank() >= 0).match ({ true => 0, false => env.fit_err(ity, ety) })
}
slicelit_err = (env: Env, items: [Expr]) i32 {
    (items.len == 0).match ({ true => 0, false => {
        ety := env.infer_expr(items[0].addr())
        acc := 0
        items.loop((h, i, it) {
            acc = acc + env.sl_elem_fit(ety, it)
        })
        acc
    } })
}
// ── narrowed LOOP/lambda-body walk: undefined BARE NAMES only ────────────────────────────────
// Loop bodies were never validated, so undefined names inside `.loop((h,i,v){…})` slipped past `check`
// and surfaced only at cc. This walk reports them — but ONLY for bare `Var` references (var_err, the
// same predicate top-level uses). It deliberately does NOT run fit / arg-type / operand checks, nor
// resolve call NAMES or struct FIELDS: a generic template's loop body legitimately calls methods on an
// unbound type param (`actor.receive`) and narrows str↔text, both valid pre-mono yet unresolvable here —
// flagging them would false-reject real stdlib. It still RECURSES through every sub-expression (and
// nested match-arm / loop / let binding envs) so a bare undefined name at any depth is caught.
lck_args = (env: Env, args: [Expr]) i32 {
    acc := 0
    args.loop((h, i, ar) {
        acc = acc + env.lck_expr(ar.addr())
    })
    acc
}
lck_inits = (env: Env, inits: [FieldInit]) i32 {
    acc := 0
    inits.loop((h, i, fi) {
        acc = acc + env.lck_expr(fi.value)
    })
    acc
}
lck_arms = (env: Env, subjty: Ty, arms: [ArmData]) i32 {
    acc := 0
    arms.loop((h, i, ar) {
        acc = acc + env.a.arm_env(env, subjty, ar).lck_expr(ar.body)
    })
    acc
}
lck_expr = (env: Env, e: Ptr<Expr>) i32 {
    load(e).match ({
        // only USER-authored names (pos > 0) are name-checked. Inliner-substituted refs (loop bindings,
        // spliced lets, param→arg) are rebuilt as position-less `vref`s whose binding structure the
        // validator's env doesn't perfectly reconstruct — re-checking them as "undefined" false-rejects.
        .Var(v)         => (v.pos > 0).match ({ true => env.var_err(v.name), false => 0 }),
        .Call(c)        => eq(c.fn, "sizeof").match ({ true => 0, false => env.lck_args(c.args) }),    // sizeof's arg is a TYPE name, not a value (mirrors check_expr)
        .SliceLit(sd)   => env.lck_args(sd.items),
        .Index(ix)      => env.lck_expr(ix.seq) + env.lck_expr(ix.idx),
        .Bin(b)         => env.lck_expr(b.lhs) + env.lck_expr(b.rhs),
        .Cond(d)        => env.lck_expr(d.c) + env.lck_expr(d.t) + env.lck_expr(d.e),
        .Member(m)      => env.lck_expr(m.obj),    // field NAME deferred (h.break_zk etc.)
        .Arrow(ar)      => env.lck_expr(ar.obj),
        .Match(m)       => {
            subjty := env.infer_expr(m.subj)
            env.lck_expr(m.subj) + env.lck_arms(subjty, m.arms)
        },
        .MakeEnum(mk)   => env.lck_expr(mk.payload),
        .MakeStruct(sd) => env.lck_inits(sd.inits),
        .Block(b)       => env.a.lck_body(env, b.stmts),
        .Loop(l)        => env.lck_expr(l.seq) + env.a.lck_body(env.a.loop_env(env, l), l.body),
        _               => 0,
    })
}
lck_stmt = (a: MutPtr<Malloc>, env: Env, st: Stmt) i32 {
    st.match ({
        .Let(l)      => env.lck_expr(l.value),
        .Assign(x)   => env.lck_expr(x.target) + env.lck_expr(x.value),
        .Return(r)   => env.lck_expr(r),
        .ExprStmt(e) => env.lck_expr(e),
        .If(f)       => env.lck_expr(f.c) + a.lck_body(env, f.then) + a.lck_body(env, f.els),
        .While(w)    => env.lck_expr(w.c) + a.lck_body(env, w.body),
        .IndexSet(x) => env.lck_expr(x.seq) + env.lck_expr(x.idx) + env.lck_expr(x.value),
    })
}
lck_body = (a: MutPtr<Malloc>, env: Env, body: [Stmt]) i32 {
    acc := 0
    e := env
    body.loop((h, i, st) {
        acc = acc + a.lck_stmt(e, st)
        e = a.extend_env(e, st)
    })
    acc
}
check_expr = (env: Env, e: Ptr<Expr>) i32 {
    load(e).match ({
        .Call(c)        => env.check_call(c) + env.store_mut_err(c) + env.null_deref_err(c) + eq(c.fn, "sizeof").match ({ true => 0, false => env.check_args(c.args) }),
        .SliceLit(sd)   => env.slicelit_err(sd.items),
        .Index(ix)      => env.check_expr(ix.seq) + env.check_expr(ix.idx) + env.index_err(ix),
        .Bin(b)         => env.check_expr(b.lhs) + env.check_expr(b.rhs) + env.operand_err(b),
        .Cond(d)        => env.check_expr(d.c) + env.check_expr(d.t) + env.check_expr(d.e) + d.t.expr_drops_return() + d.e.expr_drops_return() + env.cond_result_err(d) + d.cond_onearm_err(),
        .Member(m)      => env.check_expr(m.obj) + env.member_err(m.obj, m.field),
        .Arrow(ar)      => env.check_expr(ar.obj) + env.member_err(ar.obj, ar.field),
        .Match(m)       => {
            subjty := env.infer_expr(m.subj)
            env.check_expr(m.subj) + env.check_arms(subjty, m.arms) + env.match_err(m) + env.match_arm_result_errs(subjty, m.arms) + arm_return_errs(m.arms)
        },
        .MakeEnum(mk)   => env.check_expr(mk.payload) + env.mkenum_err(mk.ty, mk.variant) + env.enum_payload_err(mk),
        .Tag(t)         => env.mkenum_err(t.ty, t.variant),
        .MakeStruct(sd) => env.check_inits(sd.inits) + env.makestruct_err(sd),
        .Block(b)       => env.check_block(b.stmts),
        .Var(v)         => env.var_err(v.name),
        // A lowered foreach/loop: WALK the sequence and body (in the loop's element/index/handler binding
        // env) for UNDEFINED BARE NAMES. `.loop((h,i,v){…})` is THE iteration construct, so most newcomer
        // logic — and most undefined-name bugs — live here; skipping it let them reach cc as raw C / linker
        // errors. NARROWED to bare-name resolution (see lck_expr): fit/arg-type and call-NAME/field checks
        // stay deferred inside loops, because generic templates carry method calls on unbound type params
        // (`actor.receive`) and str↔text narrowings that are valid pre-mono but unresolvable here.
        .Loop(l)        => env.lck_expr(l.seq) + env.a.lck_body(env.a.loop_env(env, l), l.body),
        // A Lambda that SURVIVES resolution is a lambda used as a value the inliner couldn't splice:
        // a directly-passed HOF lambda is inlined away and a local-bound one is now spliced too (the
        // alias lowering), so a remaining Lambda was stored in a field / returned — no first-class
        // representation; reject it cleanly instead of leaking `zen__unlowered_lambda` into the C.
        .Lambda(lm)     => 1,
        _               => 0,
    })
}
// Return/assign/index-set checks only reject concrete mismatches.
ret_err = (env: Env, r: Ptr<Expr>) i32 {
    rt := env.infer_expr(r)
    lv := r.lit_slot_verdict(env.exp)    // a numeric literal return is decided by range
    (lv >= 0).match ({ true => lv, false => (env.unknown_ty(rt) || env.unknown_ty(env.exp) || env.exp.is_fnt()).match ({ true => 0, false => fits(rt, env.exp).match ({ true => 0, false => 1 }) }) })
}
// a function-VALUE return (declared return is a function type) is accepted structurally — ty_eq
// treats FnT as never-equal so fits() can't validate it; C checks the fn-ptr type (M1c).
assign_err = (env: Env, x: AssignData) i32 {
    vt := env.infer_expr(x.target)
    rt := env.infer_expr(x.value)
    lv := x.value.lit_slot_verdict(vt)
    (lv >= 0).match ({ true => lv, false => (env.unknown_ty(vt) || env.unknown_ty(rt)).match ({ true => 0, false => fits(rt, vt).match ({ true => 0, false => 1 }) }) })
}
// Stage 2 mutability, the field-write half: `b.v = …` where `b: Ptr<Box>` (read-only) writes through a
// non-writable pointer — the same hole `store()` guards, via Assign/Member. A `MutPtr<Box>` permits it
// (k_mut_ptr), and plain local/struct mutation (no pointer base) is untouched.
assign_ptr_write_err = (env: Env, x: AssignData) i32 {
    load(x.target).match ({
        .Member(m) => env.infer_expr(m.obj).is_readonly_ptr_ty().match ({ true => 1, false => 0 }),
        .Arrow(ar) => env.infer_expr(ar.obj).is_readonly_ptr_ty().match ({ true => 1, false => 0 }),
        _          => 0,
    })
}
idxset_err = (env: Env, x: IndexSetData) i32 {
    rt := env.infer_expr(x.value)
    lv := x.value.lit_slot_verdict(x.elem)
    (lv >= 0).match ({ true => lv, false => (env.unknown_ty(rt) || env.unknown_ty(x.elem)).match ({ true => 0, false => fits(rt, x.elem).match ({ true => 0, false => 1 }) }) })
}
// Annotated lets must fit their declared type; unannotated lets are inferred only.
let_fit_err = (env: Env, l: LetData) i32 {
    l.ty.is_void_ty().match ({ true => 0, false => {
        vt := env.infer_expr(l.value)
        lv := l.value.lit_slot_verdict(l.ty)
        (lv >= 0).match ({ true => lv, false => (env.unknown_ty(vt) || env.unknown_ty(l.ty)).match ({ true => 0, false => fits(vt, l.ty).match ({ true => 0, false => 1 }) }) })
    } })
}
// A generic type with a `.Void` type-arg (recursing Ptr/Slice/nested generics) — e.g. `Box<void>`.
// An unbound tparam survives inference as void, so the let's stored (inferred) type becomes Box<void>,
// which only ever lowers to `Box_void`, never a usable value.
ty_has_void_targ = (t: Ty) bool {
    t.match ({
        .Generic(g) => g.args.tys_mention_void(),
        .Ptr(pd)    => load(pd.pointee).ty_has_void_targ(),
        .Slice(e)   => load(e).ty_has_void_targ(),
        _           => false,
    })
}
tys_mention_void = (ts: [Ty]) bool {
    f := false
    ts.loop((h, i, t) {
        f = (t.is_void_ty() || t.ty_has_void_targ()).match ({ true => true, false => f })
    })
    f
}
// A let (post-resolve, ty = the inferred/declared type) whose stored type is a generic with an
// uninferred tparam (`empty<T> = (k: i32) Box<T>` then `m := empty(7)` → Box<void> → mono emits
// `Box_void`). check used to pass; require an annotation so the tparam is pinned.
let_needannot_err = (env: Env, l: LetData) i32 { l.ty.ty_has_void_targ().match ({ true => 1, false => 0 }) }
check_stmt = (a: MutPtr<Malloc>, env: Env, st: Stmt) i32 {
    st.match ({
        .Let(l)      => env.check_expr(l.value) + env.let_fit_err(l) + env.let_needannot_err(l),
        .Assign(x)   => env.check_expr(x.target) + env.check_expr(x.value) + env.assign_err(x) + env.assign_ptr_write_err(x),
        .Return(r)   => env.check_expr(r) + env.ret_err(r),
        .ExprStmt(e) => env.check_expr(e),
        .If(f)       => env.check_expr(f.c) + a.check_body(env, f.then) + a.check_body(env, f.els),
        .While(w)    => env.check_expr(w.c) + a.check_body(env, w.body),
        .IndexSet(x) => env.check_expr(x.seq) + env.check_expr(x.idx) + env.check_expr(x.value) + env.idxset_err(x),
    })
}
// Thread lets into the validating environment.
check_body = (a: MutPtr<Malloc>, env: Env, body: [Stmt]) i32 {
    acc := 0
    e := env
    body.loop((h, i, st) {
        acc = acc + a.check_stmt(e, st)
        e = a.extend_env(e, st)
    })
    acc
}
// a non-void function must YIELD a value: its body's last statement must be a value (a trailing
// expression or an explicit return), and that value must fit the return type. A body that is empty,
// or ends in a let/assign/loop (which produce no value), leaves the return indeterminate — Python
// rejects it ("void ⊀ i32"). Sound: a void return type, or a trailing expr the checker can't infer,
// is skipped (ret_err's own leniency).
trailing_err = (env: Env, body: [Stmt]) i32 { env.exp.is_void_ty().match ({ true => 0, false => (body.len == 0).match ({ true => 1, false => env.last_stmt_err(body[body.len - 1]) }) }) }    // a void fn: any body is fine
last_stmt_err = (env: Env, st: Stmt) i32 {
    st.match ({
        .ExprStmt(e) => env.ret_err(e),    // empty body, non-void return -> no value
        .Return(r)   => 0,    // a trailing expr must fit the return type
        _            => 1,
    })
}    // an explicit return is checked in check_stmt
DeadList: DeadNil | DeadCons(DeadCell)    // let/assign/while/if/index-set produce no value
// Raw ownership validation runs before resolve_module in the CLI, while source-level
// allocator-explicit `o.release_in(a)` / `r.drop_in(a)` calls still exist. After generic inlining those calls
// become plain pointer operations, so this rule cannot be recovered reliably later.
DeadCell: {
    name: str,
    tail: Ptr<DeadList>,
}
dead_buf = (a: MutPtr<Malloc>) [DeadList] { slice(a.acquire(sizeof(DeadList)), 1) }
dead_node = (a: MutPtr<Malloc>, v: DeadList) Ptr<DeadList> {
    buf := a.dead_buf()
    buf[0] = v
    buf[0].addr()
}
dead_nil = (a: MutPtr<Malloc>) Ptr<DeadList> { a.dead_node(.DeadNil) }
dead_cons = (a: MutPtr<Malloc>, name: str, tail: Ptr<DeadList>) Ptr<DeadList> {
    a.dead_node(.DeadCons(DeadCell(
        name: name,
        tail: tail,
    )))
}
dead_has = (seen: Ptr<DeadList>, name: str) bool {
    seen.match ({
        .DeadNil     => false,
        .DeadCons(c) => eq(c.name, name).match ({ true => true, false => c.tail.dead_has(name) }),
    })
}
// REVIVAL: rebuild the kill-set without `name`. Rebinding a freed/moved local to a fresh value clears
// its dead state (so `p := malloc(); a.release(p); p = malloc(); use(p)` and the idiomatic
// `p = a.resize(p, n)` are NOT use-after-free). Removes every occurrence (dups are harmless).
dead_remove = (a: MutPtr<Malloc>, seen: Ptr<DeadList>, name: str) Ptr<DeadList> {
    seen.match ({
        .DeadNil     => seen,
        .DeadCons(c) => eq(c.name, name).match ({ true => a.dead_remove(c.tail, name), false => a.dead_cons(c.name, a.dead_remove(c.tail, name)) }),
    })
}
owner_base = (t: Ty) str {
    t.match ({
        .Generic(g) => g.name,
        .Named(n)   => n,
        _           => "",
    })
}
is_consume_method = (env: Env, c: CallData) bool {
    (c.args.len > 0).match ({ true => {
        base := env.infer_expr(c.args[0].addr()).owner_base()
        eq(c.fn, "release").match ({ true => eq(base, "Own"), false => eq(c.fn, "release_in").match ({ true => eq(base, "Own"), false => eq(c.fn, "drop").match ({ true => eq(base, "Rc") || eq(base, "Arc"), false => eq(c.fn, "drop_in").match ({ true => eq(base, "Rc") || eq(base, "Arc"), false => false }) }) }) })
    }, false => false })
}
is_default_owner_method = (env: Env, c: CallData) bool {
    (c.args.len > 0).match ({ true => {
        base := env.infer_expr(c.args[0].addr()).owner_base()
        eq(c.fn, "release").match ({ true => eq(base, "Own"), false => eq(c.fn, "drop").match ({ true => eq(base, "Rc") || eq(base, "Arc"), false => false }) })
    }, false => false })
}
recv_var_name = (c: CallData) str {
    (c.args.len > 0).match ({ true => c.args[0].match ({
        .Var(v) => v.name,
        _       => "",
    }), false => "" })
}
// SENDABILITY — move-on-send. Passing an owned `Own<T>` into a `send(handle, msg)` transfers it to the
// receiving actor, so the sender must not keep using it (otherwise both sides free it → race/double-free).
// We mark the sent owner dead, reusing the use-after-free machinery. Catches the owner sent DIRECTLY or
// wrapped one level in an enum message (`send(h, .Wrap(own))`). Value/str/Arc messages are untouched —
// only `Own` is moved — so the ergonomic common case (value messages) sees zero new friction.
send_own_var = (env: Env, e: Ptr<Expr>) str {
    load(e).match ({
        .Var(v)       => eq(env.infer_expr(e).owner_base(), "Own").match ({ true => v.name, false => "" }),
        .MakeEnum(mk) => env.send_own_var(mk.payload),
        _             => "",
    })
}
send_consume = (env: Env, c: CallData) str { (eq(c.fn, "send") && c.args.len >= 2).match ({ true => env.send_own_var(c.args[1].addr()), false => "" }) }
// the bare-Var name of arg `i` (else ""). We only track frees/escapes of SIMPLE LOCALS — a field free
// like `a.release(m.keys)` (vec/map grow constantly do this) is deliberately NOT tracked, so the
// stdlib does not over-reject. Field-level liveness is out of scope for v1.
arg_var_name = (c: CallData, i: i32) str {
    (i < c.args.len).match ({ true => c.args[i].match ({
        .Var(v) => v.name,
        _       => "",
    }), false => "" })
}
ty_is_ptr_t = (t: Ty) bool {
    t.match ({
        .Ptr(pd) => true,
        _        => false,
    })
}
// ALLOCATOR-CENTRIC free detection. The free surface is the `Allocator` trait, generic over every
// allocator (built-in Heap/Malloc and user-defined) because conformance fixes the method names:
//   a.release(p)     — frees ptr arg `p`        (receiver `a` is a MutPtr<_>, NOT an Own/Rc/Arc)
//   a.resize(p, n)   — frees the OLD ptr `p`    (returns a NEW pointer; old `p` dangles)
//   free(p)          — raw FFI/bootstrap floor  (rare in user code)
// The receiver being a pointer (`.Ptr`) — not an Own/Rc/Arc generic — disambiguates the allocator
// `release` from the owner `o.release(a)` consume (handled by is_consume_method). Returns the freed
// bare-local name, or "" when nothing simple is freed.
alloc_free_call_name = (env: Env, c: CallData) str { eq(c.fn, "free").match ({ true => (c.args.len == 1).match ({ true => c.arg_var_name(0), false => "" }), false => eq(c.fn, "release").match ({ true => (c.args.len == 2 && env.infer_expr(c.args[0].addr()).ty_is_ptr_t()).match ({ true => c.arg_var_name(1), false => "" }), false => eq(c.fn, "resize").match ({ true => (c.args.len == 3 && env.infer_expr(c.args[0].addr()).ty_is_ptr_t()).match ({ true => c.arg_var_name(1), false => "" }), false => "" }) }) }) }
// the freed local for a whole statement: a bare free call, or a free that is the VALUE of a let/assign
// (e.g. `p = a.resize(p, n)` frees the old `p`; the rebind then revives it in own_step).
alloc_free_expr_name = (env: Env, e: Ptr<Expr>) str {
    load(e).match ({
        .Call(c) => env.alloc_free_call_name(c),
        _        => "",
    })
}
alloc_free_stmt_name = (env: Env, st: Stmt) str {
    st.match ({
        .ExprStmt(e) => env.alloc_free_expr_name(e),
        .Let(l)      => env.alloc_free_expr_name(l.value),
        .Assign(x)   => env.alloc_free_expr_name(x.value),
        _            => "",
    })
}
// the local (re)bound by a statement — clears its dead state (revival). A bare-Var assign target only;
// a compound target like `arr[i]`/`m.f` is a write THROUGH the base, not a rebind of a local.
// the bare-Var name of an assign/index target (else ""). Hoisted to its own fn: a nested match inside
// an outer statement-match arm miscompiles, so the load+match lives here.
target_var_name = (t: Ptr<Expr>) str {
    load(t).match ({
        .Var(v) => v.name,
        _       => "",
    })
}
rebind_stmt_name = (st: Stmt) str {
    st.match ({
        .Let(l)    => l.name,
        .Assign(x) => target_var_name(x.target),
        _          => "",
    })
}
// count an assign TARGET as a use only when it is NOT a bare local (a bare `p = …` is a rebind/revival,
// not a read of `p`; a compound `arr[i] = …` / `m.f = …` reads the base/index, so still check those).
own_assign_target_err = (a: MutPtr<Malloc>, env: Env, seen: Ptr<DeadList>, t: Ptr<Expr>) i32 {
    load(t).match ({
        .Var(v) => 0,
        _       => a.own_expr_err(env, seen, t),
    })
}
kv_own_assign_target_kind = (a: MutPtr<Malloc>, env: Env, seen: Ptr<DeadList>, t: Ptr<Expr>) i32 {
    load(t).match ({
        .Var(v) => 0,
        _       => a.kv_own_expr_kind(env, seen, t),
    })
}
own_args_err = (a: MutPtr<Malloc>, env: Env, seen: Ptr<DeadList>, args: [Expr]) i32 {
    acc := 0
    args.loop((h, i, ar) {
        acc = acc + a.own_expr_err(env, seen, ar.addr())
    })
    acc
}
own_inits_err = (a: MutPtr<Malloc>, env: Env, seen: Ptr<DeadList>, inits: [FieldInit]) i32 {
    acc := 0
    inits.loop((h, i, fi) {
        acc = acc + a.own_expr_err(env, seen, fi.value)
    })
    acc
}
own_arms_err = (a: MutPtr<Malloc>, env: Env, seen: Ptr<DeadList>, subjty: Ty, arms: [ArmData]) i32 {
    acc := 0
    arms.loop((h, i, ar) {
        acc = acc + a.own_expr_err(a.arm_env(env, subjty, ar), seen, ar.body)
    })
    acc
}
own_expr_err = (a: MutPtr<Malloc>, env: Env, seen: Ptr<DeadList>, e: Ptr<Expr>) i32 {
    load(e).match ({
        .Var(v)        => seen.dead_has(v.name).match ({ true => 1, false => 0 }),
        .Call(c)       => a.own_args_err(env, seen, c.args) + env.is_default_owner_method(c).match ({ true => 1, false => 0 }),
        .Index(ix)     => a.own_expr_err(env, seen, ix.seq) + a.own_expr_err(env, seen, ix.idx),
        .Bin(b)        => a.own_expr_err(env, seen, b.lhs) + a.own_expr_err(env, seen, b.rhs),
        .Cond(d)       => a.own_expr_err(env, seen, d.c) + a.own_expr_err(env, seen, d.t) + a.own_expr_err(env, seen, d.e),
        .Member(m)     => a.own_expr_err(env, seen, m.obj),
        .Arrow(ar)     => a.own_expr_err(env, seen, ar.obj),
        .Match(m)      => a.own_expr_err(env, seen, m.subj) + a.own_arms_err(env, seen, env.infer_expr(m.subj), m.arms),
        .MakeEnum(mk)  => a.own_expr_err(env, seen, mk.payload),
        .MakeStruct(s) => a.own_inits_err(env, seen, s.inits),
        .SliceLit(sd)  => a.own_args_err(env, seen, sd.items),
        .Loop(l)       => a.own_expr_err(env, seen, l.seq) + a.own_body_err(env, seen, l.body),
        .Block(b)      => a.own_body_err(env, seen, b.stmts),
        _              => 0,
    })
}
own_stmt_err = (a: MutPtr<Malloc>, env: Env, seen: Ptr<DeadList>, st: Stmt) i32 {
    st.match ({
        .Let(l)      => a.own_expr_err(env, seen, l.value),
        .Assign(x)   => a.own_assign_target_err(env, seen, x.target) + a.own_expr_err(env, seen, x.value),
        .Return(r)   => a.own_expr_err(env, seen, r),
        .ExprStmt(e) => a.own_expr_err(env, seen, e),
        .If(f)       => a.own_expr_err(env, seen, f.c) + a.own_body_err(env, seen, f.then) + a.own_body_err(env, seen, f.els),
        .While(w)    => a.own_expr_err(env, seen, w.c) + a.own_body_err(env, seen, w.body),
        .IndexSet(x) => a.own_expr_err(env, seen, x.seq) + a.own_expr_err(env, seen, x.idx) + a.own_expr_err(env, seen, x.value),
    })
}
consume_name = (env: Env, st: Stmt) str {
    st.match ({
        .ExprStmt(e) => load(e).match ({
            .Call(c) => env.is_consume_method(c).match ({ true => c.recv_var_name(), false => env.send_consume(c) }),
            _        => "",
        }),
        _            => "",
    })
}
// BRANCH-AWARE dead-set helpers. A free performed inside a branch (if/while body, match arm) makes the
// freed local CONDITIONALLY dead; the safe, simple rule is to treat it as dead AFTER the branch, so a
// later UNCONDITIONAL free/use is flagged as a double-free / use-after-free. A branch that does NOT fall
// through (its body ends in `return`) cannot reach the post-branch code, so its frees are EXCLUDED from
// the post-branch set — this is what keeps the common error-path idiom legal:
//   cond.match ({ err => { a.release(p)  return 1 }, ok => {} })   a.release(p)   // NOT a double-free
// (the freeing arm returned, so the `release(p)` after only runs on the ok path, where p is still live).
dead_union = (a: MutPtr<Malloc>, x: Ptr<DeadList>, y: Ptr<DeadList>) Ptr<DeadList> {
    x.match ({
        .DeadNil     => y,
        .DeadCons(c) => a.dead_cons(c.name, a.dead_union(c.tail, y)),
    })
}
// does control flow off the END of this body reach the next statement? false only when it ends in return.
body_falls_through = (body: [Stmt]) bool {
    (body.len == 0).match ({ true => true, false => body[body.len - 1].match ({
        .Return(r) => false,
        _          => true,
    }) })
}
// a match-arm / Cond body is an Expr; it diverges only when it is a Block ending in `return`.
expr_falls_through = (e: Ptr<Expr>) bool {
    load(e).match ({
        .Block(b) => body_falls_through(b.stmts),
        _         => true,
    })
}
// net dead-set after a (possibly branching) statement body — threads own_step + env exactly like
// own_body_err / kv_own_body_kind, but returns the final kill-set instead of an error count.
own_dead_body = (a: MutPtr<Malloc>, env: Env, seen: Ptr<DeadList>, body: [Stmt]) Ptr<DeadList> {
    e := env
    d := seen
    body.loop((h, i, st) {
        d = a.own_step(e, d, st)
        e = a.extend_env(e, st)
    })
    d
}
// union of the per-arm net dead-sets, over the arms that fall through (a returning arm contributes
// nothing to the post-match set). Each arm is evaluated from the pre-match kill-set `seen`.
own_dead_arms = (a: MutPtr<Malloc>, env: Env, seen: Ptr<DeadList>, subjty: Ty, arms: [ArmData]) Ptr<DeadList> {
    out := seen
    arms.loop((h, i, ar) {
        expr_falls_through(ar.body).match ({ true => {
            out = a.dead_union(a.own_dead_expr(a.arm_env(env, subjty, ar), seen, ar.body), out)
        }, false => { } })
    })
    out
}
// net dead-set after an expression in statement position (a statement-position match, a block, a ternary,
// or a bare free/consume call as a match-arm body). Mirrors own_step's free/consume detection.
own_dead_expr = (a: MutPtr<Malloc>, env: Env, seen: Ptr<DeadList>, e: Ptr<Expr>) Ptr<DeadList> {
    load(e).match ({
        .Block(b) => a.own_dead_body(env, seen, b.stmts),
        .Match(m) => a.own_dead_arms(env, seen, env.infer_expr(m.subj), m.arms),
        // a bool `.match` lowers to a Cond (ternary); apply the same fall-through exclusion as match arms
        // so a branch that ends in `return` does not propagate its frees past the conditional.
        .Cond(d)  => a.dead_union(expr_falls_through(d.t).match ({ true => a.own_dead_expr(env, seen, d.t), false => seen }), expr_falls_through(d.e).match ({ true => a.own_dead_expr(env, seen, d.e), false => seen })),
        .Call(c)  => {
            out := seen
            fn := env.alloc_free_call_name(c)
            fn.is_empty().match ({ false => {
                out = a.dead_cons(fn, out)
            } })
            cn := env.is_consume_method(c).match ({ true => c.recv_var_name(), false => env.send_consume(c) })
            cn.is_empty().match ({ false => {
                out = a.dead_cons(cn, out)
            } })
            out
        },
        _         => seen,
    })
}
own_step = (a: MutPtr<Malloc>, env: Env, seen: Ptr<DeadList>, st: Stmt) Ptr<DeadList> {
    out := seen
    // 1. owner consume (Own.release / Rc.drop / …) marks the receiver dead.
    nm := env.consume_name(st)
    nm.is_empty().match ({ false => {
        out = a.dead_cons(nm, out)
    } })
    // 2. allocator free (a.release(p) / a.resize(p,n) / free(p)) marks the freed local dead.
    fn := env.alloc_free_stmt_name(st)
    fn.is_empty().match ({ false => {
        out = a.dead_cons(fn, out)
    } })
    // 2b. branch-aware: descend into if/while bodies and statement-position matches/blocks so a free
    //     inside a branch enters the kill-set (conditionally dead → dead after the branch). Only branches
    //     that FALL THROUGH contribute; free-then-rebind within one branch nets to ALIVE via own_step.
    out = st.match ({
        .If(f)       => a.dead_union(body_falls_through(f.then).match ({ true => a.own_dead_body(env, out, f.then), false => out }), body_falls_through(f.els).match ({ true => a.own_dead_body(env, out, f.els), false => out })),
        .While(w)    => body_falls_through(w.body).match ({ true => a.own_dead_body(env, out, w.body), false => out }),
        .ExprStmt(e) => a.own_dead_expr(env, out, e),
        _            => out,
    })
    // 3. revival — a (re)bind of a local clears its dead state. Runs LAST so `p = a.resize(p, n)`
    //    (free old p in step 2, then rebind p here) nets to ALIVE, while `q := a.resize(p, n)` leaves
    //    p dead (q != p).
    rb := rebind_stmt_name(st)
    rb.is_empty().match ({ false => {
        out = a.dead_remove(out, rb)
    } })
    out
}
own_body_err = (a: MutPtr<Malloc>, env: Env, seen: Ptr<DeadList>, body: [Stmt]) i32 {
    acc := 0
    e := env
    d := seen
    body.loop((h, i, st) {
        acc = a.own_stmt_err(e, d, st) + acc
        d = a.own_step(e, d, st)
        e = a.extend_env(e, st)
    })
    acc
}
own_check_func = (a: MutPtr<Malloc>, decls: [Decl], idx: DeclIndex, f: Func) i32 {
    env := Env(
        vars: a.params_env(f.params),
        decls: decls,
        didx: idx,
        exp: f.ret,
        a: a,
    )
    a.own_body_err(env, a.dead_nil(), f.body)
}
check_module_ownership* = (a: MutPtr<Malloc>, decls: [Decl]) i32 {
    acc := 0
    idx := a.build_decl_index(decls)
    decls.loop((h, i, d) {
        acc = acc + d.match ({
            .DFunc(f) => a.own_check_func(decls, idx, f),
            _         => 0,
        })
    })
    acc
}
check_func = (a: MutPtr<Malloc>, decls: [Decl], idx: DeclIndex, f: Func) i32 {
    env := Env(
        vars: a.params_env(f.params),
        decls: decls,
        didx: idx,
        exp: f.ret,
        a: a,
    )
    a.check_body(env, f.body) + env.trailing_err(f.body)
}
// trait conformance: a `Type.impl(Trait)` must DEFINE every method the Trait declares, with a
// MATCHING SIGNATURE. The Trait is a struct whose FnT fields are the method signatures (using `Self`
// for the implementing type); im.methods is the names this impl provides, and the impl's actual
// method bodies are top-level DFuncs found by name. So per declared method: missing → 1 error;
// present but signature-mismatched → 1 error; present and matching → 0. The check is tied to THIS
// impl (im.methods), not a global function search, so an unrelated same-named fn never satisfies it.
has_method = (methods: [Param], name: str) bool {
    found := false
    methods.loop((h, i, p) {
        found = eq(p.name, name).match ({ true => true, false => found })
    })
    found
}
// rewrite `Self` to the implementing type throughout a trait method's type (recursing Ptr/Slice).
impl_ty = (tyname: str) Ty { eq(tyname, "i32").match ({ true => ti32(), false => eq(tyname, "i64").match ({ true => ti64(), false => eq(tyname, "u8").match ({ true => tu8(), false => eq(tyname, "f64").match ({ true => tf64(), false => eq(tyname, "bool").match ({ true => tbool(), false => eq(tyname, "str").match ({ true => tstr(), false => tnamed(tyname) }) }) }) }) }) }) }
subst_self = (a: MutPtr<Malloc>, t: Ty, tyname: str) Ty {
    t.match ({
        .Named(n) => eq(n, "Self").match ({ true => impl_ty(tyname), false => t }),
        .Ptr(pd)  => tptr_k(a.tnode(a.subst_self(load(pd.pointee), tyname)), pd.kind),
        .Slice(p) => tslice(a.tnode(a.subst_self(load(p), tyname))),
        _         => t,
    })
}
// each declared param type (Self→tyname) must equal the impl method's, left to right.
params_match = (a: MutPtr<Malloc>, tps: [Ty], ips: [Param], tyname: str, i: i32) bool { (i == tps.len).match ({ true => true, false => a.subst_self(tps[i], tyname).ty_eq(ips[i].ty).match ({ true => a.params_match(tps, ips, tyname, i + 1), false => false }) }) }
// the impl method `f` matches the trait's FnT field `fd` (Self→tyname): same arity, param types, ret.
sig_matches = (a: MutPtr<Malloc>, fd: FnTData, f: Func, tyname: str) bool { (fd.params.len == f.params.len).match ({ true => a.params_match(fd.params, f.params, tyname, 0).match ({ true => a.subst_self(load(fd.ret), tyname).ty_eq(f.ret), false => false }), false => false }) }
// does the trait `trname` declare a DEFAULT body for method `m`? (then an impl may OMIT it.)
trait_has_default = (decls: [Decl], trname: str, m: str) bool {
    found := false
    decls.loop((h, i, d) {
        found = d.match ({
            .DTraitDefault(td) => (eq(td.trname, trname) && eq(td.fn.name, m)).match ({ true => true, false => found }),
            _                  => found,
        })
    })
    found
}
// one declared trait field: 0 if it's not a method, or it's provided with a matching signature, or it
// is OMITTED but the trait supplies a default body; 1 if the method is missing (no default) or differs.
method_err = (a: MutPtr<Malloc>, decls: [Decl], im: ImplData, f: Field) i32 {
    f.ty.match ({
        .FnT(fd) => im.methods.has_method(f.name).match ({ true => a.sig_matches(fd, decls.the_func(a.impl_cname_in(im.trname, im.ty, f.name)), im.ty).match ({ true => 0, false => 1 }), false => decls.trait_has_default(im.trname, f.name).match ({ true => 0, false => 1 }) }),    // omitted: OK iff defaulted
        _        => 0,
    })
}
trait_conformance = (a: MutPtr<Malloc>, decls: [Decl], im: ImplData, sd: StructDecl) i32 {
    acc := 0
    sd.fields.loop((h, i, f) {
        acc = acc + a.method_err(decls, im, f)
    })
    acc
}
impl_errs = (a: MutPtr<Malloc>, decls: [Decl], im: ImplData) i32 {
    acc := 0
    decls.loop((h, i, d) {
        acc = acc + d.match ({
            .DStruct(sd) => eq(sd.name, im.trname).match ({ true => a.trait_conformance(decls, im, sd), false => 0 }),
            _            => 0,
        })
    })
    acc
}
// Two top-level decls with the same FUNCTION name emit colliding C definitions (cc "redefinition" /
// "conflicting types") — the self-hosted backend mangles only generic-type instances, not plain fns,
// so two `f`s (or two trait impls of one method) both emit `… f(…)`. Reject the second. Zen has no
// overloading.
fn_name_of = (d: Decl) str {
    d.match ({
        .DFunc(f) => f.name,
        _         => "",
    })
}
fn_dup_before = (decls: [Decl], name: str, upto: i64) bool {
    f := false
    decls.loop((h, i, d) {
        f = (i < upto).match ({ true => eq(d.fn_name_of(), name).match ({ true => true, false => f }), false => f })
    })
    f
}
dup_name_errs = (decls: [Decl]) i32 {
    n := 0
    decls.loop((h, i, d) {
        nm := d.fn_name_of()
        n = is_empty(nm).match ({ true => n, false => decls.fn_dup_before(nm, i).match ({ true => n + 1, false => n }) })
    })
    n
}
check_module* = (a: MutPtr<Malloc>, decls: [Decl]) i32 {
    acc := decls.dup_name_errs()
    idx := a.build_decl_index(decls)
    decls.loop((h, i, d) {
        acc = acc + d.match ({
            .DFunc(f)   => a.check_func(decls, idx, f),
            .DImpl(im)  => a.impl_errs(decls, im),
            .DGlobal(g) => eq(g.name, "__syntax_error").match ({ true => 1, false => 0 }),
            _           => 0,
        })
    })
    acc
}
// ════════════════════════════════════════════════════════════════════════════════════════
// ── DIAGNOSTIC ERROR KINDS (Diagnostics arc) ────────────────────────────────────────────
// check_module returns an error COUNT; a reject pins WHETHER but not WHY. This parallel layer
// re-walks the same resolved AST in the same traversal order and reports the KIND code of the
// FIRST error — so a CHECK-KIND binary (check_module_kind below) can prove a reject is for the
// RIGHT reason. It reuses every predicate from the count layer (same is_*_err logic), only
// swapping each "+ 1" for "this error's kind". Zero new judgments → the count and the kind
// agree exactly (kind != 0 iff count > 0). These are DISTINCT functions (kv_*/…_kind suffix);
// they never touch check_module/check_linked, so the oracle's count exit code is untouched.
//
// Kind codes (small fixed set the task names). KNONE=0 means "no error".
KNONE = () i32 { 0 }
KARITY = () i32 { 1 }    // a call's arg COUNT ≠ the declared parameter count
KARGTYPE = () i32 { 2 }    // an arg's type doesn't fit its parameter
KUNDEFINED = () i32 { 3 }    // a call to a non-local, non-intrinsic, non-imported, non-trait name
KSTRUCTFIELD = () i32 { 4 }    // a struct-literal init field / a member access that names no real field
KEXHAUST = () i32 { 5 }    // a non-wildcard enum match misses a variant
KDUPVARIANT = () i32 { 6 }    // a match arm repeats a variant
KOPERAND = () i32 { 7 }    // an arith/logic operator on the wrong operand category
KINDEX = () i32 { 8 }    // seq[idx] with a non-slice seq or a non-numeric idx
KRETURNFIT = () i32 { 9 }    // a returned / trailing value doesn't fit the declared return type
KASSIGNFIT = () i32 { 10 }    // x = v where v doesn't fit x's let-inferred type (incl. xs[i]=v)
KCONFORMANCE = () i32 { 11 }    // a Type.impl(Trait) misses a method or its signature differs
KDUPFN = () i32 { 12 }    // two top-level fns share a name (Zen has no overloading)
KVALPOSRETURN = () i32 { 13 }    // an early (dropped) return in a value-position block arm
KPARSE = () i32 { 14 }    // unparseable top-level input (the parser's __syntax_error sentinel)
KOWNERSHIP = () i32 { 15 }    // use of a local owner after release/drop
KTRAITBOUND = () i32 { 16 }    // a type bound to `A: Trait` at a call site does not impl Trait
KUNKNOWNTYPE = () i32 { 17 }    // a type annotation names a type that is not declared/imported/a tparam
KLAMBDAVALUE = () i32 { 18 }    // a lambda used as a value the inliner can't splice (stored/returned)
KMUSTUSE = () i32 { 19 }    // a value-mold `(Self,…) Self` self-mutation whose result is discarded
KNEEDANNOT = () i32 { 20 }    // an unannotated let whose inferred type leaves a tparam uninferred (-> T=void)
KPTRWRITE = () i32 { 21 }    // a store() through a read-only `Ptr<T>` (use `MutPtr<T>` to write)
KINFINITETYPE = () i32 { 22 }    // a struct/enum that contains ITSELF by value (transitively) — infinite size
KNULLDEREF = () i32 { 23 }    // a load/store/offset through a nullable `RawPtr<T>` (T != u8) not proven non-null
SourceSpan*: {
    start: i32,
    width: i32,
}
Diagnostic*: {
    code: i32,
    kind: str,
    span: SourceSpan,
    count: i32,
    message: str,
    hint: str,
}
CheckDiagnostic*: {
    code: i32,
    kind: str,
    source_offset: i32,
    span_width: i32,
    count: i32,
    message: str,
    hint: str,
}
source_span* = (start: i32, width: i32) SourceSpan {
    SourceSpan(
        start: start,
        width: width,
    )
}
source_span_none* = () SourceSpan { source_span(0, 0) }
diagnostic_none* = () Diagnostic {
    Diagnostic(
        code: 0,
        kind: "ok",
        span: source_span_none(),
        count: 0,
        message: "",
        hint: "",
    )
}
check_diagnostic_none* = () CheckDiagnostic {
    CheckDiagnostic(
        code: 0,
        kind: "ok",
        source_offset: 0,
        span_width: 0,
        count: 0,
        message: "",
        hint: "",
    )
}
positive_count = (n: i32) i32 { (n < 1).match ({ true => 1, false => n }) }
diagnostic_width_from = (src: str, pos: i32, n: i32) i32 { src.at(pos + n).is_alnum().match ({ true => src.diagnostic_width_from(pos, n + 1), false => n }) }
// a string literal carets across its quotes (`"hi"` -> `^~~~`), not just the opening `"`.
diagnostic_strlit_width = (src: str, pos: i32, n: i32) i32 {
    b := src.at(pos + n)
    (b == 0 || b == '\n').match ({ true => n, false => (b == '"').match ({ true => n + 1, false => src.diagnostic_strlit_width(pos, n + 1) }) })
}
diagnostic_span_width = (src: str, pos: i32) i32 {
    (pos <= 0).match ({ true => 1, false => (src.at(pos) == '"').match ({ true => src.diagnostic_strlit_width(pos, 1), false => {
        n := src.diagnostic_width_from(pos, 0)
        (n < 1).match ({ true => 1, false => n })
    } }) })
}
diagnostic_kind_name = (code: i32) str { (code == 1).match ({ true => "arity", false => (code == 2).match ({ true => "arg-type", false => (code == 3).match ({ true => "undefined-name", false => (code == 4).match ({ true => "struct-field", false => (code == 5).match ({ true => "exhaustiveness", false => (code == 6).match ({ true => "dup-variant", false => (code == 7).match ({ true => "operand-type", false => (code == 8).match ({ true => "index", false => (code == 9).match ({ true => "return-fit", false => (code == 10).match ({ true => "assign-fit", false => (code == 11).match ({ true => "conformance", false => (code == 12).match ({ true => "dup-fn", false => (code == 13).match ({ true => "value-pos-return", false => (code == 14).match ({ true => "parse", false => (code == 15).match ({ true => "ownership", false => (code == 16).match ({ true => "trait-bound", false => (code == 17).match ({ true => "unknown-type", false => (code == 18).match ({ true => "lambda-value", false => (code == 19).match ({ true => "must-use", false => (code == 20).match ({ true => "need-annotation", false => (code == 21).match ({ true => "ptr-write", false => (code == 22).match ({ true => "infinite-type", false => (code == 23).match ({ true => "null-deref", false => "type" }) }) }) }) }) }) }) }) }) }) }) }) }) }) }) }) }) }) }) }) }) }) }) }
diagnostic_message = (code: i32) str { (code == 1).match ({ true => "wrong number of arguments", false => (code == 2).match ({ true => "argument type does not fit the parameter", false => (code == 3).match ({ true => "undefined name", false => (code == 4).match ({ true => "unknown struct field or invalid field access", false => (code == 5).match ({ true => "match does not cover every variant", false => (code == 6).match ({ true => "duplicate match arm variant", false => (code == 7).match ({ true => "operator cannot be applied to these operand types", false => (code == 8).match ({ true => "invalid index operation", false => (code == 9).match ({ true => "returned value does not fit the declared return type", false => (code == 10).match ({ true => "assigned value does not fit the variable's type", false => (code == 11).match ({ true => "impl does not satisfy the trait", false => (code == 12).match ({ true => "duplicate top-level definition", false => (code == 13).match ({ true => "early `return` in a value-position match arm", false => (code == 14).match ({ true => "syntax error: unparseable top-level input", false => (code == 15).match ({ true => "use of an owner after release/drop", false => (code == 16).match ({ true => "type argument does not satisfy the trait bound", false => (code == 17).match ({ true => "unknown type name", false => (code == 18).match ({ true => "a lambda can only be used directly as a call argument", false => (code == 19).match ({ true => "result of a self-mutating container method is discarded; the receiver is invalid after this call", false => (code == 20).match ({ true => "cannot infer the type parameter of this binding", false => (code == 21).match ({ true => "cannot write through a read-only `Ptr<T>`", false => (code == 22).match ({ true => "type contains itself by value, so it has infinite size", false => (code == 23).match ({ true => "`RawPtr<T>` may be null; deref requires a null-check first", false => "type error" }) }) }) }) }) }) }) }) }) }) }) }) }) }) }) }) }) }) }) }) }) }) }) }
diagnostic_hint = (code: i32) str { (code == 1).match ({ true => "check the callee signature and pass exactly the declared parameters", false => (code == 2).match ({ true => "check the argument type or add an explicit conversion at the call site", false => (code == 3).match ({ true => "declare the name, import it, or qualify the intended module binding", false => (code == 4).match ({ true => "check the struct literal or field access against the declared fields", false => (code == 5).match ({ true => "add arms for every variant, or add an explicit `_` arm", false => (code == 6).match ({ true => "remove the repeated match arm for this variant", false => (code == 7).match ({ true => "use an operator supported by both operand types", false => (code == 8).match ({ true => "index only slice-like values with an integer index", false => (code == 9).match ({ true => "make the returned value fit the function's declared return type", false => (code == 10).match ({ true => "make the assigned value fit the target's type", false => (code == 11).match ({ true => "define every required trait method with the exact receiver, parameter, and return types", false => (code == 12).match ({ true => "rename one definition or move it behind a real module namespace", false => (code == 13).match ({ true => "return a value from the arm instead of using early `return` in value position", false => (code == 14).match ({ true => "check the syntax around this top-level declaration", false => (code == 15).match ({ true => "after release/drop, bind a fresh owner instead of reusing the consumed local", false => (code == 16).match ({ true => "implement the bound trait for this type (`Type.impl(Trait, { … })`), or relax the bound", false => (code == 17).match ({ true => "declare the type, import it, or qualify it with its module (e.g. `mod.Type`)", false => (code == 18).match ({ true => "pass the lambda directly to its consumer, or bind a named top-level function instead (no first-class lambda values yet)", false => (code == 19).match ({ true => "rebind the returned container (e.g. `m = m.put(...)`); a value-mold method may realloc and returns the updated handle", false => (code == 20).match ({ true => "annotate the binding so its type parameter is pinned, e.g. `m: Map<i32> := …`", false => (code == 21).match ({ true => "give the pointer parameter/field the `MutPtr<T>` kind to permit writes through it", false => (code == 22).match ({ true => "break the cycle with indirection: store a `Ptr<T>` (or `[T]`) instead of the type by value", false => (code == 23).match ({ true => "guard with `q := assert_nonnull(p)` (panics on null, yields `MutPtr<T>`) then deref `q`, or null-check before deref", false => "" }) }) }) }) }) }) }) }) }) }) }) }) }) }) }) }) }) }) }) }) }) }) }) }
check_diagnostic_from_packed* = (packed: i32, count: i32) CheckDiagnostic {
    (packed == 0).match ({ true => check_diagnostic_none(), false => {
        code := packed & 31
        CheckDiagnostic(
            code: code,
            kind: code.diagnostic_kind_name(),
            source_offset: packed >> 5,
            span_width: 1,
            count: count.positive_count(),
            message: code.diagnostic_message(),
            hint: code.diagnostic_hint(),
        )
    } })
}
check_diagnostic_from_source* = (src: str, packed: i32, count: i32) CheckDiagnostic {
    d := check_diagnostic_from_packed(packed, count)
    (d.code == 0).match ({ true => d, false => CheckDiagnostic(
        code: d.code,
        kind: d.kind,
        source_offset: d.source_offset,
        span_width: src.diagnostic_span_width(d.source_offset),
        count: d.count,
        message: d.message,
        hint: d.hint,
    ) })
}
check_to_diagnostic* = (d: CheckDiagnostic) Diagnostic {
    Diagnostic(
        code: d.code,
        kind: d.kind,
        span: source_span(d.source_offset, d.span_width),
        count: d.count,
        message: d.message,
        hint: d.hint,
    )
}
diagnostic_to_check* = (d: Diagnostic) CheckDiagnostic {
    CheckDiagnostic(
        code: d.code,
        kind: d.kind,
        source_offset: d.span.start,
        span_width: d.span.width,
        count: d.count,
        message: d.message,
        hint: d.hint,
    )
}
diagnostic_from_packed* = (packed: i32, count: i32) Diagnostic { check_diagnostic_from_packed(packed, count).check_to_diagnostic() }
diagnostic_from_source* = (src: str, packed: i32, count: i32) Diagnostic { src.check_diagnostic_from_source(packed, count).check_to_diagnostic() }
// first-nonzero combinator: the kind of the FIRST error in traversal order.
kv_kor = (a: i32, b: i32) i32 { (a == 0).match ({ true => b, false => a }) }
// a 0/1 count predicate → a kind code: emit `k` iff the predicate found an error.
kv_one = (n: i32, k: i32) i32 { (n == 0).match ({ true => 0, false => k }) }
// pack a SOURCE POSITION into a kind code: kinds are 1..31 (5 bits), so `kind + pos*32` carries the
// error's byte offset alongside it (pos 0 = unknown/synthesized — the bare kind, the old encoding).
// Consumers unpack with `& 31` / `>> 5`. Applied only at leaves that HAVE a pos (Call/Var); an
// already-packed nested result is never re-packed: values above 31 already carry an offset.
kv_at = (k: i32, p: i32) i32 { (k == 0 || k > 31 || p <= 0).match ({ true => k, false => k + p * 32 }) }
expr_pos = (e: Expr) i32 {
    e.match ({
        .Var(v)         => v.pos,
        .Call(c)        => c.pos,
        .Member(m)      => load(m.obj).expr_pos(),
        .Arrow(ar)      => load(ar.obj).expr_pos(),
        .Index(ix)      => load(ix.seq).expr_pos(),
        .Bin(b)         => b.pos.pos_or(load(b.lhs).expr_pos()),
        .Cond(d)        => load(d.c).expr_pos(),
        .Match(m)       => load(m.subj).expr_pos(),
        .MakeEnum(mk)   => load(mk.payload).expr_pos(),
        .StrLit(s)      => s.pos,
        .MakeStruct(sd) => (sd.inits.len == 0).match ({ true => 0, false => load(sd.inits[0].value).expr_pos() }),
        .SliceLit(sd)   => (sd.items.len == 0).match ({ true => 0, false => sd.items[0].expr_pos() }),
        .Block(b)       => (b.stmts.len == 0).match ({ true => 0, false => b.stmts[0].stmt_pos() }),
        .Loop(l)        => load(l.seq).expr_pos(),
        _               => 0,
    })
}
stmt_pos = (st: Stmt) i32 {
    st.match ({
        .Let(l)      => load(l.value).expr_pos(),
        .Assign(x)   => x.pos.pos_or(load(x.target).expr_pos()),
        .Return(r)   => load(r).expr_pos(),
        .ExprStmt(e) => load(e).expr_pos(),
        .If(f)       => load(f.c).expr_pos(),
        .While(w)    => load(w.c).expr_pos(),
        .IndexSet(x) => x.pos.pos_or(load(x.seq).expr_pos()),
    })
}
// Ownership kind pass mirrors the raw ownership count pass above.
kv_own_args_kind = (a: MutPtr<Malloc>, env: Env, seen: Ptr<DeadList>, args: [Expr]) i32 {
    acc := 0
    args.loop((h, i, ar) {
        acc = acc.kv_kor(a.kv_own_expr_kind(env, seen, ar.addr()))
    })
    acc
}
kv_own_inits_kind = (a: MutPtr<Malloc>, env: Env, seen: Ptr<DeadList>, inits: [FieldInit]) i32 {
    acc := 0
    inits.loop((h, i, fi) {
        acc = acc.kv_kor(a.kv_own_expr_kind(env, seen, fi.value))
    })
    acc
}
kv_own_arms_kind = (a: MutPtr<Malloc>, env: Env, seen: Ptr<DeadList>, subjty: Ty, arms: [ArmData]) i32 {
    acc := 0
    arms.loop((h, i, ar) {
        acc = acc.kv_kor(a.kv_own_expr_kind(a.arm_env(env, subjty, ar), seen, ar.body))
    })
    acc
}
kv_own_expr_kind = (a: MutPtr<Malloc>, env: Env, seen: Ptr<DeadList>, e: Ptr<Expr>) i32 {
    load(e).match ({
        .Var(v)        => seen.dead_has(v.name).match ({ true => KOWNERSHIP().kv_at(v.pos), false => 0 }),
        .Call(c)       => a.kv_own_args_kind(env, seen, c.args).kv_kor(env.is_default_owner_method(c).match ({ true => KOWNERSHIP().kv_at(c.pos), false => 0 })),
        .Index(ix)     => a.kv_own_expr_kind(env, seen, ix.seq).kv_kor(a.kv_own_expr_kind(env, seen, ix.idx)),
        .Bin(b)        => a.kv_own_expr_kind(env, seen, b.lhs).kv_kor(a.kv_own_expr_kind(env, seen, b.rhs)),
        .Cond(d)       => a.kv_own_expr_kind(env, seen, d.c).kv_kor(a.kv_own_expr_kind(env, seen, d.t)).kv_kor(a.kv_own_expr_kind(env, seen, d.e)),
        .Member(m)     => a.kv_own_expr_kind(env, seen, m.obj),
        .Arrow(ar)     => a.kv_own_expr_kind(env, seen, ar.obj),
        .Match(m)      => a.kv_own_expr_kind(env, seen, m.subj).kv_kor(a.kv_own_arms_kind(env, seen, env.infer_expr(m.subj), m.arms)),
        .MakeEnum(mk)  => a.kv_own_expr_kind(env, seen, mk.payload),
        .MakeStruct(s) => a.kv_own_inits_kind(env, seen, s.inits),
        .SliceLit(sd)  => a.kv_own_args_kind(env, seen, sd.items),
        .Loop(l)       => a.kv_own_expr_kind(env, seen, l.seq).kv_kor(a.kv_own_body_kind(env, seen, l.body)),
        .Block(b)      => a.kv_own_body_kind(env, seen, b.stmts),
        _              => 0,
    })
}
kv_own_stmt_kind = (a: MutPtr<Malloc>, env: Env, seen: Ptr<DeadList>, st: Stmt) i32 {
    st.match ({
        .Let(l)      => a.kv_own_expr_kind(env, seen, l.value),
        .Assign(x)   => a.kv_own_assign_target_kind(env, seen, x.target).kv_kor(a.kv_own_expr_kind(env, seen, x.value)),
        .Return(r)   => a.kv_own_expr_kind(env, seen, r),
        .ExprStmt(e) => a.kv_own_expr_kind(env, seen, e),
        .If(f)       => a.kv_own_expr_kind(env, seen, f.c).kv_kor(a.kv_own_body_kind(env, seen, f.then)).kv_kor(a.kv_own_body_kind(env, seen, f.els)),
        .While(w)    => a.kv_own_expr_kind(env, seen, w.c).kv_kor(a.kv_own_body_kind(env, seen, w.body)),
        .IndexSet(x) => a.kv_own_expr_kind(env, seen, x.seq).kv_kor(a.kv_own_expr_kind(env, seen, x.idx)).kv_kor(a.kv_own_expr_kind(env, seen, x.value)),
    })
}
kv_own_body_kind = (a: MutPtr<Malloc>, env: Env, seen: Ptr<DeadList>, body: [Stmt]) i32 {
    acc := 0
    e := env
    d := seen
    body.loop((h, i, st) {
        acc = acc.kv_kor(a.kv_own_stmt_kind(e, d, st))
        d = a.own_step(e, d, st)
        e = a.extend_env(e, st)
    })
    acc
}
kv_own_check_func_kind = (a: MutPtr<Malloc>, decls: [Decl], idx: DeclIndex, f: Func) i32 {
    env := Env(
        vars: a.params_env(f.params),
        decls: decls,
        didx: idx,
        exp: f.ret,
        a: a,
    )
    a.kv_own_body_kind(env, a.dead_nil(), f.body)
}
check_module_ownership_kind* = (a: MutPtr<Malloc>, decls: [Decl]) i32 {
    acc := 0
    idx := a.build_decl_index(decls)
    decls.loop((h, i, d) {
        acc = acc.kv_kor(d.match ({
            .DFunc(f) => a.kv_own_check_func_kind(decls, idx, f),
            _         => 0,
        }))
    })
    acc
}
// ── a CALL: arity vs arg-type vs undefined ── mirrors check_call/call_errs, but distinguishes WHY.
// arg-type position: which arg first fails to fit (so a bad arg reports KARGTYPE not a blanket code).
kv_arg_type_kind = (env: Env, tps: [Param], params: [Param], args: [Expr]) i32 {
    acc := 0
    args.loop((h, i, ar) {
        acc = acc.kv_kor(env.arg_err_at(tps, params, i, ar).kv_one(KARGTYPE()).kv_at(ar.expr_pos()))
    })
    acc
}
// a known local fn: wrong arity → KARITY; right arity but a mistyped CONCRETE arg → KARGTYPE. Slots
// typed by the callee's own tparams are skipped, mirroring call_errs (so count and kind stay in agreement).
// (Trait-BOUND violations are caught by the separate pre-inline bound pass, since local generic calls
// are inlined away before this resolved-decls pass runs.)
kv_call_errs_kind = (env: Env, c: CallData) i32 {
    f := env.env_func(c.fn)
    ps := env.env_params(c.fn)
    (ps.len == c.args.len).match ({ true => f.is_imported_generic().match ({ true => 0, false => env.kv_arg_type_kind(f.tparams, ps, c.args) }), false => KARITY() })
}
kv_check_call_kind = (env: Env, c: CallData) i32 { c.is_forbidden_raw_call().match ({ true => KUNDEFINED(), false => env.is_unresolved_trait_call(c).match ({ true => 0, false => env.env_known_fn(c.fn).match ({ true => env.kv_call_errs_kind(c), false => c.fn.is_intrinsic().match ({ true => (c.args.len == c.fn.intrinsic_arity()).match ({ true => 0, false => KARITY() }), false => (env.decls.is_imported(c.fn) || env.decls.is_trait_method(c.fn)).match ({ true => env.trait_recv_missing(c).match ({ true => kv_at(KTRAITBOUND(), c.pos), false => 0 }), false => env.var_or_global(c.fn).is_fnt().match ({ true => env.kv_fnval_call_kind(c), false => KUNDEFINED() }) }) }) }) }) }) }    // deferred UFCS trait-method call (see check_call)
kv_fnt_arg_kind = (env: Env, ptys: [Ty], args: [Expr]) i32 {
    acc := 0
    args.loop((h, i, ar) {
        acc = acc.kv_kor(env.fnt_arg_err_at(ptys, i, ar).kv_one(KARGTYPE()).kv_at(ar.expr_pos()))
    })
    acc
}
kv_fnval_call_kind = (env: Env, c: CallData) i32 {
    env.var_or_global(c.fn).match ({
        .FnT(ft) => (ft.params.len == c.args.len).match ({ true => env.kv_fnt_arg_kind(ft.params, c.args), false => KARITY() }),
        _        => KUNDEFINED(),
    })
}
kv_check_args_kind = (env: Env, args: [Expr]) i32 {
    acc := 0
    args.loop((h, i, ar) {
        acc = acc.kv_kor(env.kv_check_expr_kind(ar.addr()))
    })
    acc
}
kv_check_arms_kind = (env: Env, subjty: Ty, arms: [ArmData]) i32 {
    acc := 0
    arms.loop((h, i, ar) {
        acc = acc.kv_kor(env.a.arm_env(env, subjty, ar).kv_check_expr_kind(ar.body))
    })
    acc
}
kv_arm_result_kind = (env: Env, subjty: Ty, want: Ty, ar: ArmData) i32 { env.arm_result_err(subjty, want, ar).kv_one(KRETURNFIT()).kv_at(load(ar.body).expr_pos()) }
kv_match_arm_result_kind = (env: Env, subjty: Ty, arms: [ArmData]) i32 {
    want := env.match_result_ty(subjty, arms)
    acc := 0
    arms.loop((h, i, ar) {
        acc = acc.kv_kor(env.kv_arm_result_kind(subjty, want, ar))
    })
    acc
}
kv_arm_return_kind = (arms: [ArmData]) i32 {
    acc := 0
    arms.loop((h, i, ar) {
        acc = acc.kv_kor(ar.body.expr_drops_return().kv_one(KVALPOSRETURN()))
    })
    acc
}
// struct-literal init fields: an unknown field OR a mistyped value is KSTRUCTFIELD.
kv_check_inits_kind = (env: Env, inits: [FieldInit]) i32 {
    acc := 0
    inits.loop((h, i, fi) {
        acc = acc.kv_kor(env.kv_check_expr_kind(fi.value))
    })
    acc
}
// struct-literal init: caret on the first init value's source position when it's positioned
// (a Var/Call/StrLit survives resolve; bare numeric literals carry none — best-effort, else file-only).
kv_makestruct_kind = (env: Env, m: MakeStructData) i32 { env.makestruct_err(m).kv_one(KSTRUCTFIELD()).kv_at((m.inits.len == 0).match ({ true => 0, false => load(m.inits[0].value).expr_pos() })) }
// member access caret on the receiver object (a Var/Call survives resolve).
kv_member_kind = (env: Env, obj: Ptr<Expr>, field: str) i32 { env.member_err(obj, field).kv_one(KSTRUCTFIELD()).kv_at(load(obj).expr_pos()) }
// a match: exhaustiveness vs duplicate-variant, split out from match_err. The caret points at the
// matched subject (arms carry no source position); the subject bottoms at a Var, which survives resolve.
kv_match_kind = (env: Env, m: MatchData) i32 {
    sp := load(m.subj).expr_pos()
    base := m.arms.has_wildcard().match ({ true => m.arms.dup_arm_errs().kv_one(KDUPVARIANT()).kv_at(sp), false => env.exhaustive_err(m).kv_one(KEXHAUST()).kv_at(sp).kv_kor(m.arms.dup_arm_errs().kv_one(KDUPVARIANT()).kv_at(sp)) })
    base.kv_kor(env.unknown_arm_errs(m).kv_one(KUNDEFINED()).kv_at(sp))
}
kv_index_kind = (env: Env, ix: IndexData) i32 { env.index_err(ix).kv_one(KINDEX()) }
kv_operand_kind = (env: Env, b: BinData) i32 { env.operand_err(b).kv_one(KOPERAND()) }
// the value-position block-arm walker, kind-flavoured (mirrors check_block/check_block_stmt).
kv_check_block_stmt_kind = (env: Env, st: Stmt) i32 {
    st.match ({
        .Let(l)      => env.kv_check_expr_kind(l.value).kv_kor(env.kv_let_fit_kind(l)).kv_kor(env.kv_let_needannot_kind(l)),
        .Assign(x)   => env.kv_check_expr_kind(x.target).kv_kor(env.kv_check_expr_kind(x.value)).kv_kor(env.kv_assign_kind(x)),
        .Return(r)   => env.kv_check_expr_kind(r).kv_kor(env.kv_ret_kind(r)),
        .ExprStmt(e) => env.kv_check_expr_kind(e),
        .If(f)       => env.kv_check_expr_kind(f.c),
        .While(w)    => env.kv_check_expr_kind(w.c),
        .IndexSet(x) => env.kv_check_expr_kind(x.seq).kv_kor(env.kv_check_expr_kind(x.idx)).kv_kor(env.kv_check_expr_kind(x.value)).kv_kor(env.kv_idxset_kind(x)),
    })
}
kv_check_block_kind = (env: Env, stmts: [Stmt]) i32 {
    acc := 0
    e := env
    stmts.loop((h, i, st) {
        acc = acc.kv_kor(e.kv_check_block_stmt_kind(st))
        e = e.a.extend_env(e, st)
    })
    acc
}
// mirrors slicelit_err: a slice-literal element whose type doesn't fit the first element's → KARGTYPE.
kv_slicelit_kind = (env: Env, items: [Expr]) i32 {
    (items.len == 0).match ({ true => 0, false => {
        ety := env.infer_expr(items[0].addr())
        acc := 0
        items.loop((h, i, it) {
            acc = acc.kv_kor(env.sl_elem_fit(ety, it).kv_one(KARGTYPE()).kv_at(it.expr_pos()))
        })
        acc
    } })
}
// kind-flavoured mirror of lck_expr: undefined BARE NAMES inside loop bodies, reported as KUNDEFINED at
// the offending name's position. Same narrowing rationale as lck_expr (no fit/call-name/field checks).
lkv_args = (env: Env, args: [Expr]) i32 {
    acc := 0
    args.loop((h, i, ar) {
        acc = acc.kv_kor(env.lkv_expr_kind(ar.addr()))
    })
    acc
}
lkv_inits = (env: Env, inits: [FieldInit]) i32 {
    acc := 0
    inits.loop((h, i, fi) {
        acc = acc.kv_kor(env.lkv_expr_kind(fi.value))
    })
    acc
}
lkv_arms = (env: Env, subjty: Ty, arms: [ArmData]) i32 {
    acc := 0
    arms.loop((h, i, ar) {
        acc = acc.kv_kor(env.a.arm_env(env, subjty, ar).lkv_expr_kind(ar.body))
    })
    acc
}
lkv_expr_kind = (env: Env, e: Ptr<Expr>) i32 {
    load(e).match ({
        .Var(v)         => (v.pos > 0).match ({ true => env.var_err(v.name).kv_one(KUNDEFINED()).kv_at(v.pos), false => 0 }),
        .Call(c)        => eq(c.fn, "sizeof").match ({ true => 0, false => env.lkv_args(c.args) }),
        .SliceLit(sd)   => env.lkv_args(sd.items),
        .Index(ix)      => env.lkv_expr_kind(ix.seq).kv_kor(env.lkv_expr_kind(ix.idx)),
        .Bin(b)         => env.lkv_expr_kind(b.lhs).kv_kor(env.lkv_expr_kind(b.rhs)),
        .Cond(d)        => env.lkv_expr_kind(d.c).kv_kor(env.lkv_expr_kind(d.t)).kv_kor(env.lkv_expr_kind(d.e)),
        .Member(m)      => env.lkv_expr_kind(m.obj),
        .Arrow(ar)      => env.lkv_expr_kind(ar.obj),
        .Match(m)       => {
            subjty := env.infer_expr(m.subj)
            env.lkv_expr_kind(m.subj).kv_kor(env.lkv_arms(subjty, m.arms))
        },
        .MakeEnum(mk)   => env.lkv_expr_kind(mk.payload),
        .MakeStruct(sd) => env.lkv_inits(sd.inits),
        .Block(b)       => env.a.lkv_body_kind(env, b.stmts),
        .Loop(l)        => env.lkv_expr_kind(l.seq).kv_kor(env.a.lkv_body_kind(env.a.loop_env(env, l), l.body)),
        _               => 0,
    })
}
lkv_stmt_kind = (a: MutPtr<Malloc>, env: Env, st: Stmt) i32 {
    st.match ({
        .Let(l)      => env.lkv_expr_kind(l.value),
        .Assign(x)   => env.lkv_expr_kind(x.target).kv_kor(env.lkv_expr_kind(x.value)),
        .Return(r)   => env.lkv_expr_kind(r),
        .ExprStmt(e) => env.lkv_expr_kind(e),
        .If(f)       => env.lkv_expr_kind(f.c).kv_kor(a.lkv_body_kind(env, f.then)).kv_kor(a.lkv_body_kind(env, f.els)),
        .While(w)    => env.lkv_expr_kind(w.c).kv_kor(a.lkv_body_kind(env, w.body)),
        .IndexSet(x) => env.lkv_expr_kind(x.seq).kv_kor(env.lkv_expr_kind(x.idx)).kv_kor(env.lkv_expr_kind(x.value)),
    })
}
lkv_body_kind = (a: MutPtr<Malloc>, env: Env, body: [Stmt]) i32 {
    acc := 0
    e := env
    body.loop((h, i, st) {
        acc = acc.kv_kor(a.lkv_stmt_kind(e, st))
        e = a.extend_env(e, st)
    })
    acc
}
// mirrors check_expr exactly: same node order, same sub-error precedence, kind codes instead of counts.
kv_check_expr_kind = (env: Env, e: Ptr<Expr>) i32 {
    load(e).match ({
        .Call(c)        => env.kv_check_call_kind(c).kv_at(c.pos).kv_kor(env.store_mut_kind(c)).kv_kor(env.null_deref_kind(c)).kv_kor(eq(c.fn, "sizeof").match ({ true => 0, false => env.kv_check_args_kind(c.args) })),
        .SliceLit(sd)   => env.kv_slicelit_kind(sd.items),
        .Index(ix)      => env.kv_check_expr_kind(ix.seq).kv_kor(env.kv_check_expr_kind(ix.idx)).kv_kor(env.kv_index_kind(ix)),
        .Bin(b)         => env.kv_check_expr_kind(b.lhs).kv_kor(env.kv_check_expr_kind(b.rhs)).kv_kor(env.kv_operand_kind(b)),
        .Cond(d)        => env.kv_check_expr_kind(d.c).kv_kor(env.kv_check_expr_kind(d.t)).kv_kor(env.kv_check_expr_kind(d.e)).kv_kor(d.t.expr_drops_return().kv_one(KVALPOSRETURN())).kv_kor(d.e.expr_drops_return().kv_one(KVALPOSRETURN())).kv_kor(env.cond_result_err(d).kv_one(KRETURNFIT()).kv_at(load(d.t).expr_pos())).kv_kor(d.cond_onearm_err().kv_one(KEXHAUST()).kv_at(load(d.c).expr_pos())),
        .Member(m)      => env.kv_check_expr_kind(m.obj).kv_kor(env.kv_member_kind(m.obj, m.field)),
        .Arrow(ar)      => env.kv_check_expr_kind(ar.obj).kv_kor(env.kv_member_kind(ar.obj, ar.field)),
        .Match(m)       => {
            subjty := env.infer_expr(m.subj)
            env.kv_check_expr_kind(m.subj).kv_kor(env.kv_check_arms_kind(subjty, m.arms)).kv_kor(env.kv_match_kind(m)).kv_kor(env.kv_match_arm_result_kind(subjty, m.arms)).kv_kor(kv_arm_return_kind(m.arms))
        },
        .MakeEnum(mk)   => env.kv_check_expr_kind(mk.payload).kv_kor(env.mkenum_err(mk.ty, mk.variant).kv_one(KUNDEFINED())).kv_kor(env.enum_payload_err(mk).kv_one(KARGTYPE()).kv_at(load(mk.payload).expr_pos())),
        .Tag(t)         => env.mkenum_err(t.ty, t.variant).kv_one(KUNDEFINED()),
        .MakeStruct(sd) => env.kv_check_inits_kind(sd.inits).kv_kor(env.kv_makestruct_kind(sd)),
        .Block(b)       => env.kv_check_block_kind(b.stmts),
        .Var(v)         => env.var_err(v.name).kv_one(KUNDEFINED()).kv_at(v.pos),
        .Loop(l)        => env.lkv_expr_kind(l.seq).kv_kor(env.a.lkv_body_kind(env.a.loop_env(env, l), l.body)),
        .Lambda(lm)     => KLAMBDAVALUE(),    // a surviving lambda = used as a value (see check_expr)
        _               => 0,
    })
}
pos_or = (p: i32, fallback: i32) i32 { (p <= 0).match ({ true => fallback, false => p }) }
kv_ret_kind = (env: Env, r: Ptr<Expr>) i32 { env.ret_err(r).kv_one(KRETURNFIT()).kv_at(load(r).expr_pos()) }
kv_let_fit_kind = (env: Env, l: LetData) i32 { env.let_fit_err(l).kv_one(KASSIGNFIT()).kv_at(load(l.value).expr_pos()) }
kv_let_needannot_kind = (env: Env, l: LetData) i32 { env.let_needannot_err(l).kv_one(KNEEDANNOT()).kv_at(load(l.value).expr_pos()) }
kv_assign_kind = (env: Env, x: AssignData) i32 { ap := x.pos.pos_or(load(x.target).expr_pos()).pos_or(load(x.value).expr_pos())  env.assign_err(x).kv_one(KASSIGNFIT()).kv_at(ap).kv_kor(env.assign_ptr_write_err(x).kv_one(KPTRWRITE()).kv_at(ap)) }
kv_idxset_kind = (env: Env, x: IndexSetData) i32 { env.idxset_err(x).kv_one(KASSIGNFIT()).kv_at(x.pos.pos_or(load(x.value).expr_pos()).pos_or(load(x.seq).expr_pos())) }
// mirrors check_stmt: the statement's sub-expressions, then its own fit check.
kv_check_stmt_kind = (a: MutPtr<Malloc>, env: Env, st: Stmt) i32 {
    st.match ({
        .Let(l)      => env.kv_check_expr_kind(l.value).kv_kor(env.kv_let_fit_kind(l)).kv_kor(env.kv_let_needannot_kind(l)),
        .Assign(x)   => env.kv_check_expr_kind(x.target).kv_kor(env.kv_check_expr_kind(x.value)).kv_kor(env.kv_assign_kind(x)),
        .Return(r)   => env.kv_check_expr_kind(r).kv_kor(env.kv_ret_kind(r)),
        .ExprStmt(e) => env.kv_check_expr_kind(e),
        .If(f)       => env.kv_check_expr_kind(f.c).kv_kor(a.kv_check_body_kind(env, f.then)).kv_kor(a.kv_check_body_kind(env, f.els)),
        .While(w)    => env.kv_check_expr_kind(w.c).kv_kor(a.kv_check_body_kind(env, w.body)),
        .IndexSet(x) => env.kv_check_expr_kind(x.seq).kv_kor(env.kv_check_expr_kind(x.idx)).kv_kor(env.kv_check_expr_kind(x.value)).kv_kor(env.kv_idxset_kind(x)),
    })
}
kv_check_body_kind = (a: MutPtr<Malloc>, env: Env, body: [Stmt]) i32 {
    acc := 0
    e := env
    body.loop((h, i, st) {
        acc = acc.kv_kor(a.kv_check_stmt_kind(e, st))
        e = a.extend_env(e, st)
    })
    acc
}
// the trailing-value check, kind-flavoured: an empty / non-value-ending non-void body, or a trailing
// expr that doesn't fit, is a KRETURNFIT (a missing/mistyped produced value).
kv_last_stmt_kind = (env: Env, st: Stmt) i32 {
    st.match ({
        .ExprStmt(e) => env.kv_ret_kind(e),
        .Return(r)   => 0,
        _            => KRETURNFIT(),
    })
}
kv_trailing_kind = (env: Env, body: [Stmt]) i32 { env.exp.is_void_ty().match ({ true => 0, false => (body.len == 0).match ({ true => KRETURNFIT(), false => env.kv_last_stmt_kind(body[body.len - 1]) }) }) }
kv_check_func_kind = (a: MutPtr<Malloc>, decls: [Decl], idx: DeclIndex, f: Func) i32 {
    env := Env(
        vars: a.params_env(f.params),
        decls: decls,
        didx: idx,
        exp: f.ret,
        a: a,
    )
    a.kv_check_body_kind(env, f.body).kv_kor(env.kv_trailing_kind(f.body))
}
// ── bounded-generics enforcement over RAW (pre-inline) decls ─────────────────────────────
// Local generic calls are INLINED during resolve_module, so by check_module time the call site is
// gone. This pass therefore runs on the raw, pre-inline decls (like the M5 escape check), walking
// every function body and emitting KTRAITBOUND when a call binds a tparam `A: Trait` to a concrete
// type that does not impl Trait. It reports ONLY this one kind, so an unresolved generic body never
// false-positives the other validation kinds. Imported/foreign generics defer (bound_errs is 0).
kvb_call_kind = (env: Env, c: CallData) i32 { env.decls.is_known_fn(c.fn).match ({ true => env.bound_errs(env.decls.the_func(c.fn), c).kv_one(KTRAITBOUND()).kv_at(c.pos), false => 0 }) }
kvb_expr_kind = (env: Env, e: Ptr<Expr>) i32 {
    load(e).match ({
        .Call(c)        => env.kvb_call_kind(c).kv_kor(env.kvb_args_kind(c.args)),
        .Index(ix)      => env.kvb_expr_kind(ix.seq).kv_kor(env.kvb_expr_kind(ix.idx)),
        .Bin(b)         => env.kvb_expr_kind(b.lhs).kv_kor(env.kvb_expr_kind(b.rhs)),
        .Cond(d)        => env.kvb_expr_kind(d.c).kv_kor(env.kvb_expr_kind(d.t)).kv_kor(env.kvb_expr_kind(d.e)),
        .Member(m)      => env.kvb_expr_kind(m.obj),
        .Arrow(ar)      => env.kvb_expr_kind(ar.obj),
        .Match(m)       => env.kvb_expr_kind(m.subj).kv_kor(env.kvb_arms_kind(env.infer_expr(m.subj), m.arms)),
        .MakeEnum(mk)   => env.kvb_expr_kind(mk.payload),
        .MakeStruct(sd) => env.kvb_inits_kind(sd.inits),
        .Block(b)       => env.a.kvb_body_kind(env, b.stmts),
        .Loop(l)        => env.kvb_expr_kind(l.seq).kv_kor(env.a.kvb_body_kind(env, l.body)),
        _               => 0,
    })
}
kvb_args_kind = (env: Env, args: [Expr]) i32 {
    acc := 0
    args.loop((h, i, ar) {
        acc = acc.kv_kor(env.kvb_expr_kind(ar.addr()))
    })
    acc
}
kvb_inits_kind = (env: Env, inits: [FieldInit]) i32 {
    acc := 0
    inits.loop((h, i, fi) {
        acc = acc.kv_kor(env.kvb_expr_kind(fi.value))
    })
    acc
}
kvb_arms_kind = (env: Env, subjty: Ty, arms: [ArmData]) i32 {
    acc := 0
    arms.loop((h, i, ar) {
        acc = acc.kv_kor(env.a.arm_env(env, subjty, ar).kvb_expr_kind(ar.body))
    })
    acc
}
kvb_stmt_kind = (a: MutPtr<Malloc>, env: Env, st: Stmt) i32 {
    st.match ({
        .Let(l)      => env.kvb_expr_kind(l.value),
        .Assign(x)   => env.kvb_expr_kind(x.target).kv_kor(env.kvb_expr_kind(x.value)),
        .Return(r)   => env.kvb_expr_kind(r),
        .ExprStmt(e) => env.kvb_expr_kind(e),
        .If(f)       => env.kvb_expr_kind(f.c).kv_kor(a.kvb_body_kind(env, f.then)).kv_kor(a.kvb_body_kind(env, f.els)),
        .While(w)    => env.kvb_expr_kind(w.c).kv_kor(a.kvb_body_kind(env, w.body)),
        .IndexSet(x) => env.kvb_expr_kind(x.seq).kv_kor(env.kvb_expr_kind(x.idx)).kv_kor(env.kvb_expr_kind(x.value)),
    })
}
kvb_body_kind = (a: MutPtr<Malloc>, env: Env, body: [Stmt]) i32 {
    acc := 0
    e := env
    body.loop((h, i, st) {
        acc = acc.kv_kor(a.kvb_stmt_kind(e, st))
        e = a.extend_env(e, st)
    })
    acc
}
kvb_func_kind = (a: MutPtr<Malloc>, decls: [Decl], f: Func) i32 {
    env := Env(
        vars: a.params_env(f.params),
        decls: decls,
        exp: f.ret,
        a: a,
    )
    a.kvb_body_kind(env, f.body)
}
check_module_bound_kind* = (a: MutPtr<Malloc>, decls: [Decl]) i32 {
    acc := 0
    decls.loop((h, i, d) {
        acc = acc.kv_kor(d.match ({
            .DFunc(f) => a.kvb_func_kind(decls, f),
            _         => 0,
        }))
    })
    acc
}
check_module_bound_diagnostic_from_source* = (a: MutPtr<Malloc>, decls: [Decl], src: str) CheckDiagnostic {
    packed := a.check_module_bound_kind(decls)
    (packed == 0).match ({ true => check_diagnostic_none(), false => src.check_diagnostic_from_source(packed, 1) })
}
// ── undefined type names in annotations (a standalone, driver-only pass) ───────────────────────────
// `m: MutPtr<TotallyUndefinedType>` type-checked "ok" then leaked an unknown C type name. A Named (or
// Generic-base) type in a signature / field / payload that is NOT a primitive, a DECLARED type
// (struct/enum/gen-struct/gen-enum, incl. anon structs), an in-scope tparam, or `Self` is a real
// "unknown type". Runs ONLY in the driver check chain, on the FULLY-FLATTENED decls — where every
// legitimate (incl. imported) type is present — so an undeclared name is genuinely undefined, not the
// cross-module / pre-mono "uninferable residue" the core validator deliberately tolerates. It is NOT
// part of check_module's count/kind (the oracle runs that on NON-flattened source), so the oracle is
// untouched. Pointer/slice elements and generic args recurse; FnT internals are left to later checks.
ut_has_tparam = (tparams: [Param], n: str) bool {
    f := false
    tparams.loop((h, i, tp) {
        f = eq(tp.name, n).match ({ true => true, false => f })
    })
    f
}
ut_unknown_ty = (env: Env, tparams: [Param], t: Ty) i32 {
    t.match ({
        .Named(n)   => (eq(n, "Self") || is_prim_width(n) || tparams.ut_has_tparam(n) || env.env_named_declared(n)).match ({ true => 0, false => 1 }),
        .Generic(g) => env.env_named_declared(g.name).match ({ true => env.ut_unknown_tys(tparams, g.args), false => 1 }),
        .Ptr(pd)    => env.ut_unknown_ty(tparams, load(pd.pointee)),
        .Slice(e)   => env.ut_unknown_ty(tparams, load(e)),
        _           => 0,
    })
}
ut_unknown_tys = (env: Env, tparams: [Param], ts: [Ty]) i32 {
    acc := 0
    ts.loop((h, i, t) {
        acc = acc.kv_kor(env.ut_unknown_ty(tparams, t))
    })
    acc
}
ut_params_kind = (env: Env, tparams: [Param], ps: [Param]) i32 {
    acc := 0
    ps.loop((h, i, p) {
        acc = acc.kv_kor(env.ut_unknown_ty(tparams, p.ty).kv_one(KUNKNOWNTYPE()))
    })
    acc
}
ut_fields_kind = (env: Env, tparams: [Param], fs: [Field]) i32 {
    acc := 0
    fs.loop((h, i, f) {
        acc = acc.kv_kor(env.ut_unknown_ty(tparams, f.ty).kv_one(KUNKNOWNTYPE()))
    })
    acc
}
ut_payloads_kind = (env: Env, tparams: [Param], vs: [VariantDef]) i32 {
    acc := 0
    vs.loop((h, i, v) {
        acc = acc.kv_kor(env.ut_unknown_ty(tparams, v.payload).kv_one(KUNKNOWNTYPE()))
    })
    acc
}
// also walk the body: a LOCAL `let` with an explicit annotation (`x: Foo := e`) names a type, and an
// undefined one leaked an unknown C type just like a param/field/return would. Recurse through nested
// control flow (Block/Loop/Match/Cond) so a deeply-nested `let` annotation is checked too.
ut_arms_kind = (a: MutPtr<Malloc>, env: Env, tparams: [Param], arms: [ArmData]) i32 {
    acc := 0
    arms.loop((h, i, ar) {
        acc = acc.kv_kor(a.ut_expr_kind(env, tparams, ar.body))
    })
    acc
}
ut_expr_kind = (a: MutPtr<Malloc>, env: Env, tparams: [Param], e: Ptr<Expr>) i32 {
    load(e).match ({
        .Block(b) => a.ut_body_kind(env, tparams, b.stmts),
        .Loop(l)  => a.ut_body_kind(env, tparams, l.body),
        .Match(m) => a.ut_arms_kind(env, tparams, m.arms),
        .Cond(d)  => a.ut_expr_kind(env, tparams, d.t).kv_kor(a.ut_expr_kind(env, tparams, d.e)),
        _         => 0,
    })
}
// a LOCAL `let` annotation (`x: T := e`); tvoid means unannotated, so nothing to check.
ut_let_kind = (a: MutPtr<Malloc>, env: Env, tparams: [Param], l: LetData) i32 { l.ty.is_void_ty().match ({ true => 0, false => env.ut_unknown_ty(tparams, l.ty).kv_one(KUNKNOWNTYPE()).kv_at(load(l.value).expr_pos()) }) }
ut_stmt_kind = (a: MutPtr<Malloc>, env: Env, tparams: [Param], st: Stmt) i32 {
    st.match ({
        .Let(l)      => a.ut_let_kind(env, tparams, l).kv_kor(a.ut_expr_kind(env, tparams, l.value)),
        .Assign(x)   => a.ut_expr_kind(env, tparams, x.value),
        .Return(r)   => a.ut_expr_kind(env, tparams, r),
        .ExprStmt(e) => a.ut_expr_kind(env, tparams, e),
        .If(f)       => a.ut_expr_kind(env, tparams, f.c).kv_kor(a.ut_body_kind(env, tparams, f.then)).kv_kor(a.ut_body_kind(env, tparams, f.els)),
        .While(w)    => a.ut_expr_kind(env, tparams, w.c).kv_kor(a.ut_body_kind(env, tparams, w.body)),
        .IndexSet(x) => a.ut_expr_kind(env, tparams, x.value),
    })
}
ut_body_kind = (a: MutPtr<Malloc>, env: Env, tparams: [Param], body: [Stmt]) i32 {
    acc := 0
    body.loop((h, i, st) {
        acc = acc.kv_kor(a.ut_stmt_kind(env, tparams, st))
    })
    acc
}
ut_func_kind = (a: MutPtr<Malloc>, env: Env, f: Func) i32 { env.ut_params_kind(f.tparams, f.params).kv_kor(env.ut_unknown_ty(f.tparams, f.ret).kv_one(KUNKNOWNTYPE())).kv_kor(a.ut_body_kind(env, f.tparams, f.body)) }
check_module_unknown_type_kind* = (a: MutPtr<Malloc>, decls: [Decl]) i32 {
    idx := a.build_decl_index(decls)
    env := Env(
        vars: a.params_env(cv_no_params()),
        decls: decls,
        didx: idx,
        exp: tvoid(),
        a: a,
    )
    acc := 0
    decls.loop((h, i, d) {
        acc = acc.kv_kor(d.match ({
            .DFunc(f)      => a.ut_func_kind(env, f),
            .DForeign(f)   => a.ut_func_kind(env, f),
            .DStruct(sd)   => env.ut_fields_kind(cv_no_params(), sd.fields),
            .DEnum(ed)     => env.ut_payloads_kind(cv_no_params(), ed.variants),
            .DGenStruct(g) => env.ut_fields_kind(g.tparams, g.fields),
            .DGenEnum(g)   => env.ut_payloads_kind(g.tparams, g.variants),
            _              => 0,
        }))
    })
    acc
}
check_module_unknown_type_diagnostic_from_source* = (a: MutPtr<Malloc>, decls: [Decl], src: str) CheckDiagnostic {
    packed := a.check_module_unknown_type_kind(decls)
    (packed == 0).match ({ true => check_diagnostic_none(), false => src.check_diagnostic_from_source(packed, 1) })
}
// ── infinite type: a struct/enum that contains ITSELF by VALUE (transitively) ──────────────────────────
// A by-value field/payload whose type is the enclosing type — directly (`Node: { next: Node }`,
// `E: A(E) | B`) or through a chain of other by-value structs/enums (mutual recursion `A: { b: B }`,
// `B: { a: A }`) — has infinite size; codegen emits a self-containing C struct and `cc` dies with the
// confusing `field '…' has incomplete type`. INDIRECTION breaks the cycle: a `Ptr<T>` / `MutPtr<T>` /
// `RawPtr<T>` (all `.Ptr`) or a `[T]` slice (`.Slice`) is a finite pointer, so the compiler's own
// recursive AST (`Ptr<Expr>`, `Ptr<Ty>`) is correctly NOT flagged. A generic instance (`.Generic`) is
// treated as cycle-breaking in the concrete pass (its monomorphized size is decided later); generic
// SELF-instantiation (`Node<T>: { next: Node<T> }`) is caught by the dedicated generic pass below.
// the by-value out-edge a member type contributes to the containment graph; "" = indirection/leaf.
inf_edge_name = (t: Ty) str {
    t.match ({
        .Named(n) => n,
        _         => "",
    })
}    // Ptr/Slice/Generic/primitive/FnT all break the cycle
// does the member type `t` reach `target` by value? `depth` bounds the walk (= max distinct names) so a
// cycle terminates instead of looping forever.
inf_edge_reaches = (decls: [Decl], target: str, t: Ty, depth: i64) bool {
    en := t.inf_edge_name()
    en.is_empty().match ({ true => false, false => eq(en, target).match ({ true => true, false => (depth <= 0).match ({ true => false, false => decls.inf_named_reaches(target, en, depth - 1) }) }) })
}
inf_fields_reach = (decls: [Decl], target: str, fields: [Field], depth: i64) bool {
    hit := false
    fields.loop((h, i, fl) {
        hit = hit.match ({ true => true, false => decls.inf_edge_reaches(target, fl.ty, depth) })
    })
    hit
}
inf_variants_reach = (decls: [Decl], target: str, vs: [VariantDef], depth: i64) bool {
    hit := false
    vs.loop((h, i, v) {
        hit = hit.match ({ true => true, false => decls.inf_edge_reaches(target, v.payload, depth) })
    })
    hit
}
// expand the named type `cur` (a struct's fields or an enum's variant payloads) and recurse.
inf_named_reaches = (decls: [Decl], target: str, cur: str, depth: i64) bool { decls.is_struct(cur).match ({ true => decls.inf_fields_reach(target, decls.struct_fields(cur), depth), false => decls.inf_variants_reach(target, decls.enum_variants(cur), depth) }) }
// generic decl: a DIRECT self-instantiation by value — a field/payload typed `Self` or `Self<…>`.
inf_gen_self = (t: Ty, name: str) bool {
    t.match ({
        .Named(n)   => eq(n, name),
        .Generic(g) => eq(g.name, name),
        _           => false,
    })
}
inf_gen_fields = (fields: [Field], name: str) bool {
    f := false
    fields.loop((h, i, fl) {
        f = fl.ty.inf_gen_self(name).match ({ true => true, false => f })
    })
    f
}
inf_gen_variants = (vs: [VariantDef], name: str) bool {
    f := false
    vs.loop((h, i, v) {
        f = v.payload.inf_gen_self(name).match ({ true => true, false => f })
    })
    f
}
check_module_infinite_type_kind* = (decls: [Decl]) i32 {
    acc := 0
    decls.loop((h, i, d) {
        acc = acc.kv_kor(d.match ({
            .DStruct(sd)   => decls.inf_named_reaches(sd.name, sd.name, decls.len).match ({ true => KINFINITETYPE().kv_at(sd.pos), false => 0 }),
            .DEnum(ed)     => decls.inf_named_reaches(ed.name, ed.name, decls.len).match ({ true => KINFINITETYPE().kv_at(ed.pos), false => 0 }),
            .DGenStruct(g) => g.fields.inf_gen_fields(g.name).match ({ true => KINFINITETYPE().kv_at(g.pos), false => 0 }),
            .DGenEnum(g)   => g.variants.inf_gen_variants(g.name).match ({ true => KINFINITETYPE().kv_at(g.pos), false => 0 }),
            _              => 0,
        }))
    })
    acc
}
check_module_infinite_type_diagnostic_from_source* = (decls: [Decl], src: str) CheckDiagnostic {
    packed := decls.check_module_infinite_type_kind()
    (packed == 0).match ({ true => check_diagnostic_none(), false => src.check_diagnostic_from_source(packed, 1) })
}
// ── must-use: a DISCARDED value-mold ((Self,…) Self) self-mutation (Stage-2 A.1) ───────────────────────
// A value-mold CONTAINER method (`Map.put`, `Set.add`, … — shape `(Self, …) Self`) RETURNS the updated
// container and INVALIDATES the receiver: a grow reallocs the backing buffer, so the input header is left
// dangling. Discarding the result in statement position — `m.put(a, k, v)` as a bare statement, then
// `m.get(...)` — segfaults while `check` says ok (the #1 trust-killer for a newcomer). This driver-only
// pass runs on the RAW pre-inline decls (where the call is still a MethodCall; by check_module time the
// generic method is INLINED away) and rejects such a discard with KMUSTUSE.
//
// Scope chosen to be SAFE against the pervasive free-function builder pattern (`s = s.gen_x(…)` threads a
// `String` accumulator — those are FREE functions, never inherent methods, so they are untouched):
//   • only INHERENT struct methods (declared inside a struct body) count, and only when EVERY inherent
//     method of that name is value-mold (an ambiguous name shared with a non-value-mold method is skipped);
//   • only NON-TAIL statements are flagged — a body's last expression is its produced VALUE, not a discard,
//     so a value-mold method used as a return value / match-arm value / fluent-chain tail is never flagged.
mu_ty_is_container = (t: Ty) bool {
    t.match ({
        .Named(n)   => true,
        .Generic(g) => true,
        _           => false,
    })
}
// the `(Self, …) Self` shape: first param and return are the SAME non-pointer, non-primitive type.
mu_is_value_mold = (f: Func) bool {
    (f.params.len == 0).match ({ true => false, false => {
        p0 := f.params[0].ty
        (p0.mu_ty_is_container() && f.ret.mu_ty_is_container()).match ({ true => eq(p0.recv_name(), f.ret.recv_name()), false => false })
    } })
}
mu_methods_have = (methods: [Param], m: str) bool {
    f := false
    methods.loop((h, i, p) {
        f = eq(p.name, m).match ({ true => true, false => f })
    })
    f
}
// the hoisted inherent func `impl_<Ty>_<Ty>_<m>` (fill_inherent_methods), looked up O(1) via the index.
mu_func_value_mold = (a: MutPtr<Malloc>, decls: [Decl], idx: DeclIndex, ty: str, m: str) bool {
    cname := a.impl_cname_in(ty, ty, m)
    i := idx.func_idx.get(cname, 0 - 1)
    (i >= 0 && i < decls.len).match ({ true => decls[i].match ({
        .DFunc(f) => f.mu_is_value_mold(),
        _         => false,
    }), false => false })
}
// fold one inherent-struct impl's methods into the name→state map (0 unseen, 1 value-mold-only, 2 tainted).
mu_index_methods = (a: MutPtr<Malloc>, decls: [Decl], idx: DeclIndex, m: Map<i64>, ty: str, methods: [Param], j: i32) Map<i64> {
    (j >= methods.len).match ({ true => m, false => {
        p := methods[j]
        vm := a.mu_func_value_mold(decls, idx, ty, p.name)
        prev := m.get(p.name, 0)
        next: i64 := vm.match ({ true => (prev == 0).match ({ true => 1, false => (prev == 1).match ({ true => 1, false => 2 }) }), false => 2 })
        a.mu_index_methods(decls, idx, m.put(a, p.name, next), ty, methods, j + 1)
    } })
}
mu_index_impl = (a: MutPtr<Malloc>, decls: [Decl], idx: DeclIndex, m: Map<i64>, im: ImplData) Map<i64> { eq(im.ty, im.trname).match ({ true => a.mu_index_methods(decls, idx, m, im.ty, im.methods, 0), false => m }) }
// method name → 1 iff it is an inherent method AND value-mold on EVERY struct that declares it.
mu_build_index = (a: MutPtr<Malloc>, decls: [Decl], idx: DeclIndex) Map<i64> {
    seed: i64 := 0 - 1
    m := of(a, "", seed)
    decls.loop((h, i, d) {
        m = d.match ({
            .DImpl(im) => a.mu_index_impl(decls, idx, m, im),
            _          => m,
        })
    })
    m
}
// flag a discarded MethodCall to a safe-to-flag value-mold inherent method.
// In the normal parse, UFCS `recv.m(args)` lowers to a flat `Call(fn: m, args: [recv] ++ args)` whose
// `fn` is the SIMPLE method name — exactly the index key. (The faithful MethodCall form is fmt-only, but
// match it too for safety.) Flag a discarded call whose callee is a safe-to-flag value-mold method.
// the value-mold DANGER is reusing a STALE NAMED LOCAL after a discarded self-mutation (`m.put(...)`
// then `m.get(...)`). A fresh FLUENT CHAIN (`put("x=").i(3).nl()` — receiver is itself a call, not a
// reused binding) carries no stale-local risk, so it must NOT be flagged (else builder APIs break).
// Gate: only flag when the receiver (first arg / recv) is a bare Var.
mu_is_var = (e: Expr) bool {
    e.match ({
        .Var(v) => true,
        _       => false,
    })
}
mu_call_kind = (mvm: Map<i64>, e: Ptr<Expr>) i32 {
    load(e).match ({
        .Call(c)        => (mvm.get(c.fn, 0) == 1 && c.args.len > 0 && mu_is_var(c.args[0])).match ({ true => KMUSTUSE().kv_at(c.pos), false => 0 }),
        .MethodCall(mc) => (mvm.get(mc.method, 0) == 1 && mu_is_var(load(mc.recv))).match ({ true => KMUSTUSE().kv_at(mc.pos), false => 0 }),
        _               => 0,
    })
}
mu_arms_kind = (a: MutPtr<Malloc>, mvm: Map<i64>, arms: [ArmData]) i32 {
    acc := 0
    arms.loop((h, i, ar) {
        acc = acc.kv_kor(a.mu_expr_kind(mvm, ar.body))
    })    // arm body = the arm's VALUE (tail)
    acc
}
// recurse into nested control-flow whose bodies can hold discarded statements.
mu_expr_kind = (a: MutPtr<Malloc>, mvm: Map<i64>, e: Ptr<Expr>) i32 {
    load(e).match ({
        .Block(b) => a.mu_body_kind(mvm, b.stmts),
        .Loop(l)  => a.mu_body_kind(mvm, l.body),
        .Match(m) => a.mu_arms_kind(mvm, m.arms),
        .Cond(d)  => a.mu_expr_kind(mvm, d.t).kv_kor(a.mu_expr_kind(mvm, d.e)),
        _         => 0,
    })
}
// an ExprStmt: flag a discarded value-mold call when NOT in tail position, and always recurse for nested
// discards. (Extracted so the nested `is_tail.match(...)` is a plain statement, not a chained arm body.)
mu_exprstmt_kind = (a: MutPtr<Malloc>, mvm: Map<i64>, e: Ptr<Expr>, is_tail: bool) i32 {
    head := is_tail.match ({ true => 0, false => mvm.mu_call_kind(e) })
    head.kv_kor(a.mu_expr_kind(mvm, e))
}
mu_stmt_kind = (a: MutPtr<Malloc>, mvm: Map<i64>, st: Stmt, is_tail: bool) i32 {
    st.match ({
        .ExprStmt(e) => a.mu_exprstmt_kind(mvm, e, is_tail),
        .Let(l)      => a.mu_expr_kind(mvm, l.value),
        .Assign(x)   => a.mu_expr_kind(mvm, x.value),
        .Return(r)   => a.mu_expr_kind(mvm, r),
        .If(f)       => a.mu_body_kind(mvm, f.then).kv_kor(a.mu_body_kind(mvm, f.els)),
        .While(w)    => a.mu_body_kind(mvm, w.body),
        .IndexSet(x) => a.mu_expr_kind(mvm, x.value),
    })
}
// the body's LAST statement is its produced value (tail) — never a discard; every earlier ExprStmt is.
mu_body_kind = (a: MutPtr<Malloc>, mvm: Map<i64>, body: [Stmt]) i32 {
    acc := 0
    n := body.len
    body.loop((h, i, st) {
        acc = acc.kv_kor(a.mu_stmt_kind(mvm, st, i == n - 1))
    })
    acc
}
check_module_mustuse_kind* = (a: MutPtr<Malloc>, decls: [Decl]) i32 {
    idx := a.build_decl_index(decls)
    mvm := a.mu_build_index(decls, idx)
    acc := 0
    decls.loop((h, i, d) {
        acc = acc.kv_kor(d.match ({
            .DFunc(f) => a.mu_body_kind(mvm, f.body),
            _         => 0,
        }))
    })
    acc
}
check_module_mustuse_diagnostic_from_source* = (a: MutPtr<Malloc>, decls: [Decl], src: str) CheckDiagnostic {
    packed := a.check_module_mustuse_kind(decls)
    (packed == 0).match ({ true => check_diagnostic_none(), false => src.check_diagnostic_from_source(packed, 1) })
}
// trait conformance, kind-flavoured (mirrors impl_errs/trait_conformance/method_err).
kv_method_kind = (a: MutPtr<Malloc>, decls: [Decl], im: ImplData, f: Field) i32 { a.method_err(decls, im, f).kv_one(KCONFORMANCE()) }
kv_conformance_kind = (a: MutPtr<Malloc>, decls: [Decl], im: ImplData, sd: StructDecl) i32 {
    acc := 0
    sd.fields.loop((h, i, f) {
        acc = acc.kv_kor(a.kv_method_kind(decls, im, f))
    })
    acc
}
kv_impl_kind = (a: MutPtr<Malloc>, decls: [Decl], im: ImplData) i32 {
    acc := 0
    decls.loop((h, i, d) {
        acc = acc.kv_kor(d.match ({
            .DStruct(sd) => eq(sd.name, im.trname).match ({ true => a.kv_conformance_kind(decls, im, sd), false => 0 }),
            _            => 0,
        }))
    })
    acc.kv_at(im.pos)
}
// the KIND of the FIRST error check_module would have counted, in the same order: dup-fn names
// first, then each decl's body (DFunc) / impl (DImpl). Returns KNONE (0) for an accepting module.
// A CHECK-KIND binary reads this; check_module's COUNT is untouched, so the oracle's verdict path
// (which exits with the count) keeps working unchanged.
check_module_kind* = (a: MutPtr<Malloc>, decls: [Decl]) i32 {
    acc := decls.dup_name_errs().kv_one(KDUPFN())
    idx := a.build_decl_index(decls)
    decls.loop((h, i, d) {
        acc = acc.kv_kor(d.match ({
            .DFunc(f)   => a.kv_check_func_kind(decls, idx, f),
            .DImpl(im)  => a.kv_impl_kind(decls, im),
            .DGlobal(g) => eq(g.name, "__syntax_error").match ({ true => KPARSE().kv_at(g.init.kparse_off()), false => 0 }),
            _           => 0,
        }))
    })
    acc
}
// the __syntax_error sentinel carries the failing token's byte offset in its Int init value (0 = none);
// the Int passes through resolve unchanged (`_ => e`), so the offset survives to this post-resolve pass.
kparse_off = (init: Ptr<Expr>) i32 {
    load(init).match ({
        .Int(n) => n.to_i32(),
        _       => 0,
    })
}
check_module_diagnostic* = (a: MutPtr<Malloc>, decls: [Decl]) CheckDiagnostic {
    packed := a.check_module_kind(decls)
    (packed == 0).match ({ true => check_diagnostic_none(), false => check_diagnostic_from_packed(packed, a.check_module(decls)) })
}
check_module_ownership_diagnostic* = (a: MutPtr<Malloc>, decls: [Decl]) CheckDiagnostic {
    packed := a.check_module_ownership_kind(decls)
    (packed == 0).match ({ true => check_diagnostic_none(), false => check_diagnostic_from_packed(packed, a.check_module_ownership(decls)) })
}
check_module_diagnostic_from_source* = (a: MutPtr<Malloc>, decls: [Decl], src: str) CheckDiagnostic {
    packed := a.check_module_kind(decls)
    (packed == 0).match ({ true => check_diagnostic_none(), false => src.check_diagnostic_from_source(packed, a.check_module(decls)) })
}
check_module_ownership_diagnostic_from_source* = (a: MutPtr<Malloc>, decls: [Decl], src: str) CheckDiagnostic {
    packed := a.check_module_ownership_kind(decls)
    (packed == 0).match ({ true => check_diagnostic_none(), false => src.check_diagnostic_from_source(packed, a.check_module_ownership(decls)) })
}
module_diagnostic* = (a: MutPtr<Malloc>, decls: [Decl]) Diagnostic { a.check_module_diagnostic(decls).check_to_diagnostic() }
module_ownership_diagnostic* = (a: MutPtr<Malloc>, decls: [Decl]) Diagnostic { a.check_module_ownership_diagnostic(decls).check_to_diagnostic() }
module_diagnostic_from_source* = (a: MutPtr<Malloc>, decls: [Decl], src: str) Diagnostic { a.check_module_diagnostic_from_source(decls, src).check_to_diagnostic() }
module_ownership_diagnostic_from_source* = (a: MutPtr<Malloc>, decls: [Decl], src: str) Diagnostic { a.check_module_ownership_diagnostic_from_source(decls, src).check_to_diagnostic() }
// the kind layer over a CROSS-MODULE link (mirrors check_linked): same layered header, then
// check_module_kind instead of check_module. Lets a cross-module reject also be pinned by KIND.
check_linked_kind* = (a: MutPtr<Malloc>, decls: [Decl], lib: [Decl]) i32 {
    hdr := a.module_header(lib)
    rfile := a.resolve_module(decls)
    world := a.dbuf(hdr.len + rfile.len)
    hdr.loop((h, i, d) {
        world[i] = d
    })
    rfile.loop((h, i, d) {
        world[hdr.len + i] = d
    })
    a.check_module_kind(world)
}
// ── cross-module linking (Goal Arc 1) ───────────────────────────────────────────────
// The self-hosted "module loader". A module's HEADER is its public surface reduced to signatures:
// every function becomes a bodyless DForeign (structs/enums pass through). Checking a file against
// another module's header puts the imported names in `the_func`'s reach, so a cross-module call is
// arity/arg-type-checked exactly like a local one — while the header's bodyless sigs are never
// re-checked (check_module only descends DFunc bodies). A name imported but absent from the header
// stays known-but-unchecked (the #204 DImport path), so partial headers never false-reject.
as_sig = (a: MutPtr<Malloc>, d: Decl) Decl {
    d.match ({
        .DFunc(f) => dforeign(Func(
            name: f.name,
            params: f.params,
            ret: f.ret,
            tparams: f.tparams,
            body: no_stmts(),
        )),
        _         => d,
    })
}
module_header* = (a: MutPtr<Malloc>, decls: [Decl]) [Decl] {
    buf := a.dbuf(decls.len)
    decls.loop((h, i, d) {
        buf[i] = a.as_sig(d)
    })
    buf
}
// check `decls` (one file) against an imported module's `lib` decls: the file is resolved as usual,
// then checked in a WORLD that prepends lib's header, so its imported calls resolve to real sigs.
check_linked* = (a: MutPtr<Malloc>, decls: [Decl], lib: [Decl]) i32 {
    hdr := a.module_header(lib)
    rfile := a.resolve_module(decls)
    world := a.dbuf(hdr.len + rfile.len)
    hdr.loop((h, i, d) {
        world[i] = d
    })
    rfile.loop((h, i, d) {
        world[hdr.len + i] = d
    })
    a.check_module(world)
}
// ════════════════════════════════════════════════════════════════════════════════════════
// ── M5: LEXICAL SCOPE-ESCAPE CHECK ──────────────────────────────────────────────────────
// A parameter `s: MutPtr<Scope<…>>` is a SCOPE RECEIVER. Memory it hands out via `s.acquire(…)`
// lives in the scope's arena, which `with_sync`/`with_async` FREE on exit — so RETURNING such a
// pointer (or a local bound to it) past the scope compiles a use-after-free. Scopes are lexical, so a
// lexical rule suffices: collect the scope-receiver params, track locals bound to a scope-derived
// pointer (`p := s.acquire(…)` / `p := s.alloc.acquire(…)` / `p := s.alloc`), and REJECT a
// `return <that>` / a trailing `<that>` where `<that>` is such a local OR a direct `s.acquire(…)`.
// The direct form deliberately excludes Scope's own `s.alloc.acquire(n)` accessor (its receiver is the
// `.alloc` field, not the scope var), so std.scope's primitives are never false-rejected.
KESCAPE = () i32 { 16 }    // (own field code, NOT 4-bit packed: reported via its own diagnostic, never kv_at)
is_scope_param_ty = (t: Ty) bool {
    t.match ({
        .Ptr(pd) => load(pd.pointee).match ({
            .Generic(g) => eq(g.name, "Scope"),
            _           => false,
        }),
        _        => false,
    })
}
scope_params = (a: MutPtr<Malloc>, params: [Param]) Ptr<DeadList> {
    out := a.dead_nil()
    params.loop((h, i, p) {
        p.ty.is_scope_param_ty().match ({ true => {
            out = a.dead_cons(p.name, out)
        } })
    })
    out
}
// the root Var name of a member/arrow chain (`s.alloc` -> "s"); "" if not rooted at a plain Var.
expr_root_var = (e: Ptr<Expr>) str {
    load(e).match ({
        .Var(v)    => v.name,
        .Member(m) => m.obj.expr_root_var(),
        .Arrow(ar) => ar.obj.expr_root_var(),
        _          => "",
    })
}
// a call `acquire(recv, …)` whose receiver chain is rooted at a scope var (covers `s.acquire` and
// `s.alloc.acquire`). Used only to MARK a local binding as scope-derived (returning the local is the
// hazard; Scope.acquire itself never binds a local).
is_scope_acquire = (svars: Ptr<DeadList>, e: Ptr<Expr>) bool {
    load(e).match ({
        .Call(c) => (eq(c.fn, "acquire") && c.args.len > 0).match ({ true => svars.dead_has(c.args[0].addr().expr_root_var()), false => false }),
        _        => false,
    })
}
// the DIRECT hazard `s.acquire(…)`: a UFCS acquire whose FIRST ARG IS the scope var itself (a bare
// Var), NOT `s.alloc.acquire(…)` (whose first arg is the `.alloc` member — Scope's legit accessor).
is_direct_scope_acquire = (svars: Ptr<DeadList>, e: Ptr<Expr>) bool {
    load(e).match ({
        .Call(c) => (eq(c.fn, "acquire") && c.args.len > 0).match ({ true => c.args[0].match ({
            .Var(v) => svars.dead_has(v.name),
            _       => false,
        }), false => false }),
        _        => false,
    })
}
// `s.alloc` — the raw allocator field of a scope var (also escapes the scope if returned).
is_scope_alloc_member = (svars: Ptr<DeadList>, e: Ptr<Expr>) bool {
    load(e).match ({
        .Member(m) => eq(m.field, "alloc") && svars.dead_has(m.obj.expr_root_var()),
        _          => false,
    })
}
let_is_scope_derived = (svars: Ptr<DeadList>, e: Ptr<Expr>) bool { svars.is_scope_acquire(e) || svars.is_scope_alloc_member(e) }
// aliasing laundering: a value that IS an already-derived local — a bare Var, or a member/arrow chain
// rooted at one — so `q := p` / `q := p.f` taints `q` once `p` is derived.
expr_is_derived = (derived: Ptr<DeadList>, e: Ptr<Expr>) bool {
    load(e).match ({
        .Var(v)    => derived.dead_has(v.name),
        .Member(m) => derived.dead_has(m.obj.expr_root_var()),
        .Arrow(ar) => derived.dead_has(ar.obj.expr_root_var()),
        _          => false,
    })
}
// a `let` value that becomes a derived local: a scope acquire / `s.alloc` field, OR an alias of one.
let_taints = (svars: Ptr<DeadList>, derived: Ptr<DeadList>, e: Ptr<Expr>) bool { svars.let_is_scope_derived(e) || derived.expr_is_derived(e) }
// VALUE-position escape: a returned/trailing expr lets a scope value out when it IS a direct
// `s.acquire(…)`, the raw `s.alloc` field, a derived local, OR forwards one through a struct literal,
// a match arm value, a cond branch, or a block's value. Call ARGS are deliberately NOT walked — passing
// a scope pointer into a callee that returns a COPY (`to_i32(load_i64(p))`) does not escape.
expr_escapes = (a: MutPtr<Malloc>, svars: Ptr<DeadList>, derived: Ptr<DeadList>, e: Ptr<Expr>) bool {
    (svars.is_direct_scope_acquire(e) || svars.is_scope_alloc_member(e)).match ({ true => true, false => load(e).match ({
        .Var(v)        => derived.dead_has(v.name),
        .MakeStruct(s) => a.inits_escape(svars, derived, s.inits),
        .Match(m)      => a.arms_escape(svars, derived, m.arms),
        .Cond(d)       => a.expr_escapes(svars, derived, d.t) || a.expr_escapes(svars, derived, d.e),
        .Block(b)      => a.block_val_escapes(svars, derived, b.stmts),
        .Loop(l)       => a.loop_val_escapes(svars, derived, l.body),
        _              => false,
    }) })
}
// a loop in VALUE position: it never yields its trailing value, but a `return` inside its body
// still escapes to the caller, so walk returns only (mirrors the statement-side .Loop handling).
loop_val_escapes = (a: MutPtr<Malloc>, svars: Ptr<DeadList>, derived: Ptr<DeadList>, stmts: [Stmt]) bool {
    f := false
    d := derived
    stmts.loop((h, i, st) {
        st.match ({
            .Return(r) => {
                f = a.expr_escapes(svars, d, r).match ({ true => true, false => f })
            },
            _          => { },
        })
        d = a.escape_step(svars, d, st)
    })
    f
}
inits_escape = (a: MutPtr<Malloc>, svars: Ptr<DeadList>, derived: Ptr<DeadList>, inits: [FieldInit]) bool {
    f := false
    inits.loop((h, i, fi) {
        f = a.expr_escapes(svars, derived, fi.value).match ({ true => true, false => f })
    })
    f
}
arms_escape = (a: MutPtr<Malloc>, svars: Ptr<DeadList>, derived: Ptr<DeadList>, arms: [ArmData]) bool {
    f := false
    arms.loop((h, i, ar) {
        f = a.expr_escapes(svars, derived, ar.body).match ({ true => true, false => f })
    })
    f
}
// a block in VALUE position: its trailing value, or any `return` inside it, may escape (lets thread).
block_val_escapes = (a: MutPtr<Malloc>, svars: Ptr<DeadList>, derived: Ptr<DeadList>, stmts: [Stmt]) bool {
    f := false
    d := derived
    stmts.loop((h, i, st) {
        st.match ({
            .Return(r)   => {
                f = a.expr_escapes(svars, d, r).match ({ true => true, false => f })
            },
            .ExprStmt(e) => (i == stmts.len - 1).match ({ true => {
                f = a.expr_escapes(svars, d, e).match ({ true => true, false => f })
            } }),
            _            => { },
        })
        d = a.escape_step(svars, d, st)
    })
    f
}
// thread the derived-local set across a `let` (now including aliases of derived locals).
escape_step = (a: MutPtr<Malloc>, svars: Ptr<DeadList>, derived: Ptr<DeadList>, st: Stmt) Ptr<DeadList> {
    out := derived
    st.match ({
        .Let(l) => svars.let_taints(derived, l.value).match ({ true => {
            out = a.dead_cons(l.name, derived)
        } }),
        _       => { },
    })
    out
}
// returns-only statement walker: a `return <escaping>` ANYWHERE (incl. inside statement-position
// match/cond/loop/block arms) is a hazard; trailing arm values in statement position are DISCARDED.
escape_stmts_err = (a: MutPtr<Malloc>, svars: Ptr<DeadList>, derived: Ptr<DeadList>, body: [Stmt]) i32 {
    acc := 0
    d := derived
    body.loop((h, i, st) {
        acc = acc + a.escape_stmt_err(svars, d, st)
        d = a.escape_step(svars, d, st)
    })
    acc
}
escape_stmt_err = (a: MutPtr<Malloc>, svars: Ptr<DeadList>, derived: Ptr<DeadList>, st: Stmt) i32 {
    st.match ({
        .Return(r)   => a.expr_escapes(svars, derived, r).match ({ true => 1, false => 0 }),
        .If(f)       => a.escape_stmts_err(svars, derived, f.then) + a.escape_stmts_err(svars, derived, f.els),
        .While(w)    => a.escape_stmts_err(svars, derived, w.body),
        .ExprStmt(e) => a.escape_expr_stmt_err(svars, derived, e),
        _            => 0,
    })
}
// descend into a statement-position match/cond/loop/block to find escaping `return`s in its arms.
escape_expr_stmt_err = (a: MutPtr<Malloc>, svars: Ptr<DeadList>, derived: Ptr<DeadList>, e: Ptr<Expr>) i32 {
    load(e).match ({
        .Match(m) => a.escape_match_arms_err(svars, derived, m.arms),
        .Cond(d)  => a.escape_expr_stmt_err(svars, derived, d.t) + a.escape_expr_stmt_err(svars, derived, d.e),
        .Block(b) => a.escape_stmts_err(svars, derived, b.stmts),
        .Loop(l)  => a.escape_stmts_err(svars, derived, l.body),
        _         => 0,
    })
}
escape_match_arms_err = (a: MutPtr<Malloc>, svars: Ptr<DeadList>, derived: Ptr<DeadList>, arms: [ArmData]) i32 {
    acc := 0
    arms.loop((h, i, ar) {
        acc = acc + a.escape_arm_stmts_err(svars, derived, ar.body)
    })
    acc
}
escape_arm_stmts_err = (a: MutPtr<Malloc>, svars: Ptr<DeadList>, derived: Ptr<DeadList>, body: Ptr<Expr>) i32 {
    load(body).match ({
        .Block(b) => a.escape_stmts_err(svars, derived, b.stmts),
        _         => 0,
    })
}
// a trailing value-expression that escapes counts once (returns are handled in escape_stmt_err).
escape_trailing_err = (a: MutPtr<Malloc>, svars: Ptr<DeadList>, derived: Ptr<DeadList>, st: Stmt) i32 {
    st.match ({
        .ExprStmt(e) => a.expr_escapes(svars, derived, e).match ({ true => 1, false => 0 }),
        _            => 0,
    })
}
escape_body_err = (a: MutPtr<Malloc>, svars: Ptr<DeadList>, derived: Ptr<DeadList>, body: [Stmt]) i32 {
    acc := 0
    d := derived
    body.loop((h, i, st) {
        acc = acc + a.escape_stmt_err(svars, d, st)
        d = a.escape_step(svars, d, st)
    })
    acc + (body.len == 0).match ({ true => 0, false => a.escape_trailing_err(svars, d, body[body.len - 1]) })
}
escape_check_func = (a: MutPtr<Malloc>, f: Func) i32 {
    svars := a.scope_params(f.params)
    svars.match ({
        .DeadNil     => 0,
        .DeadCons(c) => a.escape_body_err(svars, a.dead_nil(), f.body),
    })
}
check_module_escape* = (a: MutPtr<Malloc>, decls: [Decl]) i32 {
    acc := 0
    decls.loop((h, i, d) {
        acc = acc + d.match ({
            .DFunc(f) => a.escape_check_func(f),
            _         => 0,
        })
    })
    acc
}
// kind/position pass: the source offset of the FIRST escaping return/trailing (0 = none).
// returns-only kind walker (mirrors escape_stmts_err): no trailing-value check.
kv_escape_stmts = (a: MutPtr<Malloc>, svars: Ptr<DeadList>, derived: Ptr<DeadList>, body: [Stmt]) i32 {
    acc := 0
    d := derived
    body.loop((h, i, st) {
        acc = acc.kv_kor(a.kv_escape_stmt(svars, d, st))
        d = a.escape_step(svars, d, st)
    })
    acc
}
kv_escape_stmt = (a: MutPtr<Malloc>, svars: Ptr<DeadList>, derived: Ptr<DeadList>, st: Stmt) i32 {
    st.match ({
        .Return(r)   => a.expr_escapes(svars, derived, r).match ({ true => load(r).expr_pos().pos_or(1), false => 0 }),
        .If(f)       => a.kv_escape_stmts(svars, derived, f.then).kv_kor(a.kv_escape_stmts(svars, derived, f.els)),
        .While(w)    => a.kv_escape_stmts(svars, derived, w.body),
        .ExprStmt(e) => a.kv_escape_expr_stmt(svars, derived, e),
        _            => 0,
    })
}
kv_escape_expr_stmt = (a: MutPtr<Malloc>, svars: Ptr<DeadList>, derived: Ptr<DeadList>, e: Ptr<Expr>) i32 {
    load(e).match ({
        .Match(m) => a.kv_escape_arms(svars, derived, m.arms),
        .Cond(d)  => a.kv_escape_expr_stmt(svars, derived, d.t).kv_kor(a.kv_escape_expr_stmt(svars, derived, d.e)),
        .Block(b) => a.kv_escape_stmts(svars, derived, b.stmts),
        .Loop(l)  => a.kv_escape_stmts(svars, derived, l.body),
        _         => 0,
    })
}
kv_escape_arms = (a: MutPtr<Malloc>, svars: Ptr<DeadList>, derived: Ptr<DeadList>, arms: [ArmData]) i32 {
    acc := 0
    arms.loop((h, i, ar) {
        acc = acc.kv_kor(a.kv_escape_arm(svars, derived, ar.body))
    })
    acc
}
kv_escape_arm = (a: MutPtr<Malloc>, svars: Ptr<DeadList>, derived: Ptr<DeadList>, body: Ptr<Expr>) i32 {
    load(body).match ({
        .Block(b) => a.kv_escape_stmts(svars, derived, b.stmts),
        _         => 0,
    })
}
kv_escape_trailing = (a: MutPtr<Malloc>, svars: Ptr<DeadList>, derived: Ptr<DeadList>, st: Stmt) i32 {
    st.match ({
        .ExprStmt(e) => a.expr_escapes(svars, derived, e).match ({ true => load(e).expr_pos().pos_or(1), false => 0 }),
        _            => 0,
    })
}
kv_escape_body = (a: MutPtr<Malloc>, svars: Ptr<DeadList>, derived: Ptr<DeadList>, body: [Stmt]) i32 {
    acc := 0
    d := derived
    body.loop((h, i, st) {
        acc = acc.kv_kor(a.kv_escape_stmt(svars, d, st))
        d = a.escape_step(svars, d, st)
    })
    acc.kv_kor((body.len == 0).match ({ true => 0, false => a.kv_escape_trailing(svars, d, body[body.len - 1]) }))
}
kv_escape_check_func = (a: MutPtr<Malloc>, f: Func) i32 {
    svars := a.scope_params(f.params)
    svars.match ({
        .DeadNil     => 0,
        .DeadCons(c) => a.kv_escape_body(svars, a.dead_nil(), f.body),
    })
}
check_module_escape_kind* = (a: MutPtr<Malloc>, decls: [Decl]) i32 {
    acc := 0
    decls.loop((h, i, d) {
        acc = acc.kv_kor(d.match ({
            .DFunc(f) => a.kv_escape_check_func(f),
            _         => 0,
        }))
    })
    acc
}
check_module_escape_diagnostic_from_source* = (a: MutPtr<Malloc>, decls: [Decl], src: str) CheckDiagnostic {
    n := a.check_module_escape(decls)
    (n == 0).match ({ true => check_diagnostic_none(), false => {
        pos := a.check_module_escape_kind(decls)
        CheckDiagnostic(
            code: KESCAPE(),
            kind: "scope-escape",
            source_offset: pos,
            span_width: src.diagnostic_span_width(pos),
            count: n.positive_count(),
            message: "value from scope `s` escapes its scope (its arena is freed on scope exit)",
            hint: "do not return a pointer from `s.acquire(...)`; copy the value out, or allocate in an outer scope",
        )
    } })
}
// ── ADDR-OF-LOCAL ESCAPE ──────────────────────────────────────────────────────────────────────────
// Returning `x.addr()` where `x` is a stack local hands the caller a pointer into the dead frame. This
// is a SEPARATE pass from the scope-escape above: it cannot reuse that walker, because a general
// allocator's `a.acquire(n)` returns HEAP that outlives the call (returning it is fine) — only the
// ADDRESS OF A LOCAL dangles. Conservative v1: taints `<local>.addr()` and forwards it through
// `slice(...)`, struct literals, match/cond arms, and block values; flags it in return/trailing
// position. NOT tracked (v1): aliasing through a `let`, heap-store aliasing, inter-procedural escape.
ae_collect_arms = (a: MutPtr<Malloc>, seen: Ptr<DeadList>, arms: [ArmData]) Ptr<DeadList> {
    out := seen
    arms.loop((h, i, ar) {
        out = a.ae_collect_expr(out, ar.body)
    })
    out
}
ae_collect_expr = (a: MutPtr<Malloc>, seen: Ptr<DeadList>, e: Ptr<Expr>) Ptr<DeadList> {
    load(e).match ({
        .Match(m) => a.ae_collect_arms(seen, m.arms),
        .Block(b) => a.ae_collect(seen, b.stmts),
        .Loop(l)  => a.ae_collect(seen, l.body),
        .Cond(d)  => a.ae_collect_expr(a.ae_collect_expr(seen, d.t), d.e),
        _         => seen,
    })
}
ae_collect_stmt = (a: MutPtr<Malloc>, seen: Ptr<DeadList>, st: Stmt) Ptr<DeadList> {
    st.match ({
        .Let(l)      => a.dead_cons(l.name, seen),
        .If(f)       => a.ae_collect(a.ae_collect(seen, f.then), f.els),
        .While(w)    => a.ae_collect(seen, w.body),
        .ExprStmt(e) => a.ae_collect_expr(seen, e),
        _            => seen,
    })
}
ae_collect = (a: MutPtr<Malloc>, seen: Ptr<DeadList>, body: [Stmt]) Ptr<DeadList> {
    out := seen
    body.loop((h, i, st) {
        out = a.ae_collect_stmt(out, st)
    })
    out
}
// `<local>.addr()` — a UFCS `addr` call whose sole arg is a Var that is a collected stack local.
ae_is_addr_local = (locals: Ptr<DeadList>, e: Ptr<Expr>) bool {
    load(e).match ({
        .Call(c) => (eq(c.fn, "addr") && c.args.len == 1).match ({ true => c.args[0].match ({
            .Var(v) => locals.dead_has(v.name),
            _       => false,
        }), false => false }),
        _        => false,
    })
}
// SENDABILITY rule 3: a message may not carry a pointer into the sender's frame. `send(_, msg)` whose
// message escapes a local (`.addr()` of a local, directly or forwarded) → the offset of the call, else 0.
ae_send_pos = (a: MutPtr<Malloc>, locals: Ptr<DeadList>, e: Ptr<Expr>) i32 {
    load(e).match ({
        .Call(c) => (eq(c.fn, "send") && c.args.len >= 2 && a.ae_escapes(locals, c.args[1].addr())).match ({ true => c.pos.pos_or(1), false => 0 }),
        _        => 0,
    })
}
ae_block_val_escapes = (a: MutPtr<Malloc>, locals: Ptr<DeadList>, stmts: [Stmt]) bool {
    (stmts.len == 0).match ({ true => false, false => stmts[stmts.len - 1].match ({
        .ExprStmt(e) => a.ae_escapes(locals, e),
        .Return(r)   => a.ae_escapes(locals, r),
        _            => false,
    }) })
}
ae_inits_escape = (a: MutPtr<Malloc>, locals: Ptr<DeadList>, inits: [FieldInit]) bool {
    f := false
    inits.loop((h, i, fi) {
        f = a.ae_escapes(locals, fi.value).match ({ true => true, false => f })
    })
    f
}
ae_arms_escape = (a: MutPtr<Malloc>, locals: Ptr<DeadList>, arms: [ArmData]) bool {
    f := false
    arms.loop((h, i, ar) {
        f = a.ae_escapes(locals, ar.body).match ({ true => true, false => f })
    })
    f
}
// value position: IS a `<local>.addr()`, or forwards one through slice()/struct/match/cond/block.
ae_escapes = (a: MutPtr<Malloc>, locals: Ptr<DeadList>, e: Ptr<Expr>) bool {
    locals.ae_is_addr_local(e).match ({ true => true, false => load(e).match ({
        .Call(c)       => (eq(c.fn, "slice") && c.args.len > 0).match ({ true => a.ae_escapes(locals, c.args[0].addr()), false => false }),
        .MakeEnum(mk)  => a.ae_escapes(locals, mk.payload),
        .MakeStruct(s) => a.ae_inits_escape(locals, s.inits),
        .Match(m)      => a.ae_arms_escape(locals, m.arms),
        .Cond(d)       => a.ae_escapes(locals, d.t) || a.ae_escapes(locals, d.e),
        .Block(b)      => a.ae_block_val_escapes(locals, b.stmts),
        _              => false,
    }) })
}
// position walk (mirrors kv_escape_*): the source offset of the first escaping return/trailing, 0 = none.
ae_kv_arm = (a: MutPtr<Malloc>, locals: Ptr<DeadList>, body: Ptr<Expr>) i32 {
    load(body).match ({
        .Block(b) => a.ae_kv_stmts(locals, b.stmts),
        _         => 0,
    })
}
ae_kv_arms = (a: MutPtr<Malloc>, locals: Ptr<DeadList>, arms: [ArmData]) i32 {
    acc := 0
    arms.loop((h, i, ar) {
        acc = acc.kv_kor(a.ae_kv_arm(locals, ar.body))
    })
    acc
}
ae_kv_expr_stmt = (a: MutPtr<Malloc>, locals: Ptr<DeadList>, e: Ptr<Expr>) i32 {
    load(e).match ({
        .Match(m) => a.ae_kv_arms(locals, m.arms),
        .Cond(d)  => a.ae_kv_expr_stmt(locals, d.t).kv_kor(a.ae_kv_expr_stmt(locals, d.e)),
        .Block(b) => a.ae_kv_stmts(locals, b.stmts),
        .Loop(l)  => a.ae_kv_stmts(locals, l.body),
        _         => 0,
    })
}
ae_kv_stmt = (a: MutPtr<Malloc>, locals: Ptr<DeadList>, st: Stmt) i32 {
    st.match ({
        .Return(r)   => a.ae_escapes(locals, r).match ({ true => load(r).expr_pos().pos_or(1), false => 0 }),
        .If(f)       => a.ae_kv_stmts(locals, f.then).kv_kor(a.ae_kv_stmts(locals, f.els)),
        .While(w)    => a.ae_kv_stmts(locals, w.body),
        .Let(l)      => a.ae_send_pos(locals, l.value),
        .Assign(x)   => a.ae_send_pos(locals, x.value),
        .ExprStmt(e) => a.ae_kv_expr_stmt(locals, e).kv_kor(a.ae_send_pos(locals, e)),
        _            => 0,
    })
}
ae_kv_stmts = (a: MutPtr<Malloc>, locals: Ptr<DeadList>, body: [Stmt]) i32 {
    acc := 0
    body.loop((h, i, st) {
        acc = acc.kv_kor(a.ae_kv_stmt(locals, st))
    })
    acc
}
ae_kv_body = (a: MutPtr<Malloc>, locals: Ptr<DeadList>, body: [Stmt]) i32 {
    acc := a.ae_kv_stmts(locals, body)
    acc.kv_kor((body.len == 0).match ({ true => 0, false => body[body.len - 1].match ({
        .ExprStmt(e) => a.ae_escapes(locals, e).match ({ true => load(e).expr_pos().pos_or(1), false => 0 }),
        _            => 0,
    }) }))
}
ae_check_func = (a: MutPtr<Malloc>, f: Func) i32 {
    locals := a.ae_collect(a.dead_nil(), f.body)
    a.ae_kv_body(locals, f.body)
}
check_module_addr_escape_kind* = (a: MutPtr<Malloc>, decls: [Decl]) i32 {
    acc := 0
    decls.loop((h, i, d) {
        acc = acc.kv_kor(d.match ({
            .DFunc(f) => a.ae_check_func(f),
            _         => 0,
        }))
    })
    acc
}
check_module_addr_escape* = (a: MutPtr<Malloc>, decls: [Decl]) i32 { (a.check_module_addr_escape_kind(decls) == 0).match ({ true => 0, false => 1 }) }
check_module_addr_escape_diagnostic_from_source* = (a: MutPtr<Malloc>, decls: [Decl], src: str) CheckDiagnostic {
    pos := a.check_module_addr_escape_kind(decls)
    (pos == 0).match ({ true => check_diagnostic_none(), false => CheckDiagnostic(
        code: KESCAPE(),
        kind: "escape",
        source_offset: pos,
        span_width: src.diagnostic_span_width(pos),
        count: 1,
        message: "pointer to a local escapes the function (the local's frame is gone after return)",
        hint: "return the value by copy, or allocate it through an allocator/owner that outlives the call",
    ) })
}
// ── SENDABILITY rule 2: an Rc<T> may not be sent across actors. ───────────────────────────────────
// Rc's refcount is a plain (non-atomic) i64, so sharing one between actors on different threads races.
// Flag `send(handle, msg)` whose message carries an Rc (sent directly, wrapped in an enum, or in a
// struct field). Arc<T> (atomic) and value/Own messages are fine — only Rc is rejected, so ordinary
// message sends keep zero friction.
sd_inits_rc = (env: Env, inits: [FieldInit]) bool {
    f := false
    inits.loop((h, i, fi) {
        f = env.sd_msg_rc(fi.value).match ({ true => true, false => f })
    })
    f
}
sd_msg_rc = (env: Env, e: Ptr<Expr>) bool {
    load(e).match ({
        .Var(v)        => eq(env.infer_expr(e).owner_base(), "Rc"),
        .MakeEnum(mk)  => env.sd_msg_rc(mk.payload),
        .MakeStruct(s) => env.sd_inits_rc(s.inits),
        _              => false,
    })
}
// a `send(_, msg)` whose message carries an Rc → the source offset of the call, else 0. `&&` short-
// circuits, so `c.args[1]` is only touched when the arity check passed.
sd_call_pos = (env: Env, c: CallData) i32 { (eq(c.fn, "send") && c.args.len >= 2 && env.sd_msg_rc(c.args[1].addr())).match ({ true => c.pos.pos_or(1), false => 0 }) }
sd_args = (a: MutPtr<Malloc>, env: Env, args: [Expr]) i32 {
    acc := 0
    args.loop((h, i, ar) {
        acc = acc.kv_kor(a.sd_expr(env, ar.addr()))
    })
    acc
}
sd_arms = (a: MutPtr<Malloc>, env: Env, subjty: Ty, arms: [ArmData]) i32 {
    acc := 0
    arms.loop((h, i, ar) {
        acc = acc.kv_kor(a.sd_expr(a.arm_env(env, subjty, ar), ar.body))
    })
    acc
}
sd_inits = (a: MutPtr<Malloc>, env: Env, inits: [FieldInit]) i32 {
    acc := 0
    inits.loop((h, i, fi) {
        acc = acc.kv_kor(a.sd_expr(env, fi.value))
    })
    acc
}
sd_expr = (a: MutPtr<Malloc>, env: Env, e: Ptr<Expr>) i32 {
    load(e).match ({
        .Call(c)       => env.sd_call_pos(c).kv_kor(a.sd_args(env, c.args)),
        .Bin(b)        => a.sd_expr(env, b.lhs).kv_kor(a.sd_expr(env, b.rhs)),
        .Index(ix)     => a.sd_expr(env, ix.seq).kv_kor(a.sd_expr(env, ix.idx)),
        .Cond(d)       => a.sd_expr(env, d.c).kv_kor(a.sd_expr(env, d.t)).kv_kor(a.sd_expr(env, d.e)),
        .Member(m)     => a.sd_expr(env, m.obj),
        .Arrow(ar)     => a.sd_expr(env, ar.obj),
        .Match(m)      => a.sd_expr(env, m.subj).kv_kor(a.sd_arms(env, env.infer_expr(m.subj), m.arms)),
        .MakeEnum(mk)  => a.sd_expr(env, mk.payload),
        .MakeStruct(s) => a.sd_inits(env, s.inits),
        .SliceLit(sd)  => a.sd_args(env, sd.items),
        .Loop(l)       => a.sd_expr(env, l.seq).kv_kor(a.sd_body(env, l.body)),
        .Block(b)      => a.sd_body(env, b.stmts),
        _              => 0,
    })
}
sd_stmt = (a: MutPtr<Malloc>, env: Env, st: Stmt) i32 {
    st.match ({
        .Let(l)      => a.sd_expr(env, l.value),
        .Assign(x)   => a.sd_expr(env, x.target).kv_kor(a.sd_expr(env, x.value)),
        .Return(r)   => a.sd_expr(env, r),
        .ExprStmt(e) => a.sd_expr(env, e),
        .If(f)       => a.sd_expr(env, f.c).kv_kor(a.sd_body(env, f.then)).kv_kor(a.sd_body(env, f.els)),
        .While(w)    => a.sd_expr(env, w.c).kv_kor(a.sd_body(env, w.body)),
        .IndexSet(x) => a.sd_expr(env, x.seq).kv_kor(a.sd_expr(env, x.idx)).kv_kor(a.sd_expr(env, x.value)),
    })
}
sd_body = (a: MutPtr<Malloc>, env: Env, body: [Stmt]) i32 {
    acc := 0
    e := env
    body.loop((h, i, st) {
        acc = acc.kv_kor(a.sd_stmt(e, st))
        e = a.extend_env(e, st)
    })
    acc
}
sd_check_func = (a: MutPtr<Malloc>, decls: [Decl], idx: DeclIndex, f: Func) i32 {
    env := Env(
        vars: a.params_env(f.params),
        decls: decls,
        didx: idx,
        exp: f.ret,
        a: a,
    )
    a.sd_body(env, f.body)
}
check_module_send_rc_kind* = (a: MutPtr<Malloc>, decls: [Decl]) i32 {
    acc := 0
    idx := a.build_decl_index(decls)
    decls.loop((h, i, d) {
        acc = acc.kv_kor(d.match ({
            .DFunc(f) => a.sd_check_func(decls, idx, f),
            _         => 0,
        }))
    })
    acc
}
check_module_send_rc* = (a: MutPtr<Malloc>, decls: [Decl]) i32 { (a.check_module_send_rc_kind(decls) == 0).match ({ true => 0, false => 1 }) }
check_module_send_rc_diagnostic_from_source* = (a: MutPtr<Malloc>, decls: [Decl], src: str) CheckDiagnostic {
    pos := a.check_module_send_rc_kind(decls)
    (pos == 0).match ({ true => check_diagnostic_none(), false => CheckDiagnostic(
        code: KOWNERSHIP(),
        kind: "sendable",
        source_offset: pos,
        span_width: src.diagnostic_span_width(pos),
        count: 1,
        message: "Rc<T> is not sendable across actors (its refcount is single-threaded)",
        hint: "use Arc<T> for a value shared between actors, or send a value/owned copy",
    ) })
}
