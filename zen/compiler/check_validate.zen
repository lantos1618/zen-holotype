// compiler.check_validate — read the resolved AST and count type errors.
// This pass validates calls, fields, matches, operands, indices, returns, assignment, and traits.
{ Expr, Stmt, Decl, Func, Param, Ty, StructDecl, EnumDecl, Field, ImplData, TraitDefData, ArmData, MatchData, BlockData, LetData, VariantDef, AssignData, IndexSetData, IndexData, CallData, BinData, MakeStructData, FieldInit, FnTData, is_fnt, call, arm, dforeign, impl_cname, tnamed, tptr, tslice, tvoid } = compiler.genc
{ Env, infer_expr, fits, ty_eq, ty_rank, is_f64_ty, enum_name, is_lit_numeric, is_void_ty, the_func, fn_params, params_env, tag_const, extend_env, arm_env, subj_variant_payload, is_bound, var_or_global, no_stmts, resolve_module, dbuf, tnode } = compiler.check
{ Malloc, malloc } = std.alloc
{ byte_at } = std.bytes
{ eq, is_empty } = std.str

// Local fn is known iff the_func finds it by name (sentinel name is "").
is_known_fn = (decls: [Decl], fn: str) bool { eq(decls.the_func(fn).name, fn) }
// Uninferable types are skipped so validation does not false-reject imported/generic residue.
is_uninferable = (t: Ty) bool {
    t.match ({ .Void => true, .Slice(e) => load(e).is_void_ty(), .Ptr(p) => load(p).is_void_ty(), _ => false })
}
// Undeclared Named types are treated as uninferable template residue.
named_declared = (decls: [Decl], n: str) bool {
    found := false
    decls.loop((h, i, d) { found = d.match ({
        .DStruct(sd)   => eq(sd.name, n).match ({ true => true, false => found }),
        .DEnum(ed)     => eq(ed.name, n).match ({ true => true, false => found }),
        .DGenStruct(g) => eq(g.name, n).match ({ true => true, false => found }),
        .DGenEnum(g)   => eq(g.name, n).match ({ true => true, false => found }),
        _              => found
    }) })
    found
}
unknown_ty = (env: Env, t: Ty) bool {
    t.is_uninferable().match ({
        true  => true,
        false => t.match ({ .Named(n) => env.decls.named_declared(n).match ({ true => false, false => true }), _ => false })
    })
}
fit_err = (env: Env, argty: Ty, pty: Ty) i32 {
    // FnT parameters are checked by C for now.
    (env.unknown_ty(argty) || pty.is_fnt()).match ({ true => 0, false => fits(argty, pty).match ({ true => 0, false => 1 }) })
}
// Numeric literals fit numeric slots only when in range.
lit_fits = (e: Ptr<Expr>, t: Ty) bool {
    load(e).match ({
        .Int(n) => t.match ({
            .U8  => (n >= 0) && (n <= 255),
            .I32 => (n >= 0 - 2147483648) && (n <= 2147483647),
            _    => true
        }),
        _ => true
    })
}
arg_err_at = (env: Env, params: [Param], i: i32, ar: Expr) i32 {
    (i < params.len).match ({
        true  => (ar.addr().is_lit_numeric() && params[i].ty.ty_rank() >= 0 && ar.addr().lit_fits(params[i].ty)).match ({
            true  => 0,
            false => env.fit_err(env.infer_expr(ar.addr()), params[i].ty)
        }),
        false => 0
    })
}
arg_type_errs = (env: Env, params: [Param], args: [Expr]) i32 {
    acc := 0
    args.loop((h, i, ar) { acc = acc + env.arg_err_at(params, i, ar) })
    acc
}
names_has = (names: [Param], fn: str) bool {
    found := false
    names.loop((h, i, n) { found = eq(n.name, fn).match ({ true => true, false => found }) })
    found
}
is_imported = (decls: [Decl], fn: str) bool {
    found := false
    decls.loop((h, i, d) { found = d.match ({ .DImport(im) => im.names.names_has(fn).match ({ true => true, false => found }), _ => found }) })
    found
}
// Trait methods can remain unresolved in generic bodies until monomorphization.
is_trait_method = (decls: [Decl], fn: str) bool {
    found := false
    decls.loop((h, i, d) { found = d.match ({
        .DImpl(im) => im.methods.names_has(fn).match ({ true => true, false => found }),
        .DTraitDefault(td) => eq(td.fn.name, fn).match ({ true => true, false => found }),   // a defaulted method an impl may OMIT
        _ => found }) })
    found
}
// genc/runtime intrinsics with no Zen declaration.
is_intrinsic = (fn: str) bool {
    eq(fn, "load").match   ({ true => true, false =>
    eq(fn, "store").match  ({ true => true, false =>
    eq(fn, "addr").match   ({ true => true, false =>
    eq(fn, "offset").match ({ true => true, false =>
    eq(fn, "cstr").match   ({ true => true, false =>
    eq(fn, "slice").match  ({ true => true, false =>
    eq(fn, "malloc").match ({ true => true, false =>
    eq(fn, "sizeof").match ({ true => true, false =>
    eq(fn, "load_i64").match  ({ true => true, false =>
    eq(fn, "store_i64").match ({ true => true, false =>
    eq(fn, "atomic_add_i64").match ({ true => true, false =>
    eq(fn, "null_ptr").match  ({ true => true, false =>
    eq(fn, "__str_eq").match ({ true => true, false =>          // lowered str content equality (resolve_bin)
    eq(fn, "__str_ne").match ({ true => true, false =>
    eq(fn, "to_i32").match ({ true => true, false =>             // explicit narrowing/widening casts (also accept f64 — C truncation)
    eq(fn, "to_i64").match ({ true => true, false =>
    eq(fn, "to_u8").match  ({ true => true, false =>
    eq(fn, "to_f64").match ({ true => true, false => false }) }) }) }) }) }) }) }) }) }) }) }) }) }) }) }) }) })   // explicit int -> f64 cast
}
// Intrinsic arity must be checked before emission.
intrinsic_arity = (fn: str) i32 {
    eq(fn, "__str_eq").match  ({ true => 2, false =>
    eq(fn, "__str_ne").match  ({ true => 2, false =>
    eq(fn, "store").match     ({ true => 2, false =>
    eq(fn, "offset").match    ({ true => 2, false =>
    eq(fn, "slice").match     ({ true => 2, false =>
    eq(fn, "null_ptr").match  ({ true => 0, false =>                 // null_ptr() takes no operands
    eq(fn, "atomic_add_i64").match ({ true => 2, false =>            // atomic_add_i64(p, delta) -> new value
    eq(fn, "store_i64").match ({ true => 2, false => 1 }) }) }) }) }) }) }) })   // load_i64/load/addr/cstr/malloc/sizeof/to_* (incl. to_f64) = 1
}
// Generic UFCS trait calls may need to defer even if a top-level fn has the same name.
is_unresolved_trait_call = (env: Env, c: CallData) bool {
    (c.args.len > 0).match ({
        false => false,
        true  => env.decls.is_trait_method(c.fn).match ({
            false => false,
            true  => eq(env.dispatch_name(c), c.fn).match ({
                false => false,
                true  => env.infer_expr(c.args[0].addr()).enum_name().is_empty().match ({ true => false, false => true })
            })
        })
    })
}
// `@malloc` is not a magic allocator; use an ordinary foreign function or allocator API.
is_forbidden_raw_call = (c: CallData) bool { c.raw && eq(c.fn, "malloc") }

// Calls: local signatures are checked; imported/deferred trait names are accepted; unknowns reject.
check_call = (env: Env, c: CallData) i32 {
    c.is_forbidden_raw_call().match ({
        true => 1,
        false => env.is_unresolved_trait_call(c).match ({
        true  => 0,
        false => env.decls.is_known_fn(c.fn).match ({
            true  => env.call_errs(c),
            false => c.fn.is_intrinsic().match ({
                true  => (c.args.len == c.fn.intrinsic_arity()).match ({ true => 0, false => 1 }),
                false => (env.decls.is_imported(c.fn) || env.decls.is_trait_method(c.fn) || env.var_or_global(c.fn).is_fnt()).match ({ true => 0, false => 1 })
            })
        })
    }) })
}
// Imported generic calls check arity but skip arg-fit against unbound tparams.
is_generic_call = (decls: [Decl], fn: str) bool { decls.the_func(fn).tparams.len > 0 }
call_errs = (env: Env, c: CallData) i32 {
    ps := env.decls.fn_params(c.fn)
    (ps.len == c.args.len).match ({
        false => 1,
        true  => env.decls.is_generic_call(c.fn).match ({ true => 0, false => env.arg_type_errs(ps, c.args) })
    })
}
check_args = (env: Env, args: [Expr]) i32 {
    acc := 0
    args.loop((h, i, ar) { acc = acc + env.check_expr(ar.addr()) })
    acc
}
check_arms = (env: Env, subjty: Ty, arms: [ArmData]) i32 {
    acc := 0
    arms.loop((h, i, ar) { acc = acc + env.a.arm_env(env, subjty, ar).check_expr(ar.body) })
    acc
}
// Early returns inside value-position block arms would be dropped by expression emission.
early_returns = (stmts: [Stmt]) bool {
    found := false
    stmts.loop((h, i, st) { found = (i < stmts.len - 1).match ({
        true  => st.match ({ .Return(r) => true, _ => found }),
        false => found
    }) })
    found
}
expr_drops_return = (e: Ptr<Expr>) i32 {
    load(e).match ({
        .Block(b) => b.stmts.early_returns().match ({ true => 1, false => 0 }),
        _         => 0
    })
}
arm_return_errs = (arms: [ArmData]) i32 {
    acc := 0
    arms.loop((h, i, ar) { acc = acc + ar.body.expr_drops_return() })
    acc
}
check_inits = (env: Env, inits: [FieldInit]) i32 {
    acc := 0
    inits.loop((h, i, fi) { acc = acc + env.check_expr(fi.value) })
    acc
}
// Struct literals check known fields and value fits; imported/generic literals stay lenient.
no_fields = () [Field] { slice(malloc(0), 0) }
is_struct = (decls: [Decl], name: str) bool {
    f := false
    decls.loop((h, i, d) { f = d.match ({ .DStruct(sd) => eq(sd.name, name).match ({ true => true, false => f }), _ => f }) })
    f
}
struct_fields = (decls: [Decl], name: str) [Field] {
    found := no_fields()
    decls.loop((h, i, d) { found = d.match ({ .DStruct(sd) => eq(sd.name, name).match ({ true => sd.fields, false => found }), _ => found }) })
    found
}
has_field = (fields: [Field], fname: str) bool {
    f := false
    fields.loop((h, i, fl) { f = eq(fl.name, fname).match ({ true => true, false => f }) })
    f
}
field_in = (fields: [Field], fname: str) Ty {
    found := tvoid()
    fields.loop((h, i, fl) { found = eq(fl.name, fname).match ({ true => fl.ty, false => found }) })
    found
}
field_fit_err = (env: Env, fields: [Field], fi: FieldInit) i32 {
    fty := fields.field_in(fi.name)
    (fi.value.is_lit_numeric() && fty.ty_rank() >= 0).match ({       // polymorphic literal -> any numeric field
        true  => 0,
        false => env.fit_err(env.infer_expr(fi.value), fty)
    })
}
init_err = (env: Env, fields: [Field], fi: FieldInit) i32 {
    fields.has_field(fi.name).match ({ true => env.field_fit_err(fields, fi), false => 1 })   // unknown field -> 1
}
struct_init_errs = (env: Env, fields: [Field], inits: [FieldInit]) i32 {
    acc := 0
    inits.loop((h, i, fi) { acc = acc + env.init_err(fields, fi) })
    acc
}
makestruct_err = (env: Env, m: MakeStructData) i32 {
    (m.targs.len > 0).match ({
        true  => 0,                                                  // a generic literal -> skip (lenient)
        false => env.decls.is_struct(m.ty).match ({ true => env.struct_init_errs(env.decls.struct_fields(m.ty), m.inits), false => 0 })
    })
}
// Field access checks only known concrete struct receivers.
member_err = (env: Env, obj: Ptr<Expr>, field: str) i32 {
    obj.is_lit_numeric().match ({
        true  => 1,
        false => {
            sname := env.infer_expr(obj).enum_name()
            env.decls.is_struct(sname).match ({
                true  => env.decls.struct_fields(sname).has_field(field).match ({ true => 0, false => 1 }),
                false => 0
            })
        }
    })
}
// Enum matches must be exhaustive and have no duplicate arms.
no_variants = () [VariantDef] { slice(malloc(0), 0) }
enum_variants = (decls: [Decl], ename: str) [VariantDef] {
    found := no_variants()
    decls.loop((h, i, d) { found = d.match ({ .DEnum(ed) => eq(ed.name, ename).match ({ true => ed.variants, false => found }), _ => found }) })
    found
}
has_wildcard = (arms: [ArmData]) bool {
    f := false
    arms.loop((h, i, a) { f = eq(a.variant, "_").match ({ true => true, false => f }) })
    f
}
arm_covers = (arms: [ArmData], vname: str) bool {
    f := false
    arms.loop((h, i, a) { f = eq(a.variant, vname).match ({ true => true, false => f }) })
    f
}
missing_count = (variants: [VariantDef], arms: [ArmData]) i32 {
    n := 0
    variants.loop((h, i, v) { n = arms.arm_covers(v.name).match ({ true => n, false => n + 1 }) })
    n
}
exhaustive_err = (env: Env, m: MatchData) i32 {
    vs := env.decls.enum_variants(m.ename)
    (vs.len == 0).match ({
        true  => 0,
        false => (vs.missing_count(m.arms) > 0).match ({ true => 1, false => 0 })
    })
}
dup_before = (arms: [ArmData], vname: str, upto: i32) bool {
    f := false
    arms.loop((h, i, a) { f = (i < upto).match ({ true => eq(a.variant, vname).match ({ true => true, false => f }), false => f }) })
    f
}
dup_arm_errs = (arms: [ArmData]) i32 {
    n := 0
    arms.loop((h, i, a) { n = n + eq(a.variant, "_").match ({ true => 0, false => arms.dup_before(a.variant, i).match ({ true => 1, false => 0 }) }) })
    n
}
// Reject constructors whose variant is not declared in the linked decl set.
enum_declares = (decls: [Decl], vn: str) bool {
    f := false
    decls.loop((h, i, d) { f = d.match ({
        .DEnum(ed)   => ed.variants.arm_known(vn).match ({ true => true, false => f }),
        .DGenEnum(g) => g.variants.arm_known(vn).match ({ true => true, false => f }),
        _            => f
    }) })
    f
}
mkenum_err = (env: Env, ty: str, variant: str) i32 {
    is_empty(ty).match ({
        true  => env.decls.enum_declares(variant).match ({ true => 0, false => 1 }),
        false => 0
    })
}

// Every non-wildcard arm must name a declared variant.
arm_known = (vs: [VariantDef], vname: str) bool {
    f := false
    vs.loop((h, i, v) { f = eq(v.name, vname).match ({ true => true, false => f }) })
    f
}
unknown_arm_errs = (env: Env, m: MatchData) i32 {
    vs := env.decls.enum_variants(m.ename)
    n  := 0
    (vs.len == 0).match ({
        true  => 0,
        false => {
            m.arms.loop((h, i, a) { n = n + eq(a.variant, "_").match ({ true => 0, false => vs.arm_known(a.variant).match ({ true => 0, false => 1 }) }) })
            n
        },
    })
}
match_err = (env: Env, m: MatchData) i32 {
    base := m.arms.has_wildcard().match ({
        true  => m.arms.dup_arm_errs(),
        false => env.exhaustive_err(m) + m.arms.dup_arm_errs()
    })
    base + env.unknown_arm_errs(m)
}
// Operand checking stays lenient for uninferable operands.
is_arith_op = (op: str) bool {
    b := op.byte_at(0)
    (b == '+') || (b == '-') || (b == '*') || (b == '/') || (b == '%')
}
is_logic_op = (op: str) bool { eq(op, "&&") || eq(op, "||") }
// Strict comparisons require numeric operands; shifts are separate bitwise ops.
is_cmp_op_v = (op: str) bool { eq(op, "<") || eq(op, ">") || eq(op, "<=") || eq(op, ">=") }
is_bitwise_op = (op: str) bool { eq(op, "&") || eq(op, "|") || eq(op, "^") || eq(op, "<<") || eq(op, ">>") }
is_bool_ty = (t: Ty) bool { t.match ({ .Bool => true, _ => false }) }
non_numeric = (env: Env, e: Ptr<Expr>) bool {
    t := env.infer_expr(e)
    env.unknown_ty(t).match ({ true => false, false => (t.ty_rank() >= 0).match ({ true => false, false => true }) })
}
non_bool = (env: Env, e: Ptr<Expr>) bool {
    t := env.infer_expr(e)
    env.unknown_ty(t).match ({ true => false, false => t.is_bool_ty().match ({ true => false, false => true }) })
}
// f64 operators are strict: no implicit int<->float mixing.
is_eq_op_v = (op: str) bool { eq(op, "==") || eq(op, "!=") }
f64_op_ok = (op: str) bool { eq(op, "+") || eq(op, "-") || eq(op, "*") || eq(op, "/") || op.is_cmp_op_v() }
f64_side_ok = (env: Env, t: Ty) bool { t.is_f64_ty() || env.unknown_ty(t) }
f64_operand_err = (env: Env, op: str, lt: Ty, rt: Ty) i32 {
    (env.f64_side_ok(lt) && env.f64_side_ok(rt) && op.f64_op_ok()).match ({ true => 0, false => 1 })
}
// Any f64 side routes to the f64 surface; otherwise use integer numeric rules.
num_operand_err = (env: Env, b: BinData) i32 {
    lt := env.infer_expr(b.lhs)
    rt := env.infer_expr(b.rhs)
    (lt.is_f64_ty() || rt.is_f64_ty()).match ({
        true  => env.f64_operand_err(b.op, lt, rt),
        false => (env.non_numeric(b.lhs) || env.non_numeric(b.rhs)).match ({ true => 1, false => 0 })
    })
}
// Equality allows any pair except known f64/non-f64 mixes.
eq_mix_err = (env: Env, b: BinData) i32 {
    lt := env.infer_expr(b.lhs)
    rt := env.infer_expr(b.rhs)
    (lt.is_f64_ty() || rt.is_f64_ty()).match ({
        true  => (env.f64_side_ok(lt) && env.f64_side_ok(rt)).match ({ true => 0, false => 1 }),
        false => 0
    })
}
operand_err = (env: Env, b: BinData) i32 {
    b.op.is_logic_op().match ({
        true  => (env.non_bool(b.lhs) || env.non_bool(b.rhs)).match ({ true => 1, false => 0 }),
        false => (b.op.is_arith_op() || b.op.is_bitwise_op() || b.op.is_cmp_op_v()).match ({
            true  => env.num_operand_err(b),
            false => b.op.is_eq_op_v().match ({ true => env.eq_mix_err(b), false => 0 })
        })
    })
}
// Indexing needs a slice and numeric index; uninferable types skip.
is_slice_ty = (t: Ty) bool { t.match ({ .Slice(e) => true, _ => false }) }
non_slice = (env: Env, e: Ptr<Expr>) bool {
    t := env.infer_expr(e)
    env.unknown_ty(t).match ({ true => false, false => t.is_slice_ty().match ({ true => false, false => true }) })
}
index_err = (env: Env, ix: IndexData) i32 {
    (env.non_slice(ix.seq) || env.non_numeric(ix.idx)).match ({ true => 1, false => 0 })
}
// Value-position blocks recurse into statement expressions; full env-threading stays in check_body.
check_block_stmt = (env: Env, st: Stmt) i32 {
    st.match ({
        .Let(l)      => env.check_expr(l.value),
        .Assign(x)   => env.check_expr(x.target) + env.check_expr(x.value),
        .Return(r)   => env.check_expr(r),
        .ExprStmt(e) => env.check_expr(e),
        .If(f)       => env.check_expr(f.c),
        .While(w)    => env.check_expr(w.c),
        .IndexSet(x) => env.check_expr(x.seq) + env.check_expr(x.idx) + env.check_expr(x.value)
    })
}
check_block = (env: Env, stmts: [Stmt]) i32 {
    acc := 0
    e   := env
    stmts.loop((h, i, st) { acc = acc + e.check_block_stmt(st)  e = e.a.extend_env(e, st) })
    acc
}
// Bare identifiers in value position must resolve to a local/global/function/import/trait/intrinsic.
var_err = (env: Env, name: str) i32 {
    (eq(name, "true") || eq(name, "false")
        || env.is_bound(name) || env.decls.is_known_fn(name) || env.decls.is_imported(name)
        || env.decls.is_trait_method(name) || name.is_intrinsic()
        || env.decls.is_tag_const(name)).match ({ true => 0, false => 1 })
}
// Lowered statement-match tag constants count as generated names.
variant_tags_has = (vs: [VariantDef], ename: str, name: str) bool {
    found := false
    vs.loop((h, i, v) { found = eq(name, tag_const(ename, v.name)).match ({ true => true, false => found }) })
    found
}
is_tag_const = (decls: [Decl], name: str) bool {
    found := false
    decls.loop((h, i, d) { found = d.match ({ .DEnum(ed) => ed.variants.variant_tags_has(ed.name, name).match ({ true => true, false => found }), _ => found }) })
    found
}
check_expr = (env: Env, e: Ptr<Expr>) i32 {
    load(e).match ({
        .Call(c)        => env.check_call(c) + eq(c.fn, "sizeof").match ({ true => 0, false => env.check_args(c.args) }),
        .Index(ix)      => env.check_expr(ix.seq) + env.check_expr(ix.idx) + env.index_err(ix),
        .Bin(b)         => env.check_expr(b.lhs) + env.check_expr(b.rhs) + env.operand_err(b),
        .Cond(d)        => env.check_expr(d.c) + env.check_expr(d.t) + env.check_expr(d.e) + d.t.expr_drops_return() + d.e.expr_drops_return(),
        .Member(m)      => env.check_expr(m.obj) + env.member_err(m.obj, m.field),
        .Arrow(ar)      => env.check_expr(ar.obj) + env.member_err(ar.obj, ar.field),
        .Match(m)       => env.check_expr(m.subj) + env.check_arms(env.infer_expr(m.subj), m.arms) + env.match_err(m) + arm_return_errs(m.arms),
        .MakeEnum(mk)   => env.check_expr(mk.payload) + env.mkenum_err(mk.ty, mk.variant),
        .Tag(t)         => env.mkenum_err(t.ty, t.variant),
        .MakeStruct(sd) => env.check_inits(sd.inits) + env.makestruct_err(sd),
        .Block(b)       => env.check_block(b.stmts),
        .Var(v)         => env.var_err(v.name),
        _               => 0
    })
}
// Return/assign/index-set checks only reject concrete mismatches.
ret_err = (env: Env, r: Ptr<Expr>) i32 {
    rt := env.infer_expr(r)
    lit_to_num := r.is_lit_numeric() && (env.exp.ty_rank() >= 0) && r.lit_fits(env.exp)
    (env.unknown_ty(rt) || env.unknown_ty(env.exp) || lit_to_num).match ({
        true  => 0,
        false => fits(rt, env.exp).match ({ true => 0, false => 1 })
    })
}
assign_err = (env: Env, x: AssignData) i32 {
    vt := env.infer_expr(x.target)
    rt := env.infer_expr(x.value)
    lit_to_num := x.value.is_lit_numeric() && (vt.ty_rank() >= 0) && x.value.lit_fits(vt)
    (env.unknown_ty(vt) || env.unknown_ty(rt) || lit_to_num).match ({
        true  => 0,
        false => fits(rt, vt).match ({ true => 0, false => 1 })
    })
}
idxset_err = (env: Env, x: IndexSetData) i32 {
    rt := env.infer_expr(x.value)
    lit_to_num := x.value.is_lit_numeric() && (x.elem.ty_rank() >= 0) && x.value.lit_fits(x.elem)
    (env.unknown_ty(rt) || env.unknown_ty(x.elem) || lit_to_num).match ({
        true  => 0,
        false => fits(rt, x.elem).match ({ true => 0, false => 1 })
    })
}
// Annotated lets must fit their declared type; unannotated lets are inferred only.
let_fit_err = (env: Env, l: LetData) i32 {
    l.ty.is_void_ty().match ({
        true  => 0,
        false => {
            vt := env.infer_expr(l.value)
            lit_to_num := l.value.is_lit_numeric() && (l.ty.ty_rank() >= 0) && l.value.lit_fits(l.ty)
            (env.unknown_ty(vt) || env.unknown_ty(l.ty) || lit_to_num).match ({
                true  => 0,
                false => fits(vt, l.ty).match ({ true => 0, false => 1 })
            })
        }
    })
}
check_stmt = (a: Ptr<Malloc>, env: Env, st: Stmt) i32 {
    st.match ({
        .Let(l)    => env.check_expr(l.value) + env.let_fit_err(l),
        .Assign(x) => env.check_expr(x.target) + env.check_expr(x.value) + env.assign_err(x),
        .Return(r) => env.check_expr(r) + env.ret_err(r),
        .ExprStmt(e) => env.check_expr(e),
        .If(f)     => env.check_expr(f.c) + a.check_body(env, f.then) + a.check_body(env, f.els),
        .While(w)  => env.check_expr(w.c) + a.check_body(env, w.body),
        .IndexSet(x) => env.check_expr(x.seq) + env.check_expr(x.idx) + env.check_expr(x.value) + env.idxset_err(x)
    })
}
// Thread lets into the validating environment.
check_body = (a: Ptr<Malloc>, env: Env, body: [Stmt]) i32 {
    acc := 0
    e   := env
    body.loop((h, i, st) {
        acc = acc + a.check_stmt(e, st)
        e   = a.extend_env(e, st)
    })
    acc
}
// a non-void function must YIELD a value: its body's last statement must be a value (a trailing
// expression or an explicit return), and that value must fit the return type. A body that is empty,
// or ends in a let/assign/loop (which yield no value), leaves the return indeterminate — Python
// rejects it ("void ⊀ i32"). Sound: a void return type, or a trailing expr the checker can't infer,
// is skipped (ret_err's own leniency).
trailing_err = (env: Env, body: [Stmt]) i32 {
    env.exp.is_void_ty().match ({
        true  => 0,                                              // a void fn: any body is fine
        false => (body.len == 0).match ({
            true  => 1,                                          // empty body, non-void return -> no value
            false => env.last_stmt_err(body[body.len - 1])
        })
    })
}
last_stmt_err = (env: Env, st: Stmt) i32 {
    st.match ({
        .ExprStmt(e) => env.ret_err(e),                          // a trailing expr must fit the return type
        .Return(r)   => 0,                                       // an explicit return is checked in check_stmt
        _            => 1                                        // let/assign/while/if/index-set yield no value
    })
}
check_func = (a: Ptr<Malloc>, decls: [Decl], f: Func) i32 {
    env := Env( vars: a.params_env(f.params), decls: decls, exp: f.ret, a: a )
    a.check_body(env, f.body) + env.trailing_err(f.body)
}
// trait conformance: a `Type.impl(Trait)` must DEFINE every method the Trait declares, with a
// MATCHING SIGNATURE. The Trait is a struct whose FnT fields are the method signatures (using `Self`
// for the implementing type); im.methods is the names this impl provides, and the impl's actual
// method bodies are top-level DFuncs found by name. So per declared method: missing → 1 error;
// present but signature-mismatched → 1 error; present and matching → 0. The check is tied to THIS
// impl (im.methods), not a global function search, so an unrelated same-named fn never satisfies it.
has_method = (methods: [Param], name: str) bool {
    found := false
    methods.loop((h, i, p) { found = eq(p.name, name).match ({ true => true, false => found }) })
    found
}
// rewrite `Self` to the implementing type throughout a trait method's type (recursing Ptr/Slice).
subst_self = (a: Ptr<Malloc>, t: Ty, tyname: str) Ty {
    t.match ({
        .Named(n)  => eq(n, "Self").match ({ true => tnamed(tyname), false => t }),
        .Ptr(p)    => tptr(a.tnode(a.subst_self(load(p), tyname))),
        .Slice(p)  => tslice(a.tnode(a.subst_self(load(p), tyname))),
        _          => t
    })
}
// each declared param type (Self→tyname) must equal the impl method's, left to right.
params_match = (a: Ptr<Malloc>, tps: [Ty], ips: [Param], tyname: str, i: i32) bool {
    (i == tps.len).match ({
        true  => true,
        false => a.subst_self(tps[i], tyname).ty_eq(ips[i].ty).match ({
            true  => a.params_match(tps, ips, tyname, i + 1),
            false => false
        })
    })
}
// the impl method `f` matches the trait's FnT field `fd` (Self→tyname): same arity, param types, ret.
sig_matches = (a: Ptr<Malloc>, fd: FnTData, f: Func, tyname: str) bool {
    (fd.params.len == f.params.len).match ({
        false => false,
        true  => a.params_match(fd.params, f.params, tyname, 0).match ({
            true  => a.subst_self(load(fd.ret), tyname).ty_eq(f.ret),
            false => false
        })
    })
}
// does the trait `trname` declare a DEFAULT body for method `m`? (then an impl may OMIT it.)
trait_has_default = (decls: [Decl], trname: str, m: str) bool {
    found := false
    decls.loop((h, i, d) { found = d.match ({
        .DTraitDefault(td) => (eq(td.trname, trname) && eq(td.fn.name, m)).match ({ true => true, false => found }),
        _ => found }) })
    found
}
// one declared trait field: 0 if it's not a method, or it's provided with a matching signature, or it
// is OMITTED but the trait supplies a default body; 1 if the method is missing (no default) or differs.
method_err = (a: Ptr<Malloc>, decls: [Decl], im: ImplData, f: Field) i32 {
    f.ty.match ({
        .FnT(fd) => im.methods.has_method(f.name).match ({
            false => decls.trait_has_default(im.trname, f.name).match ({ true => 0, false => 1 }),   // omitted: OK iff defaulted
            true  => a.sig_matches(fd, decls.the_func(impl_cname(im.trname, im.ty, f.name)), im.ty).match ({ true => 0, false => 1 })
        }),
        _ => 0
    })
}
trait_conformance = (a: Ptr<Malloc>, decls: [Decl], im: ImplData, sd: StructDecl) i32 {
    acc := 0
    sd.fields.loop((h, i, f) { acc = acc + a.method_err(decls, im, f) })
    acc
}
impl_errs = (a: Ptr<Malloc>, decls: [Decl], im: ImplData) i32 {
    acc := 0
    decls.loop((h, i, d) { acc = acc + d.match ({ .DStruct(sd) => eq(sd.name, im.trname).match ({ true => a.trait_conformance(decls, im, sd), false => 0 }), _ => 0 }) })
    acc
}
// Two top-level decls with the same FUNCTION name emit colliding C definitions (cc "redefinition" /
// "conflicting types") — the self-hosted backend mangles only generic-type instances, not plain fns,
// so two `f`s (or two trait impls of one method) both emit `… f(…)`. Reject the second. Zen has no
// overloading.
fn_name_of = (d: Decl) str { d.match ({ .DFunc(f) => f.name, _ => "" }) }
fn_dup_before = (decls: [Decl], name: str, upto: i64) bool {
    f := false
    decls.loop((h, i, d) {
        f = (i < upto).match ({
            true  => eq(d.fn_name_of(), name).match ({ true => true, false => f }),
            false => f
        })
    })
    f
}
dup_name_errs = (decls: [Decl]) i32 {
    n := 0
    decls.loop((h, i, d) {
        nm := d.fn_name_of()
        n = is_empty(nm).match ({
            true  => n,
            false => decls.fn_dup_before(nm, i).match ({ true => n + 1, false => n })
        })
    })
    n
}
check_module* = (a: Ptr<Malloc>, decls: [Decl]) i32 {
    acc := decls.dup_name_errs()
    decls.loop((h, i, d) { acc = acc + d.match ({ .DFunc(f) => a.check_func(decls, f), .DImpl(im) => a.impl_errs(decls, im), .DGlobal(g) => eq(g.name, "__syntax_error").match ({ true => 1, false => 0 }), _ => 0 }) })
    acc
}

// ════════════════════════════════════════════════════════════════════════════════════════
// ── DIAGNOSTIC ERROR KINDS (Diagnostics arc) ────────────────────────────────────────────
// check_module returns an error COUNT; a reject pins WHETHER but not WHY. This parallel layer
// re-walks the same resolved AST in the same traversal order and reports the KIND code of the
// FIRST error — so a CHECK-KIND binary (check_module_kind below) can prove a reject is for the
// RIGHT reason. It reuses every predicate from the count layer (same is_*_err logic), only
// swapping each "+ 1" for "this error's kind". Zero new judgments → the count and the kind
// agree exactly (kind != 0 iff count > 0). These are DISTINCT functions (kv_*/…_kind suffix);
// they never touch check_module/check_linked, so the oracle's count exit code is untouched.
//
// Kind codes (small fixed set the task names). KNONE=0 means "no error".
KNONE         = () i32 { 0 }
KARITY        = () i32 { 1 }    // a call's arg COUNT ≠ the declared parameter count
KARGTYPE      = () i32 { 2 }    // an arg's type doesn't fit its parameter
KUNDEFINED    = () i32 { 3 }    // a call to a non-local, non-intrinsic, non-imported, non-trait name
KSTRUCTFIELD  = () i32 { 4 }    // a struct-literal init field / a member access that names no real field
KEXHAUST      = () i32 { 5 }    // a non-wildcard enum match misses a variant
KDUPVARIANT   = () i32 { 6 }    // a match arm repeats a variant
KOPERAND      = () i32 { 7 }    // an arith/logic operator on the wrong operand category
KINDEX        = () i32 { 8 }    // seq[idx] with a non-slice seq or a non-numeric idx
KRETURNFIT    = () i32 { 9 }    // a returned / trailing value doesn't fit the declared return type
KASSIGNFIT    = () i32 { 10 }   // x = v where v doesn't fit x's let-inferred type (incl. xs[i]=v)
KCONFORMANCE  = () i32 { 11 }   // a Type.impl(Trait) misses a method or its signature differs
KDUPFN        = () i32 { 12 }   // two top-level fns share a name (Zen has no overloading)
KVALPOSRETURN = () i32 { 13 }   // an early (dropped) return in a value-position block arm
KPARSE        = () i32 { 14 }   // unparseable top-level input (the parser's __syntax_error sentinel)

// first-nonzero combinator: the kind of the FIRST error in traversal order.
kv_kor = (a: i32, b: i32) i32 { (a == 0).match ({ true => b, false => a }) }
// a 0/1 count predicate → a kind code: emit `k` iff the predicate found an error.
kv_one = (n: i32, k: i32) i32 { (n == 0).match ({ true => 0, false => k }) }
// pack a SOURCE POSITION into a kind code: kinds are 1..14 (4 bits), so `kind + pos*16` carries the
// error's byte offset alongside it (pos 0 = unknown/synthesized — the bare kind, the old encoding).
// Consumers unpack with `& 15` / `>> 4`. Applied only at leaves that HAVE a pos (Call/Var); an
// already-packed nested result is never re-packed (kv_at is a no-op on 0 and packs raw kinds only,
// so it must wrap a LEAF judgment, not a recursion).
kv_at = (k: i32, p: i32) i32 { (k == 0).match ({ true => 0, false => k + (p * 16) }) }

// ── a CALL: arity vs arg-type vs undefined ── mirrors check_call/call_errs, but distinguishes WHY.
// arg-type position: which arg first fails to fit (so a bad arg reports KARGTYPE not a blanket code).
kv_arg_type_kind = (env: Env, params: [Param], args: [Expr]) i32 {
    acc := 0
    args.loop((h, i, ar) { acc = acc.kv_kor(env.arg_err_at(params, i, ar).kv_one(KARGTYPE())) })
    acc
}
// a known local fn: wrong arity → KARITY; right arity but a mistyped arg → KARGTYPE. An imported
// generic call skips the arg-type kind too, mirroring call_errs (so count and kind stay in agreement).
kv_call_errs_kind = (env: Env, c: CallData) i32 {
    ps := env.decls.fn_params(c.fn)
    (ps.len == c.args.len).match ({
        false => KARITY(),
        true  => env.decls.is_generic_call(c.fn).match ({ true => 0, false => env.kv_arg_type_kind(ps, c.args) })
    })
}
kv_check_call_kind = (env: Env, c: CallData) i32 {
    c.is_forbidden_raw_call().match ({
        true => KUNDEFINED(),
        false => env.is_unresolved_trait_call(c).match ({
        true  => 0,                                       // deferred UFCS trait-method call (see check_call)
        false => env.decls.is_known_fn(c.fn).match ({
            true  => env.kv_call_errs_kind(c),
            false => c.fn.is_intrinsic().match ({
                true  => (c.args.len == c.fn.intrinsic_arity()).match ({ true => 0, false => KARITY() }),
                false => (env.decls.is_imported(c.fn) || env.decls.is_trait_method(c.fn) || env.var_or_global(c.fn).is_fnt()).match ({ true => 0, false => KUNDEFINED() })
            })
        })
    }) })
}
kv_check_args_kind = (env: Env, args: [Expr]) i32 {
    acc := 0
    args.loop((h, i, ar) { acc = acc.kv_kor(env.kv_check_expr_kind(ar.addr())) })
    acc
}
kv_check_arms_kind = (env: Env, subjty: Ty, arms: [ArmData]) i32 {
    acc := 0
    arms.loop((h, i, ar) { acc = acc.kv_kor(env.a.arm_env(env, subjty, ar).kv_check_expr_kind(ar.body)) })
    acc
}
kv_arm_return_kind = (arms: [ArmData]) i32 {
    acc := 0
    arms.loop((h, i, ar) { acc = acc.kv_kor(ar.body.expr_drops_return().kv_one(KVALPOSRETURN())) })
    acc
}
// struct-literal init fields: an unknown field OR a mistyped value is KSTRUCTFIELD.
kv_check_inits_kind = (env: Env, inits: [FieldInit]) i32 {
    acc := 0
    inits.loop((h, i, fi) { acc = acc.kv_kor(env.kv_check_expr_kind(fi.value)) })
    acc
}
kv_makestruct_kind = (env: Env, m: MakeStructData) i32 { env.makestruct_err(m).kv_one(KSTRUCTFIELD()) }
kv_member_kind     = (env: Env, obj: Ptr<Expr>, field: str) i32 { env.member_err(obj, field).kv_one(KSTRUCTFIELD()) }
// a match: exhaustiveness vs duplicate-variant, split out from match_err.
kv_match_kind = (env: Env, m: MatchData) i32 {
    base := m.arms.has_wildcard().match ({
        true  => m.arms.dup_arm_errs().kv_one(KDUPVARIANT()),
        false => env.exhaustive_err(m).kv_one(KEXHAUST()).kv_kor(m.arms.dup_arm_errs().kv_one(KDUPVARIANT()))
    })
    base.kv_kor(env.unknown_arm_errs(m).kv_one(KUNDEFINED()))
}
kv_index_kind   = (env: Env, ix: IndexData) i32 { env.index_err(ix).kv_one(KINDEX()) }
kv_operand_kind = (env: Env, b: BinData) i32 { env.operand_err(b).kv_one(KOPERAND()) }
// the value-position block-arm walker, kind-flavoured (mirrors check_block/check_block_stmt).
kv_check_block_stmt_kind = (env: Env, st: Stmt) i32 {
    st.match ({
        .Let(l)      => env.kv_check_expr_kind(l.value),
        .Assign(x)   => env.kv_check_expr_kind(x.target).kv_kor(env.kv_check_expr_kind(x.value)),
        .Return(r)   => env.kv_check_expr_kind(r),
        .ExprStmt(e) => env.kv_check_expr_kind(e),
        .If(f)       => env.kv_check_expr_kind(f.c),
        .While(w)    => env.kv_check_expr_kind(w.c),
        .IndexSet(x) => env.kv_check_expr_kind(x.seq).kv_kor(env.kv_check_expr_kind(x.idx)).kv_kor(env.kv_check_expr_kind(x.value))
    })
}
kv_check_block_kind = (env: Env, stmts: [Stmt]) i32 {
    acc := 0
    e   := env
    stmts.loop((h, i, st) { acc = acc.kv_kor(e.kv_check_block_stmt_kind(st))  e = e.a.extend_env(e, st) })
    acc
}
// mirrors check_expr exactly: same node order, same sub-error precedence, kind codes instead of counts.
kv_check_expr_kind = (env: Env, e: Ptr<Expr>) i32 {
    load(e).match ({
        .Call(c)        => env.kv_check_call_kind(c).kv_at(c.pos).kv_kor(eq(c.fn, "sizeof").match ({ true => 0, false => env.kv_check_args_kind(c.args) })),
        .Index(ix)      => env.kv_check_expr_kind(ix.seq).kv_kor(env.kv_check_expr_kind(ix.idx)).kv_kor(env.kv_index_kind(ix)),
        .Bin(b)         => env.kv_check_expr_kind(b.lhs).kv_kor(env.kv_check_expr_kind(b.rhs)).kv_kor(env.kv_operand_kind(b)),
        .Cond(d)        => env.kv_check_expr_kind(d.c).kv_kor(env.kv_check_expr_kind(d.t)).kv_kor(env.kv_check_expr_kind(d.e)).kv_kor(d.t.expr_drops_return().kv_one(KVALPOSRETURN())).kv_kor(d.e.expr_drops_return().kv_one(KVALPOSRETURN())),
        .Member(m)      => env.kv_check_expr_kind(m.obj).kv_kor(env.kv_member_kind(m.obj, m.field)),
        .Arrow(ar)      => env.kv_check_expr_kind(ar.obj).kv_kor(env.kv_member_kind(ar.obj, ar.field)),
        .Match(m)       => env.kv_check_expr_kind(m.subj).kv_kor(env.kv_check_arms_kind(env.infer_expr(m.subj), m.arms)).kv_kor(env.kv_match_kind(m)).kv_kor(kv_arm_return_kind(m.arms)),
        .MakeEnum(mk)   => env.kv_check_expr_kind(mk.payload).kv_kor(env.mkenum_err(mk.ty, mk.variant).kv_one(KUNDEFINED())),
        .Tag(t)         => env.mkenum_err(t.ty, t.variant).kv_one(KUNDEFINED()),
        .MakeStruct(sd) => env.kv_check_inits_kind(sd.inits).kv_kor(env.kv_makestruct_kind(sd)),
        .Block(b)       => env.kv_check_block_kind(b.stmts),
        .Var(v)         => env.var_err(v.name).kv_one(KUNDEFINED()).kv_at(v.pos),
        _               => 0
    })
}
kv_ret_kind    = (env: Env, r: Ptr<Expr>) i32 { env.ret_err(r).kv_one(KRETURNFIT()) }
kv_assign_kind = (env: Env, x: AssignData) i32 { env.assign_err(x).kv_one(KASSIGNFIT()) }
kv_idxset_kind = (env: Env, x: IndexSetData) i32 { env.idxset_err(x).kv_one(KASSIGNFIT()) }
// mirrors check_stmt: the statement's sub-expressions, then its own fit check.
kv_check_stmt_kind = (a: Ptr<Malloc>, env: Env, st: Stmt) i32 {
    st.match ({
        .Let(l)    => env.kv_check_expr_kind(l.value).kv_kor(env.let_fit_err(l).kv_one(KASSIGNFIT())),
        .Assign(x) => env.kv_check_expr_kind(x.target).kv_kor(env.kv_check_expr_kind(x.value)).kv_kor(env.kv_assign_kind(x)),
        .Return(r) => env.kv_check_expr_kind(r).kv_kor(env.kv_ret_kind(r)),
        .ExprStmt(e) => env.kv_check_expr_kind(e),
        .If(f)     => env.kv_check_expr_kind(f.c).kv_kor(a.kv_check_body_kind(env, f.then)).kv_kor(a.kv_check_body_kind(env, f.els)),
        .While(w)  => env.kv_check_expr_kind(w.c).kv_kor(a.kv_check_body_kind(env, w.body)),
        .IndexSet(x) => env.kv_check_expr_kind(x.seq).kv_kor(env.kv_check_expr_kind(x.idx)).kv_kor(env.kv_check_expr_kind(x.value)).kv_kor(env.kv_idxset_kind(x))
    })
}
kv_check_body_kind = (a: Ptr<Malloc>, env: Env, body: [Stmt]) i32 {
    acc := 0
    e   := env
    body.loop((h, i, st) {
        acc = acc.kv_kor(a.kv_check_stmt_kind(e, st))
        e   = a.extend_env(e, st)
    })
    acc
}
// the trailing-value check, kind-flavoured: an empty / non-value-ending non-void body, or a trailing
// expr that doesn't fit, is a KRETURNFIT (a missing/mistyped yielded value).
kv_last_stmt_kind = (env: Env, st: Stmt) i32 {
    st.match ({
        .ExprStmt(e) => env.kv_ret_kind(e),
        .Return(r)   => 0,
        _            => KRETURNFIT()
    })
}
kv_trailing_kind = (env: Env, body: [Stmt]) i32 {
    env.exp.is_void_ty().match ({
        true  => 0,
        false => (body.len == 0).match ({
            true  => KRETURNFIT(),
            false => env.kv_last_stmt_kind(body[body.len - 1])
        })
    })
}
kv_check_func_kind = (a: Ptr<Malloc>, decls: [Decl], f: Func) i32 {
    env := Env( vars: a.params_env(f.params), decls: decls, exp: f.ret, a: a )
    a.kv_check_body_kind(env, f.body).kv_kor(env.kv_trailing_kind(f.body))
}
// trait conformance, kind-flavoured (mirrors impl_errs/trait_conformance/method_err).
kv_method_kind = (a: Ptr<Malloc>, decls: [Decl], im: ImplData, f: Field) i32 { a.method_err(decls, im, f).kv_one(KCONFORMANCE()) }
kv_conformance_kind = (a: Ptr<Malloc>, decls: [Decl], im: ImplData, sd: StructDecl) i32 {
    acc := 0
    sd.fields.loop((h, i, f) { acc = acc.kv_kor(a.kv_method_kind(decls, im, f)) })
    acc
}
kv_impl_kind = (a: Ptr<Malloc>, decls: [Decl], im: ImplData) i32 {
    acc := 0
    decls.loop((h, i, d) { acc = acc.kv_kor(d.match ({ .DStruct(sd) => eq(sd.name, im.trname).match ({ true => a.kv_conformance_kind(decls, im, sd), false => 0 }), _ => 0 })) })
    acc
}
// the KIND of the FIRST error check_module would have counted, in the same order: dup-fn names
// first, then each decl's body (DFunc) / impl (DImpl). Returns KNONE (0) for an accepting module.
// A CHECK-KIND binary reads this; check_module's COUNT is untouched, so the oracle's verdict path
// (which exits with the count) keeps working unchanged.
check_module_kind* = (a: Ptr<Malloc>, decls: [Decl]) i32 {
    acc := decls.dup_name_errs().kv_one(KDUPFN())
    decls.loop((h, i, d) { acc = acc.kv_kor(d.match ({ .DFunc(f) => a.kv_check_func_kind(decls, f), .DImpl(im) => a.kv_impl_kind(decls, im), .DGlobal(g) => eq(g.name, "__syntax_error").match ({ true => KPARSE(), false => 0 }), _ => 0 })) })
    acc
}
// the kind layer over a CROSS-MODULE link (mirrors check_linked): same layered header, then
// check_module_kind instead of check_module. Lets a cross-module reject also be pinned by KIND.
check_linked_kind* = (a: Ptr<Malloc>, decls: [Decl], lib: [Decl]) i32 {
    hdr   := a.module_header(lib)
    rfile := a.resolve_module(decls)
    world := a.dbuf(hdr.len + rfile.len)
    hdr.loop((h, i, d) { world[i] = d })
    rfile.loop((h, i, d) { world[hdr.len + i] = d })
    a.check_module_kind(world)
}

// ── cross-module linking (Goal Arc 1) ───────────────────────────────────────────────
// The self-hosted "module loader". A module's HEADER is its public surface reduced to signatures:
// every function becomes a bodyless DForeign (structs/enums pass through). Checking a file against
// another module's header puts the imported names in `the_func`'s reach, so a cross-module call is
// arity/arg-type-checked exactly like a local one — while the header's bodyless sigs are never
// re-checked (check_module only descends DFunc bodies). A name imported but absent from the header
// stays known-but-unchecked (the #204 DImport path), so partial headers never false-reject.
as_sig = (a: Ptr<Malloc>, d: Decl) Decl {
    d.match ({ .DFunc(f) => dforeign(Func( name: f.name, params: f.params, ret: f.ret, tparams: f.tparams, body: no_stmts() )), _ => d })
}
module_header* = (a: Ptr<Malloc>, decls: [Decl]) [Decl] {
    buf := a.dbuf(decls.len)
    decls.loop((h, i, d) { buf[i] = a.as_sig(d) })
    buf
}
// check `decls` (one file) against an imported module's `lib` decls: the file is resolved as usual,
// then checked in a WORLD that prepends lib's header, so its imported calls resolve to real sigs.
check_linked* = (a: Ptr<Malloc>, decls: [Decl], lib: [Decl]) i32 {
    hdr   := a.module_header(lib)
    rfile := a.resolve_module(decls)
    world := a.dbuf(hdr.len + rfile.len)
    hdr.loop((h, i, d) { world[i] = d })
    rfile.loop((h, i, d) { world[hdr.len + i] = d })
    a.check_module(world)
}
