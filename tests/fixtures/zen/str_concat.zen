// Explicit allocator-threaded string concatenation (std.text.str.cat) — no hidden heap.
// Builds "a"+"b"+"c" by chaining cat, and the "name=" + name + "!" shape via join(parts, "").
halloc = std.mem.heap
{ cat, join } = std.text.str
{ println } = std.text.fmt
main = () i32 {
    a := halloc.gpa()
    ab := a.addr().cat("a", "b")
    println(a.addr().cat(ab, "c"))
    println(a.addr().join(["name=", "Zen", "!"], ""))
    0
}
