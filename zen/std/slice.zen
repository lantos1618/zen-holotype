// Heap-backed slice helpers for values that must outlive stack literals.

{ malloc } = std.alloc

nbuf*<T> = (n: i64, like: [T]) [T] { slice(malloc(n * sizeof(T)), n) }

dupx*<T> = (xs: [T]) [T] {
    buf := nbuf(xs.len, xs)
    xs.loop((h, i, x) { buf[i] = x })
    buf
}

node*<T> = (v: T) Ptr<T> { dupx([v])[0].addr() }

concat*<T> = (xs: [T], ys: [T]) [T] {
    buf := nbuf(xs.len + ys.len, xs)
    xs.loop((h, i, x) { buf[i] = x })
    ys.loop((h, i, y) { buf[xs.len + i] = y })
    buf
}
