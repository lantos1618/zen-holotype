        should_pass: false,
        kind: "arg-type",
    ), VerdictCase(
        src: "Box*: { v: i32 }\nbump* = (b: Ptr<Box>) void { b.v = b.v + 1 }\ntest* = () i32 { 0 }",
        should_pass: false,
