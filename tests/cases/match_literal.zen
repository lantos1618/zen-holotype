// match on i32/bool with literal patterns — this is the language's branching.
// With recursion it makes the language Turing-complete.

classify* = (n: i32) i32 {
    n.match { 0 => 100, 1 => 200, _ => 300 }
}                                                  //~ classify PASS

fact* = (n: i32) i32 {
    n.match { 0 => 1, _ => n * fact(n - 1) }
}                                                  //~ fact PASS  (recursion)

flip* = (b: bool) bool {
    b.match { true => false, false => true }
}                                                  //~ flip PASS  (bool is exhaustive)

// integers can't be enumerated, so a bare set of literals isn't exhaustive
no_default* = (n: i32) i32 {
    n.match { 0 => 1, 1 => 2 }
}                                                  //~ no_default FAIL non-exhaustive

// a variant pattern makes no sense on an i32
wrong_pat* = (n: i32) i32 {
    n.match { .Some => 1, _ => 0 }
}                                                  //~ wrong_pat FAIL non-enum

// a catch-all must be last — anything after it is unreachable
after_wild* = (n: i32) i32 {
    n.match { _ => 0, 5 => 1 }
}                                                  //~ after_wild FAIL unreachable

// the same literal twice is a dead arm
dup_lit* = (n: i32) i32 {
    n.match { 0 => 1, 0 => 2, _ => 3 }
}                                                  //~ dup_lit FAIL duplicate
