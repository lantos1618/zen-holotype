// Return types may be omitted and inferred from the body (local/bidirectional
// inference), including across function calls.
pub Vec: { len: i32, cap: i32 }

pub area = (v: Ptr<Vec>) { v.len * v.cap }       //~ area PASS      (ret inferred i32)
pub use_area = (v: Ptr<Vec>) { area(v) }         //~ use_area PASS  (inferred through area)
pub is_small = (a: i32) { a < 10 }               //~ is_small PASS  (ret inferred bool)

// a declared return type is still checked against the inferred body type
pub mismatch = (v: Ptr<Vec>) MutPtr<Vec> { area(v) }   //~ mismatch FAIL MutPtr<Vec>

// inference can't see through its own recursion — annotate it
pub loops = (n: i32) { loops(n) }                //~ loops FAIL needs a return-type annotation
