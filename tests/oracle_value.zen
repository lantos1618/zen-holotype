        src: "chk = (n: i32) i32 {\n  (n < 0).match ({ true => return 0 - 1 })\n  n\n}\ntest* = () i32 { chk(7) * 10 + (0 - chk(0 - 1)) }",
        want: "71",
    ), VCase(
        src: "test* = () i32 {\n  max := 0\n  nums := [3, 7, 2, 9, 4]\n  nums.loop((h, i, v) { (v > max).match ({ true => { max = v } }) })\n  max\n}",
        want: "9",
    ), VCase(
        src: "counter := 0\ntick = (x: i32) i32 { counter = counter + 1  x }\ntwice<T> = (v: T) T { v + v }\ntest* = () i32 { twice(tick(5))  counter }",
        want: "1",
    ), VCase(
        src: "Node<T>: { val: T, next: i64 }\nbyte_size<T> = (proto: T) i64 { sizeof(T) }\ntest* = () i64 { byte_size(Node<i32>(val:0,next:0)) }",
        want: "16",
    ), VCase(
        src: "strlen = (s: str) i64\ncount_ph = (sv: [u8]) i64 {\n  ph: i64 := 0\n  skip: i64 := 0\n  sv.loop((h, i, b) {\n    (i < skip).match({ true => {}, false => {\n      pair := i + 1 < sv.len\n      isph := b == '{' && pair && sv[i + 1] == '}'\n      esc := pair && (b == '{' && sv[i + 1] == '{' || b == '}' && sv[i + 1] == '}')\n      isph.match({ true => { ph = ph + 100  skip = i + 2 }, false => esc.match({ true => { ph = ph + 1  skip = i + 2 }, false => {} }) })\n    } })\n  })\n  ph\n}\ntest* = () i64 {\n  s := \"a={} b={{}} c={} d=}}\"\n  v: [u8] := slice(s, strlen(s))\n  count_ph(v)\n}",
        want: "203",
    ), VCase(
        src: "test* = () i32 {\n  x := 0\n  x += 5\n  x -= 2\n  x *= 4\n  x /= 3\n  x %= 3\n  x\n}",
        want: "1",
    ), VCase(
        src: "Box*: { n: i32 }\ntest* = () i32 {\n  s := Box(n: 10)\n  s.n += 7\n  a := [1, 2, 3]\n  a[0] += 100\n  s.n + a[0]\n}",
        want: "118",
    ), VCase(
        src: "test* = () i32 {\n  sum := 0\n  i := 0\n  @while (i < 5) {\n    sum += i\n    i += 1\n  }\n  sum\n}",
        want: "10",
    ), VCase(
        src: "g: i32 := 42\ntest* = () i32 { g }",
        want: "42",
    ), VCase(
        src: "g: i64 := 1000\ntest* = () i64 { g + 7 }",
        want: "1007",
    ), VCase(
        // M1 lambda-as-value: a NON-capturing lambda stored in a typed var, then called indirectly.
        src: "test* = () i64 { f: (i64) i64 := (x: i64) i64 { x + 1 }  f(41) }",
        want: "42",
    ), VCase(
        // M1 lambda-as-value: RETURN a non-capturing lambda from a fn, bind it, call it.
        src: "mkinc = () (i64) i64 { (x: i64) i64 { x + 1 } }\ntest* = () i64 { f := mkinc()  f(41) }",
        want: "42",
    ), VCase(
        // M1 lambda-as-value: a fn value stored in a STRUCT FIELD, then called through the field.
        src: "Box2*: { f: (i64) i64 }\ntest* = () i64 { b := Box2(f: (x: i64) i64 { x * 2 })  b.f(21) }",
        want: "42",
    ), VCase(
        // M1 KEYSTONE: an ESCAPING CAPTURING closure. make_adder returns a lambda that captures its
        // parameter `base` by value; it is bound to a local and called later — `make_adder(10)(5)` == 15.
        src: "make_adder = (base: i64) (i64) i64 { (x: i64) i64 { x + base } }\ntest* = () i64 { add := make_adder(10)  add(5) }",
        want: "15",
    ), VCase(
        // M1 closure: MULTIPLE captured params, the closure called twice with different args.
        src: "make_lin = (m: i64, b: i64) (i64) i64 { (x: i64) i64 { m * x + b } }\ntest* = () i64 { f := make_lin(3, 7)  f(5) + f(0) }",
        want: "29",
    ), VCase(
        // M1.1 DIRECT chained call `make_adder(10)(5)`: the callee is a call-result of closure type, so
        // the chained-call suffix binds it to a temp and routes through the closure-local call path. Was
        // a silent miscompile (dropped the capture → 5); must be 15.
        src: "make_adder = (base: i64) (i64) i64 { (x: i64) i64 { x + base } }\ntest* = () i64 { make_adder(10)(5) }",
        want: "15",
    ), VCase(
        // M1.1 chained call in ARGUMENT position `dbl(make_adder(10)(5))`: `f(a)(b)` must parse anywhere
        // an expression is valid, not only at statement position. (10+5)*2 = 30.
        src: "dbl = (n: i64) i64 { n * 2 }\nmake_adder = (base: i64) (i64) i64 { (x: i64) i64 { x + base } }\ntest* = () i64 { dbl(make_adder(10)(5)) }",
        want: "30",
    ), VCase(
        // M1.1 DIRECT chained call over a MULTI-capture closure: make_lin(3, 7)(5) = 3*5 + 7 = 22.
        src: "make_lin = (m: i64, b: i64) (i64) i64 { (x: i64) i64 { m * x + b } }\ntest* = () i64 { make_lin(3, 7)(5) }",
        want: "22",
    ), VCase(
        // M2 HOF — generic `fold` with an INLINE lambda. The accumulator closure is a first-class arg to
        // a generic fn; 1+2+3 = 6. Locks the std.collections.iter.fold shape end to end.
        src: "fold<T> = (xs: [T], init: T, f: (T, T) T) T { acc := init  xs.loop((h, i, x) { acc = f(acc, x) })  acc }\ntest* = () i32 { xs: [i32] := [1, 2, 3]  xs.fold(0, (a, x) { a + x }) }",
        want: "6",
    ), VCase(
        // M2 HOF — same generic `fold` but the reducer is a STORED closure (`g`), not an inline lambda.
        // Both call paths must yield 6: the stored-closure path is the M1 keystone non-inlined repr.
        src: "fold<T> = (xs: [T], init: T, f: (T, T) T) T { acc := init  xs.loop((h, i, x) { acc = f(acc, x) })  acc }\ntest* = () i32 { xs: [i32] := [1, 2, 3]  g := (a: i32, x: i32) i32 { a + x }  xs.fold(0, g) }",
        want: "6",
    ), VCase(
        // M2 HOF — allocating generic `map` (doubling). New slice of f(x); 2+4+6 = 12. The `out: [U] :=`
        // annotation pins the element type off the raw allocator pointer (else a void-element miscompile).
        src: "malloc = (n: i64) RawPtr<u8>\nmap<T, U> = (xs: [T], f: (T) U) [U] { out: [U] := slice(malloc(xs.len * sizeof(U)), xs.len)  xs.loop((h, i, x) { out[i] = f(x) })  out }\ntest* = () i32 { xs: [i32] := [1, 2, 3]  d: [i32] := xs.map((x) { x * 2 })  d[0] + d[1] + d[2] }",
        want: "12",
    ), VCase(
        // M2 HOF — generic `map` with DISTINCT element types T=i32 -> U=i64 (the <T,U> proof). f widens
        // each i32 to i64 and scales past 2^31; d[2] = 3 * 1e9 = 3000000000 (would overflow i32).
        src: "malloc = (n: i64) RawPtr<u8>\nmap<T, U> = (xs: [T], f: (T) U) [U] { out: [U] := slice(malloc(xs.len * sizeof(U)), xs.len)  xs.loop((h, i, x) { out[i] = f(x) })  out }\ntest* = () i64 { xs: [i32] := [1, 2, 3]  d: [i64] := xs.map((x) { to_i64(x) * 1000000000 })  d[2] }",
        want: "3000000000",
    ), VCase(
        // M2 HOF — allocating `filter` (evens of [1,2,3,4] = [2,4]). Packs kept elements; len*10 + sum of
        // the two kept = 2*10 + 2 + 4 = 26. The predicate is a first-class closure arg.
        src: "malloc = (n: i64) RawPtr<u8>\nfilter<T> = (xs: [T], keep: (T) bool) [T] { buf: [T] := slice(malloc(xs.len * sizeof(T)), xs.len)  n := 0  xs.loop((h, i, x) { buf[n] = x  n = n + keep(x).match ({ true => 1, false => 0 }) })  slice(buf[0].addr(), n) }\ntest* = () i32 { xs: [i32] := [1, 2, 3, 4]  ev: [i32] := xs.filter((x) { x % 2 == 0 })  to_i32(ev.len) * 10 + ev[0] + ev[1] }",
        want: "26",
    ), VCase(
        // M2 HOF — `each` with a closure that mutates a CAPTURED accumulator. No allocation; the captured
        // `tot` must see every element: 1+2+3+4 = 10. Exercises capture-by-reference through the loop.
        src: "each<T> = (xs: [T], f: (T) void) void { xs.loop((h, i, x) { f(x) }) }\ntest* = () i32 { xs: [i32] := [1, 2, 3, 4]  tot := 0  xs.each((x) { tot = tot + x })  tot }",
        want: "10",
    ), VCase(
        // M2 HOF — `find` first element > 2, reported as Opt<T>.Some; stops at the hit via h.break. = 3.
        src: "Opt<T>: Some(T) | None\nfind<T> = (xs: [T], pred: (T) bool) Opt<T> { out: Opt<T> := .None  xs.loop((h, i, x) { pred(x).match ({ true => { out = .Some(x)  h.break }, false => { } }) })  out }\ntest* = () i32 { xs: [i32] := [1, 2, 3, 4]  xs.find((x) { x > 2 }).match ({ .Some(v) => v, .None => 99 }) }",
        want: "3",
    ), VCase(
        // M2 HOF — `find` with no match returns Opt<T>.None (sentinel 99). Guards the empty-result arm.
        src: "Opt<T>: Some(T) | None\nfind<T> = (xs: [T], pred: (T) bool) Opt<T> { out: Opt<T> := .None  xs.loop((h, i, x) { pred(x).match ({ true => { out = .Some(x)  h.break }, false => { } }) })  out }\ntest* = () i32 { xs: [i32] := [1, 2, 3]  xs.find((x) { x > 9 }).match ({ .Some(v) => v, .None => 99 }) }",
        want: "99",
    )])
}
// {}-template interpolation core (mirrors std.text.fmt.format's scanner standalone, since
// the value runner links no stdlib): a `{}` placeholder, `{{`/`}}` brace escapes, and the
// skip-the-2nd-byte advance must all be detected. "a={} b={{}} c={} d=}}" has 2 placeholders
// (200) + 3 escapes (3) => 203. A miscompiled brace scan (dropped skip, wrong index) shifts it.
// div/mod guard regression: u64 > INT64_MAX must use UNSIGNED division (not the int64-cast path).
// unsigned/narrow-int LITERAL fit: a u64 literal ABOVE i64 max must check + emit correctly (the
// literal folds to a negative i64 bit pattern, so the range check must be unsigned-aware), and the
// surviving u64 value must use UNSIGNED div/mod/sub. u32 near max + u8 max round out the widths.
// Generic-enum constructor disambiguation: a bare `.Some(x)` under an annotated `Opt2<i32>` must
// resolve to the ANNOTATED enum, not the first in-scope enum sharing the variant name. The bug was
// a generic enum whose variant name COLLIDES with another in-scope enum (here `Opt`/`Plain`) — the
// expected-type-wins path only checked concrete `.DEnum`s, so it fell back to an ambient name scan
// and emitted the wrong C type (a `cc` "invalid initializer"). All four cases mix a collision.
// Inliner tparam-subst keystone (inline_template threads the tparam->arg map through xform_*):
//   - `[M]` element type in an Index reached via a MutPtr<Box<M>> receiver (was `sizeof(void)`),
//   - a `ms: [M] :=` let annotation in an inlined body,
//   - two-param `ok<T,E>` where E is inferred from the RETURN type (must be Result_i32_IoError,
//     not Result_i32_void). These are silent-miscompile guards for that fix.
// expected-type / str≡text mono unification: okv("hi") infers T from the string literal as `text`, but
// both arms must name the SAME monomorphization as fs's declared `R<str,i32>` return (no `R_text_i32`
// diverging from the `R_str_i32` Err arm) so the C conditional type-checks. Regression for m2a.
// Non-tail `return` in an INLINED body (generic / FnT-param). The body is spliced into a GCC
// statement-expression at the call site, so an un-lifted `return` would exit the CALLER (the test
// fn) — a silent miscompile. The early-return lift turns it into `?:`; control stays in the block.
// Nested ARM-TAIL `return` under a NON-tail (statement-position) match. The outer match is followed
// by `return 90`, so it lowers to an `if`; the inner match sits in the outer arm's TAIL and its arm
// `return`s must stay real control flow — they were being flattened to a value `?:` and silently
// dropped (control fell through to `return 90`). Regression for the missed #306 case.
// Same shape but GENERIC → the body is INLINED into the caller; a dropped nested-arm `return` would
// become a real C `return` from the CALLER (or fall through). Must produce the same values inlined.
// BOUNDARY guard: outer match is the function's TAIL value (not stmt position) — must still work.
// BOUNDARY guard: inner match is NOT the arm tail (a statement follows it) — already lowered, must work.
// ONE-ARMED bool match in STATEMENT position: the missing arm defaults to `{}`. only-true arm runs the
// body when the cond holds and is a no-op otherwise; the assignment must take effect.
// only-FALSE arm: body runs when the cond is false, no-op when true.
// GUARD early-return with no trailing `_`: a one-armed bool match whose only arm `return`s.
// one-armed match nested inside a `.loop` body (the running-max idiom).
// Inliner subst_var EVAL-ONCE: a generic param used N=2× must evaluate its arg ONCE — the arg is
// bound to a generated local before splicing. `tick` bumps a global; `twice(tick(5))` must tick once
// (counter==1), not twice. Without the binding the side-effecting call was duplicated (counter==2).
// Inliner subst_var 0-USE instance survival: a generic param used 0× must NOT drop its arg — the
// arg-binding local keeps the `Node<i32>` instance as a real statement so monomorphization still
// emits `struct Node_i32`. Without it the literal vanished → `sizeof(Node_i32)` with no such type
// (cc: undeclared). 4 (i32 val) + 8 (i64 next), padded to 16.
