// R6 regression: very small magnitudes used to print garbage ("1e-300" -> ".0e-301") because the
// significand was scaled by a single 10^(14-e) that overflowed f64 to +inf. The significand is now
// scaled in chunks of exact powers of ten, so true powers of ten renormalize cleanly to "1.0e-NNN"
// (no empty mantissa, no off-by-one exponent) right down to the f64 minimum. Normal values keep
// their full 15 significant digits.
{ println } = std.text.fmt
main = () i32 {
    println(1e-300)
    println(5e-300)
    println(1e-296)
    println(1e-291)
    println(1e-308)
    println(2.2e-308)
    println(1.5e-200)
    0
}
