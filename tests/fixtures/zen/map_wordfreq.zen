halloc = std.mem.heap
maps = std.collections.map
{ println } = std.text.fmt

bump<AllocT> = (alloc: MutPtr<AllocT>, m: maps.Map<i32>, w: str) maps.Map<i32> {
    m.put(alloc, w, m.get(w, 0) + 1)
}

main = () i32 {
    alloc := halloc.gpa()
    a := alloc.addr()

    w := maps.of(a, "the", 1)
    w = a.bump(w, "cat")
    w = a.bump(w, "sat")
    w = a.bump(w, "on")
    w = a.bump(w, "the")
    w = a.bump(w, "mat")
    w = a.bump(w, "the")
    w = a.bump(w, "cat")

    println(w.get("the", 0))
    println(w.get("cat", 0))
    println(w.get("sat", 0))
    println(w.get("dog", -1))
    println(w.has("mat").match ({ true => 1, false => 0 }))
    println(w.has("dog").match ({ true => 1, false => 0 }))
    println(w.len())

    w.free(a)
    0
}
