{ print, println } = std.text.fmt
halloc = std.mem.heap
{ new_in } = std.text.string

main = () i32 {
    println("borrowed")
    println("alias")

    alloc := halloc.gpa()
    a := alloc.addr()
    s := a.new_in().append_in(a, "owned")
    print(s)
    println("!")
    println(s)
    s.free_in(a)

    0
}
