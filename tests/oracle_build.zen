// tests/oracle_build.zen — BUILD category for the Zen-native correctness oracle: the self-hosted
// replacement for tests/test_build.py (the 3728-line pytest that drives `zenc build`/`run`/`check`
// against real fixture programs). NO Python: this file declares fixture cases as Zen data and a
// CUSTOM runner drives the committed `zenc` binary via std.io, asserting exit code and/or stdout.
//
// ── THE CUSTOM RUNNER (why it differs from oracle_lib.run_value) ──────────────────────────────────
// run_value compiles a tiny `test*` snippet through tests/oracle_runner.c and compares a printed int.
// A BUILD fixture is a whole `main = () i32 { … }` program: we `zenc build <path> -o $ZT/zob`, run the
// binary, and assert its EXIT CODE and (optionally) its STDOUT. The exit code is captured by embedding
// `test "$?" -eq <want_exit>` in the shell command — `std.io.file.shell` returns the system(3) wait
// status (exit<<8), not the raw code, so we let the shell do the comparison and check rc==0 instead.
//
// FixtureCase { path, want_exit, want_out, check_out }:
//   path      relative-to-ROOT path of the .zen program (the oracle runs from the repo root).
//   want_exit decimal STRING of the expected process exit code (string so it interpolates into the
//             shell `test` command without an int→str conversion).
//   want_out  exact expected stdout bytes (with embedded "\n"); only asserted when check_out is true.
//   check_out true => also assert stdout equals want_out; false => assert exit code only.
//
// For `zenc check` accept/reject fixtures we reuse oracle_lib.run_verdict on the fixture SOURCE.
{ Malloc } = std.mem.alloc
{ out, save, contents_in, shell } = std.io.file
{ eq, len, contains, is_empty } = std.text.str
{ new_in, append_in, finish_in } = std.text.string
{ VerdictCase, run_verdict, run_verdicts, DiagCase, run_diags, zo_path, zo_cmd } = oracle_lib
// a BUILD fixture: build the program, run it, assert exit code (+ optional stdout).
FixtureCase*: {
    path: str,
    want_exit: str,
    want_out: str,
    check_out: bool,
}
// an EMIT case: `zenc emit <path>` must emit C containing every `present` string and none of `absent`.
EmitCase*: {
    path: str,
    present: [str],
    absent: [str],
}
// a DOC case: `zenc doc <target>` must succeed (exit 0), its markdown containing every `present` string
// and none of `absent` (target = a `std.x.y` module name OR a `file.zen` path, both relative to ROOT).
DocCase*: {
    target: str,
    present: [str],
    absent: [str],
}
// a SHELL case: a self-contained `/bin/sh` pipeline that encodes a whole procedural test (project mode,
// fmt idempotency, --help/--version, bad-file, cross-module sibling diagnostics, emit byte-equality). It
// must exit 0 iff the test passes — every assertion is a `&&`-chained command / `test`/`grep -F` check.
ShellCase*: {
    name: str,
    cmd: str,
}
// helper: build the command body  `./zenc build <path> -o $ZT/zob 2>/dev/null` (wrapped by zo_cmd).
build_cmd = (mp: MutPtr<Malloc>, path: str) str {
    s := mp.new_in()
    s = s.append_in(mp, "./zenc build ")
    s = s.append_in(mp, path)
    s = s.append_in(mp, " -o $ZT/zob 2>/dev/null")
    mp.finish_in(s)
}
// helper: build the command body  `$ZT/zob > $ZT/zob_out.txt 2>/dev/null; test "$?" -eq <want_exit>`
// (returns rc 0 iff the program's exit code equals want_exit; stdout is left in $ZT/zob_out.txt).
run_cmd = (mp: MutPtr<Malloc>, want_exit: str) str {
    s := mp.new_in()
    s = s.append_in(mp, "$ZT/zob > $ZT/zob_out.txt 2>/dev/null; test \"$?\" -eq ")
    s = s.append_in(mp, want_exit)
    mp.finish_in(s)
}
// run ONE build fixture: build must succeed, then exit code (+ optional stdout) must match.
run_fixture* = (fc: FixtureCase) bool {
    m := Malloc(_: 0)
    mp := m.addr()
    save(mp.zo_path("zob_out.txt"), "", 0)
    bc := shell(mp.zo_cmd(mp.build_cmd(fc.path)))
    (bc == 0).match ({ true => {
        rc := shell(mp.zo_cmd(mp.run_cmd(fc.want_exit)))    // `zenc build` must succeed
        (rc == 0).match ({ true => fc.check_out.match ({ true => mp.contents_in(mp.zo_path("zob_out.txt")).match ({
            .Ok(got) => eq(got, fc.want_out),    // exit code mismatch => fail
            .Err(e)  => false,
        }), false => true }), false => false })
    }, false => false })
}    // exit-only fixture: matched
// batch BUILD runner + reporter: run every fixture, print '.'/'F', return the failing count.
run_fixtures* = (name: str, cs: [FixtureCase]) i32 {
    out(name)
    out("\n")
    fails := 0
    cs.loop((h, i, c) {
        run_fixture(c).match ({ true => out("."), false => {
            out("F")
            fails = fails + 1
        } })
    })
    out("\n")
    fails
}
// helper: build a one-arg command  `./zenc <verb> <path> <redirect>`
cmd_for = (mp: MutPtr<Malloc>, verb: str, path: str, redirect: str) str {
    s := mp.new_in()
    s = s.append_in(mp, "./zenc ")
    s = s.append_in(mp, verb)
    s = s.append_in(mp, " ")
    s = s.append_in(mp, path)
    s = s.append_in(mp, redirect)
    mp.finish_in(s)
}
// check every `present` substring is in `txt` and every `absent` substring is NOT — return the AND.
all_present_absent = (txt: str, present: [str], absent: [str]) bool {
    ok := true
    present.loop((h, i, s) {
        txt.contains(s).match ({ false => {
            ok = false
        } })
    })
    absent.loop((h, i, s) {
        txt.contains(s).match ({ true => {
            ok = false
        } })
    })
    ok
}
// run ONE emit case: `zenc emit` must succeed and the C must satisfy present/absent.
run_emit* = (ec: EmitCase) bool {
    m := Malloc(_: 0)
    mp := m.addr()
    rc := shell(mp.zo_cmd(mp.cmd_for("emit", ec.path, " > $ZT/zoe_emit.c 2>/dev/null")))
    (rc == 0).match ({ true => mp.contents_in(mp.zo_path("zoe_emit.c")).match ({
        .Ok(txt) => all_present_absent(txt, ec.present, ec.absent),
        .Err(e)  => false,
    }), false => false })
}
run_emits* = (name: str, cs: [EmitCase]) i32 {
    out(name)
    out("\n")
    fails := 0
    cs.loop((h, i, c) {
        run_emit(c).match ({ true => out("."), false => {
            out("F")
            fails = fails + 1
        } })
    })
    out("\n")
    fails
}
// run ONE doc case: `zenc doc <target>` must exit 0 and the markdown must satisfy present/absent.
run_doc* = (dc: DocCase) bool {
    m := Malloc(_: 0)
    mp := m.addr()
    rc := shell(mp.zo_cmd(mp.cmd_for("doc", dc.target, " > $ZT/zoe_doc.txt 2>&1")))
    (rc == 0).match ({ true => mp.contents_in(mp.zo_path("zoe_doc.txt")).match ({
        .Ok(txt) => all_present_absent(txt, dc.present, dc.absent),
        .Err(e)  => false,
    }), false => false })
}
run_docs* = (name: str, cs: [DocCase]) i32 {
    out(name)
    out("\n")
    fails := 0
    cs.loop((h, i, c) {
        run_doc(c).match ({ true => out("."), false => {
            out("F")
            fails = fails + 1
        } })
    })
    out("\n")
    fails
}
// run ONE shell case: the pipeline must exit 0. Each `cmd` body uses `$ZT` for its scratch paths;
// zo_cmd binds `$ZT` to this run's private dir so concurrent oracle runs never share scratch files.
run_shells* = (name: str, cs: [ShellCase]) i32 {
    m := Malloc(_: 0)
    mp := m.addr()
    out(name)
    out("\n")
    fails := 0
    cs.loop((h, i, c) {
        (shell(mp.zo_cmd(c.cmd)) == 0).match ({ true => out("."), false => {
            out("F")
            fails = fails + 1
        } })
    })
    out("\n")
    fails
}
oracle_build_run* = () i32 {
    fp := "tests/fixtures/zen/"
    // ── (a) build+run+exit-only fixtures (concurrency / scope / runtime acceptance programs) ──────
    ex := run_fixtures("build exit", [FixtureCase(
        path: "tests/fixtures/zen/or_return.zen",
        want_exit: "61",
        want_out: "",
        check_out: false,
    ), FixtureCase(
        path: "tests/fixtures/zen/scope_cancellation.zen",
        want_exit: "3",
        want_out: "",
        check_out: false,
    ), FixtureCase(
        path: "tests/fixtures/zen/scope_colorless_sync_async.zen",
        want_exit: "3",
        want_out: "",
        check_out: false,
    ), FixtureCase(
        path: "tests/fixtures/zen/thread_atomic_counter.zen",
        want_exit: "42",
        want_out: "",
        check_out: false,
    ), FixtureCase(
        path: "tests/fixtures/zen/thread_coro_tls.zen",
        want_exit: "3",
        want_out: "",
        check_out: false,
    ), FixtureCase(
        path: "tests/fixtures/zen/sync_mutex_counter.zen",
        want_exit: "42",
        want_out: "",
        check_out: false,
    ), FixtureCase(
        path: "tests/fixtures/zen/pool_parallel_actors.zen",
        want_exit: "7",
        want_out: "",
        check_out: false,
    ), FixtureCase(
        path: "tests/fixtures/zen/pool_stress_exactly_once.zen",
        want_exit: "42",
        want_out: "",
        check_out: false,
    ), FixtureCase(
        path: "tests/fixtures/zen/pool_colorless_driver.zen",
        want_exit: "7",
        want_out: "",
        check_out: false,
    ), FixtureCase(
        path: "tests/fixtures/zen/pool_with_pool_combinator.zen",
        want_exit: "9",
        want_out: "",
        check_out: false,
    ), FixtureCase(
        path: "tests/fixtures/zen/pool_arc_contention.zen",
        want_exit: "42",
        want_out: "",
        check_out: false,
    ), FixtureCase(
        path: "tests/fixtures/zen/scope_generic_field_dispatch.zen",
        want_exit: "105",
        want_out: "",
        check_out: false,
    ), FixtureCase(
        path: "tests/fixtures/zen/core_slice_explicit_allocator.zen",
        want_exit: "14",
        want_out: "",
        check_out: false,
    ), FixtureCase(
        path: "tests/fixtures/zen/string_explicit_allocator_result.zen",
        want_exit: "8",
        want_out: "",
        check_out: false,
    ), FixtureCase(
        path: "tests/fixtures/zen/build_struct_program.zen",
        want_exit: "12",
        want_out: "",
        check_out: false,
    ), FixtureCase(
        path: "tests/fixtures/zen/import_eq_true.zen",
        want_exit: "1",
        want_out: "",
        check_out: false,
    ), FixtureCase(
        path: "tests/fixtures/zen/import_eq_false.zen",
        want_exit: "0",
        want_out: "",
        check_out: false,
    ), FixtureCase(
        path: "tests/fixtures/zen/enum_match_widen.zen",
        want_exit: "0",
        want_out: "",
        check_out: false,
    ), FixtureCase(
        path: "tests/fixtures/zen/fmt_numeric_write_explicit_alloc.zen",
        want_exit: "0",
        want_out: "-71.25",
        check_out: true,
    ), FixtureCase(
        path: "tests/fixtures/zen/fmt_numeric_try_write.zen",
        want_exit: "0",
        want_out: "42",
        check_out: true,
    )])
    // build/run a struct program (zenc build emits a runnable binary): p.x*p.y = 12.
    // U1.3 std-import resolution: eq("ab","ab")=true=>1, eq("ab","xy")=false=>0.
    // enum match numeric arms widen the result type (i64) so got==big() holds.
    // fmt numeric write/try-write helpers thread an explicit (counting/limiting) allocator.
    // ── (b) build+run+stdout fixtures (print / text / map acceptance programs) ───────────────────
    so := run_fixtures("build stdout", [FixtureCase(
        path: "tests/fixtures/zen/print_text_and_ints.zen",
        want_exit: "0",
        want_out: "answer:\n42\ntrue\n",
        check_out: true,
    ), FixtureCase(
        path: "tests/fixtures/zen/print_str_and_string.zen",
        want_exit: "0",
        want_out: "borrowed\nalias\nowned!\nowned\n",
        check_out: true,
    ), FixtureCase(
        path: "tests/fixtures/zen/print_formatted_line.zen",
        want_exit: "0",
        want_out: "x=3 y=hello z=3.14\nthe: 5\nok=true\ng=world 5\n",
        check_out: true,
    ), FixtureCase(
        path: "tests/fixtures/zen/print_interpolated.zen",
        want_exit: "0",
        want_out: "name=Zen n=42\ns=hi i=7 f=3.14 b=true\nbraces {} and 9 done\nmissing 1  extra\nowned=world\n",
        check_out: true,
    ), FixtureCase(
        path: "tests/fixtures/zen/str_ops_edges.zen",
        want_exit: "0",
        want_out: "6\n-1\n0\n1\n2\n0\n1\n1\n0\n1\n0\n0\n-7\n12\n0\n123456789012\n",
        check_out: true,
    ), FixtureCase(
        path: "tests/fixtures/zen/str_allocator_result.zen",
        want_exit: "0",
        want_out: "2\n3\n97\nell\nell\n0\n0\nor\nor\n",
        check_out: true,
    ), FixtureCase(
        path: "tests/fixtures/zen/str_try_parse_result.zen",
        want_exit: "0",
        want_out: "",
        check_out: true,
    ), FixtureCase(
        path: "tests/fixtures/zen/map_wordfreq.zen",
        want_exit: "0",
        want_out: "3\n2\n1\n-1\n1\n0\n5\n",
        check_out: true,
    ), FixtureCase(
        path: "tests/fixtures/zen/int_map_roundtrip.zen",
        want_exit: "0",
        want_out: "10\n20\n99\n-1\n11\n1\n0\n0\n5000\n6300\n-1\n65\n",
        check_out: true,
    ), FixtureCase(
        path: "tests/fixtures/zen/print_floats.zen",
        want_exit: "0",
        want_out: "1.5\n0.25\n-3.0\n0.001\n2.0\n2.0\n0.0\n0.3\n1.0e-7\n",
        check_out: true,
    ), FixtureCase(
        path: "tests/fixtures/zen/print_bool_literals.zen",
        want_exit: "0",
        want_out: "true\nfalse\n",
        check_out: true,
    ), FixtureCase(
        path: "tests/fixtures/zen/integer_print_negatives.zen",
        want_exit: "0",
        want_out: "0\n-7\n1000000\n",
        check_out: true,
    )])
    // ── batch 2: smaller self-contained build+run+exit programs (generics, HOFs, operators, casts) ─
    ex2 := run_fixtures("build exit 2", [FixtureCase(
        path: "tests/fixtures/zen/gen_template_local_shadow.zen",
        want_exit: "7",
        want_out: "",
        check_out: false,
    ), FixtureCase(
        path: "tests/fixtures/zen/gen_template_local_no_capture.zen",
        want_exit: "7",
        want_out: "",
        check_out: false,
    ), FixtureCase(
        path: "tests/fixtures/zen/enum_match_block_arm.zen",
        want_exit: "0",
        want_out: "",
        check_out: false,
    ), FixtureCase(
        path: "tests/fixtures/zen/hof_named_fn_and_lambda.zen",
        want_exit: "42",
        want_out: "",
        check_out: false,
    ), FixtureCase(
        path: "tests/fixtures/zen/gen_hof_lambda_captures.zen",
        want_exit: "42",
        want_out: "",
        check_out: false,
    ), FixtureCase(
        path: "tests/fixtures/zen/bitwise_operators.zen",
        want_exit: "246",
        want_out: "",
        check_out: false,
    ), FixtureCase(
        path: "tests/fixtures/zen/bitwise_precedence.zen",
        want_exit: "1",
        want_out: "",
        check_out: false,
    ), FixtureCase(
        path: "tests/fixtures/zen/int_cast_len.zen",
        want_exit: "5",
        want_out: "",
        check_out: false,
    ), FixtureCase(
        path: "tests/fixtures/zen/int_cast_truncate.zen",
        want_exit: "2",
        want_out: "",
        check_out: false,
    ), FixtureCase(
        path: "tests/fixtures/zen/int_literal_fits_i64.zen",
        want_exit: "0",
        want_out: "",
        check_out: false,
    ), FixtureCase(
        path: "tests/fixtures/zen/struct_inherent_methods.zen",
        want_exit: "9",
        want_out: "",
        check_out: false,
    ), FixtureCase(
        path: "tests/fixtures/zen/gen_struct_inherent_methods.zen",
        want_exit: "7",
        want_out: "",
        check_out: false,
    ), FixtureCase(
        path: "tests/fixtures/zen/inherent_methods_overload.zen",
        want_exit: "42",
        want_out: "",
        check_out: false,
    ), FixtureCase(
        path: "tests/fixtures/zen/c_keyword_identifiers.zen",
        want_exit: "42",
        want_out: "",
        check_out: false,
    ), FixtureCase(
        path: "tests/fixtures/zen/vec_explicit_allocator.zen",
        want_exit: "40",
        want_out: "",
        check_out: false,
    ), FixtureCase(
        path: "tests/fixtures/zen/vec_growth_resizes.zen",
        want_exit: "21",
        want_out: "",
        check_out: false,
    ), FixtureCase(
        path: "tests/fixtures/zen/decl_cap_2000.zen",
        want_exit: "99",
        want_out: "",
        check_out: false,
    )])
    // generic inlining respects lexical locals: a template local shadows / does not capture caller.
    // enum match with a block arm that binds a payload + a local.
    // HOFs: calling a fn-typed param with a named fn and a lambda arg (22 + 20 = 42).
    // a lambda into a generic template reads a caller local after inlining (5 + 37 = 42).
    // bitwise operators & | ^ << >> (758 % 256 = 246); precedence: (6 & 3) == 2 => true => 1.
    // explicit int casts: to_i32(len("hello"))=5; to_i32(2^32+2) truncates to 2.
    // an integer literal fits an i64 parameter without an explicit cast.
    // struct-body inherent methods dispatch via UFCS (plain + generic); overload by receiver type.
    // C-keyword identifiers (`double`, field `int`) are mangled, not emitted verbatim.
    // std.collections.vec with an explicit allocator: of + push(grow) + get; 10+30 = 40.
    // repeated push past capacity forces several grows; live elements survive (1+..+6 = 21).
    // census #11: a 2000-decl program is not silently truncated at a 1024-decl cap; f1999 = 99.
    so2 := run_fixtures("build stdout 2", [FixtureCase(
        path: "tests/fixtures/zen/no_leading_paren_glue.zen",
        want_exit: "0",
        want_out: "7\n",
        check_out: true,
    ), FixtureCase(
        path: "tests/fixtures/zen/raw_intrinsics_at.zen",
        want_exit: "0",
        want_out: "42\n",
        check_out: true,
    ), FixtureCase(
        path: "tests/fixtures/zen/vec_and_print.zen",
        want_exit: "0",
        want_out: "10\n30\n",
        check_out: true,
    ), FixtureCase(
        path: "examples/stats.zen",
        want_exit: "0",
        want_out: "sum:\n39\nmax:\n9\nevens:\n3\n",
        check_out: true,
    ), FixtureCase(
        path: "examples/actor_demo.zen",
        want_exit: "0",
        want_out: "",
        check_out: true,
    )])
    // a `(` opening a NEW LINE is its own statement (no glue onto the previous `b := id`).
    // @addr/@load raw-memory intrinsics (the `@` spelling): @load(@addr(41)) + 1 = 42.
    // a single program imports a collection (vec) AND formatted output (fmt) and prints.
    // examples/stats.zen — the Goal-U capstone: vec stats printed via std.text.fmt.
    // examples/actor_demo.zen — actor ergonomics proof: builds, runs, prints nothing.
    // ── examples/*.zen: the quickstart kit — every example must build and run (exit 0) ───────────
    exm := run_fixtures("build examples", [FixtureCase(
        path: "examples/hello.zen",
        want_exit: "0",
        want_out: "",
        check_out: false,
    ), FixtureCase(
        path: "examples/shapes.zen",
        want_exit: "0",
        want_out: "",
        check_out: false,
    ), FixtureCase(
        path: "examples/stats.zen",
        want_exit: "0",
        want_out: "",
        check_out: false,
    ), FixtureCase(
        path: "examples/actor_demo.zen",
        want_exit: "0",
        want_out: "",
        check_out: false,
    ), FixtureCase(
        path: "examples/json_demo.zen",
        want_exit: "0",
        want_out: "",
        check_out: false,
    ), FixtureCase(
        path: "examples/store_demo.zen",
        want_exit: "0",
        want_out: "",
        check_out: false,
    ), FixtureCase(
        path: "examples/str_ops_demo.zen",
        want_exit: "0",
        want_out: "",
        check_out: false,
    ), FixtureCase(
        path: "examples/tour.zen",
        want_exit: "0",
        want_out: "",
        check_out: false,
    )])
    // ── (c) `zenc check` accept/reject fixtures (reuse oracle_lib.run_verdict on inline SOURCE) ───
    vd := run_verdicts("build check", [VerdictCase(
        src: "main = () i32 { 6 * 2 }\n",
        should_pass: true,
        kind: "",
    ), VerdictCase(
        src: "{ eq } = std.text.str\nmain = () i32 { eq(\"ab\", \"ab\").match ({ true => 1, false => 0 }) }\n",
        should_pass: true,
        kind: "",
    ), VerdictCase(
        src: "main = () i32 { if (1 < 2) { return 9 } 7 }\n",
        should_pass: false,
        kind: "undefined-name",
    ), VerdictCase(
        src: "main = () i32 { 1 < 2 }\n",
        should_pass: false,
        kind: "",
    ), VerdictCase(
        src: "Msg*: A | B\nmain = () i32 {\n    msg := Msg.A()\n    msg.match({ .A => 1, .B => \"bad\" })\n}\n",
        should_pass: false,
        kind: "return-fit",
    ), VerdictCase(
        src: "Msg*: A | B\nmain = () i32 {\n    msg := Msg.A()\n    bad := msg.match({ .A => 1, .B => (1 < 2) })\n    0\n}\n",
        should_pass: false,
        kind: "return-fit",
    ), VerdictCase(
        src: "main = () i32 { undefined_fn(1, 2) }\n",
        should_pass: false,
        kind: "undefined-name",
    ), VerdictCase(
        src: "num = std.text.num\nmain = () i32 { s := num.integer(42)  0 }\n",
        should_pass: false,
        kind: "",
    ), VerdictCase(
        src: "num = std.text.num\nmain = () i32 { r := num.try_integer(42)  0 }\n",
        should_pass: false,
        kind: "",
    ), VerdictCase(
        src: "num = std.text.num\nmain = () i32 { s := num.float(1.5)  0 }\n",
        should_pass: false,
        kind: "",
    ), VerdictCase(
        src: "num = std.text.num\nmain = () i32 { r := num.try_float(1.5)  0 }\n",
        should_pass: false,
        kind: "",
    ), VerdictCase(
        src: "text = std.text.str\nmain = () i32 { bs := text.dup_bytes(\"xy\")  0 }\n",
        should_pass: false,
