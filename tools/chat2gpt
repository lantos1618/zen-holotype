#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
usage: tools/chat2gpt [--out PATH] [--stdout] [--no-tests]

Bundles every .zen file in this repo into one Markdown context document.

options:
  --out PATH   Write the bundle to PATH. Defaults to build/zen-context.md.
  --stdout     Print the bundle to stdout instead of writing a file.
  --no-tests   Exclude tests/fixtures and other test .zen files.
  -h, --help   Show this help.
EOF
}

repo_root="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
out="$repo_root/build/zen-context.md"
stdout=0
include_tests=1

while [[ $# -gt 0 ]]; do
  case "$1" in
    --out)
      [[ $# -ge 2 ]] || { echo "missing value for --out" >&2; exit 2; }
      out="$2"
      shift 2
      ;;
    --stdout)
      stdout=1
      shift
      ;;
    --no-tests)
      include_tests=0
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "unknown argument: $1" >&2
      usage >&2
      exit 2
      ;;
  esac
done

collect_files() {
  git -C "$repo_root" ls-files -co --exclude-standard '*.zen' |
    while IFS= read -r rel; do
      [[ -f "$repo_root/$rel" ]] || continue
      [[ "$include_tests" -eq 1 || "$rel" != tests/* ]] || continue
      printf '%s\n' "$rel"
    done |
    LC_ALL=C sort
}

emit_bundle() {
  mapfile -t files < <(collect_files)
  generated="$(date -u '+%Y-%m-%dT%H:%M:%SZ')"

  printf '# Zen Context Bundle\n\n'
  printf 'Generated: `%s`\n\n' "$generated"
  printf 'Root: `%s`\n\n' "$repo_root"
  printf 'Files: `%s`\n\n' "${#files[@]}"
  printf 'This bundle contains the current workspace contents of every included `.zen` file. '
  printf 'Each section starts with the repo-relative path for that file.\n\n'
  printf '## File Index\n\n'

  for rel in "${files[@]}"; do
    bytes="$(wc -c < "$repo_root/$rel" | tr -d ' ')"
    lines="$(wc -l < "$repo_root/$rel" | tr -d ' ')"
    printf -- '- `%s` (%s lines, %s bytes)\n' "$rel" "$lines" "$bytes"
  done

  printf '\n'

  for rel in "${files[@]}"; do
    printf '## `%s`\n\n' "$rel"
    printf '~~~zen\n'
    cat "$repo_root/$rel"
    printf '\n~~~\n\n'
  done
}

if [[ "$stdout" -eq 1 ]]; then
  emit_bundle
else
  mkdir -p "$(dirname "$out")"
  emit_bundle > "$out"
  echo "$out"
fi
