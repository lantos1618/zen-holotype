// std.os — thin, growing wrappers over the raw POSIX bindings in std.c.libc.
//
// For now this is just the environment accessor. `getEnv` forwards straight to
// libc.getenv; proper null/empty handling (returning Result/Option) is a
// follow-up — kept a thin wrapper so it parses and lowers cleanly.

{ getenv } = std.c.libc

getEnv* = (name: str) str { getenv(name) }
