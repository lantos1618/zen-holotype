// compiler.diagnostic — map a check error's FLAT-source byte offset back to the user file's
// line:col. resolve_program strips import lines and rewrites `ns.name` -> `ns__name`, so the
// flat offset is not the user's; we recover the user line by matching the flat line's TEXT
// (exact, then an alias-`__`-removal inverse, then an on-the-fly `__`==`.` comparison).
// Ported out of bootstrap/main.c — the C driver should not carry compiler logic. Allocation-free:
// returns ints, so main.c keeps only the printf + caret rendering and the per-module search loop.

{ at } = std.text.bytes
{ view } = std.text.str
{ Malloc } = std.mem.alloc
{ String } = std.text.string
{ gstr_string, gstr_append, gstr_push, gstr_finish } = compiler.genc

// line:col span in the USER source; line == 0 means "could not locate".
DiagSpan*: { line: i32, col: i32, end_col: i32 }
dspan_none = () DiagSpan { DiagSpan(line: 0, col: 0, end_col: 0) }

// length of the line of `s` that starts at byte `p` (up to '\n' or NUL)
dline_len = (s: str, p: i32, n: i32) i32 {
    b := s.at(p + n)
    ((b == 0) || (b == '\n')).match ({ true => n, false => s.dline_len(p, n + 1) })
}
// start byte of the line containing `off` (scan back past the previous '\n')
dline_start = (s: str, off: i32) i32 {
    (off == 0).match ({
        true  => 0,
        false => (s.at(off - 1) == '\n').match ({ true => off, false => s.dline_start(off - 1) })
    })
}

// user[up..up+ln] == flat[fp..fp+ln] byte-exact
dseg_eq = (user: str, up: i32, flat: str, fp: i32, ln: i32, i: i32) bool {
    (i == ln).match ({
        true  => true,
        false => (user.at(up + i) == flat.at(fp + i)) && user.dseg_eq(up, flat, fp, ln, i + 1)
    })
}
// the 1-based line in `user` whose text exactly equals flat[fp..fp+ln], else 0.
duser_line_at = (user: str, up: i32, flat: str, fp: i32, ln: i32, no: i32) i32 {
    ulen := user.dline_len(up, 0)
    ((ulen == ln) && user.dseg_eq(up, flat, fp, ln, 0)).match ({
        true  => no,
        false => (user.at(up + ulen) == 0).match ({
            true  => 0,
            false => user.duser_line_at(up + ulen + 1, flat, fp, ln, no + 1)
        })
    })
}
duser_line* = (user: str, flat: str, fp: i32, ln: i32) i32 { user.duser_line_at(0, flat, fp, ln, 1) }

// ── alias-rewrite inverse: a flat line `…alias__name…` whose user form removed the inserted span.
//    find the first `__` after leading whitespace; the removed span is [lead, j+2). ──
dlead_ws = (s: str, p: i32, ln: i32, i: i32) i32 {
    (i >= ln).match ({ true => i, false => ((s.at(p + i) == ' ') || (s.at(p + i) == '\t')).match ({ true => s.dlead_ws(p, ln, i + 1), false => i }) })
}
// first index >= lead+1 where flat[fp+j]=='_' && flat[fp+j+1]=='_' (j+1 < ln-1), else -1
dfind_dunder = (flat: str, fp: i32, ln: i32, j: i32) i32 {
    (j + 1 >= ln - 1).match ({
        true  => 0 - 1,
        false => ((flat.at(fp + j) == '_') && (flat.at(fp + j + 1) == '_')).match ({ true => j, false => flat.dfind_dunder(fp, ln, j + 1) })
    })
}
// user[up..up+ulen] == flat[fp..fp+flen] with [start,start+n) removed (lengths must match)
dmatch_removed = (user: str, up: i32, ulen: i32, flat: str, fp: i32, flen: i32, start: i32, n: i32) bool {
    ((start + n > flen) || (ulen != flen - n)).match ({
        true  => false,
        false => user.dseg_eq(up, flat, fp, start, 0) && user.dseg_eq2(up + start, flat, fp + start + n, flen - start - n, 0)
    })
}
// second-half compare with independent offsets
dseg_eq2 = (user: str, up: i32, flat: str, fp: i32, ln: i32, i: i32) bool {
    (i == ln).match ({ true => true, false => (user.at(up + i) == flat.at(fp + i)) && user.dseg_eq2(up, flat, fp, ln, i + 1) })
}
// flat byte offset within a line -> user column after removing [start,start+n)
dremoved_col = (off: i32, start: i32, n: i32) i32 {
    (off < start).match ({
        true  => off + 1,
        false => (off < start + n).match ({ true => start + 1, false => off - n + 1 })
    })
}

// ── ns-normalize inverse: compare treating each `__` in the flat line as a single `.`. ──
// user[up..] equals flat[fp..fp+flen] with every `__` collapsed to one char; returns user line len match.
dseg_eq_ns = (user: str, up: i32, ui: i32, flat: str, fp: i32, fi: i32, flen: i32) bool {
    (fi == flen).match ({
        true  => (user.at(up + ui) == 0) || (user.at(up + ui) == '\n'),
        false => ((fi + 1 < flen) && (flat.at(fp + fi) == '_') && (flat.at(fp + fi + 1) == '_')).match ({
            true  => (user.at(up + ui) == '.') && user.dseg_eq_ns(up, ui + 1, flat, fp, fi + 2, flen),
            false => (user.at(up + ui) == flat.at(fp + fi)) && user.dseg_eq_ns(up, ui + 1, flat, fp, fi + 1, flen)
        })
    })
}
duser_line_ns_at = (user: str, up: i32, flat: str, fp: i32, flen: i32, no: i32) i32 {
    ulen := user.dline_len(up, 0)
    user.dseg_eq_ns(up, 0, flat, fp, 0, flen).match ({
        true  => no,
        false => (user.at(up + ulen) == 0).match ({ true => 0, false => user.duser_line_ns_at(up + ulen + 1, flat, fp, flen, no + 1) })
    })
}
// flat offset -> column counting each `__` as one char
dnorm_col = (flat: str, fp: i32, flen: i32, off: i32, i: i32, col: i32) i32 {
    (i >= off).match ({
        true  => col,
        false => ((i + 1 < flen) && (flat.at(fp + i) == '_') && (flat.at(fp + i + 1) == '_')).match ({
            true  => flat.dnorm_col(fp, flen, off, i + 2, col + 1),
            false => flat.dnorm_col(fp, flen, off, i + 1, col + 1)
        })
    })
}

// the entry point main.c calls per candidate source: flat = import-flattened source the checker saw,
// user = one real source file, offset = the error's flat byte offset, span_width = its width.
diag_user_span* = (flat: str, user: str, offset: i32, span_width: i32) DiagSpan {
    (offset <= 0).match ({ true => { return dspan_none() }, false => {} })
    ls    := flat.dline_start(offset)
    llen  := flat.dline_len(ls, 0)
    rel   := offset - ls
    erel0 := rel + span_width - 1
    erel  := ((erel0 >= llen) && (llen > 0)).match ({ true => llen - 1, false => erel0 })

    // 1) exact line-text match
    exact := user.duser_line(flat, ls, llen)
    (exact > 0).match ({ true => { return DiagSpan(line: exact, col: rel + 1, end_col: rel + span_width) }, false => {} })

    // 2) alias `__`-removal inverse
    lead := flat.dlead_ws(ls, llen, 0)
    j    := flat.dfind_dunder(ls, llen, lead + 1)
    (j >= 0).match ({
        true  => {
            rn   := j + 2 - lead
            al   := user.duser_line_alias(flat, ls, llen, lead, rn)
            (al > 0).match ({ true => { return DiagSpan(line: al, col: rel.dremoved_col(lead, rn), end_col: erel.dremoved_col(lead, rn)) }, false => {} })
        },
        false => {}
    })

    // 3) on-the-fly `__`==`.` normalized match
    nsl := user.duser_line_ns_at(0, flat, ls, llen, 1)
    (nsl > 0).match ({ true => { return DiagSpan(line: nsl, col: flat.dnorm_col(ls, llen, rel, 0, 1), end_col: flat.dnorm_col(ls, llen, erel, 0, 1)) }, false => {} })

    dspan_none()
}
// alias variant of duser_line: match each user line against flat[ls..ls+llen] with [lead,lead+rn) removed
duser_line_alias_at = (user: str, up: i32, flat: str, ls: i32, llen: i32, lead: i32, rn: i32, no: i32) i32 {
    ulen := user.dline_len(up, 0)
    user.dmatch_removed(up, ulen, flat, ls, llen, lead, rn).match ({
        true  => no,
        false => (user.at(up + ulen) == 0).match ({ true => 0, false => user.duser_line_alias_at(up + ulen + 1, flat, ls, llen, lead, rn, no + 1) })
    })
}
duser_line_alias = (user: str, flat: str, ls: i32, llen: i32, lead: i32, rn: i32) i32 { user.duser_line_alias_at(0, flat, ls, llen, lead, rn, 1) }

// ── zen.toml manifest value lookup — moved out of the C driver (driver.c) ──────────────────────
// Scan a manifest source for a `key = "value"` line and return the value's span (start<0 = absent);
// the driver dup_range's src[start..start+len] into a NUL-terminated string. Pure char-scan, no alloc.
MfSpan*: { start: i32, len: i32 }
mf_none = () MfSpan { MfSpan(start: 0 - 1, len: 0) }
mf_ws = (b: u8) bool { (b == ' ') || (b == '\t') }
mf_skip_ws = (s: str, p: i32, e: i32) i32 { ((p < e) && s.at(p).mf_ws()).match ({ true => s.mf_skip_ws(p + 1, e), false => p }) }
// match `key` literally at p; return pos just past it, or -1
mf_key_at = (s: str, p: i32, e: i32, key: str, k: i32) i32 {
    (key.at(k) == 0).match ({
        true  => p,
        false => ((p < e) && (s.at(p) == key.at(k))).match ({ true => s.mf_key_at(p + 1, e, key, k + 1), false => 0 - 1 })
    })
}
// the closing-quote position from `i`, or -1
mf_close = (s: str, i: i32, e: i32) i32 {
    (i >= e).match ({ true => 0 - 1, false => (s.at(i) == '"').match ({ true => i, false => s.mf_close(i + 1, e) }) })
}
// parse one line [p,e) for `key = "value"` -> the value span, or mf_none
mf_line = (s: str, p: i32, e: i32, key: str) MfSpan {
    i0 := s.mf_skip_ws(p, e)
    ((i0 >= e) || (s.at(i0) == '#')).match ({ true => { return mf_none() }, false => {} })
    ak := s.mf_key_at(i0, e, key, 0)
    (ak < 0).match ({ true => { return mf_none() }, false => {} })
    i1 := s.mf_skip_ws(ak, e)
    ((i1 >= e) || (s.at(i1) != '=')).match ({ true => { return mf_none() }, false => {} })
    i2 := s.mf_skip_ws(i1 + 1, e)
    ((i2 >= e) || (s.at(i2) != '"')).match ({ true => { return mf_none() }, false => {} })
    start := i2 + 1
    ce := s.mf_close(start, e)
    (ce < 0).match ({ true => mf_none(), false => MfSpan(start: start, len: ce - start) })
}
mf_line_end = (s: str, p: i32, len: i32) i32 {
    ((p < len) && (s.at(p) != '\n') && (s.at(p) != '\r')).match ({ true => s.mf_line_end(p + 1, len), false => p })
}
// scan `src` (length `len`) for `key`'s value, starting at line `p`. The driver calls with p=0.
manifest_value_span* = (src: str, len: i32, key: str, p: i32) MfSpan {
    (p >= len).match ({ true => { return mf_none() }, false => {} })
    e := src.mf_line_end(p, len)
    r := src.mf_line(p, e, key)
    (r.start >= 0).match ({ true => { return r }, false => {} })
    np := ((e < len) && (src.at(e) == '\r') && (e + 1 < len) && (src.at(e + 1) == '\n')).match ({ true => e + 2, false => e + 1 })
    (e >= len).match ({ true => mf_none(), false => src.manifest_value_span(len, key, np) })
}

// ── error rendering (message line + source caret) — moved out of the C driver ──────────────────
// Builds the full "zenc: path:line:col: error[kind]: message" line, the source line + ^~~~ caret,
// and the hint, into one NUL-terminated string the driver writes to stderr. The driver keeps only
// file I/O and the per-module span search.
dsbyte = (v: str, i: i64) u8 { load(offset(v, i)) }
ddigit = (d: i64) u8 { dsbyte("0123456789", d) }
dnum = (s: String, a: MutPtr<Malloc>, n: i64) String {
    (n < 10).match ({ true => s.gstr_push(a, ddigit(n)), false => s.dnum(a, n / 10).gstr_push(a, ddigit(n % 10)) })
}
// byte offset of the start of the `line`-th (1-based) line in `user`
dline_off = (user: str, line: i32, p: i32) i32 {
    (line <= 1).match ({ true => p, false => (user.at(p) == 0).match ({ true => p, false => (user.at(p) == '\n').match ({ true => user.dline_off(line - 1, p + 1), false => user.dline_off(line, p + 1) }) }) })
}
// append the source line at byte `p` (until \n/NUL/CR) to s
dput_line = (s: String, a: MutPtr<Malloc>, user: str, p: i32) String {
    b := user.at(p)
    ((b == 0) || (b == '\n') || (b == '\r')).match ({ true => s, false => s.gstr_push(a, b).dput_line(a, user, p + 1) })
}
// append `col-1` leading-blanks, preserving tabs from the source line at `ls`
dput_blanks = (s: String, a: MutPtr<Malloc>, user: str, ls: i32, col: i32, i: i32) String {
    (i >= col - 1).match ({ true => s, false => {
        c := user.at(ls + i)
        s.gstr_push(a, (c == '\t').match ({ true => '\t', false => ' ' })).dput_blanks(a, user, ls, col, i + 1)
    } })
}
// append `^` then `n-1` `~`
dput_carets = (s: String, a: MutPtr<Malloc>, n: i32, i: i32) String {
    (i >= n).match ({ true => s, false => s.gstr_push(a, (i == 0).match ({ true => '^', false => '~' })).dput_carets(a, n, i + 1) })
}
// render one diagnostic to a NUL-terminated string (line<=0 / col<=0 => no caret)
render_diagnostic* = (a: MutPtr<Malloc>, in_path: str, user: str, line: i32, col: i32, end_col: i32, kind: str, message: str, hint: str, count: i32) str {
    // Pre-size to bound the whole rendered diagnostic (header + message + source line + carets + hint)
    // so the buffer NEVER grows: a gstr_grow/resize mid-render reallocs the buffer and the inlined
    // append chain would then write through the freed pointer (heap-use-after-free). The content is
    // at most a fixed overhead + the str args + a few times the rendered source line (<= user.len).
    cap := 1024 + in_path.view().len + kind.view().len + message.view().len + hint.view().len + user.view().len * 4
    s := a.gstr_string(cap)
    s = s.gstr_append(a, "zenc: ").gstr_append(a, in_path)
    ((line > 0) && (col > 0)).match ({ true => { s = s.gstr_push(a, ':').dnum(a, line).gstr_push(a, ':').dnum(a, col) }, false => {} })
    s = s.gstr_append(a, ": error[").gstr_append(a, kind).gstr_append(a, "]: ").gstr_append(a, message)
    (count > 1).match ({ true => {
        s = s.gstr_append(a, " (+").dnum(a, count - 1).gstr_append(a, " more error")
        // no method chained after a .match (parser limitation): push the closing chars inside the arms
        s = (count - 1 == 1).match ({ true => s.gstr_push(a, ')'), false => s.gstr_push(a, 's').gstr_push(a, ')') })
    }, false => {} })
    s = s.gstr_push(a, '\n')
    ((line > 0) && (col > 0)).match ({ true => {
        ls := user.dline_off(line, 0)
        width := (end_col >= col).match ({ true => end_col - col + 1, false => 1 })
        s = s.gstr_append(a, "  ").dput_line(a, user, ls).gstr_push(a, '\n')
        s = s.gstr_append(a, "  ").dput_blanks(a, user, ls, col, 0).dput_carets(a, width, 0).gstr_push(a, '\n')
    }, false => {} })
    (hint.at(0) == 0).match ({ true => s.gstr_finish(a), false => s.gstr_append(a, "hint: ").gstr_append(a, hint).gstr_push(a, '\n').gstr_finish(a) })
}
