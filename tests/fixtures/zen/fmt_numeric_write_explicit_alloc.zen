{ Allocator, Heap } = std.mem.alloc
halloc = std.mem.heap
{ write_int_in, write_float_in } = std.text.fmt
Counting: { heap: Heap, acquired: i32, released: i32 }
Counting.impl(Allocator, {
    acquire = (a: MutPtr<Counting>, n: i64) RawPtr<u8> {
        a.acquired = a.acquired + 1
        a.heap.addr().acquire(n)
    }
    resize = (a: MutPtr<Counting>, p: RawPtr<u8>, n: i64) RawPtr<u8> {
        a.heap.addr().resize(p, n)
    }
    release = (a: MutPtr<Counting>, p: RawPtr<u8>) void {
        a.released = a.released + 1
        a.heap.addr().release(p)
    }
})
main = () i32 {
    c := Counting(heap: halloc.system(), acquired: 0, released: 0)
    a := c.addr()
    write_int_in(a, -7)
    write_float_in(a, 1.25)
    ((c.acquired == 2) && (c.released == 2)).match({ true => 0, false => 1 })
}
