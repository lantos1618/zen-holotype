// Field access (auto-deref through a pointer) and call arity.
Vec*: { len: i32, cap: i32 }

area* = (v: Ptr<Vec>) i32 { v.len * v.cap }            //~ PASS

no_such_field* = (v: Ptr<Vec>) i32 { v.depth }         //~ FAIL no field 'depth'

one_arg* = (v: Ptr<Vec>) i32 { v.len }
wrong_arity* = (v: Ptr<Vec>) i32 { one_arg(v, v) }     //~ FAIL wants 1
