halloc = std.mem.heap
maps = std.collections.map
{ println } = std.text.fmt
main = () i32 {
    alloc := halloc.system()
    a := alloc.addr()
    e1 := maps.of(a, "x", 2)
    e1 = e1.put(a, "y", 3)
    snap := e1.clone(a)
    e1 = e1.put(a, "x", 99)
    e1 = e1.put(a, "z", 5)
    println(snap.get("x", -1))
    println(snap.get("y", -1))
    println(snap.get("z", -1))
    println(snap.len())
    println(e1.get("x", -1))
    println(e1.get("z", -1))
    snap.free(a)
    e1.free(a)
    0
}
