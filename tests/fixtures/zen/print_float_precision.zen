// Float formatter prints 15 significant digits (trailing zeros trimmed), so a printed f64
// round-trips for values needing <= 15 sig digits — the old fixed 6-decimal path truncated
// 0.123456789 to "0.123457". Round values stay exact (no f64 noise), e-notation preserved.
{ println } = std.text.fmt
main = () i32 {
    println(0.123456789)
    println(2.718281828459)
    println(65536.0)
    println(1234567890.0)
    println(123456.789)
    println(0.0009765625)
    0
}
