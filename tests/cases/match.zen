// Pattern matching consumes the enums that F3 builds: a .Variant(v) arm binds
// the payload (narrowing it inside that arm), and the match must be exhaustive.
pub Status: Idle, Busy(i32)

pub code = (s: Status) i32 {
    match s {
        .Idle => 0,
        .Busy(n) => n,                 // n : i32 — the payload, narrowed here
    }
}                                      //~ code PASS

pub with_wildcard = (s: Status) i32 {
    match s { .Busy(n) => n, _ => 0 }
}                                      //~ with_wildcard PASS

// missing .Busy and no wildcard -> non-exhaustive
pub non_exhaustive = (s: Status) i32 {
    match s { .Idle => 0 }
}                                      //~ non_exhaustive FAIL non-exhaustive

// a variant the enum doesn't have
pub bad_variant = (s: Status) i32 {
    match s { .Idle => 0, .Nope => 1 }
}                                      //~ bad_variant FAIL no variant '.Nope'

// arms must agree on a result type (bool ⊀ i32)
pub arms_differ = (s: Status) i32 {
    match s { .Idle => 0, .Busy(n) => true }
}                                      //~ arms_differ FAIL
