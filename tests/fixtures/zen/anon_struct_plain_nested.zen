{ println } = std.text.fmt
mk = () __anon_q { __anon_q(q: 42) }
nested = () __anon_p_z {
    __anon_p_z(
        p: __anon_x_y(
            x: 1,
            y: 2,
        ),
        z: 3,
    )
}
