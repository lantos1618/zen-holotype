{ system_allocator } = std.mem.alloc
{ dup, dup_in, try_dup_in, substr_in, try_substr_in } = std.text.str
{ println_str, println_int } = std.text.fmt

main = () i32 {
    a := system_allocator()

    plain := dup("xy")
    println_int(plain.len)

    owned := a.addr().dup_in("abc")
    println_int(owned.len)
    println_int(owned[0])
    println_str(a.addr().substr_in("hello", 1, 3))

    a.addr().try_dup_in("").match ({
        .Ok(bytes) => println_int(bytes.len),
        .Err(e) => println_int(99)
    })
    a.addr().try_substr_in("world", 1, 2).match ({
        .Ok(s) => println_str(s),
        .Err(e) => println_str("err")
    })

    0
}
