// assignment (reassign locals, set struct fields) and the loop construct.
pub Vec: { len: i32, cap: i32 }

pub reassign  = () i32 { x := 0  x = 5  x }                 //~ reassign PASS
pub set_field = (v: MutPtr<Vec>) void { v.len = 9 }        //~ set_field PASS
pub loop_sum  = () i32 {
    s := 0
    loop(4, (h, i) { s = s + i })                          // i 0..3 -> 0+1+2+3 = 6
    s
}                                                          //~ loop_sum PASS

// can't write a field through a read-only Ptr
pub readonly = (v: Ptr<Vec>) void { v.len = 9 }            //~ readonly FAIL read-only

// the assigned value must fit the lvalue's type
pub mismatch = () i32 { x := 0  x = true  x }              //~ mismatch FAIL

// an @while condition must be a bool
pub bad_cond = () i32 { @while(5) { }  0 }                 //~ bad_cond FAIL bool
