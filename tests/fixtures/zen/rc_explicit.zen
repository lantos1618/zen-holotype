{ default } = std.mem.alloc
{ new_in } = std.mem.rc
{ to_exit } = std.core.bool
main = () i32 {
    alloc := default()
    r := alloc.addr().new_in(41)
    r2 := r.clone()
    two := r.count() == 2
    r.drop_in(alloc.addr())
    one := r2.count() == 1
    value := r2.get() == 41
    r2.drop_in(alloc.addr())
    (two && one && value).to_exit()
}
