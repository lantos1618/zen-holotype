halloc = std.mem.heap
maps = std.collections.map
{ println } = std.text.fmt
main = () i32 {
    alloc := halloc.gpa()
    a := alloc.addr()
    w := maps.of(a, "k0", 0)
    w = w.put(a, "k1", 10)
    w = w.put(a, "k2", 20)
    w = w.put(a, "k3", 30)
    w = w.put(a, "k4", 40)
    w = w.put(a, "k5", 50)
    w = w.put(a, "k6", 60)
    w = w.put(a, "k7", 70)
    w = w.put(a, "k8", 80)
    println(w.len())
    println(w.get("k0", 0 - 1))
    println(w.get("k8", 0 - 1))
    caps := maps.of(a, "uk", "london")
    caps = caps.put(a, "fr", "paris")
    caps = caps.put(a, "fr", "PARIS")
    println(caps.get("fr", "?"))
    println(caps.get("de", "miss"))
    println(caps.len())
    w.free(a)
    caps.free(a)
    0
}
