// Cancellation is a BEHAVIOR, not just a type: a Scope's checkpoint budget runs out, checkpoint
// CONSTRUCTS .Stop(.Deadline), and the body MATCHES it and bails early. Proves the Signal is
// produced and consumed end to end (answers "M1 added a type, not a behavior").
{ Scope } = std.scope
{ sync, SyncArena } = std.concurrent.runtime
halloc = std.mem.heap
g_ran := 0
// loop on checkpoint: keep working while .Go, stop the instant the scope says .Stop.
// (concrete Scope<SyncArena> — a recursive *generic* fn can't inline, so the loop driver is concrete.)
work = (s: MutPtr<Scope<SyncArena>>) i32 {
    s.checkpoint().match ({
        .Stop(r) => g_ran,    // cancelled — consume the Stop, return count
        .Go      => {
            g_ran = g_ran + 1
            s.work()
        },
    })
}    // budget remained — continue
main = () i32 {
    h := halloc.gpa()
    a := h.addr().sync(4096)
    s := Scope<SyncArena>(
        alloc: a.addr(),
        budget: 3,
    )    // 3 checkpoints of Go, then Stop
    work(s.addr())
}    // expect 3: ran 3 times, then cancelled
