// Closures-as-values: a closure passed to a template's function-typed parameter.
// The template is inlined per call site; the closure's params take their types
// from the expected (A, B) C, and a wrong result type is rejected.

fold = (xs: [i32], init: i32, f: (i32, i32) i32) i32 {
    acc := init
    xs.loop((h, i, x) { acc = f(acc, x) })
    acc
}

sum*  = () i32 { fold([10, 20, 30], 0, (a, x) { a + x }) }      //~ sum PASS
prod* = () i32 { fold([1, 2, 3, 4], 1, (a, x) { a * x }) }      //~ prod PASS

// the closure body yields bool, but the parameter's result type is i32
bad*  = () i32 { fold([1, 2, 3], 0, (a, x) { a < x }) }         //~ bad FAIL bool

each = (xs: [i32], f: (i32) void) void { xs.loop((h, i, x) { f(x) }) }

// a void closure may mutate an enclosing local — it is inlined at the call site
run*  = () i32 { r := 0  each([1, 2, 3], (x) { r = r + x })  r }   //~ run PASS

// a closure with no expected function type (bound to a plain local) is rejected
loose* = () i32 { f := (a, x) { a + x }  0 }                    //~ loose FAIL
