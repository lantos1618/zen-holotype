{ buf_in, dup_in, node_in, concat_in } = std.core.slice
alloc = std.mem.heap
arena = std.mem.arena

main = () i32 {
    heap := alloc.system()
    a := arena.make_in(heap.addr(), 1024)

    xs := a.addr().dup_in([1, 2, 3])
    ys := a.addr().concat_in(xs, [4, 5])
    p := a.addr().node_in(9)
    zs := a.addr().buf_in(2, xs)

    zs[0] = load(p)
    zs[1] = ys[4]
    out := zs[0] + zs[1]

    a.addr().free(heap.addr())
    out
}
