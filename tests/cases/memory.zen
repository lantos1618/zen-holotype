// raw memory ops — load/store/offset, with T inferred from the pointer.
pub roundtrip = (p: RawPtr<u8>) u8 {
    store(p, 65)          // 65 adapts to u8; store needs a writable pointer
    load(p)               // load returns the pointee type
}                                                      //~ roundtrip PASS

pub walk = (p: RawPtr<u8>) RawPtr<u8> { offset(p, 3) } //~ walk PASS

// can't store through a read-only Ptr
pub readonly = (p: Ptr<u8>) void { store(p, 1) }       //~ readonly FAIL read-only

// load needs a pointer, not a scalar
pub not_a_ptr = (x: i32) i32 { load(x) }               //~ not_a_ptr FAIL needs a pointer
