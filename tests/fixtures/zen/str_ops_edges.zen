{ find, contains, substr, parse_int, starts_with, char_at, eq, len } = std.text.str
{ println_int } = std.text.fmt

bi = (b: bool) i64 {
    b.match ({ true => 1, false => 0 })
}

main = () i32 {
    println_int(find("hello world", "world"))
    println_int(find("hello world", "x"))
    println_int(find("hello world", ""))
    println_int(find("aaab", "aab"))
    println_int(bi(contains("hello", "ell")) + bi(starts_with("hello", "he")))
    println_int(bi(starts_with("he", "hello")))
    println_int(bi(eq(substr("hello world", 6, 5), "world")))
    println_int(bi(eq(substr("hi", 1, 99), "i")))
    println_int(len(substr("hi", 5, 2)))
    println_int(bi(eq(substr("hi", -3, 1), "h")))
    println_int(to_i64(char_at("abc", 2)) - 'c')
    println_int(to_i64(char_at("abc", 3)) + to_i64(char_at("abc", -1)))
    println_int(parse_int("-7"))
    println_int(parse_int("12ab"))
    println_int(parse_int("zen") + parse_int("") + parse_int("-"))
    println_int(parse_int("123456789012"))
    0
}
